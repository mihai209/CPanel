APP_PORT=3000
APP_SECRET=test
APP_URL=https://cpanel-rocky.example.com

# Database Configuration
# Options: sqlite, mysql, mariadb, postgres
# by default is sqlite and is recommended, modify it if you know what are you doing!
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=panel
DB_PASSWORD=secret

# Providers
# Manage them from admin panel

GITHUB_PROVIDER=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK=/auth/github/callback

DISCORD_PROVIDER=false
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK=/auth/discord/callback

DEBUG=FALSE
CUSTOM_FONT=false
TIMEZONE=Europe/Bucharest
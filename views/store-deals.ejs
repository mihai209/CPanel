<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<%
const compactCoins = (value) => {
    const num = Number(value || 0);
    if (!Number.isFinite(num)) return '0';
    return new Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 }).format(num);
};
const deals = Array.isArray(storeDeals) ? storeDeals : [];
const formatDealResources = (resources) => {
    const r = resources && typeof resources === 'object' ? resources : {};
    const chunks = [];
    const ramGb = Number(r.ramMb || 0) / 1024;
    const cpuCores = Number(r.cpuPercent || 0) / 100;
    const diskGb = Number(r.diskMb || 0) / 1024;
    const swapGb = Number(r.swapMb || 0) / 1024;
    const allocations = Number(r.allocations || 0);
    const images = Number(r.images || 0);
    const databases = Number(r.databases || 0);
    const packages = Number(r.packages || 0);
    if (ramGb > 0) chunks.push(`${ramGb % 1 === 0 ? ramGb.toFixed(0) : ramGb.toFixed(2)} GB RAM`);
    if (cpuCores > 0) chunks.push(`${cpuCores % 1 === 0 ? cpuCores.toFixed(0) : cpuCores.toFixed(2)} CPU`);
    if (diskGb > 0) chunks.push(`${diskGb % 1 === 0 ? diskGb.toFixed(0) : diskGb.toFixed(2)} GB Disk`);
    if (swapGb > 0) chunks.push(`${swapGb % 1 === 0 ? swapGb.toFixed(0) : swapGb.toFixed(2)} GB Swap`);
    if (allocations > 0) chunks.push(`${allocations} Allocation`);
    if (images > 0) chunks.push(`${images} Image`);
    if (databases > 0) chunks.push(`${databases} Database`);
    if (packages > 0) chunks.push(`${packages} Package`);
    return chunks.length ? chunks.join(' | ') : 'No resources';
};
%>

<style>
    .store-shell { max-width: 1200px; margin: 0 auto; }
    .store-card { border: 1px solid #2e3036; background: linear-gradient(180deg, rgba(31, 32, 35, 0.95), rgba(31, 32, 35, 0.72)); border-radius: 14px; padding: 1.25rem; }
</style>

<div class="container-fluid py-4">
    <div class="store-shell">
        <div class="store-card mb-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h1 class="h4 fw-bold mb-1">Store Deals</h1>
                    <p class="text-muted mb-0 small">Bundles configurate de admin. Unele pot avea stoc limitat.</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="/store" class="btn btn-outline-light btn-sm">Back to Store</a>
                </div>
            </div>
        </div>

        <% if (success) { %>
            <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle-fill me-2"></i><%= success %></div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
        <% } %>
        <% if (!inventoryEnabled) { %>
            <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-warning">
                <i class="bi bi-exclamation-triangle me-2"></i>Inventory mode is disabled by admin. Deals are visible, but purchase is blocked.
            </div>
        <% } %>

        <div class="store-card mb-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">Wallet</div>
                <div class="h5 mb-0 fw-bold"><%= compactCoins(user.coins || 0) %> <%= economyUnit %></div>
            </div>
        </div>

        <div class="store-card">
            <% if (!deals.length) { %>
                <div class="text-muted">No deals available right now.</div>
            <% } else { %>
                <div class="row g-3">
                    <% deals.forEach((deal) => { %>
                        <div class="col-12 col-lg-6">
                            <div class="p-3 rounded border border-secondary border-opacity-25 h-100 d-flex flex-column">
                                <div class="d-flex align-items-start gap-3 mb-2">
                                    <% if (deal.imageUrl) { %>
                                        <img src="<%= deal.imageUrl %>" alt="Deal image" style="width:74px;height:74px;object-fit:cover;border-radius:10px;border:1px solid rgba(255,255,255,0.12);">
                                    <% } else { %>
                                        <div class="d-flex align-items-center justify-content-center" style="width:74px;height:74px;border-radius:10px;border:1px solid rgba(255,255,255,0.12);background:#1a1a20;">
                                            <i class="bi bi-box2 text-muted"></i>
                                        </div>
                                    <% } %>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <div class="fw-semibold"><%= deal.name %></div>
                                            <span class="badge <%= deal.status === 'active' ? 'bg-success' : (deal.status === 'sold_out' ? 'bg-warning text-dark' : 'bg-secondary') %>"><%= deal.status %></span>
                                            <% if (deal.featured) { %><span class="badge bg-info text-dark">featured</span><% } %>
                                        </div>
                                        <div class="text-muted small">Stock: <strong><%= deal.remainingStock %></strong> / <%= deal.stockTotal %></div>
                                        <div class="text-muted small">Price: <strong><%= compactCoins(deal.priceCoins || 0) %> <%= economyUnit %></strong> / unit</div>
                                    </div>
                                </div>
                                <% if (deal.description) { %>
                                    <div class="small text-muted mb-2"><%= deal.description %></div>
                                <% } %>
                                <div class="small mb-3"><%= formatDealResources(deal.resources) %></div>
                                <div class="mt-auto d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                    <form method="POST" action="/store/deals/<%= deal.id %>/purchase" class="d-flex align-items-center gap-2">
                                        <input type="number" name="quantity" min="1" max="<%= Math.max(1, Number(deal.remainingStock || 0)) %>" value="1" class="form-control form-control-sm" style="width:92px;background-color:#1a1a20;border-color:#2d2d35;" <%= deal.canPurchase ? '' : 'disabled' %>>
                                        <button type="submit" class="btn btn-sm btn-primary" <%= deal.canPurchase ? '' : 'disabled' %>>Buy Deal</button>
                                    </form>
                                    <% if (!deal.canPurchase) { %>
                                        <span class="text-muted small">Unavailable</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1 text-light">Theme Builder</h2>
            <p class="text-muted mb-0 small">Build a private theme for your account. Saved only for your user.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/themes" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to Themes
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-7">
            <div class="card border-0 shadow-sm" style="background-color: #141419; border: 1px solid rgba(255,255,255,0.06) !important;">
                <div class="card-header bg-transparent border-bottom border-secondary border-opacity-25">
                    <h5 class="mb-0 fs-6 fw-bold text-light">
                        <i class="bi bi-brush me-2 text-primary"></i>Custom Theme Settings
                    </h5>
                </div>
                <div class="card-body p-3 p-lg-4">
                    <form method="POST" action="/themes/builder" id="themeBuilderForm">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" role="switch" id="builderEnabled" name="enabled" <%= customTheme && customTheme.enabled ? 'checked' : '' %>>
                            <label class="form-check-label text-light" for="builderEnabled">
                                Enable custom theme override after save
                            </label>
                        </div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label text-muted small text-uppercase">Background Image URL (supports GIF)</label>
                                <input type="url"
                                    class="form-control bg-dark border-secondary text-light"
                                    id="builderBackgroundImageUrl"
                                    name="backgroundImageUrl"
                                    value="<%= (customTheme && customTheme.backgroundImageUrl) || '' %>"
                                    placeholder="https://example.com/background.gif">
                                <div class="form-text text-muted small">Allowed extensions: png, jpg, jpeg, gif, webp, bmp, svg, avif. Video/audio URLs are ignored.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Page Background</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderBackgroundColor" name="backgroundColor" value="<%= (customTheme && customTheme.backgroundColor) || '#0d0d0f' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Panel Surface</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderPanelSurface" name="panelSurface" value="<%= (customTheme && customTheme.panelSurface) || '#141419' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Card Background</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderCardBackground" name="cardBackground" value="<%= (customTheme && customTheme.cardBackground) || '#1f2023' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Card Border</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderCardBorder" name="cardBorder" value="<%= (customTheme && customTheme.cardBorder) || '#2e3036' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Accent Color</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderAccentColor" name="accentColor" value="<%= (customTheme && customTheme.accentColor) || '#3b82f6' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Text Color</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderTextColor" name="textColor" value="<%= (customTheme && customTheme.textColor) || '#ffffff' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Muted Text</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderMutedTextColor" name="mutedTextColor" value="<%= (customTheme && customTheme.mutedTextColor) || '#a1a1aa' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Server Card Background</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderServerCardBackground" name="serverCardBackground" value="<%= (customTheme && customTheme.serverCardBackground) || '#1f2023' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase">Server Card Border</label>
                                <input type="color" class="form-control form-control-color bg-dark border-secondary" id="builderServerCardBorder" name="serverCardBorder" value="<%= (customTheme && customTheme.serverCardBorder) || '#2e3036' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase d-flex justify-content-between">
                                    <span>Server Card Radius</span>
                                    <span id="builderServerCardRadiusValue"><%= (customTheme && customTheme.serverCardRadius) || 12 %>px</span>
                                </label>
                                <input type="range" class="form-range" id="builderServerCardRadius" name="serverCardRadius" min="4" max="28" step="1" value="<%= (customTheme && customTheme.serverCardRadius) || 12 %>">
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Save Custom Theme
                            </button>
                            <button type="button" id="builderResetDefaults" class="btn btn-outline-warning">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset to Defaults
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card border-0 shadow-sm h-100" style="background-color: #141419; border: 1px solid rgba(255,255,255,0.06) !important;">
                <div class="card-header bg-transparent border-bottom border-secondary border-opacity-25">
                    <h5 class="mb-0 fs-6 fw-bold text-light">
                        <i class="bi bi-eye me-2 text-info"></i>Live Preview
                    </h5>
                </div>
                <div class="card-body p-3 p-lg-4">
                    <div class="dashboard-hero mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="server-name">Demo Server</div>
                                <div class="server-subtext">Status: Running</div>
                            </div>
                            <button type="button" class="btn btn-primary btn-sm">Manage</button>
                        </div>
                    </div>
                    <div class="server-card mb-3">
                        <div class="server-name">Survival #1</div>
                        <div class="server-subtext">4 GB RAM • 2 vCPU • Online</div>
                    </div>
                    <div class="server-card">
                        <div class="server-name">Proxy</div>
                        <div class="server-subtext">Velocity • 128 Players</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(() => {
    const defaults = <%- JSON.stringify(defaultCustomTheme || {}) %>;
    const root = document.documentElement;
    const body = document.body;
    const form = document.getElementById('themeBuilderForm');
    const radiusValue = document.getElementById('builderServerCardRadiusValue');
    const resetBtn = document.getElementById('builderResetDefaults');
    if (!form) return;

    const readInput = (id) => {
        const el = document.getElementById(id);
        return el ? String(el.value || '').trim() : '';
    };

    const setInput = (id, value) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.value = String(value === undefined || value === null ? '' : value);
    };

    const setCustomEnabled = (enabled) => {
        const state = enabled ? 'on' : 'off';
        root.setAttribute('data-user-custom-theme', state);
        if (body) body.setAttribute('data-user-custom-theme', state);
    };

    const applyPreview = () => {
        const enabledToggle = document.getElementById('builderEnabled');
        setCustomEnabled(enabledToggle ? enabledToggle.checked : true);
        root.style.setProperty('--cp-user-bg-color', readInput('builderBackgroundColor') || '#0d0d0f');
        root.style.setProperty('--cp-user-panel-surface', readInput('builderPanelSurface') || '#141419');
        root.style.setProperty('--cp-user-card-bg', readInput('builderCardBackground') || '#1f2023');
        root.style.setProperty('--cp-user-card-border', readInput('builderCardBorder') || '#2e3036');
        root.style.setProperty('--cp-user-accent-color', readInput('builderAccentColor') || '#3b82f6');
        root.style.setProperty('--cp-user-text-color', readInput('builderTextColor') || '#ffffff');
        root.style.setProperty('--cp-user-muted-text-color', readInput('builderMutedTextColor') || '#a1a1aa');
        root.style.setProperty('--cp-user-server-card-bg', readInput('builderServerCardBackground') || '#1f2023');
        root.style.setProperty('--cp-user-server-card-border', readInput('builderServerCardBorder') || '#2e3036');
        const radius = Number.parseInt(readInput('builderServerCardRadius'), 10);
        const normalizedRadius = Number.isInteger(radius) ? Math.min(28, Math.max(4, radius)) : 12;
        root.style.setProperty('--cp-user-server-card-radius', normalizedRadius + 'px');
        if (radiusValue) radiusValue.textContent = normalizedRadius + 'px';

        const backgroundImageUrl = readInput('builderBackgroundImageUrl');
        root.style.setProperty('--cp-user-bg-image', backgroundImageUrl ? 'url("' + backgroundImageUrl.replace(/"/g, '\\"') + '")' : 'none');
    };

    [
        'builderEnabled',
        'builderBackgroundImageUrl',
        'builderBackgroundColor',
        'builderPanelSurface',
        'builderCardBackground',
        'builderCardBorder',
        'builderAccentColor',
        'builderTextColor',
        'builderMutedTextColor',
        'builderServerCardBackground',
        'builderServerCardBorder',
        'builderServerCardRadius'
    ].forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input', applyPreview);
        el.addEventListener('change', applyPreview);
    });

    if (resetBtn) {
        resetBtn.addEventListener('click', () => {
            const enabled = document.getElementById('builderEnabled');
            if (enabled) enabled.checked = Boolean(defaults.enabled);
            setInput('builderBackgroundImageUrl', defaults.backgroundImageUrl || '');
            setInput('builderBackgroundColor', defaults.backgroundColor || '#0d0d0f');
            setInput('builderPanelSurface', defaults.panelSurface || '#141419');
            setInput('builderCardBackground', defaults.cardBackground || '#1f2023');
            setInput('builderCardBorder', defaults.cardBorder || '#2e3036');
            setInput('builderAccentColor', defaults.accentColor || '#3b82f6');
            setInput('builderTextColor', defaults.textColor || '#ffffff');
            setInput('builderMutedTextColor', defaults.mutedTextColor || '#a1a1aa');
            setInput('builderServerCardBackground', defaults.serverCardBackground || '#1f2023');
            setInput('builderServerCardBorder', defaults.serverCardBorder || '#2e3036');
            setInput('builderServerCardRadius', defaults.serverCardRadius || 12);
            applyPreview();
        });
    }

    applyPreview();
})();
</script>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

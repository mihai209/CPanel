<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<%
const serverList = Array.isArray(servers) ? servers : [];
const totalServers = serverList.length;
const runningServers = serverList.filter((server) => String(server.status || '').toLowerCase() === 'running').length;
const installingServers = serverList.filter((server) => String(server.status || '').toLowerCase() === 'installing').length;
const offlineServers = serverList.filter((server) => !['running', 'installing'].includes(String(server.status || '').toLowerCase())).length;
const suspendedServers = serverList.filter((server) => !!server.isSuspended).length;
const userCreateEnabled = String((settings && settings.featureUserCreateEnabled) || 'false') === 'true';
const isAdminDashboardView = Boolean(typeof isAdminDashboard !== 'undefined' ? isAdminDashboard : (user && user.isAdmin));
const showOthersServersView = Boolean(typeof showOthersServers !== 'undefined' ? showOthersServers : false);
const serverSectionTitle = isAdminDashboardView && showOthersServersView ? 'All Servers' : 'Your Servers';
const announcerEnabled = String((settings && settings.extensionAnnouncerEnabled) || 'false') === 'true';
const announcerMessage = String((settings && settings.extensionAnnouncerMessage) || '').trim();
const announcerSeverity = String((settings && settings.extensionAnnouncerSeverity) || 'normal').toLowerCase();
const incidentFeedSource = typeof openIncidents !== 'undefined' ? openIncidents : [];
const maintenanceFeedSource = typeof pendingMaintenance !== 'undefined' ? pendingMaintenance : [];
const securityFeedSource = typeof openSecurityAlerts !== 'undefined' ? openSecurityAlerts : [];
const incidentFeed = Array.isArray(incidentFeedSource) ? incidentFeedSource : [];
const maintenanceFeed = Array.isArray(maintenanceFeedSource) ? maintenanceFeedSource : [];
const securityFeed = Array.isArray(securityFeedSource) ? securityFeedSource : [];
const dashboardNow = Number.isFinite(Number(typeof dashboardNowMs !== 'undefined' ? dashboardNowMs : Date.now()))
    ? Number(typeof dashboardNowMs !== 'undefined' ? dashboardNowMs : Date.now())
    : Date.now();
const announcerSeverityMap = {
    normal: {
        badge: 'NORMAL',
        classes: '',
        style: 'background-color: rgba(25, 135, 84, 0.15); border-color: rgba(25, 135, 84, 0.45); color: #d1fae5;'
    },
    warning: {
        badge: 'WARNING',
        classes: '',
        style: 'background-color: rgba(255, 193, 7, 0.16); border-color: rgba(255, 193, 7, 0.52); color: #fde68a;'
    },
    critical: {
        badge: 'CRITICAL',
        classes: '',
        style: 'background-color: rgba(220, 53, 69, 0.16); border-color: rgba(220, 53, 69, 0.52); color: #fecaca;'
    }
};
const activeAnnouncerSeverity = Object.prototype.hasOwnProperty.call(announcerSeverityMap, announcerSeverity) ? announcerSeverity : 'normal';
const activeAnnouncerConfig = announcerSeverityMap[activeAnnouncerSeverity];
const normalizeTimestamp = (value) => {
    const parsed = Number.parseInt(value, 10);
    if (!Number.isFinite(parsed) || parsed <= 0) return 0;
    if (parsed < 10000000000) return parsed * 1000;
    return parsed;
};
const formatDateTime = (value) => {
    const parsed = normalizeTimestamp(value);
    if (!Number.isFinite(parsed) || parsed <= 0) return 'N/A';
    return new Date(parsed).toLocaleString();
};
const severityBadgeClass = (severity) => {
    const normalized = String(severity || '').toLowerCase();
    if (normalized === 'critical') return 'bg-danger';
    if (normalized === 'warning') return 'bg-warning text-dark';
    return 'bg-success';
};
const maintenanceState = (entry) => {
    const startsAt = normalizeTimestamp(entry && entry.startsAtMs);
    const endsAt = normalizeTimestamp(entry && entry.endsAtMs);
    if (dashboardNow < startsAt) return 'upcoming';
    if (dashboardNow > endsAt) return 'awaiting completion';
    return 'active';
};
const formatLimit = (value) => {
    if (!value || Number(value) <= 0) return 'N/A';
    const mb = Number(value);
    if (mb >= 1024) return `${(mb / 1024).toFixed(mb % 1024 === 0 ? 0 : 1)} GB`;
    return `${mb} MB`;
};
const normalizeServerIdList = (input) => {
    if (!Array.isArray(input)) return [];
    const seen = new Set();
    const values = [];
    input.forEach((entry) => {
        const parsed = Number.parseInt(entry, 10);
        if (!Number.isInteger(parsed) || parsed <= 0 || seen.has(parsed)) return;
        seen.add(parsed);
        values.push(parsed);
    });
    return values;
};
const activeDashboardSortMode = (() => {
    const raw = String(typeof dashboardSortMode !== 'undefined' ? dashboardSortMode : 'latest').trim().toLowerCase();
    if (raw === 'alphabetical' || raw === 'custom') return raw;
    return 'latest';
})();
const dashboardCustomOrderIdsList = normalizeServerIdList(typeof dashboardCustomOrderIds !== 'undefined' ? dashboardCustomOrderIds : []);
const dashboardLatestOrderIdsList = normalizeServerIdList(typeof dashboardLatestOrderIds !== 'undefined' ? dashboardLatestOrderIds : []);
const dashboardLatestOrderIndexById = new Map(dashboardLatestOrderIdsList.map((id, index) => [id, index]));
const dashboardCustomOrderIndexById = new Map(dashboardCustomOrderIdsList.map((id, index) => [id, index]));
const dashboardFoldersRaw = typeof dashboardFolders !== 'undefined' ? dashboardFolders : [];
const dashboardTagsRaw = typeof dashboardTags !== 'undefined' ? dashboardTags : [];
const dashboardFoldersList = Array.isArray(dashboardFoldersRaw) ? dashboardFoldersRaw : [];
const dashboardTagsList = Array.isArray(dashboardTagsRaw) ? dashboardTagsRaw : [];
%>

<style>
    .dashboard-shell {
        max-width: 1400px;
        margin: 0 auto;
    }

    .dashboard-hero {
        border: 1px solid #2e3036;
        background: linear-gradient(180deg, rgba(31, 32, 35, 0.95), rgba(31, 32, 35, 0.65));
        border-radius: 14px;
        padding: 1.25rem;
    }

    .metric-card {
        background-color: #1f2023;
        border: 1px solid #2e3036;
        border-radius: 12px;
        padding: 1rem;
        height: 100%;
    }

    .metric-label {
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .metric-value {
        font-size: 1.85rem;
        line-height: 1;
        font-weight: 700;
        margin-top: 0.45rem;
    }

    .servers-grid {
        margin-top: 1.25rem;
    }

    .server-card {
        background-color: #1f2023;
        border: 1px solid #2e3036;
        border-radius: 12px;
        padding: 1rem;
        transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .server-card:hover {
        border-color: #3f3f46;
        transform: translateY(-2px);
    }

    .server-name {
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .server-subtext {
        color: #9ca3af;
        font-size: 0.78rem;
        margin-top: 0.25rem;
    }

    .server-tag {
        display: inline-block;
        font-size: 0.7rem;
        border: 1px solid #3f3f46;
        border-radius: 999px;
        padding: 0.08rem 0.45rem;
        margin-right: 0.32rem;
        margin-top: 0.24rem;
        color: #d1d5db;
        background: rgba(255, 255, 255, 0.04);
    }

    .resource-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.65rem;
        margin-top: 1rem;
    }

    .resource-pill {
        border: 1px solid #2e3036;
        border-radius: 10px;
        padding: 0.6rem 0.65rem;
        background-color: rgba(255, 255, 255, 0.02);
    }

    .resource-pill-label {
        display: block;
        color: #9ca3af;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.1rem;
    }

    .resource-pill-value {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .empty-state-card {
        border: 1px dashed #3f3f46;
        border-radius: 14px;
        background-color: #1f2023;
        text-align: center;
        padding: 3rem 1rem;
    }

    .announcement-card {
        border-radius: 12px;
        border-width: 1px;
        border-style: solid;
        padding: 0.85rem 0.95rem;
        margin-bottom: 1rem;
    }

    .announcement-meta {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.8;
    }

    .announcement-body {
        font-size: 0.95rem;
        margin-top: 0.4rem;
        white-space: pre-wrap;
        line-height: 1.45;
    }

    .ops-feed-card {
        border: 1px solid #2e3036;
        border-radius: 12px;
        background: #1a1b1f;
        padding: 0.9rem;
    }

    .ops-feed-item {
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 10px;
        padding: 0.65rem 0.7rem;
        background: rgba(255, 255, 255, 0.02);
    }

    .ops-feed-item-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #f3f4f6;
    }

    .ops-feed-item-meta {
        margin-top: 0.25rem;
        color: #9ca3af;
        font-size: 0.76rem;
    }

    .ops-feed-item-message {
        margin-top: 0.35rem;
        color: #d1d5db;
        font-size: 0.84rem;
        white-space: pre-wrap;
    }

    .dashboard-sort-controls {
        min-width: 220px;
    }

    .dashboard-sort-feedback {
        min-height: 1.1rem;
    }

    .dashboard-custom-order-list .list-group-item {
        background: #1f2023;
        border-color: #2e3036;
        color: #e5e7eb;
    }

    .dashboard-custom-order-handle {
        cursor: grab;
        color: #9ca3af;
    }

    .dashboard-custom-order-item.dragging {
        opacity: 0.55;
    }

    @media (max-width: 767px) {
        .dashboard-hero {
            padding: 1rem;
        }

        .dashboard-hero .d-flex {
            flex-direction: column;
            align-items: flex-start !important;
        }

        .dashboard-hero .d-flex > div:last-child {
            width: 100%;
            justify-content: flex-start !important;
        }

        .dashboard-hero .btn {
            width: 100%;
        }

        .metric-card {
            padding: 0.85rem;
        }

        .metric-value {
            font-size: 1.45rem;
        }

        .server-card {
            padding: 0.85rem;
        }

        .server-name {
            font-size: 0.98rem;
            line-height: 1.3;
            word-break: break-word;
        }

        .server-subtext {
            font-size: 0.72rem;
            word-break: break-word;
        }

        .resource-grid {
            grid-template-columns: 1fr;
        }

        .ops-feed-card {
            padding: 0.75rem;
        }

        .ops-feed-item {
            padding: 0.55rem 0.6rem;
        }

        .dashboard-sort-controls {
            width: 100%;
            min-width: 0;
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="dashboard-shell">
        <div class="dashboard-hero mb-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <h1 class="h3 mb-1 fw-bold" style="letter-spacing: -0.02em;">
                    <img src="<%= settings.faviconUrl %>" alt="Favicon"
                class="rounded-circle border border-secondary border-opacity-25 me-2" style="object-fit: cover;"
                width="40" height="40">
                        <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> Servers</h1>
                    <p class="text-muted mb-0 small">Manage your instances from one place.</p>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                    <% if (userCreateEnabled) { %>
                        <a href="/user/create" class="btn btn-primary btn-sm fw-semibold">
                            <i class="bi bi-plus-square me-1"></i>Create Server
                        </a>
                        <a href="/store" class="btn btn-outline-light btn-sm fw-semibold">
                            <i class="bi bi-shop me-1"></i>Store
                        </a>
                    <% } %>
                    <% if (isAdminDashboardView) { %>
                        <form id="dashboardOthersToggleForm" action="/" method="GET" class="d-flex align-items-center gap-2 mb-0">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" role="switch" id="dashboardOthersToggle" name="others" value="1" <%= showOthersServersView ? 'checked' : '' %>>
                            </div>
                            <label class="small text-muted mb-0" for="dashboardOthersToggle">See Other Servers</label>
                        </form>
                    <% } %>
                    <% if (serverList.length > 1) { %>
                        <div class="dashboard-sort-controls">
                            <label for="dashboardServerSort" class="small text-muted mb-1 d-block">Order Servers</label>
                            <div class="d-flex align-items-center gap-2">
                                <select id="dashboardServerSort" class="form-select form-select-sm bg-dark text-light border-secondary">
                                    <option value="latest" <%= activeDashboardSortMode === 'latest' ? 'selected' : '' %>>Latest</option>
                                    <option value="alphabetical" <%= activeDashboardSortMode === 'alphabetical' ? 'selected' : '' %>>Alphabetical</option>
                                    <option value="custom" <%= activeDashboardSortMode === 'custom' ? 'selected' : '' %>>Custom</option>
                                </select>
                                <button
                                    type="button"
                                    class="btn btn-outline-warning btn-sm fw-semibold d-none d-md-inline-flex align-items-center"
                                    id="dashboardCustomOrderBtn"
                                    title="Edit custom order"
                                >
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </div>
                            <div id="dashboardSortFeedback" class="dashboard-sort-feedback text-muted small mt-1"></div>
                        </div>
                    <% } %>
                    <% if (serverList.length > 0) { %>
                        <div class="dashboard-sort-controls">
                            <label class="small text-muted mb-1 d-block">Filter</label>
                            <div class="d-flex align-items-center gap-2">
                                <select id="dashboardFolderFilter" class="form-select form-select-sm bg-dark text-light border-secondary">
                                    <option value="">All folders</option>
                                    <% dashboardFoldersList.forEach((folderName) => { %>
                                        <option value="<%= folderName %>"><%= folderName %></option>
                                    <% }); %>
                                </select>
                                <select id="dashboardTagFilter" class="form-select form-select-sm bg-dark text-light border-secondary">
                                    <option value="">All tags</option>
                                    <% dashboardTagsList.forEach((tagName) => { %>
                                        <option value="<%= tagName %>"><%= tagName %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                    <% } %>
                    <div class="text-muted small">Signed in as <span class="text-light fw-semibold"><%= user.username %></span></div>
                </div>
            </div>
        </div>

        <% if (announcerEnabled && announcerMessage.length > 0) { %>
            <div class="announcement-card <%= activeAnnouncerConfig.classes %>" style="<%= activeAnnouncerConfig.style %>">
                <div class="announcement-meta">
                    <i class="bi bi-megaphone me-1"></i>Announcer • <%= activeAnnouncerConfig.badge %>
                </div>
                <div class="announcement-body"><%= announcerMessage %></div>
            </div>
        <% } %>

        <% if (incidentFeed.length > 0 || maintenanceFeed.length > 0 || securityFeed.length > 0) { %>
            <div class="row g-3 mb-3">
                <% if (incidentFeed.length > 0) { %>
                    <div class="col-12 col-xl-4">
                        <div class="ops-feed-card">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h2 class="h6 mb-0 text-uppercase fw-bold" style="letter-spacing: 0.04em;">Open Incidents</h2>
                                <span class="badge bg-danger"><%= incidentFeed.length %></span>
                            </div>
                            <div class="d-grid gap-2">
                                <% incidentFeed.forEach((entry) => { %>
                                    <div class="ops-feed-item">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div class="ops-feed-item-title"><%= entry.title %></div>
                                            <span class="badge <%= severityBadgeClass(entry.severity) %>"><%= entry.severity %></span>
                                        </div>
                                        <div class="ops-feed-item-meta">Created: <%= formatDateTime(entry.createdAtMs) %></div>
                                        <% if (entry.message) { %><div class="ops-feed-item-message"><%= entry.message %></div><% } %>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                <% } %>

                <% if (maintenanceFeed.length > 0) { %>
                    <div class="col-12 col-xl-4">
                        <div class="ops-feed-card">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h2 class="h6 mb-0 text-uppercase fw-bold" style="letter-spacing: 0.04em;">Maintenance</h2>
                                <span class="badge bg-primary"><%= maintenanceFeed.length %></span>
                            </div>
                            <div class="d-grid gap-2">
                                <% maintenanceFeed.forEach((entry) => { %>
                                    <div class="ops-feed-item">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div class="ops-feed-item-title"><%= entry.title %></div>
                                            <span class="badge bg-secondary"><%= maintenanceState(entry) %></span>
                                        </div>
                                        <div class="ops-feed-item-meta">Window: <%= formatDateTime(entry.startsAtMs) %> -> <%= formatDateTime(entry.endsAtMs) %></div>
                                        <% if (entry.message) { %><div class="ops-feed-item-message"><%= entry.message %></div><% } %>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                <% } %>

                <% if (securityFeed.length > 0) { %>
                    <div class="col-12 col-xl-4">
                        <div class="ops-feed-card">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h2 class="h6 mb-0 text-uppercase fw-bold" style="letter-spacing: 0.04em;">Security Alerts</h2>
                                <span class="badge bg-warning text-dark"><%= securityFeed.length %></span>
                            </div>
                            <div class="d-grid gap-2">
                                <% securityFeed.forEach((entry) => { %>
                                    <div class="ops-feed-item">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div class="ops-feed-item-title"><%= entry.title %></div>
                                            <span class="badge <%= severityBadgeClass(entry.severity) %>"><%= entry.severity %></span>
                                        </div>
                                        <div class="ops-feed-item-meta">Category: <%= entry.category || 'general' %> • Created: <%= formatDateTime(entry.createdAtMs) %></div>
                                        <% if (entry.message) { %><div class="ops-feed-item-message"><%= entry.message %></div><% } %>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>

        <div class="row g-3">
            <div class="col-6 col-lg-3">
                <div class="metric-card">
                    <div class="metric-label">Total Servers</div>
                    <div class="metric-value"><%= totalServers %></div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="metric-card">
                    <div class="metric-label">Running</div>
                    <div class="metric-value"><%= runningServers %></div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="metric-card">
                    <div class="metric-label">Offline</div>
                    <div class="metric-value"><%= offlineServers %></div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="metric-card">
                    <div class="metric-label">Suspended</div>
                    <div class="metric-value"><%= suspendedServers %></div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="metric-card">
                    <div class="metric-label">Wallet (Coins)</div>
                    <div class="metric-value"><%= Number(user.coins || 0).toLocaleString() %></div>
                </div>
            </div>
        </div>

        <% if (serverList.length > 0) { %>
            <div class="d-flex align-items-center justify-content-between mt-4 mb-2">
                <h2 class="h6 mb-0 text-uppercase fw-bold" style="letter-spacing: 0.04em;"><%= serverSectionTitle %></h2>
                <span class="text-muted small"><%= totalServers %> total</span>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 servers-grid" id="dashboardServersGrid">
                <% serverList.forEach((server, currentIndex) => { %>
                    <%
                    const rawStatus = String(server.status || 'unknown').toLowerCase();
                    let badgeClass = 'bg-secondary';
                    let statusLabel = rawStatus;

                    if (server.isSuspended) {
                        badgeClass = 'bg-danger';
                        statusLabel = 'suspended';
                    } else if (rawStatus === 'running') {
                        badgeClass = 'bg-success';
                    } else if (rawStatus === 'stopped') {
                        badgeClass = 'bg-danger';
                    } else if (rawStatus === 'installing') {
                        badgeClass = 'bg-warning text-dark';
                    }
                    const serverIdValue = Number.parseInt(server && server.id, 10);
                    const latestIndex = dashboardLatestOrderIndexById.has(serverIdValue) ? dashboardLatestOrderIndexById.get(serverIdValue) : currentIndex;
                    const customIndex = dashboardCustomOrderIndexById.has(serverIdValue) ? dashboardCustomOrderIndexById.get(serverIdValue) : -1;
                    const folderName = String(server && server.folder || '').trim();
                    const tagsValue = Array.isArray(server && server.tags) ? server.tags : [];
                    %>
                    <div
                        class="col dashboard-server-item"
                        data-server-id="<%= Number.isInteger(serverIdValue) ? serverIdValue : 0 %>"
                        data-server-name="<%= server.name || '' %>"
                        data-folder="<%= folderName %>"
                        data-tags="<%= tagsValue.join('|').toLowerCase() %>"
                        data-latest-index="<%= latestIndex %>"
                        data-custom-index="<%= customIndex %>"
                        data-current-index="<%= currentIndex %>"
                    >
                        <div class="server-card h-100">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="server-name"><%= server.name %></div>
                                    <div class="server-subtext">Container ID: <%= server.containerId ? server.containerId.substring(0, 12) : 'N/A' %></div>
                                    <% if (server.description) { %>
                                        <div class="server-subtext text-info"><%= server.description %></div>
                                    <% } %>
                                    <% if (folderName) { %>
                                        <div class="server-subtext">Folder: <span class="text-warning"><%= folderName %></span></div>
                                    <% } %>
                                    <% if (tagsValue.length > 0) { %>
                                        <div class="server-subtext">
                                            <% tagsValue.forEach((tagItem) => { %>
                                                <span class="server-tag"><%= tagItem %></span>
                                            <% }); %>
                                        </div>
                                    <% } %>
                                    <% if (isAdminDashboardView) { %>
                                        <div class="server-subtext">Owner: @<%= server.owner && server.owner.username ? server.owner.username : 'unknown' %></div>
                                    <% } %>
                                </div>
                                <span class="badge <%= badgeClass %> text-uppercase"><%= statusLabel %></span>
                            </div>

                            <div class="resource-grid">
                                <div class="resource-pill">
                                    <span class="resource-pill-label">Memory</span>
                                    <span class="resource-pill-value"><%= formatLimit(server.memory) %></span>
                                </div>
                                <div class="resource-pill">
                                    <span class="resource-pill-label">Disk</span>
                                    <span class="resource-pill-value"><%= formatLimit(server.disk) %></span>
                                </div>
                                <div class="resource-pill">
                                    <span class="resource-pill-label">CPU</span>
                                    <span class="resource-pill-value"><%= server.cpu ? `${server.cpu}%` : 'N/A' %></span>
                                </div>
                            </div>

                            <div class="mt-3 d-grid gap-2">
                                <a href="/server/<%= server.containerId %>" class="btn btn-primary btn-sm fw-semibold">Manage Server</a>
                                <% if (isAdminDashboardView) { %>
                                    <a href="/admin/servers/<%= server.containerId %>/manage" class="btn btn-outline-info btn-sm fw-semibold">Admin Manage Page</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state-card mt-4">
                <h3 class="h4 fw-bold mb-2">No servers found</h3>
                <p class="text-muted mb-0">
                    <%= isAdminDashboardView && showOthersServersView
                        ? 'No servers are currently available in the system.'
                        : 'There are no servers assigned to this account yet.' %>
                </p>
                <% if (userCreateEnabled) { %>
                    <div class="mt-3 d-flex justify-content-center gap-2 flex-wrap">
                        <a href="/user/create" class="btn btn-primary btn-sm fw-semibold">Create First Server</a>
                        <a href="/store" class="btn btn-outline-light btn-sm fw-semibold">Open Store</a>
                    </div>
                <% } %>
            </div>
        <% } %>

        <% if (serverList.length > 1) { %>
            <div class="modal fade" id="dashboardCustomOrderModal" tabindex="-1" aria-labelledby="dashboardCustomOrderModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content bg-dark text-light border-secondary">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title" id="dashboardCustomOrderModalLabel">Custom Server Order</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="small text-muted mb-2">Drag servers in the order you want, then save.</p>
                            <div id="dashboardCustomOrderFeedback" class="small text-muted mb-2"></div>
                            <div id="dashboardCustomOrderList" class="list-group dashboard-custom-order-list"></div>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light btn-sm" data-bs-dismiss="modal">Close</button>
                            <button type="button" class="btn btn-warning btn-sm fw-semibold" id="dashboardCustomOrderSaveBtn">
                                Save Custom Order
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
<script>
    (() => {
        const toggle = document.getElementById('dashboardOthersToggle');
        const form = document.getElementById('dashboardOthersToggleForm');
        if (toggle && form) {
            toggle.addEventListener('change', () => form.submit());
        }

        const grid = document.getElementById('dashboardServersGrid');
        const sortSelect = document.getElementById('dashboardServerSort');
        const folderFilter = document.getElementById('dashboardFolderFilter');
        const tagFilter = document.getElementById('dashboardTagFilter');
        const sortFeedback = document.getElementById('dashboardSortFeedback');
        if (!grid) return;

        const initialMode = '<%= activeDashboardSortMode %>';
        let savedCustomOrderIds = <%- JSON.stringify(dashboardCustomOrderIdsList) %>;
        const userId = Number.parseInt('<%= Number.parseInt(user && user.id, 10) || 0 %>', 10) || 0;
        const storagePrefix = userId > 0 ? `dashboardServerOrder:${userId}` : 'dashboardServerOrder:default';
        const sortModeStorageKey = `${storagePrefix}:mode`;
        const sortCustomIdsStorageKey = `${storagePrefix}:customIds`;

        const normalizeServerIds = (input) => {
            const source = Array.isArray(input) ? input : [];
            const seen = new Set();
            const output = [];
            source.forEach((entry) => {
                const parsed = Number.parseInt(entry, 10);
                if (!Number.isInteger(parsed) || parsed <= 0 || seen.has(parsed)) return;
                seen.add(parsed);
                output.push(parsed);
            });
            return output;
        };

        const normalizeSortMode = (input) => {
            const normalized = String(input || '').trim().toLowerCase();
            if (normalized === 'alphabetical' || normalized === 'custom') return normalized;
            return 'latest';
        };

        const readStoredSortMode = () => {
            try {
                return normalizeSortMode(window.localStorage.getItem(sortModeStorageKey));
            } catch (_error) {
                return 'latest';
            }
        };

        const readStoredCustomOrderIds = () => {
            try {
                const raw = window.localStorage.getItem(sortCustomIdsStorageKey);
                if (!raw) return [];
                const parsed = JSON.parse(raw);
                return normalizeServerIds(parsed);
            } catch (_error) {
                return [];
            }
        };

        const persistSortStateLocally = (mode, customIds) => {
            try {
                window.localStorage.setItem(sortModeStorageKey, normalizeSortMode(mode));
                if (Array.isArray(customIds)) {
                    window.localStorage.setItem(sortCustomIdsStorageKey, JSON.stringify(normalizeServerIds(customIds)));
                }
            } catch (_error) {
                // Ignore localStorage failures.
            }
        };

        savedCustomOrderIds = normalizeServerIds(savedCustomOrderIds);
        const storedCustomOrderIds = readStoredCustomOrderIds();
        if (savedCustomOrderIds.length === 0 && storedCustomOrderIds.length > 0) {
            savedCustomOrderIds = storedCustomOrderIds;
        }

        let activeMode = normalizeSortMode(initialMode);
        const storedMode = readStoredSortMode();
        if (activeMode === 'latest' && (storedMode === 'alphabetical' || storedMode === 'custom')) {
            activeMode = storedMode;
        }
        if (sortSelect) {
            sortSelect.value = activeMode;
        }

        const setSortFeedback = (message, variant = 'muted') => {
            if (!sortFeedback) return;
            sortFeedback.textContent = message || '';
            sortFeedback.classList.remove('text-muted', 'text-success', 'text-danger', 'text-warning');
            if (variant === 'success') sortFeedback.classList.add('text-success');
            else if (variant === 'danger') sortFeedback.classList.add('text-danger');
            else if (variant === 'warning') sortFeedback.classList.add('text-warning');
            else sortFeedback.classList.add('text-muted');
        };

        const getServerItems = () => Array.from(grid.querySelectorAll('.dashboard-server-item'));
        const getServerId = (element) => Number.parseInt(element && element.dataset ? element.dataset.serverId : '0', 10) || 0;
        const getLatestIndex = (element) => Number.parseInt(element && element.dataset ? element.dataset.latestIndex : '999999', 10) || 999999;
        const getServerName = (element) => String(element && element.dataset ? element.dataset.serverName : '').toLowerCase();
        const getServerFolder = (element) => String(element && element.dataset ? element.dataset.folder : '').trim().toLowerCase();
        const getServerTags = (element) => String(element && element.dataset ? element.dataset.tags : '').trim().toLowerCase();
        const applyGridOrder = (orderedItems) => {
            orderedItems.forEach((item) => grid.appendChild(item));
        };
        const applyVisibilityFilters = () => {
            const selectedFolder = String(folderFilter && folderFilter.value || '').trim().toLowerCase();
            const selectedTag = String(tagFilter && tagFilter.value || '').trim().toLowerCase();
            let visibleCount = 0;
            getServerItems().forEach((item) => {
                const folderMatch = !selectedFolder || getServerFolder(item) === selectedFolder;
                const tags = getServerTags(item) ? getServerTags(item).split('|').filter(Boolean) : [];
                const tagMatch = !selectedTag || tags.includes(selectedTag);
                const visible = folderMatch && tagMatch;
                item.style.display = visible ? '' : 'none';
                if (visible) visibleCount += 1;
            });
            if ((selectedFolder || selectedTag) && sortFeedback) {
                setSortFeedback(`Showing ${visibleCount} server(s) after filters.`, 'muted');
            }
        };

        const sortByLatest = (items) => {
            return items.slice().sort((a, b) => getLatestIndex(a) - getLatestIndex(b));
        };

        const sortByAlphabetical = (items) => {
            return items.slice().sort((a, b) => getServerName(a).localeCompare(getServerName(b), undefined, { sensitivity: 'base', numeric: true }));
        };

        const sortByCustom = (items, customIds) => {
            const orderMap = new Map(normalizeServerIds(customIds).map((id, index) => [id, index]));
            return items.slice().sort((a, b) => {
                const aOrder = orderMap.has(getServerId(a)) ? orderMap.get(getServerId(a)) : Number.MAX_SAFE_INTEGER;
                const bOrder = orderMap.has(getServerId(b)) ? orderMap.get(getServerId(b)) : Number.MAX_SAFE_INTEGER;
                if (aOrder !== bOrder) return aOrder - bOrder;
                return getLatestIndex(a) - getLatestIndex(b);
            });
        };

        const persistServerOrder = async (mode, customIds) => {
            const payload = new URLSearchParams();
            payload.set('mode', mode);
            if (Array.isArray(customIds)) payload.set('customIds', JSON.stringify(normalizeServerIds(customIds)));

            const response = await fetch('/dashboard/server-order', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'Accept': 'application/json'
                },
                body: payload.toString()
            });
            const data = await response.json().catch(() => ({}));
            if (!response.ok || !data.success) {
                throw new Error(data && data.error ? data.error : 'Failed to save dashboard order.');
            }
            return data;
        };

        const applyModeToGrid = (mode) => {
            const items = getServerItems();
            if (items.length < 2) {
                applyVisibilityFilters();
                return;
            }
            if (mode === 'alphabetical') {
                applyGridOrder(sortByAlphabetical(items));
                applyVisibilityFilters();
                return;
            }
            if (mode === 'custom') {
                applyGridOrder(sortByCustom(items, savedCustomOrderIds));
                applyVisibilityFilters();
                return;
            }
            applyGridOrder(sortByLatest(items));
            applyVisibilityFilters();
        };

        if (sortSelect) {
            sortSelect.addEventListener('change', async () => {
            const selectedMode = String(sortSelect.value || 'latest').toLowerCase();
            applyModeToGrid(selectedMode);

            try {
                const data = await persistServerOrder(selectedMode);
                savedCustomOrderIds = normalizeServerIds(data.customIds || savedCustomOrderIds);
                activeMode = selectedMode;
                persistSortStateLocally(activeMode, savedCustomOrderIds);
                if (selectedMode === 'custom') {
                    applyModeToGrid('custom');
                }
                if (selectedMode === 'alphabetical') {
                    setSortFeedback('Alphabetical order saved.', 'success');
                } else if (selectedMode === 'latest') {
                    setSortFeedback('Latest order saved.', 'success');
                } else if (savedCustomOrderIds.length > 0) {
                    setSortFeedback('Custom order mode saved.', 'success');
                } else {
                    setSortFeedback('No custom order saved yet. Use the pencil button on desktop.', 'warning');
                }
            } catch (error) {
                setSortFeedback(error.message || 'Failed to save dashboard order.', 'danger');
            }
            });
        }

        if (folderFilter) {
            folderFilter.addEventListener('change', applyVisibilityFilters);
        }
        if (tagFilter) {
            tagFilter.addEventListener('change', applyVisibilityFilters);
        }

        if (activeMode === 'alphabetical' || activeMode === 'custom') {
            applyModeToGrid(activeMode);
        } else {
            applyVisibilityFilters();
        }

        if (activeMode === 'custom' && savedCustomOrderIds.length === 0) {
            persistServerOrder('custom')
                .then((data) => {
                    savedCustomOrderIds = normalizeServerIds(data.customIds || []);
                    persistSortStateLocally('custom', savedCustomOrderIds);
                    if (savedCustomOrderIds.length > 0) {
                        applyModeToGrid('custom');
                    }
                })
                .catch(() => {});
        }

        const customButton = document.getElementById('dashboardCustomOrderBtn');
        const customModalElement = document.getElementById('dashboardCustomOrderModal');
        const customList = document.getElementById('dashboardCustomOrderList');
        const customSaveButton = document.getElementById('dashboardCustomOrderSaveBtn');
        const customFeedback = document.getElementById('dashboardCustomOrderFeedback');

        if (!customButton || !customModalElement || !customList || !customSaveButton || !window.bootstrap) return;

        const customModal = bootstrap.Modal.getOrCreateInstance(customModalElement);

        const setCustomFeedback = (message, variant = 'muted') => {
            if (!customFeedback) return;
            customFeedback.textContent = message || '';
            customFeedback.classList.remove('text-muted', 'text-success', 'text-danger', 'text-warning');
            if (variant === 'success') customFeedback.classList.add('text-success');
            else if (variant === 'danger') customFeedback.classList.add('text-danger');
            else if (variant === 'warning') customFeedback.classList.add('text-warning');
            else customFeedback.classList.add('text-muted');
        };

        const buildCustomList = () => {
            customList.innerHTML = '';
            const orderedItems = sortByCustom(getServerItems(), savedCustomOrderIds);
            orderedItems.forEach((item) => {
                const serverId = getServerId(item);
                const name = String(item.dataset.serverName || `Server #${serverId}`);

                const row = document.createElement('div');
                row.className = 'list-group-item dashboard-custom-order-item d-flex align-items-center justify-content-between gap-2';
                row.draggable = true;
                row.dataset.serverId = String(serverId);

                const left = document.createElement('div');
                left.className = 'd-flex align-items-center gap-2';

                const handle = document.createElement('i');
                handle.className = 'bi bi-grip-vertical dashboard-custom-order-handle';
                handle.setAttribute('aria-hidden', 'true');
                left.appendChild(handle);

                const label = document.createElement('span');
                label.className = 'small';
                label.textContent = name;
                left.appendChild(label);

                row.appendChild(left);
                customList.appendChild(row);
            });
        };

        const getDragAfterElement = (container, clientY) => {
            const draggableElements = Array.from(container.querySelectorAll('.dashboard-custom-order-item:not(.dragging)'));
            let closest = { offset: Number.NEGATIVE_INFINITY, element: null };

            draggableElements.forEach((child) => {
                const box = child.getBoundingClientRect();
                const offset = clientY - box.top - (box.height / 2);
                if (offset < 0 && offset > closest.offset) {
                    closest = { offset, element: child };
                }
            });

            return closest.element;
        };

        customList.addEventListener('dragstart', (event) => {
            const row = event.target && event.target.closest ? event.target.closest('.dashboard-custom-order-item') : null;
            if (!row) return;
            row.classList.add('dragging');
            if (event.dataTransfer) event.dataTransfer.effectAllowed = 'move';
        });

        customList.addEventListener('dragend', (event) => {
            const row = event.target && event.target.closest ? event.target.closest('.dashboard-custom-order-item') : null;
            if (!row) return;
            row.classList.remove('dragging');
        });

        customList.addEventListener('dragover', (event) => {
            event.preventDefault();
            const draggingRow = customList.querySelector('.dashboard-custom-order-item.dragging');
            if (!draggingRow) return;
            const nextRow = getDragAfterElement(customList, event.clientY);
            if (!nextRow) customList.appendChild(draggingRow);
            else customList.insertBefore(draggingRow, nextRow);
        });

        customButton.addEventListener('click', () => {
            buildCustomList();
            setCustomFeedback('Save and refresh the page to apply the new custom order.', 'muted');
            customModal.show();
        });

        customSaveButton.addEventListener('click', async () => {
            const orderedIds = normalizeServerIds(
                Array.from(customList.querySelectorAll('.dashboard-custom-order-item')).map((row) => row.dataset.serverId)
            );
            if (orderedIds.length === 0) {
                setCustomFeedback('No servers available for custom ordering.', 'warning');
                return;
            }

            customSaveButton.disabled = true;
            try {
                const data = await persistServerOrder('custom', orderedIds);
                savedCustomOrderIds = normalizeServerIds(data.customIds || orderedIds);
                activeMode = 'custom';
                persistSortStateLocally(activeMode, savedCustomOrderIds);
                if (sortSelect) sortSelect.value = 'custom';
                applyModeToGrid('custom');
                setCustomFeedback('Custom order saved. Refresh page to apply it.', 'success');
                setSortFeedback('Custom order saved. Refresh page to apply it.', 'warning');
            } catch (error) {
                setCustomFeedback(error.message || 'Failed to save custom order.', 'danger');
            } finally {
                customSaveButton.disabled = false;
            }
        });
    })();
</script>
</body>
</html>

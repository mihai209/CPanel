<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> - Too Many Requests</title>
    <%- include ('partials/favicon.ejs') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0a0a0c;
            --accent-blue: #3b82f6;
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --card-bg: rgba(26, 26, 32, 0.9);
            --border-color: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: radial-gradient(circle at center, #111827 0%, #000000 100%);
        }

        .limit-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 3rem;
            width: 100%;
            max-width: 500px;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .mascot-container {
            margin-bottom: 2rem;
            position: relative;
        }

        .mascot-img {
            width: 180px;
            height: auto;
            filter: drop-shadow(0 0 20px rgba(59, 130, 246, 0.3));
            animation: float 4s ease-in-out infinite;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        .warning-icon {
            position: absolute;
            bottom: 0;
            right: calc(50% - 90px);
            background: #ef4444;
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            border: 4px solid var(--bg-dark);
            box-shadow: 0 4px 10px rgba(239, 68, 68, 0.4);
        }

        h1 {
            font-weight: 800;
            font-size: 2rem;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, #9ca3af 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .description {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 2.5rem;
        }

        .countdown-container {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .countdown-timer {
            font-family: 'Monaco', 'Consolas', monospace;
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--accent-blue);
            letter-spacing: 2px;
        }

        .countdown-label {
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--text-secondary);
        }

        .btn-retry {
            margin-top: 2rem;
            background: white;
            color: black;
            border: none;
            padding: 0.75rem 2rem;
            border-radius: 12px;
            font-weight: 700;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-retry:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
            background: #f3f4f6;
        }

        .btn-retry.disabled {
            opacity: 0.5;
            pointer-events: none;
        }
    </style>
</head>

<body>
    <div class="limit-card">
        <div class="mascot-container">
            <img src="/assets/rocky-security.png" alt="Rocky Security" class="mascot-img">
            <div class="warning-icon">
                <i class="bi bi-shield-exclamation"></i>
            </div>
        </div>

        <h1>Too Many Requests</h1>
        <p class="description">
            Whoa there! You're moving a bit too fast for our servers. Please take a small break while we reset your
            limits.
        </p>

        <div class="countdown-container">
            <span class="countdown-label">Resets in</span>
            <div id="timer" class="countdown-timer">00:00</div>
        </div>

        <a href="/" id="retryBtn" class="btn-retry disabled">Try Again</a>
    </div>

    <script>
        (() => {
            if (window.__cpanelRateLimitLifecycleBound) return;
            window.__cpanelRateLimitLifecycleBound = true;

            let rateLimitState = null;

            const initRateLimitPage = () => {
                const timerEl = document.getElementById('timer');
                const retryBtn = document.getElementById('retryBtn');
                if (!timerEl || !retryBtn) return;
                if (timerEl.dataset.cpanelRateLimitInit === '1') return;
                timerEl.dataset.cpanelRateLimitInit = '1';

                let secondsLeft = 60;
                const updateTimer = () => {
                    const mins = Math.floor(secondsLeft / 60);
                    const secs = secondsLeft % 60;
                    timerEl.innerText = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;

                    if (secondsLeft <= 0) {
                        if (rateLimitState && rateLimitState.interval) {
                            clearInterval(rateLimitState.interval);
                        }
                        timerEl.innerText = 'READY';
                        retryBtn.classList.remove('disabled');
                        retryBtn.style.background = 'var(--accent-blue)';
                        retryBtn.style.color = 'white';
                    }
                    secondsLeft--;
                };

                updateTimer();
                const interval = setInterval(updateTimer, 1000);
                rateLimitState = { timerEl, interval };
            };

            const cleanupRateLimitPage = () => {
                if (!rateLimitState) return;
                if (rateLimitState.interval) clearInterval(rateLimitState.interval);
                if (rateLimitState.timerEl) {
                    rateLimitState.timerEl.dataset.cpanelRateLimitInit = '0';
                }
                rateLimitState = null;
            };

            document.addEventListener('turbo:load', initRateLimitPage);
            document.addEventListener('turbo:before-cache', cleanupRateLimitPage);
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initRateLimitPage, { once: true });
            } else {
                initRateLimitPage();
            }
        })();
    </script>
</body>

</html>

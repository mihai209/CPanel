<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<%
const items = Array.isArray(cards) ? cards : [];
const allCount = Number(totalCards || items.length);
const f = filters || {};
const selectedStatus = String(f.status || 'all');
const selectedSearch = String(f.search || '');
const selectedMinFreeRamGb = Number(f.minFreeRamGb || 0);
const selectedMinFreeDiskGb = Number(f.minFreeDiskGb || 0);
const selectedMinFreeAllocations = Number(f.minFreeAllocations || 0);
const fmt = (value, digits = 1) => {
    const num = Number(value || 0);
    if (!Number.isFinite(num)) return '0';
    return num.toFixed(digits);
};
const fmtTime = (value) => {
    if (!value) return 'Never';
    const dt = new Date(value);
    if (Number.isNaN(dt.getTime())) return 'Never';
    return dt.toLocaleString();
};
const progressClass = (pct) => {
    const val = Number(pct || 0);
    if (val >= 95) return 'bg-danger';
    if (val >= 80) return 'bg-warning';
    return 'bg-primary';
};
%>

<style>
    .check-shell { max-width: 1280px; margin: 0 auto; }
    .check-card {
        border: 1px solid #2e3036;
        background: linear-gradient(180deg, rgba(31, 32, 35, 0.95), rgba(31, 32, 35, 0.72));
        border-radius: 14px;
        padding: 1.15rem;
        height: 100%;
    }
    .metric-title { font-size: 0.75rem; color: #9ba0aa; text-transform: uppercase; letter-spacing: .06em; }
    .metric-value { font-weight: 700; }
    .capacity-progress { height: 8px; background: rgba(255,255,255,0.06); border-radius: 999px; }
</style>

<div class="container-fluid py-4">
    <div class="check-shell">
        <div class="check-card mb-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h1 class="h4 fw-bold mb-1">Connectors Check</h1>
                    <div class="text-muted small">Real free capacity per connector: RAM, Disk, Allocations and live node health.</div>
                </div>
                <a href="/" class="btn btn-outline-light btn-sm">Back to Dashboard</a>
            </div>
        </div>

        <div class="check-card mb-3">
            <form method="GET" action="/connectors-check" class="row g-2 align-items-end">
                <div class="col-12 col-lg-3">
                    <label class="form-label text-muted small text-uppercase fw-bold mb-1">Search</label>
                    <input type="text" name="search" value="<%= selectedSearch %>" class="form-control form-control-sm" placeholder="name, fqdn, location" style="background:#1a1a20;border-color:#2d2d35;">
                </div>
                <div class="col-6 col-lg-2">
                    <label class="form-label text-muted small text-uppercase fw-bold mb-1">Status</label>
                    <select name="status" class="form-select form-select-sm" style="background:#1a1a20;border-color:#2d2d35;">
                        <option value="all" <%= selectedStatus === 'all' ? 'selected' : '' %>>All</option>
                        <option value="online" <%= selectedStatus === 'online' ? 'selected' : '' %>>Online</option>
                        <option value="offline" <%= selectedStatus === 'offline' ? 'selected' : '' %>>Offline</option>
                    </select>
                </div>
                <div class="col-6 col-lg-2">
                    <label class="form-label text-muted small text-uppercase fw-bold mb-1">Min RAM Free (GB)</label>
                    <input type="number" step="0.1" min="0" name="minFreeRamGb" value="<%= selectedMinFreeRamGb %>" class="form-control form-control-sm" style="background:#1a1a20;border-color:#2d2d35;">
                </div>
                <div class="col-6 col-lg-2">
                    <label class="form-label text-muted small text-uppercase fw-bold mb-1">Min Disk Free (GB)</label>
                    <input type="number" step="0.1" min="0" name="minFreeDiskGb" value="<%= selectedMinFreeDiskGb %>" class="form-control form-control-sm" style="background:#1a1a20;border-color:#2d2d35;">
                </div>
                <div class="col-6 col-lg-2">
                    <label class="form-label text-muted small text-uppercase fw-bold mb-1">Min Free Alloc</label>
                    <input type="number" step="1" min="0" name="minFreeAllocations" value="<%= selectedMinFreeAllocations %>" class="form-control form-control-sm" style="background:#1a1a20;border-color:#2d2d35;">
                </div>
                <div class="col-12 col-lg-1 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary w-100">Apply</button>
                    <a href="/connectors-check" class="btn btn-sm btn-outline-light w-100">Reset</a>
                </div>
            </form>
            <div class="text-muted small mt-2">Showing <strong><%= items.length %></strong> of <strong><%= allCount %></strong> connector(s).</div>
        </div>

        <% if (success) { %>
            <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle-fill me-2"></i><%= success %></div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
        <% } %>

        <% if (!items.length) { %>
            <div class="check-card text-center text-muted">No connectors available.</div>
        <% } else { %>
            <div class="row g-3">
                <% items.forEach((item) => { %>
                    <% const connector = item.connector || {}; const metrics = item.metrics || {}; %>
                    <div class="col-12 col-xl-6">
                        <div class="check-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <div class="fw-semibold"><%= connector.name %></div>
                                    <div class="text-muted small"><%= connector.fqdn %><% if (connector.location && connector.location.shortName) { %> | <%= connector.location.shortName %><% } %></div>
                                </div>
                                <span class="badge <%= item.isOnline ? 'bg-success' : 'bg-secondary' %>"><%= item.isOnline ? 'ONLINE' : 'OFFLINE' %></span>
                            </div>

                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <div class="metric-title">RAM Free / Cap</div>
                                    <div class="metric-value"><%= fmt(metrics.memoryFreeGb) %> GB / <%= fmt(metrics.memoryCapGb) %> GB</div>
                                    <div class="progress capacity-progress mt-1"><div class="progress-bar <%= progressClass(metrics.memoryUsagePct) %>" style="width:<%= Math.min(100, Number(metrics.memoryUsagePct || 0)) %>%"></div></div>
                                    <div class="text-muted small mt-1">Used: <%= fmt(metrics.memoryUsedGb) %> GB (<%= fmt(metrics.memoryUsagePct, 0) %>%)</div>
                                </div>
                                <div class="col-6">
                                    <div class="metric-title">Disk Free / Cap</div>
                                    <div class="metric-value"><%= fmt(metrics.diskFreeGb) %> GB / <%= fmt(metrics.diskCapGb) %> GB</div>
                                    <div class="progress capacity-progress mt-1"><div class="progress-bar <%= progressClass(metrics.diskUsagePct) %>" style="width:<%= Math.min(100, Number(metrics.diskUsagePct || 0)) %>%"></div></div>
                                    <div class="text-muted small mt-1">Used: <%= fmt(metrics.diskUsedGb) %> GB (<%= fmt(metrics.diskUsagePct, 0) %>%)</div>
                                </div>
                            </div>

                            <div class="row g-2 mt-1">
                                <div class="col-4">
                                    <div class="metric-title">Allocations Free</div>
                                    <div class="metric-value"><%= Number(metrics.freeAllocations || 0) %> / <%= Number(metrics.totalAllocations || 0) %></div>
                                </div>
                                <div class="col-4">
                                    <div class="metric-title">CPU Allocated</div>
                                    <div class="metric-value"><%= fmt(metrics.cpuAllocatedCores, 2) %> cores</div>
                                    <div class="text-muted small"><%= fmt(metrics.cpuAllocatedPercent, 0) %>% total</div>
                                </div>
                                <div class="col-4">
                                    <div class="metric-title">CPU Live</div>
                                    <div class="metric-value"><%= fmt(metrics.cpuLivePercent, 1) %>%</div>
                                    <div class="text-muted small">host realtime</div>
                                </div>
                            </div>

                            <div class="text-muted small mt-3">Last seen: <strong><%= fmtTime(item.statusData && item.statusData.lastSeen) %></strong></div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %> - Account Suspended
    </title>
    <%- include('partials/favicon') %>
    <%- include ('partials/error-modal') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
        <style>
            body {
                background-color: #0c0c10;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                margin: 0;
                font-family: 'Inter', sans-serif;
                color: #ffffff;
            }

            .suspension-card {
                background-color: #141419;
                border: 1px solid rgba(255, 255, 255, 0.05);
                border-radius: 1.5rem;
                padding: 3rem;
                max-width: 500px;
                text-align: center;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            }

            .icon-box {
                width: 80px;
                height: 80px;
                background: rgba(239, 68, 68, 0.1);
                color: #ef4444;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 2rem;
                font-size: 2.5rem;
            }

            .brand-name {
                font-weight: 800;
                letter-spacing: 0.1em;
                color: #6366f1;
                margin-bottom: 0.5rem;
            }

            .btn-logout {
                background: #2d2d35;
                border: none;
                color: #ffffff;
                font-weight: 600;
                padding: 0.75rem 2rem;
                border-radius: 0.75rem;
                transition: all 0.2s;
                text-decoration: none;
                display: inline-block;
                margin-top: 2rem;
            }

            .btn-logout:hover {
                background: #3f3f4a;
                color: #ffffff;
                transform: translateY(-2px);
            }
        </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>

<body>
    <div class="suspension-card border-0">
        <div class="icon-box">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div class="brand-name small text-uppercase">
            <%= settings.brandName || 'CPanel' %>
        </div>
        <h2 class="fw-bold mb-3">Account Suspended</h2>
        <p class="text-muted mb-0">Your access to this panel has been restricted by an administrator.</p>
        <p class="text-muted small mt-2">If you believe this is a mistake, please contact support.</p>

        <a href="/logout" class="btn-logout">
            <i class="bi bi-box-arrow-left me-2"></i>Logout
        </a>
    </div>
</body>

</html>
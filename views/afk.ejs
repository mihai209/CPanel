<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<style>
    .afk-shell {
        max-width: 980px;
        margin: 0 auto;
    }

    .afk-card {
        border: 1px solid #2e3036;
        background: linear-gradient(180deg, rgba(31, 32, 35, 0.95), rgba(31, 32, 35, 0.72));
        border-radius: 14px;
        padding: 1.25rem;
    }

    .afk-metric {
        border: 1px solid #2e3036;
        border-radius: 12px;
        padding: 1rem;
        background-color: rgba(255, 255, 255, 0.02);
        height: 100%;
    }

    .afk-label {
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .afk-value {
        font-size: 1.45rem;
        font-weight: 700;
        margin-top: 0.4rem;
        line-height: 1.1;
    }

    .status-chip {
        border: 1px solid #2e3036;
        border-radius: 999px;
        padding: 0.35rem 0.8rem;
        font-size: 0.8rem;
        color: #d1d5db;
        background-color: rgba(255, 255, 255, 0.02);
    }
</style>

<div class="container-fluid py-4">
    <%
        const compactCoins = (value) => {
            const num = Number(value || 0);
            if (!Number.isFinite(num)) return '0';
            return new Intl.NumberFormat('en', {
                notation: 'compact',
                maximumFractionDigits: 1
            }).format(num);
        };
    %>
    <div class="afk-shell">
        <div class="afk-card mb-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h1 class="h4 fw-bold mb-1">AFK Timer</h1>
                    <p class="text-muted mb-0 small">Stai pe această pagină și primești automat coin-uri la intervalul configurat.</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="/rewards" class="btn btn-outline-primary btn-sm">Open Rewards</a>
                    <a href="/" class="btn btn-outline-light btn-sm">Back to Dashboard</a>
                </div>
            </div>
        </div>

        <% if (success) { %>
            <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success">
                <i class="bi bi-check-circle-fill me-2"></i><%= success %>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
            </div>
        <% } %>

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="afk-metric">
                    <div class="afk-label">Wallet</div>
                    <div id="walletValue" class="afk-value"><%= compactCoins(user.coins || 0) %> <%= economyUnit %></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="afk-metric">
                    <div class="afk-label">Next Reward</div>
                    <div id="afkRemainingValue" class="afk-value"><%= Number(afkRemainingSeconds || 0) %>s</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="afk-metric">
                    <div class="afk-label">Reward Amount</div>
                    <div class="afk-value">+<%= compactCoins(afkTimerCoins || 0) %> <%= economyUnit %></div>
                    <div class="text-muted small mt-1">Interval: <%= Number(afkTimerCooldownSeconds || 60) %>s</div>
                </div>
            </div>
        </div>

        <div class="afk-card">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <h2 class="h6 text-uppercase mb-0" style="letter-spacing: 0.04em;">AFK Status</h2>
                <span id="afkStatus" class="status-chip">Initializing...</span>
            </div>

            <% if (!afkTimerEnabled) { %>
                <div class="alert alert-warning mb-0">AFK timer is disabled by admin.</div>
            <% } else { %>
                <p class="text-muted small mb-0">Heartbeat-ul rulează automat la 10 secunde pentru a confirma activitatea paginii.</p>
            <% } %>
        </div>
    </div>
</div>

<script>
    (function () {
        if (window.__cpanelAfkLifecycleBound) return;
        window.__cpanelAfkLifecycleBound = true;

        let afkPageState = null;
        const economyUnit = '<%= economyUnit %>';
        const afkTimerEnabled = <%= afkTimerEnabled ? 'true' : 'false' %>;
        const compactFormatter = new Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 });

        const walletValueEl = document.getElementById('walletValue');
        const afkRemainingEl = document.getElementById('afkRemainingValue');
        const afkStatusEl = document.getElementById('afkStatus');

        let afkRemainingSeconds = Number.parseInt('<%= Number(afkRemainingSeconds || 0) %>', 10);
        if (!Number.isFinite(afkRemainingSeconds) || afkRemainingSeconds < 0) afkRemainingSeconds = 0;

        const updateWallet = (coins) => {
            if (!walletValueEl) return;
            const parsed = Number(coins);
            if (!Number.isFinite(parsed)) return;
            walletValueEl.textContent = `${compactFormatter.format(parsed)} ${economyUnit}`;
        };

        const tick = () => {
            if (afkRemainingEl) afkRemainingEl.textContent = `${Math.max(0, afkRemainingSeconds)}s`;
            if (afkRemainingSeconds > 0) afkRemainingSeconds -= 1;
        };

        const pingAfk = async () => {
            if (!afkTimerEnabled) return;
            try {
                const response = await fetch('/afk/ping', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: '{}'
                });
                const payload = await response.json();
                if (!response.ok || !payload || payload.success !== true) {
                    throw new Error(payload && payload.error ? payload.error : 'AFK ping failed');
                }

                if (Number.isFinite(Number(payload.remainingSeconds))) {
                    afkRemainingSeconds = Math.max(0, Number(payload.remainingSeconds));
                }
                if (Number.isFinite(Number(payload.coins))) {
                    updateWallet(payload.coins);
                }

                if (afkStatusEl) {
                    if (payload.awarded && Number(payload.awardedCoins) > 0) {
                        afkStatusEl.textContent = `+${payload.awardedCoins} ${payload.economyUnit || economyUnit} awarded`;
                    } else {
                        afkStatusEl.textContent = 'AFK heartbeat synced';
                    }
                }
            } catch (error) {
                if (afkStatusEl) {
                    afkStatusEl.textContent = String(error && error.message ? error.message : 'AFK ping error');
                }
            }
        };

        const initAfkPage = () => {
            const root = document.querySelector('.afk-shell');
            if (!root) return;
            if (root.dataset.cpanelAfkInit === '1') return;
            root.dataset.cpanelAfkInit = '1';

            tick();
            const tickTimer = window.setInterval(tick, 1000);
            let pingTimer = null;

            if (afkTimerEnabled) {
                pingAfk();
                pingTimer = window.setInterval(pingAfk, 10000);
            } else if (afkStatusEl) {
                afkStatusEl.textContent = 'AFK timer disabled';
            }

            afkPageState = { root, tickTimer, pingTimer };
        };

        const cleanupAfkPage = () => {
            if (!afkPageState) return;
            if (afkPageState.tickTimer) clearInterval(afkPageState.tickTimer);
            if (afkPageState.pingTimer) clearInterval(afkPageState.pingTimer);
            if (afkPageState.root) {
                afkPageState.root.dataset.cpanelAfkInit = '0';
            }
            afkPageState = null;
        };

        document.addEventListener('turbo:load', initAfkPage);
        document.addEventListener('turbo:before-cache', cleanupAfkPage);
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initAfkPage, { once: true });
        } else {
            initAfkPage();
        }
    })();
</script>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

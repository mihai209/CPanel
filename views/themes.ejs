<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1 text-light">Themes</h2>
            <p class="text-muted mb-0 small">Pick a preset theme or manage your private custom theme override.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/themes/builder" class="btn btn-outline-info btn-sm">
                <i class="bi bi-sliders me-1"></i>Theme Builder
            </a>
            <a href="/account" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to Account
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="background-color: #141419; border: 1px solid rgba(255,255,255,0.06) !important;">
        <div class="card-body p-3 p-lg-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">Base Theme</div>
                    <div class="fw-bold text-light"><%= String(activeTheme || 'default').toLowerCase() %></div>
                </div>
                <div>
                    <div class="text-muted small text-uppercase mb-1">Custom Override</div>
                    <% if (customTheme && customTheme.enabled) { %>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">Enabled</span>
                    <% } else { %>
                        <span class="badge bg-secondary bg-opacity-10 text-muted border border-secondary border-opacity-25">Disabled</span>
                    <% } %>
                </div>
            </div>

            <div class="mt-3 pt-3 border-top border-secondary border-opacity-25 d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div id="themePreviewState" class="small text-muted">
                    Preview is off. You are seeing your saved theme.
                </div>
                <div class="d-flex gap-2">
                    <button type="button" id="resetThemePreviewBtn" class="btn btn-outline-warning btn-sm" disabled>
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Preview
                    </button>
                    <% if (customTheme && customTheme.enabled) { %>
                        <form method="POST" action="/themes/custom-mode" class="d-inline">
                            <input type="hidden" name="enabled" value="false">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-x-circle me-1"></i>Disable Custom Override
                            </button>
                        </form>
                    <% } else { %>
                        <form method="POST" action="/themes/custom-mode" class="d-inline">
                            <input type="hidden" name="enabled" value="true">
                            <button type="submit" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-check-circle me-1"></i>Enable Custom Override
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <% (Array.isArray(themeCatalog) ? themeCatalog : []).forEach((theme) => { %>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm"
                    style="background-color: #1a1a20; border: 1px solid rgba(255,255,255,0.06) !important;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div>
                                <h5 class="text-light mb-1"><%= theme.label %></h5>
                                <div class="small text-muted"><code><%= theme.id %></code></div>
                            </div>
                            <% if (String(activeTheme || '').toLowerCase() === String(theme.id || '').toLowerCase()) { %>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">Active Base</span>
                            <% } %>
                        </div>

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <button
                                type="button"
                                class="btn btn-outline-info btn-sm theme-preview-btn"
                                data-theme-id="<%= theme.id %>"
                                data-theme-label="<%= theme.label %>"
                                data-theme-css="<%= theme.cssPath %>">
                                <i class="bi bi-eye me-1"></i>Preview
                            </button>

                            <form method="POST" action="/themes/apply" class="d-inline">
                                <input type="hidden" name="theme" value="<%= theme.id %>">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="bi bi-check2 me-1"></i>Apply
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<script>
(() => {
    const previewButtons = Array.from(document.querySelectorAll('.theme-preview-btn'));
    const resetBtn = document.getElementById('resetThemePreviewBtn');
    const stateEl = document.getElementById('themePreviewState');
    const themeLink = document.getElementById('cpanel-theme-css');
    const root = document.documentElement;
    const body = document.body;
    if (!themeLink || !previewButtons.length || !resetBtn || !stateEl) return;

    const initialThemeId = String((themeLink.dataset && themeLink.dataset.theme) || 'default').trim().toLowerCase() || 'default';
    const initialThemeHref = themeLink.getAttribute('href') || '/themes/default/index.css';
    const initialCustomState = root.getAttribute('data-user-custom-theme') === 'on';
    let previewing = false;

    const applyTheme = (themeId, cssPath) => {
        if (window.CPanelThemeLoader && typeof window.CPanelThemeLoader.applyTheme === 'function') {
            window.CPanelThemeLoader.applyTheme(themeId, cssPath);
            return;
        }
        themeLink.dataset.theme = String(themeId || 'default').trim().toLowerCase() || 'default';
        themeLink.setAttribute('href', cssPath || themeLink.getAttribute('href'));
        document.dispatchEvent(new Event('turbo:load'));
    };

    const restoreTheme = () => {
        if (window.CPanelThemeLoader && typeof window.CPanelThemeLoader.restoreInitialTheme === 'function') {
            window.CPanelThemeLoader.restoreInitialTheme();
        } else {
            themeLink.dataset.theme = initialThemeId;
            themeLink.setAttribute('href', initialThemeHref);
            document.dispatchEvent(new Event('turbo:load'));
        }
    };

    const setCustomState = (enabled) => {
        const value = enabled ? 'on' : 'off';
        root.setAttribute('data-user-custom-theme', value);
        if (body) body.setAttribute('data-user-custom-theme', value);
    };

    previewButtons.forEach((button) => {
        button.addEventListener('click', () => {
            const themeId = String(button.getAttribute('data-theme-id') || '').trim().toLowerCase();
            const themeLabel = String(button.getAttribute('data-theme-label') || themeId || 'theme').trim();
            const themeCss = String(button.getAttribute('data-theme-css') || '').trim();
            if (!themeId || !themeCss) return;
            previewing = true;
            applyTheme(themeId, themeCss);
            setCustomState(false);
            resetBtn.disabled = false;
            stateEl.textContent = `Previewing: ${themeLabel}. Click "Reset Preview" to return to saved theme.`;
        });
    });

    resetBtn.addEventListener('click', () => {
        if (!previewing) return;
        restoreTheme();
        setCustomState(initialCustomState);
        previewing = false;
        resetBtn.disabled = true;
        stateEl.textContent = 'Preview is off. You are seeing your saved theme.';
    });
})();
</script>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

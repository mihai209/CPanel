<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Server Not Found | <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <style>
            body {
                background-color: #0c0c10;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                margin: 0;
                font-family: 'Inter', sans-serif;
                color: #ffffff;
            }

            .error-card {
                background-color: #141419;
                border: 1px solid rgba(255, 255, 255, 0.05);
                border-radius: 1.5rem;
                padding: 3rem;
                max-width: 500px;
                text-align: center;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            }

            .mascot-box {
                margin: 0 auto 2rem;
            }

            .mascot-img {
                max-width: 200px;
                height: auto;
                border-radius: 1rem;
            }

            .brand-name {
                font-weight: 800;
                letter-spacing: 0.1em;
                color: #f59e0b;
                margin-bottom: 0.5rem;
            }

            .btn-back {
                background: #2d2d35;
                border: none;
                color: #ffffff;
                font-weight: 600;
                padding: 0.75rem 2rem;
                border-radius: 0.75rem;
                transition: all 0.2s;
                text-decoration: none;
                display: inline-block;
                margin-top: 2rem;
            }

            .btn-back:hover {
                background: #3f3f4a;
                color: #ffffff;
                transform: translateY(-2px);
            }
        </style>
</head>

<body>
    <div class="error-card border-0">
        <div class="mascot-box">
            <img src="/assets/sad-rocky.png" alt="Sad Mascot" class="mascot-img">
        </div>
        <div class="brand-name small text-uppercase">
            <%= settings.brandName || 'CPanel' %>
        </div>
        <h2 class="fw-bold mb-3">Server Not Found</h2>
        <p class="text-white mb-0">The server you are looking for does not exist or has been deleted.</p>

        <a href="/" class="btn-back">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</body>

</html>
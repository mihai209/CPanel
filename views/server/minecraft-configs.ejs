<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minecraft Control <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --bg: #0f0f12;
            --panel: #121216;
            --border: #2d2d35;
            --text: #e1e1e6;
            --muted: #8b8b9a;
            --accent: #3b82f6;
        }

        body {
            background: var(--bg);
            color: var(--text);
            margin: 0;
            font-family: Inter, system-ui, -apple-system, sans-serif;
            height: 100vh;
            overflow: hidden;
        }

        .wrapper {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: 260px;
            background: var(--panel);
            border-right: 1px solid var(--border);
            overflow-y: auto;
        }

        .sidebar.collapsed {
            margin-left: -260px;
        }

        .content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .top-navbar {
            background: var(--panel);
            border-bottom: 1px solid var(--border);
            padding: .75rem 1rem;
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 1.25rem;
        }

        .cardx {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: .8rem;
        }

        .text-muted-2 {
            color: var(--muted);
        }

        .btn-icon {
            background: transparent;
            border: 0;
            color: var(--muted);
            font-size: 1.2rem;
        }

        .btn-primary-soft {
            background: var(--accent);
            border: 1px solid var(--accent);
            color: #fff;
        }

        .btn-primary-soft:hover {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        .head-avatar {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border: 1px solid #2f2f39;
            object-fit: cover;
            background: #0f1115;
        }

        .motd-line {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.83rem;
            color: #d1d5db;
            background: #16161b;
            border: 1px solid #2d2d35;
            border-radius: 0.45rem;
            padding: 0.4rem 0.55rem;
            margin-bottom: 0.4rem;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .status-icon {
            width: 54px;
            height: 54px;
            border-radius: 10px;
            border: 1px solid #2d2d35;
            object-fit: cover;
            background: #0e1014;
        }

        .permission-note {
            border: 1px dashed #3a3a45;
            background: #16161b;
            border-radius: 0.55rem;
            padding: 0.6rem;
            font-size: 0.82rem;
            color: #a1a1aa;
        }

        .table-dark {
            --bs-table-bg: transparent;
        }
    </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>

<body>
    
<%- include('../partials/error-modal') %>
<div class="wrapper">
        <nav class="sidebar" id="sidebar">
            <div class="p-3">
                <%- include('../partials/server-sidebar', { server, active: 'mccenter' }) %>
            </div>
        </nav>

        <main class="content">
            <header class="top-navbar">
                <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
                <h1 class="h5 mb-0">Minecraft Control / <span class="text-muted-2"><%= server.name %></span></h1>
            </header>

            <section class="scroll-area">
                <% const status = minecraftStatusPreview || {}; %>
                <% const players = Array.isArray(status.playersList) ? status.playersList : []; %>
                <% const online = Boolean(status.online); %>
                <% const canKick = Boolean(minecraftActionPermissions && minecraftActionPermissions.canKick); %>
                <% const canBan = Boolean(minecraftActionPermissions && minecraftActionPermissions.canBan); %>
                <% const canOp = Boolean(minecraftActionPermissions && minecraftActionPermissions.canOp); %>
                <% const canDeop = Boolean(minecraftActionPermissions && minecraftActionPermissions.canDeop); %>
                <% const canTempban = Boolean(minecraftActionPermissions && minecraftActionPermissions.canTempban); %>
                <% const canTeleport = Boolean(minecraftActionPermissions && minecraftActionPermissions.canTeleport); %>
                <% const cacheExpiresLabel = status.cacheExpireAtIso ? new Date(status.cacheExpireAtIso).toLocaleString() : 'N/A'; %>
                <% const proxyMode = String(minecraftProxyMode || '').trim(); %>
                <% const macros = Array.isArray(commandMacros) ? commandMacros : []; %>
                <% const playtimeSupported = !minecraftBedrockMode; %>

                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <div class="cardx p-3 mb-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <div class="small text-muted-2 text-uppercase mb-1">Status Endpoint</div>
                            <div class="fw-semibold" id="mcStatusAddress"><%= minecraftStatusAddress || 'Unknown allocation' %></div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <form method="GET" action="/server/<%= server.containerId %>/minecraft/configs" class="mb-0" data-turbo="false">
                                <input type="hidden" name="bedrock" value="0">
                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" role="switch" id="bedrockSwitch" name="bedrock" value="1" <%= minecraftBedrockMode ? 'checked' : '' %> onchange="this.form.submit()">
                                    <label class="form-check-label small" for="bedrockSwitch">Bedrock mode</label>
                                </div>
                            </form>
                            <button class="btn btn-sm btn-outline-info" type="button" id="refreshStatusBtn">
                                <i class="bi bi-arrow-repeat"></i> Live Refresh
                            </button>
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" role="switch" id="autoRefreshSwitch">
                                <label class="form-check-label small" for="autoRefreshSwitch">Auto</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="cardx p-3 mb-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <div class="small text-muted-2 text-uppercase mb-1">Proxy Network Mode</div>
                            <div class="fw-semibold"><%= proxyMode ? proxyMode : 'disabled' %></div>
                            <div class="small text-muted-2">Enable this only for BungeeCord/Waterfall/Velocity servers.</div>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs/proxy-mode" class="d-flex align-items-center gap-2 mb-0">
                                <select class="form-select form-select-sm" name="proxyMode" style="min-width: 170px;">
                                    <option value="" <%= !proxyMode ? 'selected' : '' %>>Disabled</option>
                                    <option value="velocity" <%= proxyMode === 'velocity' ? 'selected' : '' %>>Velocity</option>
                                    <option value="bungeecord" <%= proxyMode === 'bungeecord' ? 'selected' : '' %>>BungeeCord</option>
                                    <option value="waterfall" <%= proxyMode === 'waterfall' ? 'selected' : '' %>>Waterfall</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-light">
                                    <i class="bi bi-save me-1"></i>Save Mode
                                </button>
                            </form>
                            <a href="/server/<%= server.containerId %>/minecraft/proxy" class="btn btn-sm btn-primary">
                                <i class="bi bi-diagram-3 me-1"></i>Open Proxy Panel
                            </a>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-12 col-xl-7">
                        <div class="cardx p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h2 class="h6 mb-0">Server Preview</h2>
                                <% if (online) { %>
                                    <span class="badge bg-success" id="mcStatusBadge">ONLINE</span>
                                <% } else { %>
                                    <span class="badge bg-danger" id="mcStatusBadge">OFFLINE</span>
                                <% } %>
                            </div>

                            <% if (!status.ok) { %>
                                <div class="alert alert-warning mb-0">
                                    Could not fetch live status: <%= status.error || 'Unknown error.' %>
                                </div>
                            <% } else { %>
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <img id="mcStatusIcon" src="<%= status.iconDataUri || 'https://api.mcsrvstat.us/icon/' + encodeURIComponent(minecraftStatusAddress || '') %>" class="status-icon" alt="Server Icon">
                                    <div>
                                        <div class="fw-semibold" id="mcStatusHostname"><%= status.hostname || status.ip || minecraftStatusAddress %></div>
                                        <div class="small text-muted-2" id="mcStatusMeta">
                                            Version: <span id="mcStatusVersion"><%= status.version || status.protocolName || 'Unknown' %></span>
                                            <% if (status.software) { %>· Software: <span id="mcStatusSoftware"><%= status.software %></span><% } %>
                                            <% if (minecraftBedrockMode && status.gamemode) { %>· Mode: <span id="mcStatusGamemode"><%= status.gamemode %></span><% } %>
                                        </div>
                                        <div class="small text-muted-2" id="mcStatusCache">Cache expires: <%= cacheExpiresLabel %></div>
                                    </div>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-6 col-md-4">
                                        <div class="cardx p-2">
                                            <div class="small text-muted-2">Players</div>
                                            <div class="fw-semibold" id="mcPlayersCount"><%= Number(status.playersOnline || 0) %> / <%= Number(status.playersMax || 0) %></div>
                                        </div>
                                    </div>
                                    <div class="col-6 col-md-4">
                                        <div class="cardx p-2">
                                            <div class="small text-muted-2">Port</div>
                                            <div class="fw-semibold" id="mcStatusPort"><%= status.port || 'N/A' %></div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <div class="cardx p-2">
                                            <div class="small text-muted-2">EULA Blocked</div>
                                            <div class="fw-semibold" id="mcStatusEula"><%= status.eulaBlocked ? 'Yes' : 'No' %></div>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <div class="small text-muted-2 text-uppercase mb-2">MOTD</div>
                                    <div id="mcMotdLines">
                                        <% if (Array.isArray(status.motdClean) && status.motdClean.length > 0) { %>
                                            <% status.motdClean.forEach((line) => { %>
                                                <div class="motd-line"><%= line %></div>
                                            <% }) %>
                                        <% } else { %>
                                            <div class="text-muted-2 small">No MOTD data available.</div>
                                        <% } %>
                                    </div>
                                </div>

                            <% } %>

                            <div class="mt-3 border-top border-secondary border-opacity-25 pt-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <div class="fw-semibold">Quick MOTD Editor</div>
                                    <button class="btn btn-sm btn-primary-soft" type="button" id="saveMotdBtn" <%= !connectorOnline ? 'disabled' : '' %>>
                                        <i class="bi bi-save me-1"></i>Save MOTD
                                    </button>
                                </div>
                                <textarea id="motdInput" class="form-control" rows="2" maxlength="200" placeholder="Line 1&#10;Line 2" <%= !connectorOnline ? 'disabled' : '' %>><%= minecraftMotd || '' %></textarea>
                                <div class="small text-muted-2 mt-1">Use a new line for multi-line MOTD (stored as \\n).</div>
                                <% if (minecraftPropertiesError) { %>
                                    <div class="alert alert-warning py-2 mt-2 mb-0"><%= minecraftPropertiesError %></div>
                                <% } %>
                            </div>

                            <div class="mt-3 border-top border-secondary border-opacity-25 pt-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <div class="fw-semibold">MOTD Preset Library</div>
                                    <button class="btn btn-sm btn-outline-light" type="button" id="saveMotdPresetBtn" <%= !connectorOnline ? 'disabled' : '' %>>
                                        <i class="bi bi-bookmark-plus me-1"></i>Save Preset
                                    </button>
                                </div>
                                <div class="small text-muted-2 mb-2">Save reusable MOTDs and apply them instantly.</div>
                                <div id="motdPresetList" class="d-grid gap-2"></div>
                            </div>

                            <div class="mt-3 border-top border-secondary border-opacity-25 pt-3">
                                <div class="fw-semibold mb-2">Server Icon</div>
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <input class="form-control" type="file" id="iconInput" accept="image/png" <%= !connectorOnline ? 'disabled' : '' %>>
                                    <button class="btn btn-sm btn-outline-light" type="button" id="uploadIconBtn" <%= !connectorOnline ? 'disabled' : '' %>>
                                        <i class="bi bi-cloud-arrow-up me-1"></i>Upload Icon
                                    </button>
                                </div>
                                <div class="small text-muted-2 mt-1">PNG only, 64x64 recommended. File will be saved as server-icon.png.</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xl-5">
                        <div class="d-flex flex-column gap-3">
                        <div class="cardx p-3">
                            <h2 class="h6 mb-3">Minecraft Commands</h2>

                            <% if (!connectorOnline) { %>
                                <div class="alert alert-warning py-2">Connector is offline. Commands are disabled.</div>
                            <% } %>

                            <div class="permission-note mb-3">
                                Required permissions: <code>minecraft.op</code>, <code>minecraft.deop</code>, <code>minecraft.kick</code>, <code>minecraft.ban</code>,
                                <code>minecraft.tempban</code>, <code>minecraft.teleport</code>.
                            </div>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="op">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">OP Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-success" type="submit" <%= (!connectorOnline || !canOp) ? 'disabled' : '' %>>OP</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="deop">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">DEOP Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-outline-warning" type="submit" <%= (!connectorOnline || !canDeop) ? 'disabled' : '' %>>DEOP</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="kick">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">Kick Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-outline-light" type="submit" <%= (!connectorOnline || !canKick) ? 'disabled' : '' %>>KICK</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="teleport">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">Teleport Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-outline-info" type="submit" <%= (!connectorOnline || !canTeleport) ? 'disabled' : '' %>>TP</button>
                                </div>
                                <input name="destination" class="form-control" required maxlength="64" placeholder="Destination (player or coords)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" data-turbo="false">
                                <input type="hidden" name="action" value="ban">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">Ban Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-danger" type="submit" <%= (!connectorOnline || !canBan) ? 'disabled' : '' %>>BAN</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" data-turbo="false">
                                <input type="hidden" name="action" value="tempban">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">Tempban Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-outline-danger" type="submit" <%= (!connectorOnline || !canTempban) ? 'disabled' : '' %>>TEMPBAN</button>
                                </div>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <input name="duration" class="form-control" required maxlength="16" placeholder="Duration (e.g. 1h)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    </div>
                                    <div class="col-md-8">
                                        <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    </div>
                                </div>
                            </form>
                        </div>

                        <div class="cardx p-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h2 class="h6 mb-0">Mini RCON Console</h2>
                                <span class="small text-muted-2">Filtered mode</span>
                            </div>
                            <% if (!canRunConsole) { %>
                                <div class="alert alert-warning py-2">Missing permission: <code>server.console</code>.</div>
                            <% } %>
                            <div class="input-group mb-2">
                                <input id="mcMiniCommandInput" class="form-control" placeholder="say Hello players" <%= (!connectorOnline || !canRunConsole) ? 'disabled' : '' %>>
                                <button class="btn btn-primary-soft" type="button" id="mcMiniCommandBtn" <%= (!connectorOnline || !canRunConsole) ? 'disabled' : '' %>>
                                    <i class="bi bi-send"></i> Send
                                </button>
                            </div>
                            <div class="small text-muted-2 mb-3">Blocked: stop/restart/reload/op/deop/kick/ban/tempban.</div>

                            <% if (canUseMacros && macros.length > 0) { %>
                                <div class="small text-muted-2 text-uppercase mb-2">Macro Shortcuts</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <% macros.forEach((macro) => { %>
                                        <button class="btn btn-sm btn-outline-light mc-macro-btn"
                                            type="button"
                                            data-command="<%= macro.command || '' %>"
                                            title="<%= macro.description || macro.command || '' %>">
                                            <%= macro.name || 'Macro' %>
                                        </button>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-muted-2 small">No macros available for this server.</div>
                            <% } %>
                        </div>
                        </div>
                    </div>
                </div>

                <div class="cardx p-3 mb-3">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                        <h2 class="h6 mb-0">Resource Pack Manager</h2>
                        <span class="small text-muted-2">Auto-download &amp; validate</span>
                    </div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small text-uppercase text-muted-2">Resource Pack URL</label>
                            <input class="form-control" id="resourcePackUrlInput" value="<%= minecraftResourcePack && minecraftResourcePack.url ? minecraftResourcePack.url : '' %>" placeholder="https://example.com/resourcepack.zip" <%= !connectorOnline ? 'disabled' : '' %>>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-uppercase text-muted-2">SHA1 (auto)</label>
                            <input class="form-control" id="resourcePackSha1Input" value="<%= minecraftResourcePack && minecraftResourcePack.sha1 ? minecraftResourcePack.sha1 : '' %>" placeholder="computed on apply" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-uppercase text-muted-2">Prompt</label>
                            <input class="form-control" id="resourcePackPromptInput" value="<%= minecraftResourcePack && minecraftResourcePack.prompt ? minecraftResourcePack.prompt : '' %>" placeholder="Optional prompt" <%= !connectorOnline ? 'disabled' : '' %>>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-uppercase text-muted-2">Required</label>
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input" type="checkbox" id="resourcePackRequiredInput" <%= minecraftResourcePack && minecraftResourcePack.required ? 'checked' : '' %> <%= !connectorOnline ? 'disabled' : '' %>>
                                <label class="form-check-label small text-muted-2" for="resourcePackRequiredInput">Force pack on join</label>
                            </div>
                        </div>
                        <div class="col-12 d-flex justify-content-end">
                            <button class="btn btn-primary-soft" type="button" id="resourcePackApplyBtn" <%= !connectorOnline ? 'disabled' : '' %>>
                                <i class="bi bi-shield-check me-1"></i>Validate &amp; Apply
                            </button>
                        </div>
                    </div>
                    <div class="small text-muted-2 mt-2">Resource packs are downloaded to <code>/resourcepacks</code> and SHA1 is computed automatically.</div>
                </div>

                <div class="cardx p-3 mb-3" id="playtimeCard">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h2 class="h6 mb-0">Playtime Top 10</h2>
                        <button class="btn btn-sm btn-outline-info" type="button" id="playtimeLoadBtn" <%= (!connectorOnline || !playtimeSupported) ? 'disabled' : '' %>>
                            <i class="bi bi-clock-history me-1"></i>Load Top 10
                        </button>
                    </div>
                    <div class="small text-muted-2 mb-2" id="playtimeStatus">
                        <% if (!playtimeSupported) { %>
                            Playtime viewer is not available for Bedrock servers.
                        <% } else if (!connectorOnline) { %>
                            Connector is offline.
                        <% } else { %>
                            Click “Load Top 10” to fetch playtime stats from <code>/stats</code>.
                        <% } %>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Player</th>
                                    <th class="text-end">Playtime</th>
                                </tr>
                            </thead>
                            <tbody id="playtimeBody">
                                <tr>
                                    <td colspan="2" class="text-muted-2">No playtime data loaded.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="cardx p-3">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h2 class="h6 mb-0">Online Players</h2>
                        <span class="text-muted-2 small" id="mcPlayersDetected"><%= Number(status.playersOnline || 0) %> detected</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-dark table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Player</th>
                                    <th>UUID</th>
                                    <th class="text-end">Quick Actions</th>
                                </tr>
                            </thead>
                            <tbody id="mcPlayersBody">
                                <% if (players.length === 0) { %>
                                    <tr>
                                        <td colspan="3" class="text-muted-2">No player sample available from status API.</td>
                                    </tr>
                                <% } else { %>
                                    <% players.forEach((player) => { %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <img class="head-avatar" src="<%= player.headUrl %>" alt="Head" onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='https://minotar.net/avatar/Steve/40';}else{this.onerror=null;}">
                                                    <div class="fw-semibold"><%= player.name %></div>
                                                </div>
                                            </td>
                                            <td><code><%= player.uuid || '-' %></code></td>
                                            <td class="text-end">
                                                <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="op">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-success js-mc-guarded-action" data-action-label="OP" title="OP" <%= (!connectorOnline || !canOp) ? 'disabled' : '' %>>OP</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="deop">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-warning js-mc-guarded-action" data-action-label="DEOP" title="DEOP" <%= (!connectorOnline || !canDeop) ? 'disabled' : '' %>>DEOP</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="kick">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-light js-mc-guarded-action" data-action-label="KICK" data-requires-reason="1" title="KICK" <%= (!connectorOnline || !canKick) ? 'disabled' : '' %>>KICK</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="teleport">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="destination" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-info js-mc-guarded-action" data-action-label="TP" data-requires-destination="1" title="Teleport" <%= (!connectorOnline || !canTeleport) ? 'disabled' : '' %>>TP</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="ban">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger js-mc-guarded-action" data-action-label="BAN" data-requires-reason="1" title="BAN" <%= (!connectorOnline || !canBan) ? 'disabled' : '' %>>BAN</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft/configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="tempban">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="duration" value="">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger js-mc-guarded-action" data-action-label="TEMPBAN" data-requires-duration="1" data-requires-reason="1" title="Tempban" <%= (!connectorOnline || !canTempban) ? 'disabled' : '' %>>TEMP</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
    <script>
        const serverId = '<%= server.containerId %>';
        const bedrockMode = <%= minecraftBedrockMode ? 'true' : 'false' %>;
        const connectorOnline = <%= connectorOnline ? 'true' : 'false' %>;
        const perms = {
            canOp: <%= canOp ? 'true' : 'false' %>,
            canDeop: <%= canDeop ? 'true' : 'false' %>,
            canKick: <%= canKick ? 'true' : 'false' %>,
            canBan: <%= canBan ? 'true' : 'false' %>,
            canTempban: <%= canTempban ? 'true' : 'false' %>,
            canTeleport: <%= canTeleport ? 'true' : 'false' %>
        };

        const showStatus = (message, type = 'info') => {
            if (window.showStatusModal) {
                window.showStatusModal(message, type);
                return;
            }
            alert(message);
        };

        const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (ch) => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
        }[ch]));

        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('sidebar')?.classList.toggle('collapsed');
        });

        function attachGuardedActions() {
            document.querySelectorAll('.js-mc-guarded-action').forEach((button) => {
                if (button.dataset.guardBound === '1') return;
                button.dataset.guardBound = '1';
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    const form = button.closest('form');
                    if (!form) return;
                    const actionLabel = String(button.getAttribute('data-action-label') || 'ACTION').trim();
                    const playerInput = form.querySelector('input[name="player"]');
                    const playerName = playerInput ? String(playerInput.value || '').trim() : 'player';
                    const needsReason = button.getAttribute('data-requires-reason') === '1';
                    const needsDuration = button.getAttribute('data-requires-duration') === '1';
                    const needsDestination = button.getAttribute('data-requires-destination') === '1';

                    if (needsDestination) {
                        const destination = window.prompt(`Teleport destination for ${playerName}:`, '');
                        if (destination === null) return;
                        const trimmed = String(destination || '').trim();
                        if (trimmed.length < 1) {
                            showStatus('Destination is required.', 'error');
                            return;
                        }
                        const destinationInput = form.querySelector('input[name="destination"]');
                        if (destinationInput) destinationInput.value = trimmed.slice(0, 64);
                    }

                    if (needsDuration) {
                        const duration = window.prompt(`Tempban duration for ${playerName} (e.g. 1h, 30m):`, '');
                        if (duration === null) return;
                        const trimmed = String(duration || '').trim();
                        if (trimmed.length < 1) {
                            showStatus('Duration is required.', 'error');
                            return;
                        }
                        const durationInput = form.querySelector('input[name="duration"]');
                        if (durationInput) durationInput.value = trimmed.slice(0, 16);
                    }

                    if (needsReason) {
                        const reason = window.prompt(`${actionLabel} reason for ${playerName}:`, '');
                        if (reason === null) return;
                        const normalized = String(reason || '').trim();
                        if (normalized.length < 3) {
                            showStatus('Reason must be at least 3 characters.', 'error');
                            return;
                        }
                        const reasonInput = form.querySelector('input[name="reason"]');
                        if (reasonInput) reasonInput.value = normalized.slice(0, 96);
                    }

                    form.submit();
                });
            });
        }

        attachGuardedActions();

        const refreshStatusBtn = document.getElementById('refreshStatusBtn');
        const autoRefreshSwitch = document.getElementById('autoRefreshSwitch');
        const statusAddress = <%- JSON.stringify(minecraftStatusAddress || '') %>;

        function renderMotd(lines) {
            const container = document.getElementById('mcMotdLines');
            if (!container) return;
            if (!Array.isArray(lines) || lines.length === 0) {
                container.innerHTML = '<div class="text-muted-2 small">No MOTD data available.</div>';
                return;
            }
            container.innerHTML = lines.map((line) => `<div class="motd-line">${escapeHtml(line)}</div>`).join('');
        }

        function renderPlayers(players) {
            const body = document.getElementById('mcPlayersBody');
            if (!body) return;
            if (!Array.isArray(players) || players.length === 0) {
                body.innerHTML = '<tr><td colspan="3" class="text-muted-2">No player sample available from status API.</td></tr>';
                return;
            }
            body.innerHTML = players.map((player) => {
                const name = escapeHtml(player.name || '');
                const uuid = escapeHtml(player.uuid || '-');
                const head = escapeHtml(player.headUrl || '');
                return `
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img class="head-avatar" src="${head}" alt="Head" onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='https://minotar.net/avatar/Steve/40';}else{this.onerror=null;}">
                                <div class="fw-semibold">${name}</div>
                            </div>
                        </td>
                        <td><code>${uuid || '-'}</code></td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                                <form method="POST" action="/server/${serverId}/minecraft/configs" class="d-inline" data-turbo="false">
                                    <input type="hidden" name="action" value="op">
                                    <input type="hidden" name="player" value="${name}">
                                    <input type="hidden" name="bedrock" value="${bedrockMode ? '1' : '0'}">
                                    <input type="hidden" name="reason" value="">
                                    <button type="submit" class="btn btn-sm btn-outline-success js-mc-guarded-action" data-action-label="OP" title="OP" ${(!connectorOnline || !perms.canOp) ? 'disabled' : ''}>OP</button>
                                </form>
                                <form method="POST" action="/server/${serverId}/minecraft/configs" class="d-inline" data-turbo="false">
                                    <input type="hidden" name="action" value="deop">
                                    <input type="hidden" name="player" value="${name}">
                                    <input type="hidden" name="bedrock" value="${bedrockMode ? '1' : '0'}">
                                    <input type="hidden" name="reason" value="">
                                    <button type="submit" class="btn btn-sm btn-outline-warning js-mc-guarded-action" data-action-label="DEOP" title="DEOP" ${(!connectorOnline || !perms.canDeop) ? 'disabled' : ''}>DEOP</button>
                                </form>
                                <form method="POST" action="/server/${serverId}/minecraft/configs" class="d-inline" data-turbo="false">
                                    <input type="hidden" name="action" value="kick">
                                    <input type="hidden" name="player" value="${name}">
                                    <input type="hidden" name="bedrock" value="${bedrockMode ? '1' : '0'}">
                                    <input type="hidden" name="reason" value="">
                                    <button type="submit" class="btn btn-sm btn-outline-light js-mc-guarded-action" data-action-label="KICK" data-requires-reason="1" title="KICK" ${(!connectorOnline || !perms.canKick) ? 'disabled' : ''}>KICK</button>
                                </form>
                                <form method="POST" action="/server/${serverId}/minecraft/configs" class="d-inline" data-turbo="false">
                                    <input type="hidden" name="action" value="teleport">
                                    <input type="hidden" name="player" value="${name}">
                                    <input type="hidden" name="bedrock" value="${bedrockMode ? '1' : '0'}">
                                    <input type="hidden" name="destination" value="">
                                    <button type="submit" class="btn btn-sm btn-outline-info js-mc-guarded-action" data-action-label="TP" data-requires-destination="1" title="Teleport" ${(!connectorOnline || !perms.canTeleport) ? 'disabled' : ''}>TP</button>
                                </form>
                                <form method="POST" action="/server/${serverId}/minecraft/configs" class="d-inline" data-turbo="false">
                                    <input type="hidden" name="action" value="ban">
                                    <input type="hidden" name="player" value="${name}">
                                    <input type="hidden" name="bedrock" value="${bedrockMode ? '1' : '0'}">
                                    <input type="hidden" name="reason" value="">
                                    <button type="submit" class="btn btn-sm btn-outline-danger js-mc-guarded-action" data-action-label="BAN" data-requires-reason="1" title="BAN" ${(!connectorOnline || !perms.canBan) ? 'disabled' : ''}>BAN</button>
                                </form>
                                <form method="POST" action="/server/${serverId}/minecraft/configs" class="d-inline" data-turbo="false">
                                    <input type="hidden" name="action" value="tempban">
                                    <input type="hidden" name="player" value="${name}">
                                    <input type="hidden" name="bedrock" value="${bedrockMode ? '1' : '0'}">
                                    <input type="hidden" name="duration" value="">
                                    <input type="hidden" name="reason" value="">
                                    <button type="submit" class="btn btn-sm btn-outline-danger js-mc-guarded-action" data-action-label="TEMPBAN" data-requires-duration="1" data-requires-reason="1" title="Tempban" ${(!connectorOnline || !perms.canTempban) ? 'disabled' : ''}>TEMP</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
            attachGuardedActions();
        }

        async function refreshStatus() {
            if (!refreshStatusBtn) return;
            refreshStatusBtn.disabled = true;
            try {
                const response = await fetch(`/server/${serverId}/minecraft/configs/status?bedrock=${bedrockMode ? '1' : '0'}`);
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Failed to refresh status.');
                }
                const status = payload.status || {};
                const badge = document.getElementById('mcStatusBadge');
                if (badge) {
                    badge.className = `badge ${status.online ? 'bg-success' : 'bg-danger'}`;
                    badge.textContent = status.online ? 'ONLINE' : 'OFFLINE';
                }
                const icon = document.getElementById('mcStatusIcon');
                if (icon) {
                    icon.src = status.iconDataUri || `https://api.mcsrvstat.us/icon/${encodeURIComponent(statusAddress || '')}`;
                }
                const hostname = document.getElementById('mcStatusHostname');
                if (hostname) hostname.textContent = status.hostname || status.ip || statusAddress || 'Unknown';
                const meta = document.getElementById('mcStatusMeta');
                if (meta) {
                    const parts = [];
                    parts.push(`Version: ${status.version || status.protocolName || 'Unknown'}`);
                    if (status.software) parts.push(`Software: ${status.software}`);
                    if (bedrockMode && status.gamemode) parts.push(`Mode: ${status.gamemode}`);
                    meta.textContent = parts.join(' · ');
                }
                const cache = document.getElementById('mcStatusCache');
                if (cache) cache.textContent = status.cacheExpireAtIso ? `Cache expires: ${new Date(status.cacheExpireAtIso).toLocaleString()}` : 'Cache expires: N/A';
                const playersCount = document.getElementById('mcPlayersCount');
                if (playersCount) playersCount.textContent = `${Number(status.playersOnline || 0)} / ${Number(status.playersMax || 0)}`;
                const playersDetected = document.getElementById('mcPlayersDetected');
                if (playersDetected) playersDetected.textContent = `${Number(status.playersOnline || 0)} detected`;
                const portEl = document.getElementById('mcStatusPort');
                if (portEl) portEl.textContent = status.port || 'N/A';
                const eula = document.getElementById('mcStatusEula');
                if (eula) eula.textContent = status.eulaBlocked ? 'Yes' : 'No';

                renderMotd(status.motdClean || []);
                renderPlayers(status.playersList || []);
            } catch (error) {
                showStatus(error.message || 'Failed to refresh status.', 'error');
            } finally {
                refreshStatusBtn.disabled = false;
            }
        }

        let autoRefreshTimer = null;
        if (autoRefreshSwitch) {
            autoRefreshSwitch.addEventListener('change', () => {
                if (autoRefreshSwitch.checked) {
                    refreshStatus();
                    autoRefreshTimer = setInterval(refreshStatus, 30000);
                } else if (autoRefreshTimer) {
                    clearInterval(autoRefreshTimer);
                    autoRefreshTimer = null;
                }
            });
        }
        refreshStatusBtn?.addEventListener('click', refreshStatus);

        const playtimeLoadBtn = document.getElementById('playtimeLoadBtn');
        const playtimeBody = document.getElementById('playtimeBody');
        const playtimeStatus = document.getElementById('playtimeStatus');

        const renderPlaytimeRows = (entries) => {
            if (!playtimeBody) return;
            if (!Array.isArray(entries) || entries.length === 0) {
                playtimeBody.innerHTML = '<tr><td colspan="2" class="text-muted-2">No playtime data available.</td></tr>';
                return;
            }
            playtimeBody.innerHTML = entries.map((entry) => {
                const name = escapeHtml(entry.name || entry.uuid || 'unknown');
                const head = escapeHtml(entry.headUrl || '');
                const label = escapeHtml(entry.label || '0m');
                return `
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img class="head-avatar" src="${head}" alt="Head" onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='https://minotar.net/avatar/Steve/40';}else{this.onerror=null;}">
                                <div class="fw-semibold">${name}</div>
                            </div>
                        </td>
                        <td class="text-end fw-semibold">${label}</td>
                    </tr>
                `;
            }).join('');
        };

        const loadPlaytime = async () => {
            if (!playtimeLoadBtn || !playtimeStatus) return;
            if (playtimeLoadBtn.disabled) return;
            playtimeLoadBtn.disabled = true;
            playtimeStatus.textContent = 'Loading playtime stats...';
            try {
                const response = await fetch(`/server/${serverId}/minecraft/configs/playtime?bedrock=${bedrockMode ? '1' : '0'}`);
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Failed to load playtime data.');
                }
                renderPlaytimeRows(payload.top || []);
                const metaParts = [];
                metaParts.push(`World: <code>${escapeHtml(payload.worldName || 'world')}</code>`);
                metaParts.push(`Total tracked: ${Number(payload.totalPlayers || 0)}`);
                if (payload.truncated) metaParts.push('Truncated list');
                if (payload.cached) metaParts.push('Cached result');
                if (payload.generatedAt) {
                    metaParts.push(`Updated: ${escapeHtml(new Date(payload.generatedAt).toLocaleString())}`);
                }
                playtimeStatus.innerHTML = metaParts.join(' · ');
            } catch (error) {
                playtimeStatus.textContent = error.message || 'Failed to load playtime data.';
                renderPlaytimeRows([]);
            } finally {
                playtimeLoadBtn.disabled = false;
            }
        };

        playtimeLoadBtn?.addEventListener('click', loadPlaytime);

        const saveMotdBtn = document.getElementById('saveMotdBtn');
        const motdInput = document.getElementById('motdInput');
        async function saveMotd() {
            if (!motdInput) return;
            saveMotdBtn.disabled = true;
            try {
                const response = await fetch(`/server/${serverId}/minecraft/configs/motd`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ motd: motdInput.value || '' })
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Failed to save MOTD.');
                }
                showStatus(payload.message || 'MOTD saved.', 'success');
                refreshStatus();
            } catch (error) {
                showStatus(error.message || 'Failed to save MOTD.', 'error');
            } finally {
                saveMotdBtn.disabled = false;
            }
        }

        saveMotdBtn?.addEventListener('click', saveMotd);

        const motdPresetList = document.getElementById('motdPresetList');
        let motdPresets = <%- JSON.stringify(motdPresets || []) %>;

        const renderMotdPresets = () => {
            if (!motdPresetList) return;
            if (!Array.isArray(motdPresets) || motdPresets.length === 0) {
                motdPresetList.innerHTML = '<div class="text-muted-2 small">No presets saved yet.</div>';
                return;
            }
            motdPresetList.innerHTML = motdPresets.map((preset) => {
                const safeName = escapeHtml(preset.name || '');
                const preview = escapeHtml(String(preset.content || '').split('\\n').slice(0, 2).join(' / '));
                return `
                    <div class="cardx p-2 d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div>
                            <div class="fw-semibold">${safeName}</div>
                            <div class="small text-muted-2">${preview || 'Empty MOTD'}</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-sm btn-outline-light" type="button" data-action="load" data-id="${preset.id}">Load</button>
                            <button class="btn btn-sm btn-outline-info" type="button" data-action="apply" data-id="${preset.id}">Apply</button>
                            <button class="btn btn-sm btn-outline-danger" type="button" data-action="delete" data-id="${preset.id}">Delete</button>
                        </div>
                    </div>
                `;
            }).join('');
        };

        renderMotdPresets();

        const saveMotdPresetBtn = document.getElementById('saveMotdPresetBtn');
        saveMotdPresetBtn?.addEventListener('click', async () => {
            if (!motdInput) return;
            const name = window.prompt('Preset name:', '');
            if (name === null) return;
            const trimmed = String(name || '').trim();
            if (!trimmed) {
                showStatus('Preset name is required.', 'error');
                return;
            }
            saveMotdPresetBtn.disabled = true;
            try {
                const response = await fetch(`/server/${serverId}/minecraft/configs/motd-presets`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'create', name: trimmed, content: motdInput.value || '' })
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Failed to save preset.');
                }
                motdPresets = payload.presets || [];
                renderMotdPresets();
                showStatus('Preset saved.', 'success');
            } catch (error) {
                showStatus(error.message || 'Failed to save preset.', 'error');
            } finally {
                saveMotdPresetBtn.disabled = false;
            }
        });

        motdPresetList?.addEventListener('click', async (event) => {
            const target = event.target;
            if (!target || !target.dataset) return;
            const action = target.dataset.action;
            const id = target.dataset.id;
            if (!action || !id) return;
            const preset = (motdPresets || []).find((entry) => entry.id === id);
            if (!preset) return;

            if (action === 'load') {
                if (motdInput) motdInput.value = preset.content || '';
                showStatus('Preset loaded into editor.', 'info');
                return;
            }
            if (action === 'apply') {
                if (motdInput) motdInput.value = preset.content || '';
                await saveMotd();
                return;
            }
            if (action === 'delete') {
                if (!confirm(`Delete preset "${preset.name}"?`)) return;
                try {
                    const response = await fetch(`/server/${serverId}/minecraft/configs/motd-presets`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'delete', id })
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.error || 'Failed to delete preset.');
                    }
                    motdPresets = payload.presets || [];
                    renderMotdPresets();
                    showStatus('Preset deleted.', 'success');
                } catch (error) {
                    showStatus(error.message || 'Failed to delete preset.', 'error');
                }
            }
        });

        const uploadIconBtn = document.getElementById('uploadIconBtn');
        const iconInput = document.getElementById('iconInput');
        uploadIconBtn?.addEventListener('click', async () => {
            if (!iconInput || !iconInput.files || !iconInput.files.length) {
                showStatus('Select a PNG icon first.', 'error');
                return;
            }
            const file = iconInput.files[0];
            if (file.size > 1024 * 1024) {
                showStatus('Icon must be under 1 MB.', 'error');
                return;
            }
            uploadIconBtn.disabled = true;
            try {
                const response = await fetch(`/server/${serverId}/files/upload?path=/`, {
                    method: 'POST',
                    headers: { 'x-file-name': 'server-icon.png' },
                    body: file
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Upload failed.');
                }
                showStatus('Icon uploaded. Restart server to apply.', 'success');
                refreshStatus();
            } catch (error) {
                showStatus(error.message || 'Upload failed.', 'error');
            } finally {
                uploadIconBtn.disabled = false;
            }
        });

        const resourcePackApplyBtn = document.getElementById('resourcePackApplyBtn');
        resourcePackApplyBtn?.addEventListener('click', async () => {
            const urlInput = document.getElementById('resourcePackUrlInput');
            const requiredInput = document.getElementById('resourcePackRequiredInput');
            const promptInput = document.getElementById('resourcePackPromptInput');
            const shaInput = document.getElementById('resourcePackSha1Input');
            if (!urlInput) return;
            const url = String(urlInput.value || '').trim();
            if (!url) {
                showStatus('Resource pack URL is required.', 'error');
                return;
            }
            resourcePackApplyBtn.disabled = true;
            try {
                const response = await fetch(`/server/${serverId}/minecraft/configs/resource-pack`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        url,
                        required: requiredInput && requiredInput.checked ? 'true' : 'false',
                        prompt: promptInput ? promptInput.value || '' : ''
                    })
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Failed to apply resource pack.');
                }
                if (shaInput && payload.sha1) {
                    shaInput.value = payload.sha1;
                }
                showStatus(payload.message || 'Resource pack applied.', 'success');
            } catch (error) {
                showStatus(error.message || 'Failed to apply resource pack.', 'error');
            } finally {
                resourcePackApplyBtn.disabled = false;
            }
        });

        const mcMiniCommandBtn = document.getElementById('mcMiniCommandBtn');
        const mcMiniCommandInput = document.getElementById('mcMiniCommandInput');
        const blockedCommands = new Set(['stop', 'restart', 'reload', 'op', 'deop', 'kick', 'ban', 'tempban']);

        const normalizeMiniCommand = (value) => {
            let command = String(value || '').trim();
            if (command.startsWith('/')) command = command.slice(1);
            command = command.replace(/\s+/g, ' ').trim();
            if (!command || command.length > 200) return '';
            if (/[\r\n]/.test(command)) return '';
            if (/[`"'\\|&$<>;]/.test(command)) return '';
            return command;
        };

        async function sendMiniCommand(command) {
            const normalized = normalizeMiniCommand(command);
            if (!normalized) {
                showStatus('Command is required.', 'error');
                return;
            }
            const base = normalized.split(/\s+/)[0].toLowerCase();
            if (blockedCommands.has(base)) {
                showStatus('Command blocked. Use the dedicated action buttons.', 'error');
                return;
            }
            mcMiniCommandBtn.disabled = true;
            try {
                const response = await fetch(`/server/${serverId}/minecraft/configs/command`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ command: normalized })
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Failed to send command.');
                }
                showStatus(payload.message || 'Command sent.', 'success');
                mcMiniCommandInput.value = '';
            } catch (error) {
                showStatus(error.message || 'Failed to send command.', 'error');
            } finally {
                mcMiniCommandBtn.disabled = false;
            }
        }

        mcMiniCommandBtn?.addEventListener('click', () => sendMiniCommand(mcMiniCommandInput?.value || ''));
        mcMiniCommandInput?.addEventListener('keydown', (event) => {
            if (event.key === 'Enter') {
                event.preventDefault();
                sendMiniCommand(mcMiniCommandInput.value || '');
            }
        });

        document.querySelectorAll('.mc-macro-btn').forEach((button) => {
            button.addEventListener('click', () => {
                const command = button.getAttribute('data-command') || '';
                if (mcMiniCommandInput) {
                    mcMiniCommandInput.value = command;
                }
                sendMiniCommand(command);
            });
        });
    </script>
</body>

</html>

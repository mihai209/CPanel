<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minecraft Control <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --bg: #0f0f12;
            --panel: #121216;
            --border: #2d2d35;
            --text: #e1e1e6;
            --muted: #8b8b9a;
            --accent: #3b82f6;
        }

        body {
            background: var(--bg);
            color: var(--text);
            margin: 0;
            font-family: Inter, system-ui, -apple-system, sans-serif;
            height: 100vh;
            overflow: hidden;
        }

        .wrapper {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: 260px;
            background: var(--panel);
            border-right: 1px solid var(--border);
            overflow-y: auto;
        }

        .sidebar.collapsed {
            margin-left: -260px;
        }

        .content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .top-navbar {
            background: var(--panel);
            border-bottom: 1px solid var(--border);
            padding: .75rem 1rem;
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 1.25rem;
        }

        .cardx {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: .8rem;
        }

        .text-muted-2 {
            color: var(--muted);
        }

        .btn-icon {
            background: transparent;
            border: 0;
            color: var(--muted);
            font-size: 1.2rem;
        }

        .head-avatar {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border: 1px solid #2f2f39;
            object-fit: cover;
            background: #0f1115;
        }

        .motd-line {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.83rem;
            color: #d1d5db;
            background: #16161b;
            border: 1px solid #2d2d35;
            border-radius: 0.45rem;
            padding: 0.4rem 0.55rem;
            margin-bottom: 0.4rem;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .status-icon {
            width: 54px;
            height: 54px;
            border-radius: 10px;
            border: 1px solid #2d2d35;
            object-fit: cover;
            background: #0e1014;
        }

        .permission-note {
            border: 1px dashed #3a3a45;
            background: #16161b;
            border-radius: 0.55rem;
            padding: 0.6rem;
            font-size: 0.82rem;
            color: #a1a1aa;
        }

        .table-dark {
            --bs-table-bg: transparent;
        }
    </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>

<body>
    
<%- include('../partials/error-modal') %>
<div class="wrapper">
        <nav class="sidebar" id="sidebar">
            <div class="p-3">
                <%- include('../partials/server-sidebar', { server, active: 'mcconfigs' }) %>
            </div>
        </nav>

        <main class="content">
            <header class="top-navbar">
                <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
                <h1 class="h5 mb-0">Minecraft Control / <span class="text-muted-2"><%= server.name %></span></h1>
            </header>

            <section class="scroll-area">
                <% const status = minecraftStatusPreview || {}; %>
                <% const players = Array.isArray(status.playersList) ? status.playersList : []; %>
                <% const online = Boolean(status.online); %>
                <% const canKick = Boolean(minecraftActionPermissions && minecraftActionPermissions.canKick); %>
                <% const canBan = Boolean(minecraftActionPermissions && minecraftActionPermissions.canBan); %>
                <% const canOp = Boolean(minecraftActionPermissions && minecraftActionPermissions.canOp); %>
                <% const canDeop = Boolean(minecraftActionPermissions && minecraftActionPermissions.canDeop); %>
                <% const cacheExpiresLabel = status.cacheExpireAtIso ? new Date(status.cacheExpireAtIso).toLocaleString() : 'N/A'; %>
                <% const proxyMode = String(minecraftProxyMode || '').trim(); %>

                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <div class="cardx p-3 mb-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <div class="small text-muted-2 text-uppercase mb-1">Status Endpoint</div>
                            <div class="fw-semibold"><%= minecraftStatusAddress || 'Unknown allocation' %></div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <form method="GET" action="/server/<%= server.containerId %>/minecraft-configs" class="mb-0" data-turbo="false">
                                <input type="hidden" name="bedrock" value="0">
                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" role="switch" id="bedrockSwitch" name="bedrock" value="1" <%= minecraftBedrockMode ? 'checked' : '' %> onchange="this.form.submit()">
                                    <label class="form-check-label small" for="bedrockSwitch">Bedrock mode</label>
                                </div>
                            </form>
                            <a href="/server/<%= server.containerId %>/minecraft-configs?bedrock=<%= minecraftBedrockMode ? '1' : '0' %>" class="btn btn-sm btn-outline-light">
                                <i class="bi bi-arrow-repeat"></i> Refresh
                            </a>
                        </div>
                    </div>
                </div>

                <div class="cardx p-3 mb-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <div class="small text-muted-2 text-uppercase mb-1">Proxy Network Mode</div>
                            <div class="fw-semibold"><%= proxyMode ? proxyMode : 'disabled' %></div>
                            <div class="small text-muted-2">Enable this only for BungeeCord/Waterfall/Velocity servers.</div>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs/proxy-mode" class="d-flex align-items-center gap-2 mb-0">
                                <select class="form-select form-select-sm" name="proxyMode" style="min-width: 170px;">
                                    <option value="" <%= !proxyMode ? 'selected' : '' %>>Disabled</option>
                                    <option value="velocity" <%= proxyMode === 'velocity' ? 'selected' : '' %>>Velocity</option>
                                    <option value="bungeecord" <%= proxyMode === 'bungeecord' ? 'selected' : '' %>>BungeeCord</option>
                                    <option value="waterfall" <%= proxyMode === 'waterfall' ? 'selected' : '' %>>Waterfall</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-light">
                                    <i class="bi bi-save me-1"></i>Save Mode
                                </button>
                            </form>
                            <a href="/server/<%= server.containerId %>/proxy-network" class="btn btn-sm btn-primary">
                                <i class="bi bi-diagram-3 me-1"></i>Open Proxy Panel
                            </a>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-12 col-xl-7">
                        <div class="cardx p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h2 class="h6 mb-0">Server Preview</h2>
                                <% if (online) { %>
                                    <span class="badge bg-success">ONLINE</span>
                                <% } else { %>
                                    <span class="badge bg-danger">OFFLINE</span>
                                <% } %>
                            </div>

                            <% if (!status.ok) { %>
                                <div class="alert alert-warning mb-0">
                                    Could not fetch live status: <%= status.error || 'Unknown error.' %>
                                </div>
                            <% } else { %>
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <img src="<%= status.iconDataUri || 'https://api.mcsrvstat.us/icon/' + encodeURIComponent(minecraftStatusAddress || '') %>" class="status-icon" alt="Server Icon">
                                    <div>
                                        <div class="fw-semibold"><%= status.hostname || status.ip || minecraftStatusAddress %></div>
                                        <div class="small text-muted-2">
                                            Version: <%= status.version || status.protocolName || 'Unknown' %>
                                            <% if (status.software) { %>· Software: <%= status.software %><% } %>
                                            <% if (minecraftBedrockMode && status.gamemode) { %>· Mode: <%= status.gamemode %><% } %>
                                        </div>
                                        <div class="small text-muted-2">Cache expires: <%= cacheExpiresLabel %></div>
                                    </div>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-6 col-md-4">
                                        <div class="cardx p-2">
                                            <div class="small text-muted-2">Players</div>
                                            <div class="fw-semibold"><%= Number(status.playersOnline || 0) %> / <%= Number(status.playersMax || 0) %></div>
                                        </div>
                                    </div>
                                    <div class="col-6 col-md-4">
                                        <div class="cardx p-2">
                                            <div class="small text-muted-2">Port</div>
                                            <div class="fw-semibold"><%= status.port || 'N/A' %></div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <div class="cardx p-2">
                                            <div class="small text-muted-2">EULA Blocked</div>
                                            <div class="fw-semibold"><%= status.eulaBlocked ? 'Yes' : 'No' %></div>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <div class="small text-muted-2 text-uppercase mb-2">MOTD</div>
                                    <% if (Array.isArray(status.motdClean) && status.motdClean.length > 0) { %>
                                        <% status.motdClean.forEach((line) => { %>
                                            <div class="motd-line"><%= line %></div>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="text-muted-2 small">No MOTD data available.</div>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="col-12 col-xl-5">
                        <div class="cardx p-3 h-100">
                            <h2 class="h6 mb-3">Minecraft Commands</h2>

                            <% if (!connectorOnline) { %>
                                <div class="alert alert-warning py-2">Connector is offline. Commands are disabled.</div>
                            <% } %>

                            <div class="permission-note mb-3">
                                Required permissions: <code>minecraft.op</code>, <code>minecraft.deop</code>, <code>minecraft.kick</code>, <code>minecraft.ban</code>.
                            </div>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="op">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">OP Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-success" type="submit" <%= (!connectorOnline || !canOp) ? 'disabled' : '' %>>OP</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="deop">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">DEOP Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-outline-warning" type="submit" <%= (!connectorOnline || !canDeop) ? 'disabled' : '' %>>DEOP</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="mb-2" data-turbo="false">
                                <input type="hidden" name="action" value="kick">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">Kick Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-outline-light" type="submit" <%= (!connectorOnline || !canKick) ? 'disabled' : '' %>>KICK</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>

                            <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" data-turbo="false">
                                <input type="hidden" name="action" value="ban">
                                <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                <label class="form-label small text-uppercase text-muted-2">Ban Player</label>
                                <div class="input-group mb-2">
                                    <input name="player" class="form-control" required maxlength="32" placeholder="Player name" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                    <button class="btn btn-danger" type="submit" <%= (!connectorOnline || !canBan) ? 'disabled' : '' %>>BAN</button>
                                </div>
                                <input name="reason" class="form-control" required minlength="3" maxlength="96" placeholder="Reason (required)" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            </form>
                        </div>
                    </div>
                </div>

                <div class="cardx p-3">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h2 class="h6 mb-0">Online Players</h2>
                        <span class="text-muted-2 small"><%= Number(status.playersOnline || 0) %> detected</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-dark table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Player</th>
                                    <th>UUID</th>
                                    <th class="text-end">Quick Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (players.length === 0) { %>
                                    <tr>
                                        <td colspan="3" class="text-muted-2">No player sample available from status API.</td>
                                    </tr>
                                <% } else { %>
                                    <% players.forEach((player) => { %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <img class="head-avatar" src="<%= player.headUrl %>" alt="Head" onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='https://minotar.net/avatar/Steve/40';}else{this.onerror=null;}">
                                                    <div class="fw-semibold"><%= player.name %></div>
                                                </div>
                                            </td>
                                            <td><code><%= player.uuid || '-' %></code></td>
                                            <td class="text-end">
                                                <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="op">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-success js-mc-guarded-action" data-action-label="OP" title="OP" <%= (!connectorOnline || !canOp) ? 'disabled' : '' %>>OP</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="deop">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-warning js-mc-guarded-action" data-action-label="DEOP" title="DEOP" <%= (!connectorOnline || !canDeop) ? 'disabled' : '' %>>DEOP</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="kick">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-light js-mc-guarded-action" data-action-label="KICK" title="KICK" <%= (!connectorOnline || !canKick) ? 'disabled' : '' %>>KICK</button>
                                                    </form>
                                                    <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs" class="d-inline" data-turbo="false">
                                                        <input type="hidden" name="action" value="ban">
                                                        <input type="hidden" name="player" value="<%= player.name %>">
                                                        <input type="hidden" name="bedrock" value="<%= minecraftBedrockMode ? '1' : '0' %>">
                                                        <input type="hidden" name="reason" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger js-mc-guarded-action" data-action-label="BAN" title="BAN" <%= (!connectorOnline || !canBan) ? 'disabled' : '' %>>BAN</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function () {
            document.getElementById('sidebar')?.classList.toggle('collapsed');
        });

        document.querySelectorAll('.js-mc-guarded-action').forEach((button) => {
            button.addEventListener('click', (event) => {
                event.preventDefault();
                const form = button.closest('form');
                if (!form) return;
                const actionLabel = String(button.getAttribute('data-action-label') || 'ACTION').trim();
                const playerInput = form.querySelector('input[name="player"]');
                const playerName = playerInput ? String(playerInput.value || '').trim() : 'player';
                const reason = window.prompt(`${actionLabel} reason for ${playerName}:`, '');
                if (reason === null) return;
                const normalized = String(reason || '').trim();
                if (normalized.length < 3) {
                    if (window.showStatusModal) {
                        window.showStatusModal('Reason must be at least 3 characters.', 'error');
                    } else {
                        alert('Reason must be at least 3 characters.');
                    }
                    return;
                }
                const reasonInput = form.querySelector('input[name="reason"]');
                if (reasonInput) {
                    reasonInput.value = normalized.slice(0, 96);
                }
                form.submit();
            });
        });
    </script>
</body>

</html>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-visit-control" content="reload">
    <title>
        Minecraft Configs <%= server.name %> | <%= settings.brandName.toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --bg-dark: #0f0f12;
            --bg-sidebar: #121216;
            --border-color: #2d2d35;
            --text-primary: #e1e1e6;
            --text-secondary: #8b8b9a;
            --accent-blue: #3b82f6;
            --accent-yellow: #f59e0b;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            overflow: hidden;
            height: 100vh;
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .wrapper {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: 260px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            overflow-y: auto;
        }

        .sidebar .sidebar-content {
            padding: 1.5rem 0.75rem;
        }

        .content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .top-navbar {
            background: var(--bg-sidebar);
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }

        .navbar-toggle {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            font-size: 1.5rem;
            margin-right: 1rem;
            cursor: pointer;
            padding: 0;
        }

        .navbar-toggle:hover {
            color: var(--text-primary);
        }

        .server-name {
            font-size: 1.2rem;
            font-weight: 600;
            margin: 0;
        }

        .scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
        }

        .settings-card {
            background: var(--bg-sidebar);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .settings-card-header {
            border-bottom: 1px solid var(--border-color);
            background: rgba(255, 255, 255, 0.02);
            padding: 1rem 1.25rem;
        }

        .settings-card-body {
            padding: 1.25rem;
        }

        .form-label {
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 600;
        }

        .form-control,
        .form-select,
        .form-check-input {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
        }

        .form-select option {
            background-color: #141419;
            color: var(--text-primary);
        }

        .form-control:focus,
        .form-select:focus,
        .form-check-input:focus {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
            color: var(--text-primary);
        }

        .btn-primary-soft {
            background: var(--accent-blue);
            border: 1px solid var(--accent-blue);
            color: #fff;
        }

        .btn-primary-soft:hover {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        .text-muted-soft {
            color: var(--text-secondary);
        }

        .warning-box {
            border: 1px solid rgba(245, 158, 11, 0.5);
            background: rgba(245, 158, 11, 0.09);
            color: #fbbf24;
            border-radius: 10px;
            padding: 0.8rem 0.9rem;
        }

        @media (max-width: 992px) {
            .sidebar {
                position: absolute;
                z-index: 1000;
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .scroll-area {
                padding: 1rem;
            }
        }
    </style>
</head>

<body data-turbo="false">
    <%- include ('../partials/error-modal') %>
    <div class="wrapper">
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-content">
                <%- include('../partials/server-sidebar', { server, active: 'mcconfigs', settings }) %>
            </div>
        </nav>

        <div class="content">
            <div class="top-navbar">
                <button id="sidebarToggle" class="navbar-toggle" type="button">
                    <i class="bi bi-list"></i>
                </button>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <h1 class="server-name">Minecraft Configs</h1>
                    <span class="text-muted-soft opacity-50">/</span>
                    <span class="text-muted-soft"><%= server.name %></span>
                </div>
            </div>

            <div class="scroll-area">
                <form method="POST" action="/server/<%= server.containerId %>/minecraft-configs">
                    <div class="settings-card">
                        <div class="settings-card-header">
                            <h6 class="mb-1 fw-semibold">Server Properties</h6>
                            <div class="small text-muted-soft">Structured editor for common <code>server.properties</code> keys.</div>
                        </div>
                        <div class="settings-card-body">
                            <% minecraftPropertyFieldGroups.forEach((group) => { %>
                                <div class="mb-4">
                                    <h6 class="mb-3 text-muted-soft"><%= group.title %></h6>
                                    <div class="row g-3">
                                        <% group.fields.forEach((field) => { %>
                                            <div class="col-md-4">
                                                <label class="form-label"><%= field.label %></label>
                                                <% if (field.type === 'boolean') { %>
                                                    <input type="hidden" name="prop_<%= field.key %>" value="false">
                                                    <div class="form-check form-switch mt-2">
                                                        <input class="form-check-input" type="checkbox" role="switch"
                                                            name="prop_<%= field.key %>" value="true"
                                                            id="prop_<%= field.key %>"
                                                            <%= minecraftPropertyValues[field.key] === 'true' ? 'checked' : '' %>>
                                                        <label class="form-check-label text-muted-soft" for="prop_<%= field.key %>">
                                                            <%= minecraftPropertyValues[field.key] === 'true' ? 'Enabled' : 'Disabled' %>
                                                        </label>
                                                    </div>
                                                <% } else if (field.type === 'select') { %>
                                                    <select class="form-select" name="prop_<%= field.key %>" <%= field.readonly ? 'readonly disabled' : '' %>>
                                                        <% (field.options || []).forEach((opt) => { %>
                                                            <option value="<%= opt %>" <%= minecraftPropertyValues[field.key] === String(opt) ? 'selected' : '' %>><%= opt %></option>
                                                        <% }) %>
                                                    </select>
                                                <% } else { %>
                                                    <input class="form-control" type="<%= field.type === 'number' ? 'number' : 'text' %>"
                                                        name="prop_<%= field.key %>"
                                                        value="<%= minecraftPropertyValues[field.key] %>"
                                                        <%= Number.isInteger(field.min) ? `min=\"${field.min}\"` : '' %>
                                                        <%= Number.isInteger(field.max) ? `max=\"${field.max}\"` : '' %>
                                                        <%= field.placeholder ? `placeholder=\"${field.placeholder}\"` : '' %>
                                                        <%= field.readonly ? 'readonly' : '' %>>
                                                <% } %>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="settings-card">
                        <div class="settings-card-header">
                            <h6 class="mb-1 fw-semibold">EULA</h6>
                            <div class="small text-muted-soft">Manage <code>eula.txt</code> without opening file editor.</div>
                        </div>
                        <div class="settings-card-body">
                            <input type="hidden" name="eulaAccepted" value="false">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" name="eulaAccepted" value="true"
                                    id="eulaAcceptedSwitch" <%= eulaAccepted ? 'checked' : '' %>>
                                <label class="form-check-label text-muted-soft" for="eulaAcceptedSwitch">
                                    Accept Mojang EULA (<code>eula=true</code>)
                                </label>
                            </div>
                            <div class="small text-muted-soft mt-2">
                                EULA URL: <a href="https://www.minecraft.net/eula" target="_blank" class="link-info">minecraft.net/eula</a>
                            </div>
                        </div>
                    </div>

                    <div class="settings-card">
                        <div class="settings-card-header">
                            <h6 class="mb-1 fw-semibold">Whitelist & Operators</h6>
                            <div class="small text-muted-soft">
                                Whitelist names: one username per line. Ops format: <code>name:level:bypass</code> (example <code>Mihai:4:true</code>).
                            </div>
                        </div>
                        <div class="settings-card-body">
                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <label class="form-label">Whitelist Usernames</label>
                                    <textarea class="form-control" name="whitelistNames" rows="10" placeholder="PlayerOne&#10;PlayerTwo"><%= whitelistNamesText %></textarea>
                                </div>
                                <div class="col-lg-6">
                                    <label class="form-label">Operator Entries</label>
                                    <textarea class="form-control" name="opsEntries" rows="10" placeholder="Admin:4:true&#10;Moderator:2:true"><%= opsEntriesText %></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="settings-card">
                        <div class="settings-card-header">
                            <h6 class="mb-1 fw-semibold">permissions.yml (Simplified)</h6>
                            <div class="small text-muted-soft">
                                One entry per line: <code>permission.node|default|description</code>. Default supports: <code>true</code>, <code>false</code>, <code>op</code>, <code>notop</code>.
                            </div>
                        </div>
                        <div class="settings-card-body">
                            <% if (permissionsDetectedComplex) { %>
                                <div class="warning-box mb-3">
                                    <strong>Complex permissions.yml detected.</strong> Current file has a structure outside this simplified editor.
                                    Keep "Apply simplified permissions.yml" OFF if you don't want overwrite.
                                </div>
                            <% } %>
                            <% if (permissionsFileMissing) { %>
                                <div class="alert alert-secondary py-2">
                                    <i class="bi bi-info-circle me-1"></i>
                                    permissions.yml was missing and will be created if apply toggle is enabled.
                                </div>
                            <% } %>
                            <input type="hidden" name="applyPermissionsEditor" value="false">
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" role="switch" name="applyPermissionsEditor" value="true"
                                    id="applyPermissionsEditorSwitch" <%= permissionsDetectedComplex ? '' : 'checked' %>>
                                <label class="form-check-label text-muted-soft" for="applyPermissionsEditorSwitch">
                                    Apply simplified permissions.yml on save
                                </label>
                            </div>
                            <textarea class="form-control" name="permissionsEntries" rows="8"
                                placeholder="bukkit.command.plugins|op|Allow plugin list&#10;minecraft.command.say|true|Allow /say"><%= permissionsEntriesText %></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mb-5">
                        <a href="/server/<%= server.containerId %>/minecraft" class="btn btn-outline-secondary">
                            <i class="bi bi-box me-1"></i> Minecraft Addons
                        </a>
                        <button type="submit" class="btn btn-primary-soft">
                            <i class="bi bi-save me-1"></i> Save Minecraft Configs
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
    <script>
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        if (toggleBtn && sidebar) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('open');
            });
        }
    </script>
</body>

</html>

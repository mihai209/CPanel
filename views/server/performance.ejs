<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Performance Insights <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}
        .btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .pill { display:inline-flex; align-items:center; gap:.4rem; padding:.35rem .65rem; border-radius:999px; border:1px solid #2d2d35; background:rgba(255,255,255,0.04); font-size:.75rem; }
        .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
        .table-dark { --bs-table-bg: transparent; }
    </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>
<body>

<%- include('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'performance' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Performance Insights / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <% if (success) { %>
                <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success">
                    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                </div>
            <% } %>
            <% if (error) { %>
                <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                </div>
            <% } %>

            <div class="cardx p-3 mb-3">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                    <div>
                        <div class="small text-secondary">Size-based estimate for plugin/mod impact. For accurate profiling, run a timings or spark report.</div>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <span class="pill"><i class="bi bi-plug"></i> Plugins: <%= performanceStats.pluginsCount %></span>
                            <span class="pill"><i class="bi bi-puzzle"></i> Mods: <%= performanceStats.modsCount %></span>
                            <span class="pill"><i class="bi bi-hdd"></i> Total size: <%= performanceStats.totalSizeMb %> MB</span>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <% if (canRunCommands) { %>
                            <button class="btn btn-outline-light btn-sm" id="btnRunTimings"><i class="bi bi-play-fill me-1"></i>Run Timings Report</button>
                        <% } %>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Type</th>
                            <th>Name</th>
                            <th>Size</th>
                            <th>Path</th>
                        </tr>
                        </thead>
                        <tbody>
                        <% if (!performanceRows || performanceRows.length === 0) { %>
                            <tr><td colspan="4" class="text-secondary">No plugins/mods detected (or connector offline).</td></tr>
                        <% } else { performanceRows.forEach((row) => { %>
                            <tr>
                                <td><span class="badge bg-secondary text-uppercase"><%= row.kind %></span></td>
                                <td><%= row.name %></td>
                                <td><%= row.sizeMb %> MB</td>
                                <td class="mono text-secondary"><%= row.path %></td>
                            </tr>
                        <% }) } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="cardx p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                    <div class="fw-semibold">Performance Report Link</div>
                    <% if (performanceReportUrl) { %>
                        <a href="<%= performanceReportUrl %>" target="_blank" rel="noopener" class="btn btn-outline-info btn-sm">
                            Open Report
                        </a>
                    <% } %>
                </div>
                <form method="POST" action="/server/<%= server.containerId %>/performance/report" class="d-flex flex-wrap gap-2">
                    <input type="url" name="reportUrl" class="form-control bg-dark text-light border-secondary flex-grow-1"
                        placeholder="Paste Timings/Spark report URL"
                        value="<%= performanceReportUrl || '' %>">
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </form>
                <div class="small text-muted mt-2">We store only the link for quick access. Run a report in-game, then paste the URL here.</div>
            </div>
        </section>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
<script>
    document.getElementById('sidebarToggle')?.addEventListener('click', () => document.getElementById('sidebar')?.classList.toggle('collapsed'));
    const btnRunTimings = document.getElementById('btnRunTimings');
    if (btnRunTimings) {
        btnRunTimings.addEventListener('click', async () => {
            btnRunTimings.disabled = true;
            try {
                const response = await fetch(`/server/<%= server.containerId %>/performance/run-timings`, { method: 'POST' });
                const data = await response.json();
                if (!response.ok || !data.success) {
                    throw new Error((data && data.error) || 'Failed to dispatch timings report.');
                }
                if (window.showStatusModal) {
                    window.showStatusModal('Timings report command sent. Wait for the URL in console, then paste it above.', 'success');
                } else {
                    alert('Timings report command sent. Wait for the URL in console, then paste it above.');
                }
            } catch (err) {
                if (window.showStatusModal) {
                    window.showStatusModal(err.message || 'Failed to dispatch timings report.', 'error');
                } else {
                    alert(err.message || 'Failed to dispatch timings report.');
                }
            } finally {
                btnRunTimings.disabled = false;
            }
        });
    }
</script>
</body>
</html>

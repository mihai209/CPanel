<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Network <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}.btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        code { color:#93c5fd; }
    </style>
</head>
<body>
    <%- include ('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'network' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Network / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-3">Assigned Allocations</h2>
                <% if (!assignedAllocations || assignedAllocations.length === 0) { %>
                    <div class="text-secondary">No allocations are linked to this server.</div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-dark table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Address</th>
                                    <th>Alias</th>
                                    <th>Type</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% assignedAllocations.forEach((allocation) => { %>
                                    <% const isPrimary = Number(allocation.id) === Number(primaryAllocationId); %>
                                    <% const hasAlias = Boolean(allocation.alias && String(allocation.alias).trim()); %>
                                    <tr>
                                        <td>
                                            <% if (hasAlias) { %>
                                                <code><%= allocation.alias %>:<%= allocation.port %></code>
                                            <% } else { %>
                                                <code><%= allocation.ip %>:<%= allocation.port %></code>
                                            <% } %>
                                        </td>
                                        <td><%= allocation.alias || '-' %></td>
                                        <td>
                                            <% if (isPrimary) { %>
                                                <span class="badge text-bg-primary">Primary</span>
                                            <% } else { %>
                                                <span class="badge text-bg-secondary">Additional</span>
                                            <% } %>
                                        </td>
                                        <td class="text-end">
                                            <% if (canManageNetwork && !isPrimary) { %>
                                                <form method="POST" action="/server/<%= server.containerId %>/network/allocations/<%= allocation.id %>/delete" class="d-inline">
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Unassign</button>
                                                </form>
                                            <% } else { %>
                                                <span class="text-secondary small">-</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>

            <% if (canManageNetwork && server.allocation) { %>
            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-2">Inventory Port Limit</h2>
                <% if (!inventoryEnabled) { %>
                    <div class="alert alert-warning mb-0 py-2"><%= inventoryAssignBlockedReason || 'Inventory mode is disabled by admin.' %></div>
                <% } else { %>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge text-bg-secondary">Tokens: <%= allocationTokens %></span>
                        <span class="badge text-bg-secondary">Assigned Additional: <%= additionalAssignedCount %></span>
                        <span class="badge text-bg-primary">Remaining: <%= remainingAssignable %></span>
                    </div>
                    <% if (inventoryAssignBlockedReason) { %>
                        <div class="alert alert-warning mb-0 py-2 mt-2"><%= inventoryAssignBlockedReason %></div>
                    <% } %>
                <% } %>
            </div>

            <div class="cardx p-3">
                <h2 class="h6">Assign Additional Allocation</h2>
                <% if (!inventoryEnabled) { %>
                    <div class="text-secondary">Assign is locked because inventory mode is disabled.</div>
                <% } else if (inventoryAssignBlockedReason) { %>
                    <div class="text-secondary">Assign is locked until you have free allocation tokens.</div>
                <% } else if (!availableAllocations || availableAllocations.length === 0) { %>
                    <div class="text-secondary">No free allocations available on this node.</div>
                <% } else { %>
                <form method="POST" action="/server/<%= server.containerId %>/network/allocations" class="row g-2 align-items-end">
                    <div class="col-md-9">
                        <label class="form-label small">Available Allocation</label>
                        <select class="form-select" name="allocationId" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;" required>
                            <option value="">Select allocation</option>
                            <% availableAllocations.forEach((allocation) => { %>
                                <% const optionHasAlias = Boolean(allocation.alias && String(allocation.alias).trim()); %>
                                <option value="<%= allocation.id %>">
                                    <% if (optionHasAlias) { %>
                                        <%= allocation.alias %>:<%= allocation.port %>
                                    <% } else { %>
                                        <%= allocation.ip %>:<%= allocation.port %>
                                    <% } %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary w-100" type="submit">Assign</button>
                    </div>
                </form>
                <div class="text-secondary small mt-2">Tip: after changing allocations, restart/reinstall the server so container port bindings are fully refreshed.</div>
                <% } %>
            </div>
            <% } %>
        </section>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
<script>document.getElementById('sidebarToggle')?.addEventListener('click',()=>document.getElementById('sidebar')?.classList.toggle('collapsed'));</script>
</body>
</html>

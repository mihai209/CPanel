<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Startup <%= server.name %> | <%= settings.brandName.toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
        <style>
            :root {
                --bg-dark: #0f0f12;
                --bg-darker: #0a0a0c;
                --bg-sidebar: #121216;
                --border-color: #2d2d35;
                --text-primary: #e1e1e6;
                --text-secondary: #8b8b9a;
                --accent-blue: #3b82f6;
                --accent-green: #10b981;
                --accent-red: #ef4444;
                --accent-yellow: #f59e0b;
            }

            body {
                background-color: var(--bg-dark);
                color: var(--text-primary);
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                overflow: hidden;
                height: 100vh;
                margin: 0;
            }

            .wrapper {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            .sidebar {
                width: 260px;
                background: var(--bg-sidebar);
                border-right: 1px solid var(--border-color);
                transition: all 0.3s ease;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                overflow-y: auto;
            }

            .sidebar .sidebar-content {
                padding: 1.5rem 0.75rem;
            }

            .sidebar-item {
                display: flex;
                align-items: center;
                padding: 0.75rem 1rem;
                color: var(--text-secondary);
                text-decoration: none;
                border-radius: 8px;
                transition: all 0.2s ease;
                font-weight: 500;
                font-size: 0.9rem;
                margin-bottom: 0.25rem;
            }

            .sidebar-item:hover {
                background: rgba(255, 255, 255, 0.03);
                color: var(--text-primary);
            }

            .sidebar-item.active {
                background: rgba(59, 130, 246, 0.1);
                color: var(--accent-blue);
            }

            .sidebar-icon {
                margin-right: 12px;
                font-size: 1.1rem;
                width: 24px;
                text-align: center;
            }

            .content {
                flex: 1;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                background: var(--bg-dark);
            }

            .top-navbar {
                background: var(--bg-sidebar);
                border-bottom: 1px solid var(--border-color);
                padding: 0.75rem 1.5rem;
                display: flex;
                align-items: center;
                flex-shrink: 0;
            }

            .navbar-toggle {
                background: transparent;
                border: none;
                color: var(--text-secondary);
                font-size: 1.5rem;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-right: 1rem;
                cursor: pointer;
                padding: 0;
            }

            .navbar-toggle:hover {
                color: var(--text-primary);
            }

            .server-info {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .server-name {
                font-size: 1.25rem;
                font-weight: 600;
                margin: 0;
            }

            .scroll-area {
                flex: 1;
                overflow-y: auto;
                padding: 1.5rem;
            }

            .settings-card {
                background: var(--bg-sidebar);
                border: 1px solid var(--border-color);
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
                margin-bottom: 1.25rem;
            }

            .settings-card-header {
                border-bottom: 1px solid var(--border-color);
                background: rgba(255, 255, 255, 0.02);
                padding: 1rem 1.25rem;
            }

            .settings-card-body {
                padding: 1.25rem;
            }

            .form-control,
            .form-select {
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid var(--border-color);
                color: var(--text-primary);
            }

            .form-select option {
                background-color: var(--bg-darker);
                color: var(--text-primary);
            }

            .form-control:focus,
            .form-select:focus {
                background: rgba(255, 255, 255, 0.04);
                border-color: var(--accent-blue);
                color: var(--text-primary);
                box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
            }

            .form-control[readonly] {
                opacity: 0.75;
            }

            .form-label {
                color: var(--text-secondary);
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                font-weight: 600;
            }

            .hint {
                color: var(--text-secondary);
                font-size: 0.85rem;
            }

            .btn-action {
                border-radius: 8px;
                font-weight: 600;
                padding: 0.6rem 1rem;
            }

            .btn-primary-soft {
                background: var(--accent-blue);
                border: 1px solid var(--accent-blue);
                color: #fff;
            }

            .btn-warning-soft {
                background: var(--accent-yellow);
                border: 1px solid var(--accent-yellow);
                color: #111;
            }

            .notice {
                border: 1px solid rgba(245, 158, 11, 0.35);
                background: rgba(245, 158, 11, 0.08);
                color: #fcd34d;
                border-radius: 10px;
                padding: 0.75rem 1rem;
                font-size: 0.9rem;
            }

            textarea.form-control {
                min-height: 92px;
                font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
                font-size: 0.9rem;
            }

            @media (max-width: 768px) {
                .sidebar {
                    margin-left: -260px;
                    position: fixed;
                    top: 0;
                    bottom: 0;
                    z-index: 1050;
                    box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
                }

                .sidebar.show {
                    margin-left: 0;
                }

                .content {
                    width: 100%;
                }

                .scroll-area {
                    padding: 1rem;
                }
            }
        </style>
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="wrapper">
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-content">
                    <%- include('../partials/server-sidebar', { server, active: 'startup' , settings }) %>
                </div>
            </nav>

            <div class="content">
                <div class="top-navbar">
                    <button id="sidebarToggle" class="navbar-toggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="server-info">
                        <h1 class="server-name">Startup</h1>
                        <span class="text-secondary opacity-50 mx-2">/</span>
                        <span class="text-secondary">
                            <%= server.name %>
                        </span>
                    </div>
                </div>

                <div class="scroll-area">
                    <form method="POST" action="/server/<%= server.containerId %>/startup">
                        <div class="settings-card">
                            <div class="settings-card-header">
                                <h6 class="mb-0 fw-semibold">Startup Command</h6>
                            </div>
                            <div class="settings-card-body">
                                <label class="form-label">Resolved Startup</label>
                                <textarea class="form-control" readonly><%= resolvedStartup %></textarea>
                                <div class="hint mt-2">
                                    Startup template comes from the selected image.
                                </div>
                            </div>
                        </div>

                        <div class="settings-card">
                            <div class="settings-card-header">
                                <h6 class="mb-0 fw-semibold">Docker Image</h6>
                            </div>
                            <div class="settings-card-body">
                                <label for="startupPreset" class="form-label">Startup Preset</label>
                                <select id="startupPreset" name="startupPreset" class="form-select mb-3">
                                    <option value="custom" <%= !selectedStartupPresetId ? 'selected' : '' %>>Custom (no preset)</option>
                                    <% if (startupPresets && startupPresets.length > 0) { %>
                                        <% startupPresets.forEach((preset) => { %>
                                            <option value="<%= preset.id %>" <%= selectedStartupPresetId === preset.id ? 'selected' : '' %>>
                                                <%= preset.label %>
                                            </option>
                                        <% }) %>
                                    <% } %>
                                </select>
                                <div class="hint mb-3">
                                    Presets auto-fill common variables (Paper, Purpur, Forge, Fabric) and pass the same validation rules as manual values.
                                </div>

                                <% if (startupPresets && startupPresets.length > 0) { %>
                                    <div id="presetPreviewList" class="mb-3">
                                        <% startupPresets.forEach((preset) => { %>
                                            <div class="preset-preview border rounded p-2 mb-2 <%= selectedStartupPresetId === preset.id ? '' : 'd-none' %>" data-preset-id="<%= preset.id %>" style="border-color: var(--border-color) !important; background: rgba(255,255,255,0.02);">
                                                <div class="small text-uppercase text-secondary fw-bold mb-1"><%= preset.label %></div>
                                                <div class="hint mb-2"><%= preset.description %></div>
                                                <pre class="mb-0" style="font-size: 0.78rem; color: #cbd5e1;"><%= JSON.stringify(preset.variables, null, 2) %></pre>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } %>

                                <label for="dockerImage" class="form-label">Docker Tag</label>
                                <select id="dockerImage" name="dockerImage" class="form-select">
                                    <% if (dockerChoices && dockerChoices.length> 0) { %>
                                        <% dockerChoices.forEach((choice)=> { %>
                                            <option value="<%= choice.tag %>" <%=selectedDockerImage===choice.tag
                                                ? 'selected' : '' %>>
                                                <%= choice.label %> - <%= choice.tag %>
                                            </option>
                                            <% }) %>
                                                <% } else { %>
                                                    <option value="<%= selectedDockerImage %>" selected>
                                                        <%= selectedDockerImage %>
                                                    </option>
                                                    <% } %>
                                </select>
                                <div class="hint mt-2">
                                    Changing image is applied only after reinstall.
                                </div>
                            </div>
                        </div>

                        <div class="settings-card">
                            <div class="settings-card-header">
                                <h6 class="mb-0 fw-semibold">Environment Variables</h6>
                            </div>
                            <div class="settings-card-body">
                                <div class="row g-3">
                                    <% if (!variableDefinitions || variableDefinitions.length===0) { %>
                                        <div class="col-12">
                                            <div class="hint">No configurable startup variables for this image.</div>
                                        </div>
                                        <% } else { %>
                                            <% variableDefinitions.forEach((variable)=> { %>
                                                <% const key=variable.env_variable; %>
                                                    <% const isViewable=variable.user_viewable==1 ||
                                                        variable.user_viewable===true; %>
                                                        <% const isEditable=variable.user_editable==1 ||
                                                            variable.user_editable===true; %>
                                                            <% if (isViewable) { %>
                                                                <% const label=(typeof variable.name==='string' &&
                                                                    variable.name.trim()) ? variable.name.trim() : key;
                                                                    %>
                                                                    <% const
                                                                        currentValue=Object.prototype.hasOwnProperty.call(resolvedVariables
                                                                        || {}, key) ? resolvedVariables[key] :
                                                                        (variable.default_value ?? '' ); %>
                                                                        <div class="col-md-6">
                                                                            <label class="form-label">
                                                                                <%= label %>
                                                                            </label>
                                                                            <input type="text"
                                                                                name="variables[<%= key %>]"
                                                                                class="form-control"
                                                                                value="<%= String(currentValue === null || currentValue === undefined ? '' : currentValue) %>"
                                                                                <%=isEditable ? '' : 'readonly' %>>
                                                                            <% if (variable.description ||
                                                                                variable.rules) { %>
                                                                                <div class="hint mt-2">
                                                                                    <%= variable.description || '' %>
                                                                                        <% if (variable.rules) { %>
                                                                                            <span class="ms-1">Rules:
                                                                                                <code><%= variable.rules %></code></span>
                                                                                            <% } %>
                                                                                </div>
                                                                                <% } %>
                                                                        </div>
                                                                        <% } %>
                                                                            <% }) %>
                                                                                <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="notice mb-3">
                            Save updates database settings only. Use <strong>Save and Reinstall</strong> to apply
                            immediately on the container.
                        </div>

                        <% const imageNameLower=String((image && image.name) ? image.name : '' ).toLowerCase(); %>
                            <% const mcVersionValue=resolvedVariables &&
                                Object.prototype.hasOwnProperty.call(resolvedVariables, 'MINECRAFT_VERSION' ) ?
                                String(resolvedVariables.MINECRAFT_VERSION || '' ).trim() : '' ; %>
                                <% if (imageNameLower.includes('paper') && mcVersionValue==='1.8.9' ) { %>
                                    <div class="notice mb-3"
                                        style="border-color: rgba(239, 68, 68, 0.35); background: rgba(239, 68, 68, 0.08); color: #fca5a5;">
                                        Paper does not provide build <strong>1.8.9</strong>. The install script falls
                                        back to latest, which usually needs Java 17+.
                                        Use <strong>1.8.8</strong> or switch Docker image to Java 17+.
                                    </div>
                                    <% } %>

                                        <div class="d-flex flex-wrap gap-2">
                                            <button type="submit" name="action" value="save"
                                                class="btn btn-action btn-primary-soft">
                                                <i class="bi bi-save me-1"></i> Save
                                            </button>
                                            <button type="submit" name="action" value="apply"
                                                class="btn btn-action btn-warning-soft">
                                                <i class="bi bi-arrow-repeat me-1"></i> Save and Reinstall
                                            </button>
                                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <script>
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', () => sidebar.classList.toggle('show'));
            }

            const presetSelect = document.getElementById('startupPreset');
            const presetCards = Array.from(document.querySelectorAll('.preset-preview'));
            function renderPresetPreview() {
                if (!presetSelect || presetCards.length === 0) return;
                const selected = presetSelect.value;
                presetCards.forEach((card) => {
                    const cardId = card.getAttribute('data-preset-id');
                    if (selected && cardId === selected) {
                        card.classList.remove('d-none');
                    } else {
                        card.classList.add('d-none');
                    }
                });
            }
            if (presetSelect) {
                presetSelect.addEventListener('change', renderPresetPreview);
                renderPresetPreview();
            }
        </script>
</body>

</html>

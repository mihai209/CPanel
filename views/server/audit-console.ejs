<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audit Console <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}
        .btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}.table-dark{--bs-table-bg:transparent}
        .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
        .audit-command { color:#93c5fd; }
        .audit-power { color:#fbbf24; }
        .audit-debug { color:#fca5a5; }
    </style>
</head>
<body>

<%- include('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'auditconsole' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Audit Console / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <div class="cardx p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="small text-secondary">Read-only stream of command/power/debug audit events.</div>
                    <span class="badge bg-secondary" id="auditCount"><%= Array.isArray(logs) ? logs.length : 0 %></span>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                        <tr>
                            <th>ID</th>
                            <th>When</th>
                            <th>Actor</th>
                            <th>Action</th>
                            <th>Details</th>
                        </tr>
                        </thead>
                        <tbody id="auditBody">
                        <% if (!logs || logs.length === 0) { %>
                            <tr id="auditEmptyRow"><td colspan="5" class="text-secondary">No audit events yet.</td></tr>
                        <% } else { logs.forEach((row) => { const meta = row.metadata && typeof row.metadata === 'object' ? row.metadata : {}; %>
                            <tr data-audit-id="<%= row.id %>">
                                <td class="mono text-secondary"><%= row.id %></td>
                                <td><%= new Date(row.createdAt).toLocaleString() %></td>
                                <td><%= row.actor && row.actor.username ? row.actor.username : 'system' %></td>
                                <td class="mono">
                                    <% const action = String(row.action || ''); %>
                                    <% if (action.startsWith('server:console')) { %>
                                        <span class="audit-command"><%= action %></span>
                                    <% } else if (action.startsWith('server:power') || action.startsWith('server:ack')) { %>
                                        <span class="audit-power"><%= action %></span>
                                    <% } else { %>
                                        <span class="audit-debug"><%= action %></span>
                                    <% } %>
                                </td>
                                <td class="small">
                                    <% if (meta.command) { %>
                                        <code><%= String(meta.command).slice(0, 180) %></code>
                                    <% } else if (meta.powerAction) { %>
                                        Power: <code><%= meta.powerAction %></code>
                                    <% } else if (meta.message) { %>
                                        <%= String(meta.message).slice(0, 180) %>
                                    <% } else { %>
                                        <span class="text-secondary">-</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</div>
<script>
    document.getElementById('sidebarToggle')?.addEventListener('click', () => document.getElementById('sidebar')?.classList.toggle('collapsed'));
    (() => {
        const body = document.getElementById('auditBody');
        const empty = document.getElementById('auditEmptyRow');
        const countBadge = document.getElementById('auditCount');
        if (!body) return;

        const getLastId = () => {
            const rows = body.querySelectorAll('tr[data-audit-id]');
            if (!rows.length) return 0;
            let max = 0;
            rows.forEach((row) => {
                const id = Number.parseInt(row.getAttribute('data-audit-id') || '0', 10) || 0;
                if (id > max) max = id;
            });
            return max;
        };

        const escapeHtml = (value) => String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const rowHtml = (entry) => {
            const action = String(entry.action || '');
            const meta = entry.metadata && typeof entry.metadata === 'object' ? entry.metadata : {};
            let actionClass = 'audit-debug';
            if (action.startsWith('server:console')) actionClass = 'audit-command';
            else if (action.startsWith('server:power') || action.startsWith('server:ack')) actionClass = 'audit-power';

            let details = '<span class="text-secondary">-</span>';
            if (meta.command) details = `<code>${escapeHtml(String(meta.command).slice(0, 180))}</code>`;
            else if (meta.powerAction) details = `Power: <code>${escapeHtml(meta.powerAction)}</code>`;
            else if (meta.message) details = escapeHtml(String(meta.message).slice(0, 180));

            const actor = entry.actor && entry.actor.username ? entry.actor.username : 'system';
            const when = entry.createdAt ? new Date(entry.createdAt).toLocaleString() : '-';
            return `
                <tr data-audit-id="${Number.parseInt(entry.id, 10) || 0}">
                    <td class="mono text-secondary">${Number.parseInt(entry.id, 10) || 0}</td>
                    <td>${escapeHtml(when)}</td>
                    <td>${escapeHtml(actor)}</td>
                    <td class="mono"><span class="${actionClass}">${escapeHtml(action)}</span></td>
                    <td class="small">${details}</td>
                </tr>
            `;
        };

        const poll = async () => {
            try {
                const afterId = getLastId();
                const response = await fetch(`/server/<%= server.containerId %>/audit-console/feed?afterId=${encodeURIComponent(afterId)}`, {
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-store'
                });
                if (!response.ok) return;
                const payload = await response.json();
                if (!payload || !payload.success || !Array.isArray(payload.logs) || payload.logs.length === 0) return;

                if (empty) empty.remove();
                payload.logs.forEach((entry) => {
                    body.insertAdjacentHTML('beforeend', rowHtml(entry));
                });
                if (countBadge) {
                    countBadge.textContent = String(body.querySelectorAll('tr[data-audit-id]').length);
                }
            } catch (_error) {
                // Keep polling silently.
            }
        };

        setInterval(poll, 4500);
    })();
</script>
</body>
</html>

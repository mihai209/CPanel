<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users <%= server.name %> | <%= settings.brandName.toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
        <style>
            :root {
                --bg: #0f0f12;
                --panel: #121216;
                --border: #2d2d35;
                --text: #e1e1e6;
                --muted: #8b8b9a;
                --accent: #3b82f6;
            }

            body {
                background: var(--bg);
                color: var(--text);
                margin: 0;
                font-family: Inter, system-ui, -apple-system, sans-serif;
                height: 100vh;
                overflow: hidden;
            }

            .wrapper {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            .sidebar {
                width: 260px;
                background: var(--panel);
                border-right: 1px solid var(--border);
                overflow-y: auto;
            }

            .sidebar.collapsed {
                margin-left: -260px;
            }

            .content {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .top-navbar {
                background: var(--panel);
                border-bottom: 1px solid var(--border);
                padding: .75rem 1rem;
                display: flex;
                align-items: center;
                gap: .75rem;
            }

            .scroll-area {
                flex: 1;
                overflow-y: auto;
                padding: 1.25rem;
            }

            .cardx {
                background: var(--panel);
                border: 1px solid var(--border);
                border-radius: .8rem;
            }

            .text-muted-2 {
                color: var(--muted);
            }

            .btn-icon {
                background: transparent;
                border: 0;
                color: var(--muted);
                font-size: 1.2rem;
            }

            .table-dark {
                --bs-table-bg: transparent;
            }

            .permission-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
                gap: .4rem;
            }

            code {
                color: #93c5fd;
            }
        </style>
</head>

<body>
    <div class="wrapper">
        <nav class="sidebar" id="sidebar">
            <div class="p-3">
                <%- include('../partials/server-sidebar', { server, active: 'users' }) %>
            </div>
        </nav>

        <main class="content">
            <header class="top-navbar">
                <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
                <h1 class="h5 mb-0">Users / <span class="text-muted-2">
                        <%= server.name %>
                    </span></h1>
            </header>

            <section class="scroll-area">
                <% if (success) { %>
                    <div class="alert alert-success">
                        <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="cardx p-3 mb-3">
                                    <div class="small text-muted-2 text-uppercase mb-1">Owner</div>
                                    <div class="fw-semibold">
                                        <%= owner ? owner.username : 'Unknown' %>
                                    </div>
                                    <div class="text-muted-2">
                                        <%= owner ? owner.email : '-' %>
                                    </div>
                                </div>

                                <div class="cardx p-3 mb-3">
                                    <div class="d-flex align-items-center justify-content-between mb-3">
                                        <h2 class="h6 mb-0">Subusers</h2>
                                        <% if (canManageUsers) { %>
                                            <button class="btn btn-sm btn-primary" data-action="create"
                                                data-bs-toggle="modal" data-bs-target="#subuserModal">
                                                <i class="bi bi-person-plus"></i> Invite User
                                            </button>
                                            <% } %>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-dark table-sm align-middle mb-0">
                                            <thead>
                                                <tr>
                                                    <th>User</th>
                                                    <th>Permissions</th>
                                                    <th>Invited By</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (!memberships || memberships.length===0) { %>
                                                    <tr>
                                                        <td colspan="4" class="text-muted-2">No subusers yet.</td>
                                                    </tr>
                                                    <% } else { memberships.forEach((entry)=> { %>
                                                        <tr>
                                                            <td>
                                                                <div class="fw-semibold">
                                                                    <%= entry.user ? entry.user.username : ('#' +
                                                                        entry.userId) %>
                                                                </div>
                                                                <div class="small text-muted-2">
                                                                    <%= entry.user ? entry.user.email : '' %>
                                                                </div>
                                                            </td>
                                                            <td><code><%= Array.isArray(entry.permissions) ? entry.permissions.join(', ') : '' %></code>
                                                            </td>
                                                            <td>
                                                                <%= entry.invitedBy ? entry.invitedBy.username : '-' %>
                                                            </td>
                                                            <td class="text-end">
                                                                <% if (canManageUsers) { %>
                                                                    <button type="button"
                                                                        class="btn btn-sm btn-outline-light"
                                                                        data-action="edit" data-bs-toggle="modal"
                                                                        data-bs-target="#subuserModal"
                                                                        data-membership-id="<%= entry.id %>"
                                                                        data-user-id="<%= entry.userId %>"
                                                                        data-username="<%= entry.user ? entry.user.username : '' %>"
                                                                        data-email="<%= entry.user ? entry.user.email : '' %>"
                                                                        data-permissions='<%= JSON.stringify(Array.isArray(entry.permissions) ? entry.permissions : []) %>'>
                                                                        Manage
                                                                    </button>
                                                                    <% } else { %>
                                                                        <span class="text-muted-2">-</span>
                                                                        <% } %>
                                                            </td>
                                                        </tr>
                                                        <% }) } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

            </section>
        </main>
    </div>

    <% if (canManageUsers) { %>
        <div class="modal fade" id="subuserModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content" style="background:#121216;border:1px solid #2d2d35;color:#e1e1e6;">
                    <div class="modal-header border-secondary border-opacity-25">
                        <h5 class="modal-title" id="subuserModalTitle">Invite Subuser</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form method="POST" action="/server/<%= server.containerId %>/users" id="subuserForm"
                            data-turbo="false">
                            <input type="hidden" name="membershipId" id="subuserMembershipId">
                            <div class="row g-2 mb-3">
                                <!--- REMOVED TO AVOID DOXXING
                        <div class="col-md-6">
                            <label class="form-label small text-uppercase text-muted-2">User</label>
                            <select name="userId" id="subuserUserSelect" class="form-select" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                <option value="">Select existing user</option>
                                <% (candidateUsers || []).forEach((u) => { %>
                                    <option value="<%= u.id %>">(removed email + username display to avoid doxxing)</option>
                                <% }) %>
                            </select>
                        </div>-->
                                <div class="col-md-6">
                                    <label class="form-label small text-uppercase text-muted-2">Or Identifier</label>
                                    <input name="identifier" id="subuserIdentifier" class="form-control"
                                        placeholder="username or email"
                                        style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                                </div>
                            </div>

                            <label class="form-label small text-uppercase text-muted-2">Permissions</label>
                            <div class="permission-grid mb-3">
                                <% (permissionCatalog || []).forEach((perm)=> { %>
                                    <label class="form-check"
                                        style="padding:.4rem .5rem;border:1px solid #2d2d35;border-radius:.5rem;background:#16161b;">
                                        <input class="form-check-input subuser-permission" type="checkbox"
                                            name="permissions" value="<%= perm %>" <%=perm==='server.view' ? 'checked'
                                            : '' %>>
                                        <span class="form-check-label">
                                            <div class="fw-semibold"><%= perm %></div>
                                            <div class="small text-muted-2" data-permission-desc="<%= perm %>"></div>
                                        </span>
                                    </label>
                                    <% }) %>
                            </div>

                            <button class="btn btn-primary" type="submit" id="subuserSubmitBtn">Save Subuser</button>
                            <button type="button" class="btn btn-outline-secondary ms-2"
                                data-bs-dismiss="modal">Cancel</button>
                        </form>

                        <form method="POST" id="subuserRemoveForm" class="mt-3 d-none" data-turbo="false">
                            <button type="submit" class="btn btn-outline-danger">Remove Subuser</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
                data-turbo-eval="false"></script>
            <script>
                document.getElementById('sidebarToggle')?.addEventListener('click', function () {
                    document.getElementById('sidebar')?.classList.toggle('collapsed');
                });

                const subuserModal = document.getElementById('subuserModal');
                const modalTitle = document.getElementById('subuserModalTitle');
                const membershipInput = document.getElementById('subuserMembershipId');
                const userSelect = document.getElementById('subuserUserSelect');
                const identifierInput = document.getElementById('subuserIdentifier');
                const removeForm = document.getElementById('subuserRemoveForm');
                const submitBtn = document.getElementById('subuserSubmitBtn');

                function resetPermissions(defaults = ['server.view']) {
                    document.querySelectorAll('.subuser-permission').forEach((checkbox) => {
                        checkbox.checked = defaults.includes(checkbox.value);
                    });
                }

                function openInviteModal() {
                    if (modalTitle) modalTitle.textContent = 'Invite Subuser';
                    if (membershipInput) membershipInput.value = '';
                    if (userSelect) userSelect.value = '';
                    if (identifierInput) identifierInput.value = '';
                    resetPermissions(['server.view']);
                    if (removeForm) removeForm.classList.add('d-none');
                    if (submitBtn) submitBtn.textContent = 'Save Subuser';
                }

                function openEditModal(button) {
                    const membershipId = button.dataset.membershipId || '';
                    const userId = button.dataset.userId || '';
                    const username = button.dataset.username || '';
                    const email = button.dataset.email || '';
                    const permissions = JSON.parse(button.dataset.permissions || '[]');

                    if (modalTitle) modalTitle.textContent = `Manage ${username || 'Subuser'}`;
                    if (membershipInput) membershipInput.value = membershipId;
                    if (userSelect) userSelect.value = userId;
                    if (identifierInput) identifierInput.value = email || username || '';
                    resetPermissions(permissions.length ? permissions : ['server.view']);

                    if (removeForm && membershipId) {
                        removeForm.action = `/server/<%= server.containerId %>/users/${membershipId}/delete`;
                        removeForm.classList.remove('d-none');
                    }
                    if (submitBtn) submitBtn.textContent = 'Update Subuser';
                }

                document.querySelectorAll('[data-action=\"create\"]').forEach((btn) => {
                    btn.addEventListener('click', openInviteModal);
                });

                document.querySelectorAll('[data-action=\"edit\"]').forEach((btn) => {
                    btn.addEventListener('click', () => openEditModal(btn));
                });

                const userPermissionDescriptions = {
                    'server.view': 'Access the server overview and basic details.',
                    'server.console': 'View the console and send commands.',
                    'server.power': 'Start, stop, restart, or kill the server.',
                    'server.files': 'View and edit server files.',
                    'server.startup': 'Change startup command and variables.',
                    'server.minecraft': 'Access Minecraft tools (mods/plugins).',
                    'minecraft.kick': 'Kick players from the Minecraft server.',
                    'minecraft.ban': 'Ban players from the Minecraft server.',
                    'minecraft.op': 'Grant operator rights with /op.',
                    'minecraft.deop': 'Remove operator rights with /deop.',
                    'server.backups.view': 'View backups list.',
                    'server.backups.manage': 'Create/delete backups (if enabled).',
                    'server.databases.view': 'View databases linked to the server.',
                    'server.databases.manage': 'Create/update/delete databases.',
                    'server.schedules.view': 'View schedules.',
                    'server.schedules.manage': 'Create/update/delete schedules.',
                    'server.network.view': 'View allocations and ports.',
                    'server.network.manage': 'Manage allocations/ports.',
                    'server.mounts': 'Attach/detach mounts.',
                    'server.users.view': 'View subusers list.',
                    'server.users.manage': 'Invite/remove subusers and edit permissions.',
                    'server.activity.view': 'View activity logs.',
                    'server.smartalerts': 'Configure smart alerts.',
                    'server.policy': 'Configure policy engine.'
                };

                document.querySelectorAll('[data-permission-desc]').forEach((el) => {
                    const key = el.getAttribute('data-permission-desc');
                    if (!key) return;
                    el.textContent = userPermissionDescriptions[key] || 'Permission access.';
                });
            </script>
</body>

</html>

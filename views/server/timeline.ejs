<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resource Timeline <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}
        .btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .timeline-canvas { width: 100%; height: 300px; background:#0c0d10; border:1px solid #2d2d35; border-radius:.65rem; }
        .metric { font-size:.85rem; color:#9ca3af; }
        .metric strong { color:#e5e7eb; }
        .legend-dot { display:inline-block; width:.75rem; height:.75rem; border-radius:999px; margin-right:.35rem; }
    </style>
</head>
<body>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'timeline' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Resource Timeline / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <div class="cardx p-3">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                    <div class="d-flex gap-3 small">
                        <span><span class="legend-dot" style="background:#22c55e"></span>CPU %</span>
                        <span><span class="legend-dot" style="background:#3b82f6"></span>Memory %</span>
                        <span><span class="legend-dot" style="background:#f59e0b"></span>Disk %</span>
                    </div>
                    <div class="metric">
                        Last: <strong id="timelineLast">N/A</strong>
                    </div>
                </div>
                <canvas id="timelineCanvas" class="timeline-canvas"></canvas>
                <div class="row g-2 mt-2">
                    <div class="col-md-4 metric">CPU: <strong id="cpuNow">0%</strong></div>
                    <div class="col-md-4 metric">Memory: <strong id="memNow">0 / <%= Number(server.memory || 0) %> MB</strong></div>
                    <div class="col-md-4 metric">Disk: <strong id="diskNow">0 / <%= Number(server.disk || 0) %> MB</strong></div>
                </div>
            </div>
        </section>
    </main>
</div>
<script>
    document.getElementById('sidebarToggle')?.addEventListener('click', () => document.getElementById('sidebar')?.classList.toggle('collapsed'));
    (() => {
        const rawSamples = <%- JSON.stringify(Array.isArray(samples) ? samples : []) %>;
        const memoryLimit = Math.max(1, Number.parseInt('<%= Number(server.memory || 0) %>', 10) || 1);
        const diskLimit = Math.max(1, Number.parseInt('<%= Number(server.disk || 0) %>', 10) || 1);
        const maxPoints = 180;
        const canvas = document.getElementById('timelineCanvas');
        if (!canvas) return;

        const cpuNow = document.getElementById('cpuNow');
        const memNow = document.getElementById('memNow');
        const diskNow = document.getElementById('diskNow');
        const timelineLast = document.getElementById('timelineLast');

        const state = rawSamples
            .map((row) => ({
                ts: row && row.collectedAt ? new Date(row.collectedAt).getTime() : Date.now(),
                cpu: Math.max(0, Number.parseFloat(row && row.cpuPercent) || 0),
                mem: Math.max(0, Number.parseFloat(row && row.memoryMb) || 0),
                disk: Math.max(0, Number.parseFloat(row && row.diskMb) || 0)
            }))
            .filter((row) => Number.isFinite(row.ts))
            .slice(-maxPoints);

        const clampPercent = (value) => Math.max(0, Math.min(100, value));
        const toMemPercent = (mb) => clampPercent((mb / memoryLimit) * 100);
        const toDiskPercent = (mb) => clampPercent((mb / diskLimit) * 100);

        const draw = () => {
            const dpr = window.devicePixelRatio || 1;
            const rect = canvas.getBoundingClientRect();
            const width = Math.max(300, Math.floor(rect.width));
            const height = Math.max(180, Math.floor(rect.height));
            canvas.width = Math.floor(width * dpr);
            canvas.height = Math.floor(height * dpr);
            const ctx = canvas.getContext('2d');
            ctx.scale(dpr, dpr);

            ctx.clearRect(0, 0, width, height);
            ctx.fillStyle = '#0c0d10';
            ctx.fillRect(0, 0, width, height);

            for (let i = 0; i <= 5; i += 1) {
                const y = Math.round((height - 20) * (i / 5)) + 10;
                ctx.strokeStyle = 'rgba(255,255,255,0.08)';
                ctx.beginPath();
                ctx.moveTo(10, y);
                ctx.lineTo(width - 10, y);
                ctx.stroke();
            }

            const points = state.slice(-maxPoints);
            if (!points.length) return;
            const xAt = (idx, total) => {
                if (total <= 1) return 10;
                return 10 + ((width - 20) * (idx / (total - 1)));
            };
            const yAt = (percent) => 10 + ((height - 20) * (1 - clampPercent(percent) / 100));

            const drawLine = (extractPercent, color) => {
                ctx.beginPath();
                points.forEach((point, idx) => {
                    const x = xAt(idx, points.length);
                    const y = yAt(extractPercent(point));
                    if (idx === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                });
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.stroke();
            };

            drawLine((point) => point.cpu, '#22c55e');
            drawLine((point) => toMemPercent(point.mem), '#3b82f6');
            drawLine((point) => toDiskPercent(point.disk), '#f59e0b');
        };

        const updateNow = (point) => {
            if (!point) return;
            cpuNow.textContent = `${point.cpu.toFixed(1)}%`;
            memNow.textContent = `${Math.round(point.mem)} / ${memoryLimit} MB`;
            diskNow.textContent = `${Math.round(point.disk)} / ${diskLimit} MB`;
            timelineLast.textContent = new Date(point.ts).toLocaleTimeString();
        };

        const pushPoint = (cpu, mem, disk) => {
            const point = {
                ts: Date.now(),
                cpu: Math.max(0, Number.parseFloat(cpu) || 0),
                mem: Math.max(0, Number.parseFloat(mem) || 0),
                disk: Math.max(0, Number.parseFloat(disk) || 0)
            };
            state.push(point);
            while (state.length > maxPoints) state.shift();
            updateNow(point);
            draw();
        };

        if (state.length > 0) updateNow(state[state.length - 1]);
        draw();
        window.addEventListener('resize', draw);

        const wsToken = '<%= wsToken || "" %>';
        const finalWsUrl = window.location.protocol.replace('http', 'ws') + '//' + window.location.host + '/ws/server/<%= server.containerId %>?token=' + encodeURIComponent(wsToken);
        let ws = null;
        let reconnectMs = 1000;
        const connect = () => {
            ws = new WebSocket(finalWsUrl);
            ws.onopen = () => { reconnectMs = 1000; };
            ws.onmessage = (event) => {
                try {
                    const data = JSON.parse(event.data);
                    if (data && data.type === 'server_stats') {
                        pushPoint(data.cpu, data.memory, data.disk || 0);
                    }
                } catch (_error) {
                    // ignore
                }
            };
            ws.onclose = () => {
                setTimeout(connect, reconnectMs);
                reconnectMs = Math.min(5000, Math.round(reconnectMs * 1.5));
            };
        };
        connect();
    })();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schedules <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}.btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .table-dark{--bs-table-bg:transparent}
    </style>
</head>
<body>

<%- include('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'schedules' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Schedules / <span class="text-secondary"><%= server.name %></span></h1>
            <div class="ms-auto">
                <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="modal" data-bs-target="#scheduleTutorialModal">
                    <i class="bi bi-question-circle me-1"></i>Tutorial
                </button>
            </div>
        </header>
        <section class="scroll">
            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <% if (canManageSchedules) { %>
            <div class="cardx p-3 mb-3">
                <h2 class="h6">Create Schedule</h2>
                <form method="POST" action="/server/<%= server.containerId %>/schedules" class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small">Name</label>
                        <input class="form-control" name="name" required style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Action</label>
                        <select class="form-select" name="action" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                            <option value="command">Command</option>
                            <option value="power">Power</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Cron</label>
                        <input class="form-control" name="cron" value="* * * * *" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Payload</label>
                        <input class="form-control" name="payload" placeholder="say hello / restart" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button class="btn btn-primary flex-fill" type="submit">Save</button>
                    </div>
                    <div class="col-12 d-flex flex-wrap gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="scheduleEnabled" name="enabled" value="1" checked>
                            <label class="form-check-label" for="scheduleEnabled">Enabled</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="scheduleOnlyWhenOnline" name="onlyWhenOnline" value="1">
                            <label class="form-check-label" for="scheduleOnlyWhenOnline">Run only when server is online</label>
                        </div>
                    </div>
                </form>
                <div class="small text-secondary mt-2">Power payload: <code>start|stop|restart|kill</code>. Command payload: text command.</div>
            </div>
            <% } %>

            <div class="cardx p-3">
                <h2 class="h6 mb-3">Schedules</h2>
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead><tr><th>Name</th><th>Action</th><th>Cron</th><th>Payload</th><th>Status</th><th>Last Run</th><th class="text-end">Actions</th></tr></thead>
                        <tbody>
                            <% if (!schedules || schedules.length === 0) { %>
                                <tr><td colspan="7" class="text-secondary">No schedules configured.</td></tr>
                            <% } else { schedules.forEach((entry) => { %>
                                <tr>
                                    <td><%= entry.name %></td>
                                    <td><span class="badge bg-info text-dark"><%= entry.action %></span></td>
                                    <td><code><%= entry.cron || '-' %></code></td>
                                    <td><code><%= entry.payload || '-' %></code></td>
                                    <td>
                                        <span class="badge <%= entry.enabled === false ? 'bg-secondary' : 'bg-success' %>">
                                            <%= entry.enabled === false ? 'Disabled' : 'Enabled' %>
                                        </span>
                                        <% if (entry.onlyWhenOnline) { %>
                                            <span class="badge bg-warning text-dark ms-1">Online only</span>
                                        <% } %>
                                    </td>
                                    <td><%= entry.lastRunAt ? new Date(entry.lastRunAt).toLocaleString() : '-' %></td>
                                    <td class="text-end">
                                        <% if (canManageSchedules) { %>
                                        <form method="POST" action="/server/<%= server.containerId %>/schedules/<%= entry.id %>/run" class="d-inline">
                                            <button class="btn btn-sm btn-outline-success" type="submit">Run</button>
                                        </form>
                                        <form method="POST" action="/server/<%= server.containerId %>/schedules/<%= entry.id %>/delete" class="d-inline">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                        </form>
                                        <% } else { %>
                                            <span class="text-secondary">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</div>
<div class="modal fade" id="scheduleTutorialModal" tabindex="-1" aria-labelledby="scheduleTutorialModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="background:#121216;border:1px solid #2d2d35;color:#e1e1e6;">
            <div class="modal-header" style="border-bottom:1px solid #2d2d35;">
                <h5 class="modal-title" id="scheduleTutorialModalLabel">Schedules Tutorial</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-secondary mb-3">Folosești schedule-uri ca să rulezi comenzi automat. Totul rulează pe timezone-ul panelului (<code><%= settings.timezone || 'system default' %></code>).</p>

                <h6 class="mb-2">1) Câmpurile principale</h6>
                <ul class="text-secondary">
                    <li><strong>Name:</strong> numele task-ului (ex: <code>Auto Save</code>).</li>
                    <li><strong>Action:</strong> <code>command</code> sau <code>power</code>.</li>
                    <li><strong>Cron:</strong> formatul este <code>minute hour day month weekday</code>.</li>
                    <li><strong>Payload:</strong> pentru <code>command</code> pui comanda, pentru <code>power</code> pui <code>start|stop|restart|kill</code>.</li>
                </ul>

                <h6 class="mb-2 mt-3">2) Exemple rapide</h6>
                <div class="mb-2"><strong>Autosave la 5 minute</strong></div>
                <pre class="p-2 rounded" style="background:#0f0f12;border:1px solid #2d2d35;"><code>Name: Auto Save
Action: command
Cron: */5 * * * *
Payload: save-all</code></pre>

                <div class="mb-2 mt-3"><strong>Restart zilnic la 04:00</strong></div>
                <pre class="p-2 rounded" style="background:#0f0f12;border:1px solid #2d2d35;"><code>Name: Daily Restart
Action: power
Cron: 0 4 * * *
Payload: restart</code></pre>

                <h6 class="mb-2 mt-3">3) Recomandări</h6>
                <ul class="text-secondary mb-0">
                    <li>Bifează <em>Run only when server is online</em> pentru comenzi care au nevoie de server pornit.</li>
                    <li>Pentru task-uri critice, apasă <strong>Run</strong> după creare ca test.</li>
                    <li>Dacă nu rulează, verifică <code>cron</code>, <code>payload</code> și status-ul serverului.</li>
                </ul>
            </div>
            <div class="modal-footer" style="border-top:1px solid #2d2d35;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
<script>document.getElementById('sidebarToggle')?.addEventListener('click',()=>document.getElementById('sidebar')?.classList.toggle('collapsed'));</script>
</body>
</html>

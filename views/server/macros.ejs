<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Command Macros <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}
        .btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .form-control,.form-select{background:#0f0f12;border-color:#2d2d35;color:#e5e7eb}
        .mono{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace}
    </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>
<body>

<%- include('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'macros' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Command Macros / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <% if (success) { %><div class="alert alert-success py-2"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger py-2"><%= error %></div><% } %>

            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-3">Create Macro</h2>
                <form method="POST" action="/server/<%= server.containerId %>/macros" class="row g-2">
                    <div class="col-md-3">
                        <input class="form-control" name="name" maxlength="80" placeholder="Macro name" required>
                    </div>
                    <div class="col-md-6">
                        <input class="form-control mono" name="command" maxlength="1024" placeholder="say Hello world" required>
                    </div>
                    <div class="col-md-3">
                        <input class="form-control" name="description" maxlength="160" placeholder="Optional description">
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button class="btn btn-primary btn-sm" type="submit"><i class="bi bi-plus-circle me-1"></i>Create Macro</button>
                    </div>
                </form>
            </div>

            <div class="cardx p-3">
                <h2 class="h6 mb-3">Installed Macros</h2>
                <% if (!macros || macros.length === 0) { %>
                    <div class="text-secondary">No macros yet.</div>
                <% } else { %>
                    <div class="d-grid gap-2">
                        <% macros.forEach((macro) => { %>
                            <div class="border rounded p-2" style="border-color:#2d2d35 !important;background:#0f0f12;">
                                <form method="POST" action="/server/<%= server.containerId %>/macros/<%= macro.id %>/update" class="row g-2 align-items-center">
                                    <div class="col-md-2">
                                        <input class="form-control form-control-sm" name="name" maxlength="80" value="<%= macro.name || '' %>" required>
                                    </div>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm mono" name="command" maxlength="1024" value="<%= macro.command || '' %>" required>
                                    </div>
                                    <div class="col-md-3">
                                        <input class="form-control form-control-sm" name="description" maxlength="160" value="<%= macro.description || '' %>">
                                    </div>
                                    <div class="col-md-1">
                                        <input class="form-control form-control-sm" type="number" min="0" name="position" value="<%= Number.parseInt(macro.position, 10) || 0 %>" title="Order">
                                    </div>
                                    <div class="col-md-1 d-flex justify-content-end">
                                        <button class="btn btn-outline-info btn-sm" type="submit" title="Save"><i class="bi bi-save"></i></button>
                                    </div>
                                </form>
                                <div class="d-flex gap-1 justify-content-end mt-2">
                                    <% if (canRunCommands) { %>
                                        <form method="POST" action="/server/<%= server.containerId %>/macros/<%= macro.id %>/run" class="d-inline">
                                            <button class="btn btn-outline-success btn-sm" type="submit" title="Run"><i class="bi bi-play"></i></button>
                                        </form>
                                    <% } %>
                                    <form method="POST" action="/server/<%= server.containerId %>/macros/<%= macro.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this macro?');">
                                        <button class="btn btn-outline-danger btn-sm" type="submit" title="Delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                                <div class="small text-secondary mt-2">
                                    Created by: <%= macro.creator && macro.creator.username ? macro.creator.username : 'unknown' %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </section>
    </main>
</div>
<script>document.getElementById('sidebarToggle')?.addEventListener('click',()=>document.getElementById('sidebar')?.classList.toggle('collapsed'));</script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-visit-control" content="reload">
    <title>
        <%= title %> | <%= settings.brandName.toUpperCase() %>
    </title>
    <%- include('../partials/favicon.ejs') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.2.1/css/xterm.css" />
        <script>
            const isPopout = new URLSearchParams(window.location.search).get('popout') === 'true';
            if (isPopout) {
                document.documentElement.classList.add('is-popout');
            }
        </script>
        <style>
            html.is-popout .sidebar,
            html.is-popout .top-navbar {
                display: none !important;
            }

            html.is-popout .terminal-wrapper {
                padding: 0 !important;
            }

            html.is-popout .terminal-container {
                border-radius: 0 !important;
                border: none !important;
            }

            html.is-popout .wrapper {
                width: 100vw !important;
                height: 100vh !important;
            }

            :root {
                --bg-dark: #0f0f12;
                --bg-darker: #0a0a0c;
                --bg-sidebar: #121216;
                --border-color: #2d2d35;
                --text-primary: #e1e1e6;
                --text-secondary: #8b8b9a;
                --accent-blue: #3b82f6;
                --accent-green: #10b981;
                --accent-red: #ef4444;
                --accent-yellow: #f59e0b;
            }

            body {
                background-color: var(--bg-dark);
                color: var(--text-primary);
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                overflow: hidden;
                height: 100vh;
            }

            /* Wrapper for sidebar + content */
            .wrapper {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            /* Sidebar styles */
            .sidebar {
                width: 260px;
                background: var(--bg-sidebar);
                border-right: 1px solid var(--border-color);
                transition: all 0.3s ease;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                overflow-y: auto;
            }

            .sidebar.collapsed {
                margin-left: -260px;
            }

            .sidebar .sidebar-content {
                padding: 1.5rem 0.75rem;
            }

            .sidebar-item {
                display: flex;
                align-items: center;
                padding: 0.75rem 1rem;
                color: var(--text-secondary);
                text-decoration: none;
                border-radius: 8px;
                transition: all 0.2s ease;
                font-weight: 500;
                font-size: 0.9rem;
                margin-bottom: 0.25rem;
            }

            .sidebar-item:hover {
                background: rgba(255, 255, 255, 0.03);
                color: var(--text-primary);
            }

            .sidebar-item.active {
                background: rgba(59, 130, 246, 0.1);
                color: var(--accent-blue);
            }

            .sidebar-icon {
                margin-right: 12px;
                font-size: 1.1rem;
                width: 24px;
                text-align: center;
            }

            /* Main content area */
            .content {
                flex: 1;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                background: var(--bg-dark);
            }

            /* Top navbar */
            .top-navbar {
                background: var(--bg-sidebar);
                border-bottom: 1px solid var(--border-color);
                padding: 0.75rem 1.5rem;
                display: flex;
                align-items: center;
                flex-shrink: 0;
                gap: 0.75rem;
            }

            .navbar-toggle {
                background: transparent;
                border: none;
                color: var(--text-secondary);
                font-size: 1.5rem;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-right: 1rem;
                cursor: pointer;
                padding: 0;
            }

            .navbar-toggle:hover {
                color: var(--text-primary);
            }

            .server-info {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .server-meta-line {
                color: var(--text-secondary);
                font-size: 0.78rem;
                width: 100%;
                margin-top: -0.25rem;
            }

            .top-navbar-right {
                margin-left: auto;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                flex-wrap: wrap;
                justify-content: flex-end;
            }

            .server-name {
                font-size: 1.25rem;
                font-weight: 600;
                margin: 0;
            }

            .server-address {
                color: var(--text-secondary);
                font-size: 0.85rem;
            }

            /* Status badge (reuse existing styles but adjust) */
            .status-badge {
                padding: 0.4rem 1rem;
                border-radius: 20px;
                font-size: 0.75rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                background: rgba(16, 185, 129, 0.15);
                color: #10b981;
                border: 1px solid rgba(16, 185, 129, 0.3);
            }

            .status-dot {
                display: inline-block;
                width: 8px;
                height: 8px;
                border-radius: 50%;
                margin-right: 8px;
            }

            .status-running .status-dot {
                background: #10b981;
                animation: pulse 2s infinite;
            }

            .status-stopped .status-dot {
                background: #ef4444;
            }

            .status-stopped {
                background: rgba(239, 68, 68, 0.15);
                color: #ef4444;
                border-color: rgba(239, 68, 68, 0.3);
            }

            .status-starting .status-dot {
                background: #3b82f6;
                animation: pulse 2s infinite;
            }

            .status-starting {
                background: rgba(59, 130, 246, 0.15);
                color: #3b82f6;
                border-color: rgba(59, 130, 246, 0.3);
            }

            @keyframes pulse {

                0%,
                100% {
                    opacity: 1;
                }

                50% {
                    opacity: 0.5;
                }
            }

            /* Terminal container */
            .terminal-wrapper {
                flex: 1;
                padding: 1.1rem 1.25rem;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            .terminal-container {
                background: var(--bg-darker);
                border-radius: 12px;
                border: 1px solid var(--border-color);
                display: flex;
                flex-direction: column;
                height: 100%;
                overflow: hidden;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            }

            .console-grid {
                display: flex;
                gap: 0.8rem;
                height: 100%;
                min-height: 0;
            }

            .console-grid .terminal-container {
                flex: 1 1 auto;
                min-width: 0;
            }

            .player-panel {
                width: 280px;
                background: var(--bg-darker);
                border: 1px solid var(--border-color);
                border-radius: 12px;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.35);
            }

            .player-panel-header {
                background: var(--bg-sidebar);
                padding: 0.75rem 1rem;
                border-bottom: 1px solid var(--border-color);
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 0.5rem;
            }

            .player-panel-title {
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }

            .player-panel-body {
                padding: 0.75rem 0.75rem 0.5rem;
                overflow: auto;
                flex: 1 1 auto;
            }

            .player-card {
                border: 1px solid #2d2d35;
                background: rgba(15, 15, 18, 0.8);
                border-radius: 10px;
                padding: 0.6rem 0.75rem;
            }

            .player-card + .player-card {
                margin-top: 0.6rem;
            }

            .player-card .player-name {
                font-weight: 600;
                font-size: 0.9rem;
            }

            .player-card img {
                width: 34px;
                height: 34px;
                border-radius: 8px;
                border: 1px solid #2f2f39;
                object-fit: cover;
                background: #0f1115;
            }

            .player-actions {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
                margin-top: 0.45rem;
            }

            .player-panel-footer {
                border-top: 1px solid var(--border-color);
                background: var(--bg-sidebar);
                padding: 0.6rem 0.75rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                font-size: 0.8rem;
                color: var(--text-secondary);
            }

            .terminal-header {
                background: var(--bg-sidebar);
                padding: 0.6rem 1.1rem;
                border-bottom: 1px solid var(--border-color);
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-shrink: 0;
                gap: 0.75rem;
            }

            .console-info {
                border-bottom: 1px solid var(--border-color);
                background: rgba(15, 15, 18, 0.92);
                padding: 0.45rem 1.1rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem 1.5rem;
                font-size: 0.8rem;
                color: var(--text-secondary);
            }

            .console-info .info-label {
                text-transform: uppercase;
                letter-spacing: 0.08em;
                font-size: 0.65rem;
                color: rgba(255, 255, 255, 0.4);
                margin-right: 0.35rem;
            }

            .console-info .info-pill {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 999px;
                padding: 0.25rem 0.6rem;
            }

            .terminal-title {
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .terminal-controls {
                display: flex;
                gap: 0.5rem;
                align-items: center;
                flex-wrap: wrap;
            }

            #terminal {
                flex: 1;
                padding: 0.5rem;
                min-height: 0;
                background: #0d0d10;
            }

            .terminal-footer {
                background: var(--bg-sidebar);
                padding: 0.6rem 1.1rem;
                border-top: 1px solid var(--border-color);
                flex-shrink: 0;
            }

            .input-group-text {
                background: var(--bg-darker);
                border-color: var(--border-color);
                color: var(--text-secondary);
            }

            .form-control {
                background: var(--bg-darker);
                border-color: var(--border-color);
                color: var(--text-primary);
            }

            .form-control:focus {
                background: #1a1a20;
                border-color: var(--accent-blue);
                color: var(--text-primary);
                box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.15);
            }

            /* Connection Toast */
            .connection-toast {
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                z-index: 9999;
                background: #1a1a20;
                border: 1px solid rgba(239, 68, 68, 0.3);
                border-left: 4px solid #ef4444;
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
                border-radius: 8px;
                padding: 1rem 1.25rem;
                min-width: 320px;
                max-width: 400px;
                display: flex;
                align-items: flex-start;
                gap: 12px;
                animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            }

            .connection-toast.d-none {
                display: none !important;
            }

            @keyframes slideIn {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .toast-icon {
                font-size: 1.5rem;
                color: #ef4444;
                line-height: 1;
            }

            .toast-content h5 {
                margin: 0 0 4px 0;
                font-size: 0.95rem;
                font-weight: 600;
                color: #e1e1e6;
            }

            .toast-content p {
                margin: 0;
                font-size: 0.85rem;
                color: #a1a1aa;
                line-height: 1.4;
            }

            /* Responsive */
            @media (max-width: 768px) {
                .sidebar {
                    margin-left: -260px;
                    position: fixed;
                    top: 0;
                    bottom: 0;
                    z-index: 1050;
                    box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
                }

                .sidebar.show {
                    margin-left: 0;
                }

                .content {
                    width: 100%;
                }

                .terminal-wrapper {
                    padding: 1rem;
                }

                .top-navbar-right {
                    margin-left: 0;
                    width: 100%;
                    justify-content: flex-start;
                }

                .terminal-header {
                    flex-direction: column;
                    align-items: flex-start;
                }

                .terminal-controls {
                    width: 100%;
                    gap: 0.5rem;
                }

                #powerActions {
                    width: 100%;
                    display: grid;
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 0.5rem;
                }

                #btnPopout {
                    grid-column: 1 / -1;
                }

                #consoleTools {
                    width: 100%;
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.5rem;
                }

                #consoleTools .btn {
                    flex: 1 1 calc(33.333% - 0.5rem);
                }

                .connection-toast {
                    left: 1rem;
                    right: 1rem;
                    min-width: auto;
                }

                .console-grid {
                    flex-direction: column;
                }

                .player-panel {
                    width: 100%;
                }
            }

            @media (max-width: 520px) {
                #powerActions {
                    grid-template-columns: 1fr;
                }

                #consoleTools .btn {
                    flex: 1 1 100%;
                }
            }

            /* Small adjustments */
            .btn-sm {
                padding: 0.25rem 0.75rem;
                font-size: 0.85rem;
            }

            #wsStatusBadge {
                margin-left: auto;
                margin-right: 0.5rem;
            }
        </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>

<body data-turbo="false"> <%- include ('../partials/error-modal') %>
<%
const consoleShortcuts = [
    { action: 'Focus command input', keys: 'Ctrl + K' },
    { action: 'Send command', keys: 'Ctrl + Enter' },
    { action: 'Clear console output', keys: 'Ctrl + L' },
    { action: 'Restart server', keys: 'Ctrl + Shift + R' },
    { action: 'Start/Stop server', keys: 'Ctrl + Shift + S' }
];
%>
        <div class="wrapper">
            <!-- Sidebar -->
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-content">
                    <%- include('../partials/server-sidebar', { server, active: 'console' , settings }) %>
                </div>
            </nav>

            <!-- Main Content -->
            <div class="content">
                <!-- Top Navbar -->
                <div class="top-navbar">
                    <button id="sidebarToggle" class="navbar-toggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="server-info">
                        <h1 class="server-name">
                            <%= server.name %>
                        </h1>
                    </div>
                    <div class="top-navbar-right">
                        <% if (Number(server.ownerId) === Number(user && user.id)) { %>
                            <a href="/user/server/<%= server.containerId %>/edit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-pencil-square me-1"></i>Edit Details
                            </a>
                        <% } %>
                        <% if (user && user.isAdmin) { %>
                            <a href="/admin/servers/<%= server.containerId %>/manage" class="btn btn-outline-info btn-sm">
                                <i class="bi bi-gear me-1"></i>Admin Manage
                            </a>
                        <% } %>
                    </div>
                </div>

                <!-- Terminal Wrapper -->
                <div class="terminal-wrapper">
                    <!-- Connection Toast (moved inside but absolute positioned) -->
                    <div id="connectionAlert" class="connection-toast d-none">
                        <div class="toast-icon">
                            <i class="bi bi-wifi-off"></i>
                        </div>
                        <div class="toast-content">
                            <h5>Connection Lost</h5>
                            <p>The server node is currently unreachable. Controls are disabled until connection is
                                restored.
                            </p>
                        </div>
                    </div>

                    <div class="console-grid">
                        <!-- Terminal Container -->
                        <div class="terminal-container">
                        <div class="terminal-header">
                            <div class="d-flex align-items-center">
                                <span class="terminal-title">
                                    <i class="bi bi-terminal"></i> [<%= server.name %>] Console
                                </span>
                                <span id="statusBadge" class="status-badge status-<%= server.status %>" style="margin-left: 0.75rem;">
                                    <span class="status-dot"></span>
                                    <span id="statusText">
                                        <%= server.status.toUpperCase() %>
                                    </span>
                                </span>
                                <button id="toggleConsoleInfo" class="btn btn-outline-secondary btn-sm ms-2" type="button">
                                    <i class="bi bi-info-circle"></i>
                                </button>
                            </div>
                            <div class="terminal-controls">
                                <span id="wsStatusBadge" class="badge bg-secondary" title="Panel status">
                                    <i class="bi bi-arrow-repeat"></i> Connecting...
                                </span>
                                <div id="consoleTools" class="d-flex gap-2">
                                    <button id="btnFontMinus" class="btn btn-outline-secondary btn-sm" title="Font size -">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>
                                    <button id="btnFontPlus" class="btn btn-outline-secondary btn-sm" title="Font size +">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                    <button id="btnClear" class="btn btn-outline-secondary btn-sm" title="Clear console">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm" title="Keyboard shortcuts" data-shortcuts-modal="consoleShortcutsModal">
                                        <i class="bi bi-keyboard"></i>
                                    </button>
                                </div>
                                <div id="powerActions" class="d-flex gap-2">
                                    <button id="btnPopout" class="btn btn-outline-secondary btn-sm"
                                        data-server-id="<%= server.containerId %>">
                                        <i class="bi bi-box-arrow-up-right"></i> Popout
                                    </button>
                                    <button id="btnStart" class="btn btn-success btn-sm">
                                        <i class="bi bi-play-fill"></i> Start
                                    </button>
                                    <button id="btnRestart" class="btn btn-warning btn-sm">
                                        <i class="bi bi-arrow-clockwise"></i> Restart
                                    </button>
                                    <button id="btnStop"
                                        class="btn btn-danger btn-sm <%= server.status === 'stopping' ? 'd-none' : '' %>">
                                        <i class="bi bi-stop-fill"></i> Stop
                                    </button>
                                    <button id="btnKill"
                                        class="btn btn-danger btn-sm <%= server.status === 'stopping' ? '' : 'd-none' %>">
                                        <i class="bi bi-lightning-fill"></i> Kill
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div id="consoleInfoBar" class="console-info d-none">
                            <% if (server.description) { %>
                                <div class="info-pill"><span class="info-label">Description</span><span><%= server.description %></span></div>
                            <% } %>
                            <% if (user && user.isAdmin) { %>
                                <div class="info-pill"><span class="info-label">Owner</span><span>@<%= server.owner && server.owner.username ? server.owner.username : 'unknown' %></span></div>
                            <% } %>
                            <% if (server.allocation && (server.allocation.alias || server.allocation.ip)) { %>
                                <div class="info-pill"><span class="info-label">Address</span><span><%= server.allocation.alias || server.allocation.ip %>:<%= server.allocation.port %></span></div>
                            <% } %>
                        </div>
                        <div id="terminal"></div>
                        <div class="terminal-footer">
                            <% if (canUseMacros && Array.isArray(commandMacros) && commandMacros.length > 0) { %>
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    <select id="macroSelect" class="form-select form-select-sm bg-dark text-light border-secondary" style="max-width: 340px;">
                                        <option value="">Select macro...</option>
                                        <% commandMacros.forEach((macro) => { %>
                                            <option value="<%= macro.command %>"><%= macro.name %> - <%= macro.command %></option>
                                        <% }); %>
                                    </select>
                                    <button id="btnRunMacro" class="btn btn-outline-info btn-sm" type="button">
                                        <i class="bi bi-play-fill me-1"></i>Run Macro
                                    </button>
                                    <a href="/server/<%= server.containerId %>/macros" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-lightning-charge me-1"></i>Manage Macros
                                    </a>
                                </div>
                            <% } %>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="text" id="consoleInput" class="form-control"
                                    placeholder="Type a command...">
                            </div>
                        </div>
                        </div>

                        <% if (isMinecraftServer && canViewMinecraft) { %>
                            <aside class="player-panel" id="playerPanel">
                                <div class="player-panel-header">
                                    <div class="player-panel-title">Online Players</div>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" id="playerPanelRefreshBtn">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </div>
                                <div class="player-panel-body" id="playerPanelList">
                                    <div class="text-secondary small">Loading players...</div>
                                </div>
                                <div class="player-panel-footer">
                                    <span id="playerPanelCount">0 online</span>
                                    <span class="text-muted">Minecraft</span>
                                </div>
                            </aside>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <% if (showMinecraftEulaModal) { %>
            <!-- EULA Modal -->
            <div class="modal fade" id="eulaModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-white border-secondary">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title fw-bold">Minecraft EULA Agreement</h5>
                        </div>
                        <div class="modal-body">
                            <p>To run a Minecraft server, you must agree to Minecraft's End User License Agreement.</p>
                            <p class="small text-muted">By clicking "Agree", you explicitly accept the EULA found at <a
                                    href="https://www.minecraft.net/eula" target="_blank"
                                    class="text-info">minecraft.net/eula</a>.</p>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" id="btnAcceptEula" class="btn btn-primary w-100">I Agree</button>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <script src="https://cdn.jsdelivr.net/npm/xterm@5.2.1/lib/xterm.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.7.0/lib/xterm-addon-fit.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/xterm-addon-webgl@0.16.0/lib/xterm-addon-webgl.js"></script>

        <script>
            // Sidebar toggle functionality (for mobile and desktop)
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');

            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
                setTimeout(() => {
                    if (typeof fitAddon !== 'undefined') fitAddon.fit();
                }, 300);
            });

            // Close sidebar on outside click for mobile
            document.addEventListener('click', (e) => {
                if (window.innerWidth <= 768) {
                    if (!sidebar.contains(e.target) && !sidebarToggle.contains(e.target)) {
                        sidebar.classList.remove('show');
                    }
                }
            });

            const consoleInfoBar = document.getElementById('consoleInfoBar');
            const toggleConsoleInfo = document.getElementById('toggleConsoleInfo');
            toggleConsoleInfo?.addEventListener('click', () => {
                if (!consoleInfoBar) return;
                consoleInfoBar.classList.toggle('d-none');
            });

            // ================== Existing console functionality (preserved) ==================
            const serverId = '<%= server.id %>';
            const serverContainerId = '<%= server.containerId %>';
            const serverMemory = <%= server.memory || 0 %>;
            const serverDisk = <%= server.disk || 0 %>;
            let currentServerStatus = '<%= String(server.status || "stopped").toLowerCase() %>';
            const promptBrand = <%- JSON.stringify(String((settings && settings.brandName) ? settings.brandName : 'cpanel').toLowerCase()) %>;
            const showMinecraftEulaModal = <%- JSON.stringify(Boolean(showMinecraftEulaModal)) %>;
            const minecraftPanelEnabled = <%- JSON.stringify(Boolean(isMinecraftServer && canViewMinecraft)) %>;
            const minecraftStatusAddress = <%- JSON.stringify(minecraftStatusAddress || '') %>;
            const minecraftBedrockMode = <%- JSON.stringify(Boolean(minecraftBedrockMode)) %>;
            const minecraftActionPerms = {
                canKick: <%= minecraftActionPermissions && minecraftActionPermissions.canKick ? 'true' : 'false' %>,
                canBan: <%= minecraftActionPermissions && minecraftActionPermissions.canBan ? 'true' : 'false' %>,
                canOp: <%= minecraftActionPermissions && minecraftActionPermissions.canOp ? 'true' : 'false' %>,
                canDeop: <%= minecraftActionPermissions && minecraftActionPermissions.canDeop ? 'true' : 'false' %>,
                canTempban: <%= minecraftActionPermissions && minecraftActionPermissions.canTempban ? 'true' : 'false' %>,
                canTeleport: <%= minecraftActionPermissions && minecraftActionPermissions.canTeleport ? 'true' : 'false' %>
            };
            const eulaModalEl = showMinecraftEulaModal ? document.getElementById('eulaModal') : null;
            const eulaModalInstance = eulaModalEl && window.bootstrap ? bootstrap.Modal.getOrCreateInstance(eulaModalEl) : null;

            let connectorOnline = true;

            const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (ch) => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#39;'
            }[ch]));

            const showConsoleStatus = (message) => {
                if (window.showStatusModal) {
                    window.showStatusModal(message, 'info');
                    return;
                }
                console.log(message);
            };

            const dispatchMinecraftAction = (action, player, extra = {}) => {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/server/${serverContainerId}/minecraft/configs`;
                form.setAttribute('data-turbo', 'false');

                const appendInput = (name, value) => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = name;
                    input.value = value;
                    form.appendChild(input);
                };

                appendInput('action', action);
                appendInput('player', player);
                appendInput('bedrock', minecraftBedrockMode ? '1' : '0');
                if (extra.reason) appendInput('reason', extra.reason);
                if (extra.duration) appendInput('duration', extra.duration);
                if (extra.destination) appendInput('destination', extra.destination);

                document.body.appendChild(form);
                form.submit();
            };

            const promptMinecraftAction = (action, player) => {
                if (!player) return;
                const requiresReason = ['kick', 'ban', 'tempban'].includes(action);
                const requiresDuration = action === 'tempban';
                const requiresDestination = action === 'teleport';

                const extra = {};
                if (requiresDestination) {
                    const destination = window.prompt(`Teleport destination for ${player}:`, '');
                    if (destination === null) return;
                    const trimmed = String(destination || '').trim();
                    if (!trimmed) return showConsoleStatus('Destination is required.');
                    extra.destination = trimmed.slice(0, 64);
                }

                if (requiresDuration) {
                    const duration = window.prompt(`Tempban duration for ${player} (e.g. 1h):`, '');
                    if (duration === null) return;
                    const trimmed = String(duration || '').trim();
                    if (!trimmed) return showConsoleStatus('Duration is required.');
                    extra.duration = trimmed.slice(0, 16);
                }

                if (requiresReason) {
                    const reason = window.prompt(`Reason for ${action.toUpperCase()} ${player}:`, '');
                    if (reason === null) return;
                    const trimmed = String(reason || '').trim();
                    if (trimmed.length < 3) return showConsoleStatus('Reason must be at least 3 characters.');
                    extra.reason = trimmed.slice(0, 96);
                }

                dispatchMinecraftAction(action, player, extra);
            };

            const playerPanelList = document.getElementById('playerPanelList');
            const playerPanelCount = document.getElementById('playerPanelCount');
            const playerPanelRefreshBtn = document.getElementById('playerPanelRefreshBtn');

            const renderPlayerPanel = (players = []) => {
                if (!playerPanelList) return;
                if (!Array.isArray(players) || players.length === 0) {
                    playerPanelList.innerHTML = '<div class="text-secondary small">No players online.</div>';
                    if (playerPanelCount) playerPanelCount.textContent = '0 online';
                    return;
                }

                if (playerPanelCount) playerPanelCount.textContent = `${players.length} online`;
                playerPanelList.innerHTML = players.map((entry) => {
                    const name = escapeHtml(entry.name || '');
                    const head = escapeHtml(entry.headUrl || '');
                    return `
                        <div class="player-card">
                            <div class="d-flex align-items-center gap-2">
                                <img src="${head}" alt="Head" onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='https://minotar.net/avatar/Steve/40';}else{this.onerror=null;}">
                                <div class="player-name">${name}</div>
                            </div>
                            <div class="player-actions">
                                <button class="btn btn-outline-success btn-sm" data-action="op" data-player="${name}" ${!minecraftActionPerms.canOp ? 'disabled' : ''}>OP</button>
                                <button class="btn btn-outline-warning btn-sm" data-action="deop" data-player="${name}" ${!minecraftActionPerms.canDeop ? 'disabled' : ''}>DEOP</button>
                                <button class="btn btn-outline-light btn-sm" data-action="kick" data-player="${name}" ${!minecraftActionPerms.canKick ? 'disabled' : ''}>Kick</button>
                                <button class="btn btn-outline-info btn-sm" data-action="teleport" data-player="${name}" ${!minecraftActionPerms.canTeleport ? 'disabled' : ''}>TP</button>
                                <button class="btn btn-outline-danger btn-sm" data-action="ban" data-player="${name}" ${!minecraftActionPerms.canBan ? 'disabled' : ''}>Ban</button>
                                <button class="btn btn-outline-danger btn-sm" data-action="tempban" data-player="${name}" ${!minecraftActionPerms.canTempban ? 'disabled' : ''}>Temp</button>
                            </div>
                        </div>
                    `;
                }).join('');
            };

            const refreshPlayerPanel = async () => {
                if (!minecraftPanelEnabled) return;
                if (!playerPanelList) return;
                playerPanelList.innerHTML = '<div class="text-secondary small">Refreshing players...</div>';
                try {
                    const response = await fetch(`/server/${serverContainerId}/minecraft/configs/status?bedrock=${minecraftBedrockMode ? '1' : '0'}`);
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.error || 'Failed to refresh players.');
                    }
                    const status = payload.status || {};
                    renderPlayerPanel(status.playersList || []);
                } catch (error) {
                    playerPanelList.innerHTML = `<div class="text-secondary small">${escapeHtml(error.message || 'Failed to refresh players.')}</div>`;
                }
            };

            if (minecraftPanelEnabled) {
                refreshPlayerPanel();
                if (playerPanelRefreshBtn) {
                    playerPanelRefreshBtn.addEventListener('click', refreshPlayerPanel);
                }
                playerPanelList?.addEventListener('click', (event) => {
                    const target = event.target;
                    if (!target || !target.dataset) return;
                    const action = String(target.dataset.action || '');
                    const player = String(target.dataset.player || '');
                    if (!action || !player) return;
                    promptMinecraftAction(action, player);
                });
                setInterval(refreshPlayerPanel, 30000);
            }

            const term = new Terminal({
                theme: {
                    background: '#0d0d10',
                    foreground: '#e1e1e6',
                    cursor: '#e1e1e6',
                    black: '#16161a',
                    red: '#ef4444',
                    green: '#10b981',
                    yellow: '#f59e0b',
                    blue: '#3b82f6',
                    magenta: '#8b5cf6',
                    cyan: '#06b6d4',
                    white: '#e1e1e6'
                },
                fontFamily: 'Menlo, Monaco, "Courier New", monospace',
                fontSize: 13,
                cursorBlink: true,
                scrollback: 1000,
                convertEol: true
            });
            let consoleFontSize = 13;

            const fitAddon = new FitAddon.FitAddon();
            term.loadAddon(fitAddon);
            term.open(document.getElementById('terminal'));

            try {
                const webglAddon = new WebglAddon.WebglAddon();
                webglAddon.onContextLoss(() => { webglAddon.dispose(); });
                term.loadAddon(webglAddon);
                console.log('xterm WebGL addon loaded successfully.');
            } catch (e) {
                console.warn('xterm WebGL addon could not load. Falling back to default renderer.', e);
            }

            fitAddon.fit();

            // WebSocket Manager Class for Robust Connection
            class ConsoleClient {
                constructor(url) {
                    this.url = url;
                    this.ws = null;
                    this.reconnectInterval = 1000;
                    this.maxReconnectInterval = 5000;
                    this.isExplicitDisconnect = false;
                    this.heartbeatTimer = null;
                }

                connect() {
                    this.isExplicitDisconnect = false;
                    this.ws = new WebSocket(this.url);
                    this.updateStatus('connecting');

                    this.ws.onopen = () => {
                        this.updateStatus('connected');
                        this.reconnectInterval = 1000; // Reset backoff
                        term.writeln('\x1b[1;32m[✓] Console stream connected.\x1b[0m');
                        this.startHeartbeat();
                    };

                    this.ws.onmessage = (event) => {
                        try {
                            const data = JSON.parse(event.data);
                            this.handleMessage(data);
                        } catch (e) {
                            console.error('Failed to parse WS message:', e);
                        }
                    };

                    this.ws.onclose = (e) => {
                        this.stopHeartbeat();
                        this.updateStatus('disconnected');
                        if (!this.isExplicitDisconnect) {
                            term.writeln('\x1b[1;33m[!] Connection lost. Reconnecting in ' + (this.reconnectInterval / 1000) + 's...\x1b[0m');
                            setTimeout(() => {
                                this.reconnectInterval = Math.min(this.reconnectInterval * 1.5, this.maxReconnectInterval);
                                this.connect();
                            }, this.reconnectInterval);
                        }
                    };

                    this.ws.onerror = (err) => {
                        console.error('WebSocket error:', err);
                        this.ws.close();
                    };
                }

                send(type, payload = {}) {
                    if (this.ws && this.ws.readyState === WebSocket.OPEN) {
                        this.ws.send(JSON.stringify({ type, ...payload }));
                    }
                }

                handleMessage(data) {
                    switch (data.type) {
                        case 'console_output':
                            const cleanOutput = this.scrubAnsi(data.output);
                            const mcStyledOutput = this.translateMinecraftFormatting(cleanOutput);
                            const styledOutput = this.translateAdventureFormatting(mcStyledOutput);
                            term.write(this.rewritePromptBrand(styledOutput));
                            break;
                        case 'server_status_update':
                            updateUIStatus(data.status);
                            break;
                        case 'connector_status':
                            updateConnectorStatus(data.online);
                            break;
                        case 'server_action_ack': {
                            const phase = String(data.phase || '').toLowerCase();
                            const actionType = String(data.actionType || 'action');
                            const text = String(data.message || '').trim() || `${actionType} ${phase}`;
                            if (phase === 'failed') {
                                term.writeln(`\x1b[1;31m[ACK] ${actionType}: ${text}\x1b[0m`);
                            } else if (phase === 'executed') {
                                term.writeln(`\x1b[1;32m[ACK] ${actionType}: ${text}\x1b[0m`);
                            } else {
                                term.writeln(`\x1b[1;34m[ACK] ${actionType}: ${text}\x1b[0m`);
                            }
                            break;
                        }
                        case 'resource_limits_result':
                            if (data.success) {
                                term.writeln('\x1b[1;32m[✓] Live resource limits were applied.\x1b[0m');
                            } else {
                                term.writeln(`\x1b[1;31m[!] Live resource apply failed: ${data.error || 'unknown error'}\x1b[0m`);
                            }
                            break;
                        case 'eula_status':
                            if (showMinecraftEulaModal && eulaModalInstance) {
                                if (data.accepted) {
                                    eulaModalInstance.hide();
                                } else {
                                    eulaModalInstance.show();
                                }
                            }
                            break;
                        case 'error':
                            term.writeln(`\x1b[1;31m[!] Error: ${data.message}\x1b[0m`);
                            break;
                    }
                }

                scrubAnsi(text) {
                    if (!text) return '';
                    return text.replace(/\\x1b/g, '\x1b');
                }

                translateMinecraftFormatting(text) {
                    if (!text || text.indexOf('§') === -1) return text || '';

                    const colorMap = {
                        '0': '\x1b[0m\x1b[30m',
                        '1': '\x1b[0m\x1b[34m',
                        '2': '\x1b[0m\x1b[32m',
                        '3': '\x1b[0m\x1b[36m',
                        '4': '\x1b[0m\x1b[31m',
                        '5': '\x1b[0m\x1b[35m',
                        '6': '\x1b[0m\x1b[33m',
                        '7': '\x1b[0m\x1b[37m',
                        '8': '\x1b[0m\x1b[90m',
                        '9': '\x1b[0m\x1b[94m',
                        'a': '\x1b[0m\x1b[92m',
                        'b': '\x1b[0m\x1b[96m',
                        'c': '\x1b[0m\x1b[91m',
                        'd': '\x1b[0m\x1b[95m',
                        'e': '\x1b[0m\x1b[93m',
                        'f': '\x1b[0m\x1b[97m'
                    };

                    const formatMap = {
                        'l': '\x1b[1m',
                        'm': '\x1b[9m',
                        'n': '\x1b[4m',
                        'o': '\x1b[3m',
                        'r': '\x1b[0m'
                    };

                    const isHex = (ch) => /[0-9a-f]/i.test(ch);
                    const longHexToAnsi = (hex) => {
                        const r = parseInt(hex.slice(0, 2), 16);
                        const g = parseInt(hex.slice(2, 4), 16);
                        const b = parseInt(hex.slice(4, 6), 16);
                        return `\x1b[0m\x1b[38;2;${r};${g};${b}m`;
                    };

                    let out = '';
                    let i = 0;
                    while (i < text.length) {
                        const ch = text[i];
                        if (ch !== '§' || i + 1 >= text.length) {
                            out += ch;
                            i += 1;
                            continue;
                        }

                        const codeRaw = text[i + 1];
                        const code = String(codeRaw || '').toLowerCase();

                        // Hex format: §x§R§R§G§G§B§B
                        if (code === 'x') {
                            if (i + 13 < text.length) {
                                let hex = '';
                                let validLongHex = true;
                                for (let n = 0; n < 6; n += 1) {
                                    const markerIdx = i + 2 + (n * 2);
                                    const digitIdx = markerIdx + 1;
                                    if (text[markerIdx] !== '§' || !isHex(text[digitIdx])) {
                                        validLongHex = false;
                                        break;
                                    }
                                    hex += text[digitIdx];
                                }
                                if (validLongHex) {
                                    out += longHexToAnsi(hex);
                                    i += 14;
                                    continue;
                                }
                            }

                            // Fallback hex format: §xRRGGBB
                            if (i + 7 < text.length) {
                                const compactHex = text.slice(i + 2, i + 8);
                                if (/^[0-9a-f]{6}$/i.test(compactHex)) {
                                    out += longHexToAnsi(compactHex);
                                    i += 8;
                                    continue;
                                }
                            }

                            // Unknown §x variant, strip control token.
                            i += 2;
                            continue;
                        }

                        // Alternate hex format: §#RRGGBB
                        if (code === '#' && i + 7 < text.length) {
                            const hashHex = text.slice(i + 2, i + 8);
                            if (/^[0-9a-f]{6}$/i.test(hashHex)) {
                                out += longHexToAnsi(hashHex);
                                i += 8;
                                continue;
                            }
                        }

                        if (colorMap[code]) {
                            out += colorMap[code];
                            i += 2;
                            continue;
                        }

                        if (formatMap[code]) {
                            out += formatMap[code];
                            i += 2;
                            continue;
                        }

                        // Ignore unsupported formatting code and keep parsing.
                        i += 2;
                    }

                    return out;
                }

                translateAdventureFormatting(text) {
                    if (!text || text.indexOf('<') === -1) return text || '';

                    const colorTags = {
                        'black': '\x1b[30m',
                        'dark_blue': '\x1b[34m',
                        'dark_green': '\x1b[32m',
                        'dark_aqua': '\x1b[36m',
                        'dark_red': '\x1b[31m',
                        'dark_purple': '\x1b[35m',
                        'gold': '\x1b[33m',
                        'gray': '\x1b[37m',
                        'grey': '\x1b[37m',
                        'dark_gray': '\x1b[90m',
                        'dark_grey': '\x1b[90m',
                        'blue': '\x1b[94m',
                        'green': '\x1b[92m',
                        'aqua': '\x1b[96m',
                        'red': '\x1b[91m',
                        'light_purple': '\x1b[95m',
                        'yellow': '\x1b[93m',
                        'white': '\x1b[97m'
                    };

                    const styleOn = {
                        'bold': '\x1b[1m',
                        'b': '\x1b[1m',
                        'italic': '\x1b[3m',
                        'i': '\x1b[3m',
                        'underlined': '\x1b[4m',
                        'underline': '\x1b[4m',
                        'u': '\x1b[4m',
                        'strikethrough': '\x1b[9m',
                        'st': '\x1b[9m',
                        'obfuscated': '\x1b[2m',
                        'obf': '\x1b[2m'
                    };

                    const styleOff = {
                        'bold': '\x1b[22m',
                        'b': '\x1b[22m',
                        'italic': '\x1b[23m',
                        'i': '\x1b[23m',
                        'underlined': '\x1b[24m',
                        'underline': '\x1b[24m',
                        'u': '\x1b[24m',
                        'strikethrough': '\x1b[29m',
                        'st': '\x1b[29m',
                        'obfuscated': '\x1b[22m',
                        'obf': '\x1b[22m'
                    };

                    const osc8Link = (url, label) => `\x1b]8;;${url}\x1b\\${label}\x1b]8;;\x1b\\`;
                    const hexToAnsi = (hex) => {
                        const r = parseInt(hex.slice(0, 2), 16);
                        const g = parseInt(hex.slice(2, 4), 16);
                        const b = parseInt(hex.slice(4, 6), 16);
                        return `\x1b[38;2;${r};${g};${b}m`;
                    };

                    // Common MiniMessage case: <link:url>https://... (without explicit </link>)
                    let input = text.replace(/<link:([^>\s]+)>([^\s<]+)/gi, (match, rawUrl, label) => {
                        const url = String(rawUrl || '').trim();
                        if (!url) return label || '';
                        return osc8Link(url, label || url);
                    });

                    let out = '';
                    let i = 0;
                    while (i < input.length) {
                        if (input[i] !== '<') {
                            out += input[i];
                            i += 1;
                            continue;
                        }

                        const end = input.indexOf('>', i + 1);
                        if (end === -1) {
                            out += input[i];
                            i += 1;
                            continue;
                        }

                        const rawTag = input.slice(i + 1, end).trim();
                        if (!rawTag) {
                            out += input[i];
                            i += 1;
                            continue;
                        }

                        const lowerTag = rawTag.toLowerCase();

                        if (lowerTag === 'reset' || lowerTag === 'r') {
                            out += '\x1b[0m';
                            i = end + 1;
                            continue;
                        }

                        if (lowerTag.startsWith('/')) {
                            const closeTag = lowerTag.slice(1).trim();
                            if (!closeTag) {
                                i = end + 1;
                                continue;
                            }

                            if (closeTag === 'reset' || closeTag === 'r') {
                                out += '\x1b[0m';
                                i = end + 1;
                                continue;
                            }
                            if (closeTag === 'link') {
                                out += '\x1b]8;;\x1b\\';
                                i = end + 1;
                                continue;
                            }
                            if (styleOff[closeTag]) {
                                out += styleOff[closeTag];
                                i = end + 1;
                                continue;
                            }
                            if (colorTags[closeTag] || /^#[0-9a-f]{6}$/i.test(closeTag)) {
                                out += '\x1b[39m';
                                i = end + 1;
                                continue;
                            }
                        } else {
                            if (lowerTag.startsWith('link:')) {
                                const rawUrl = rawTag.slice(rawTag.indexOf(':') + 1).trim();
                                if (rawUrl) out += `\x1b]8;;${rawUrl}\x1b\\`;
                                i = end + 1;
                                continue;
                            }
                            if (/^#[0-9a-f]{6}$/i.test(lowerTag)) {
                                out += hexToAnsi(lowerTag.slice(1));
                                i = end + 1;
                                continue;
                            }
                            if (colorTags[lowerTag]) {
                                out += colorTags[lowerTag];
                                i = end + 1;
                                continue;
                            }
                            if (styleOn[lowerTag]) {
                                out += styleOn[lowerTag];
                                i = end + 1;
                                continue;
                            }
                        }

                        // Unknown tag: keep text untouched.
                        out += input.slice(i, end + 1);
                        i = end + 1;
                    }

                    return out;
                }

                rewritePromptBrand(text) {
                    if (!text || !promptBrand) return text || '';
                    return text.replace(/@pterodactyl/gi, `@${promptBrand}`);
                }

                updateStatus(state) {
                    const badge = document.getElementById('wsStatusBadge');
                    if (!badge) return;

                    if (state === 'connected') {
                        badge.className = 'badge bg-success ms-2';
                        badge.innerHTML = '<i class="bi bi-hdd-network"></i> Connected';
                    } else if (state === 'connecting') {
                        badge.className = 'badge bg-warning text-dark ms-2';
                        badge.innerHTML = '<i class="bi bi-arrow-repeat"></i> Reconnecting...';
                    } else {
                        badge.className = 'badge bg-danger ms-2';
                        badge.innerHTML = '<i class="bi bi-hdd-network"></i> Disconnected';
                    }
                }

                startHeartbeat() {
                    this.stopHeartbeat();
                    this.heartbeatTimer = setInterval(() => {
                        this.send('ping');
                    }, 30000);
                }

                stopHeartbeat() {
                    if (this.heartbeatTimer) clearInterval(this.heartbeatTimer);
                }
            }


            // Persistent Status Polling
            let statusPollingTimer = null;
            const statusUrl = `/server/<%= server.containerId %>/status`;

            function startStatusCheck() {
                if (statusPollingTimer) return;
                console.log('Starting persistent status polling (5.5s)...');
                statusPollingTimer = setInterval(checkStatus, 5500);
            }

            async function checkStatus() {
                try {
                    const response = await fetch(statusUrl);
                    const data = await response.json();

                    if (data.online) {
                        if (!connectorOnline) {
                            console.log('Connector is back online (polling detected)');
                            updateConnectorStatus(true);
                        }
                    } else {
                        if (connectorOnline) {
                            console.log('Connector went offline (polling detected)');
                            updateConnectorStatus(false);
                        }
                    }
                } catch (err) {
                    console.error('Status check error:', err);
                    if (connectorOnline) {
                        updateConnectorStatus(false);
                    }
                }
            }

            // Initialize Client
            const wsToken = '<%= wsToken || "" %>';
            const finalWsUrl = window.location.protocol.replace('http', 'ws') + '//' + window.location.host + '/ws/server/<%= server.containerId %>?token=' + encodeURIComponent(wsToken);

            const client = new ConsoleClient(finalWsUrl);
            client.connect();
            startStatusCheck();

            // UI Event Listeners
            const consoleInput = document.getElementById('consoleInput');
            const macroSelect = document.getElementById('macroSelect');
            const btnRunMacro = document.getElementById('btnRunMacro');
            consoleInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter' && connectorOnline) {
                    const command = consoleInput.value;
                    if (command) {
                        client.send('console_input', { command });
                        consoleInput.value = '';
                    }
                }
            });

            const btnStart = document.getElementById('btnStart');
            const btnStop = document.getElementById('btnStop');
            const btnRestart = document.getElementById('btnRestart');
            const btnClear = document.getElementById('btnClear');

            document.addEventListener('keydown', (e) => {
                const isInput = document.activeElement && ['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName);
                const key = String(e.key || '').toLowerCase();

                if ((e.ctrlKey || e.metaKey) && key === 'k') {
                    e.preventDefault();
                    consoleInput?.focus();
                    return;
                }
                if ((e.ctrlKey || e.metaKey) && key === 'l') {
                    if (btnClear) {
                        e.preventDefault();
                        btnClear.click();
                    }
                    return;
                }
                if ((e.ctrlKey || e.metaKey) && key === 'enter') {
                    e.preventDefault();
                    if (!connectorOnline) return;
                    const command = consoleInput ? consoleInput.value : '';
                    if (command) {
                        client.send('console_input', { command });
                        if (consoleInput) consoleInput.value = '';
                    }
                    return;
                }
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && key === 'r') {
                    if (btnRestart && !btnRestart.disabled) {
                        e.preventDefault();
                        btnRestart.click();
                    }
                    return;
                }
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && key === 's') {
                    e.preventDefault();
                    const startVisible = btnStart && !btnStart.classList.contains('d-none');
                    const stopVisible = btnStop && !btnStop.classList.contains('d-none');
                    if (startVisible && btnStart && !btnStart.disabled) {
                        btnStart.click();
                    } else if (stopVisible && btnStop && !btnStop.disabled) {
                        btnStop.click();
                    }
                }
            });

            if (btnRunMacro && macroSelect) {
                btnRunMacro.addEventListener('click', () => {
                    if (!connectorOnline) {
                        term.writeln('\x1b[1;31m[!] Cannot run macro: connector is offline.\x1b[0m');
                        return;
                    }
                    const command = String(macroSelect.value || '').trim();
                    if (!command) return;
                    client.send('console_input', { command });
                    term.writeln(`\x1b[1;36m[*] Macro command sent: ${command}\x1b[0m`);
                });
            }

            const btnPopout = document.getElementById('btnPopout');
            if (btnPopout) {
                btnPopout.addEventListener('click', function () {
                    const srvId = this.getAttribute('data-server-id');
                    window.open(`/server/${srvId}?popout=true`, `console_popout_${srvId}`, 'width=900,height=600');
                });
            }

            const btnFontMinus = document.getElementById('btnFontMinus');
            const btnFontPlus = document.getElementById('btnFontPlus');

            function applyConsoleFontSize(nextSize) {
                const size = Math.max(10, Math.min(18, nextSize));
                consoleFontSize = size;
                term.options.fontSize = size;
                fitAddon.fit();
            }

            if (btnFontMinus) {
                btnFontMinus.addEventListener('click', () => applyConsoleFontSize(consoleFontSize - 1));
            }

            if (btnFontPlus) {
                btnFontPlus.addEventListener('click', () => applyConsoleFontSize(consoleFontSize + 1));
            }

            if (btnClear) {
                btnClear.addEventListener('click', () => term.clear());
            }

            document.getElementById('btnStart').addEventListener('click', () => sendPower('start'));
            document.getElementById('btnRestart').addEventListener('click', () => sendPower('restart'));
            document.getElementById('btnStop').addEventListener('click', function () {
                sendPower('stop');
                this.classList.add('d-none');
                document.getElementById('btnKill').classList.remove('d-none');
            });
            document.getElementById('btnKill').addEventListener('click', () => sendPower('kill'));

            const btnAcceptEula = document.getElementById('btnAcceptEula');
            if (btnAcceptEula) {
                btnAcceptEula.addEventListener('click', () => {
                    client.send('accept_eula');
                    if (eulaModalInstance) eulaModalInstance.hide();
                    term.writeln('\x1b[1;32m[*] EULA accepted! Please start your server now.\x1b[0m');
                });
            }

            function sendPower(action) {
                if (!connectorOnline) {
                    term.writeln('\x1b[1;31m[!] Cannot execute command: connector is offline.\x1b[0m');
                    return;
                }
                client.send('power_action', { action });
                term.writeln(`\x1b[1;33m[*] Sending ${action} command...\x1b[0m`);
            }

            function updateUIStatus(status) {
                const nextStatus = String(status || '').toLowerCase();
                const previousStatus = currentServerStatus;
                currentServerStatus = nextStatus;

                const badge = document.getElementById('statusBadge');
                const text = document.getElementById('statusText');
                badge.className = `status-badge status-${nextStatus}`;
                text.textContent = nextStatus.toUpperCase();

                // Clear terminal if server stops and was previously running/starting
                if (nextStatus === 'stopped' && previousStatus !== 'stopped') {
                    term.clear();
                }

                if (connectorOnline) {
                    const btnStart = document.getElementById('btnStart');
                    const btnRestart = document.getElementById('btnRestart');
                    const btnStop = document.getElementById('btnStop');
                    const btnKill = document.getElementById('btnKill');

                    if (nextStatus === 'running') {
                        btnStart.disabled = true;
                        btnRestart.disabled = false;
                        btnStop.disabled = false;
                        btnStop.classList.remove('d-none');
                        btnKill.disabled = false;
                        btnKill.classList.add('d-none');
                    } else if (nextStatus === 'stopping') {
                        btnStart.disabled = true;
                        btnRestart.disabled = true;
                        btnStop.disabled = true;
                        btnStop.classList.add('d-none');
                        btnKill.disabled = false;
                        btnKill.classList.remove('d-none');
                    } else {
                        btnStart.disabled = false;
                        btnRestart.disabled = true;
                        btnStop.disabled = true;
                        btnStop.classList.remove('d-none');
                        btnKill.disabled = true;
                        btnKill.classList.add('d-none');
                    }
                }

                if (previousStatus === nextStatus) return;

                if (nextStatus === 'running') {
                    term.writeln('\x1b[1;32m[✓] Server is now running.\x1b[0m');
                } else if (nextStatus === 'stopped') {
                    term.writeln('\x1b[1;31m[✗] Server has stopped.\x1b[0m');
                }
            }

            function updateConnectorStatus(online) {
                connectorOnline = online;
                const alert = document.getElementById('connectionAlert');
                const buttons = [
                    document.getElementById('btnStart'),
                    document.getElementById('btnRestart'),
                    document.getElementById('btnStop'),
                    document.getElementById('btnKill')
                ];
                const input = document.getElementById('consoleInput');

                if (online) {
                    alert.classList.add('d-none');
                    buttons.forEach(btn => btn.disabled = false);
                    input.disabled = false;
                } else {
                    alert.classList.remove('d-none');
                    buttons.forEach(btn => btn.disabled = true);
                    input.disabled = true;
                }
            }

            const handleResize = () => fitAddon.fit();
            window.addEventListener('resize', handleResize);

            let consoleRuntimeCleaned = false;
            function cleanupConsoleRuntime() {
                if (consoleRuntimeCleaned) return;
                consoleRuntimeCleaned = true;

                if (statusPollingTimer) {
                    clearInterval(statusPollingTimer);
                    statusPollingTimer = null;
                }

                try {
                    client.isExplicitDisconnect = true;
                    client.stopHeartbeat();
                    if (client.ws && (client.ws.readyState === WebSocket.OPEN || client.ws.readyState === WebSocket.CONNECTING)) {
                        client.ws.close(1000, 'Leaving console page');
                    }
                } catch (error) {
                    console.warn('Console cleanup warning:', error);
                }

                window.removeEventListener('resize', handleResize);
            }

            window.addEventListener('beforeunload', cleanupConsoleRuntime);
            document.addEventListener('turbo:before-cache', cleanupConsoleRuntime);
        </script>
        <%- include('../partials/shortcuts-modal', { shortcutsId: 'consoleShortcutsModal', shortcutsTitle: 'Console Shortcuts', shortcutsList: consoleShortcuts }) %>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API Keys <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root { --bg:#0f0f12; --panel:#121216; --border:#2d2d35; --text:#e1e1e6; --muted:#8b8b9a; --accent:#3b82f6; }
        body { background: var(--bg); color: var(--text); margin: 0; font-family: Inter, system-ui, -apple-system, sans-serif; height: 100vh; overflow: hidden; }
        .wrapper { display: flex; height: 100vh; overflow: hidden; }
        .sidebar { width: 260px; background: var(--panel); border-right: 1px solid var(--border); overflow-y: auto; }
        .sidebar.collapsed { margin-left: -260px; }
        .content { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        .top-navbar { background: var(--panel); border-bottom: 1px solid var(--border); padding: .75rem 1rem; display: flex; align-items: center; gap: .75rem; }
        .scroll-area { flex: 1; overflow-y: auto; padding: 1.25rem; }
        .cardx { background: var(--panel); border: 1px solid var(--border); border-radius: .8rem; }
        .text-muted-2 { color: var(--muted); }
        .btn-icon { background: transparent; border: 0; color: var(--muted); font-size: 1.2rem; }
        .table-dark { --bs-table-bg: transparent; }
        .permission-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: .4rem; }
        code { color: #93c5fd; }
    </style>
</head>
<body>
<div class="wrapper">
    <nav class="sidebar" id="sidebar">
        <div class="p-3">
            <%- include('../partials/server-sidebar', { server, active: 'api' }) %>
        </div>
    </nav>

    <main class="content">
        <header class="top-navbar">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">API Keys / <span class="text-muted-2"><%= server.name %></span></h1>
        </header>

        <section class="scroll-area">
            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <div class="cardx p-3 mb-3">
                <div class="small text-muted-2 text-uppercase mb-1">Owner</div>
                <div class="fw-semibold"><%= owner ? owner.username : 'Unknown' %></div>
                <div class="text-muted-2"><%= owner ? owner.email : '-' %></div>
            </div>

            <% if (freshToken && freshToken.token) { %>
            <div class="cardx p-3 mb-3 border border-success border-opacity-50">
                <h2 class="h6 mb-2 text-success">New API Key Generated</h2>
                <p class="small text-muted-2 mb-2">Copy this token now. For security reasons, it will not be shown again.</p>
                <div class="input-group">
                    <input class="form-control" id="freshApiToken" readonly value="<%= freshToken.token %>" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                    <button type="button" class="btn btn-outline-light" id="copyApiTokenBtn">Copy</button>
                </div>
            </div>
            <% } %>

            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-3">Active Keys</h2>
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Name</th>
                            <th>Token Prefix</th>
                            <th>Permissions</th>
                            <th>Last Used</th>
                            <th>Expires</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        <% if (!apiKeys || apiKeys.length === 0) { %>
                            <tr><td colspan="7" class="text-muted-2">No API keys created yet.</td></tr>
                        <% } else { apiKeys.forEach((entry) => { %>
                            <tr>
                                <td>
                                    <div class="fw-semibold"><%= entry.name %></div>
                                    <div class="small text-muted-2">Created <%= new Date(entry.createdAt).toLocaleString() %></div>
                                </td>
                                <td><code><%= entry.keyPrefixMasked %></code></td>
                                <td><code><%= Array.isArray(entry.permissions) ? entry.permissions.join(', ') : '' %></code></td>
                                <td>
                                    <% if (entry.lastUsedAt) { %>
                                        <div><%= new Date(entry.lastUsedAt).toLocaleString() %></div>
                                        <div class="small text-muted-2"><%= entry.lastUsedIp || '-' %></div>
                                    <% } else { %>
                                        <span class="text-muted-2">Never used</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (entry.expiresAt) { %>
                                        <%= new Date(entry.expiresAt).toLocaleString() %>
                                    <% } else { %>
                                        <span class="text-muted-2">Never</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (entry.active) { %>
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">active</span>
                                    <% } else { %>
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">inactive</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <% if (canManageApiKeys && entry.active) { %>
                                    <form method="POST" action="/server/<%= server.containerId %>/api-keys/<%= entry.id %>/revoke" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Revoke</button>
                                    </form>
                                    <% } else { %>
                                        <span class="text-muted-2">-</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <% if (canManageApiKeys) { %>
            <div class="cardx p-3">
                <h2 class="h6 mb-3">Create API Key</h2>
                <form method="POST" action="/server/<%= server.containerId %>/api-keys">
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small text-uppercase text-muted-2">Name</label>
                            <input name="name" class="form-control" required maxlength="120" placeholder="CI deploy key" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-uppercase text-muted-2">Expires At (optional)</label>
                            <input type="datetime-local" name="expiresAt" class="form-control" style="background:#18181d;border-color:#2d2d35;color:#e1e1e6;">
                        </div>
                    </div>

                    <label class="form-label small text-uppercase text-muted-2">Permissions</label>
                    <div class="permission-grid mb-3">
                        <% (apiPermissionCatalog || []).forEach((perm) => { %>
                        <label class="form-check" style="padding:.4rem .5rem;border:1px solid #2d2d35;border-radius:.5rem;background:#16161b;">
                            <input class="form-check-input" type="checkbox" name="permissions" value="<%= perm %>" <%= perm === 'server.view' ? 'checked' : '' %>>
                            <span class="form-check-label"><%= perm %></span>
                        </label>
                        <% }) %>
                    </div>

                    <button class="btn btn-primary" type="submit">Create API Key</button>
                </form>
            </div>
            <% } %>
        </section>
    </main>
</div>

<script>
    document.getElementById('sidebarToggle')?.addEventListener('click', function () {
        document.getElementById('sidebar')?.classList.toggle('collapsed');
    });

    document.getElementById('copyApiTokenBtn')?.addEventListener('click', async function () {
        const input = document.getElementById('freshApiToken');
        if (!input) return;
        try {
            await navigator.clipboard.writeText(input.value);
            this.textContent = 'Copied';
            setTimeout(() => { this.textContent = 'Copy'; }, 1200);
        } catch {
            input.focus();
            input.select();
            document.execCommand('copy');
            this.textContent = 'Copied';
            setTimeout(() => { this.textContent = 'Copy'; }, 1200);
        }
    });
</script>
</body>
</html>

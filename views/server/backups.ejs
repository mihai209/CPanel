<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Backups <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}
        .sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}
        .sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}
        .top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}
        .cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}
        .btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .badge-soft{background:#1c2430;color:#8fb7ff}
        .table-darkx{--bs-table-bg:#111218;--bs-table-color:#e1e1e6;--bs-table-border-color:#2d2d35}
        .text-mono{font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
        .backup-modal-overlay{
            position:fixed; inset:0; background:rgba(0,0,0,.65); display:none; align-items:center; justify-content:center; z-index:1080;
        }
        .backup-modal{
            width:min(520px,calc(100vw - 2rem)); background:#121216; border:1px solid #2d2d35; border-radius:.9rem; padding:1rem;
        }
    </style>
</head>
<body>
<%
    const drive = googleDriveState || {};
    const history = Array.isArray(backupHistory) ? backupHistory : [];
    const selectedInterval = Number.parseInt(intervalMinutes, 10) || 360;
    const intervalOptions = [15, 30, 60, 120, 180, 360, 720, 1440, 2880, 10080];
    const hasActiveJob = Boolean(activeJob);

    function fmtDate(raw) {
        if (!raw) return '-';
        try {
            return new Date(raw).toLocaleString();
        } catch {
            return String(raw);
        }
    }

    function fmtSize(bytes) {
        const value = Number(bytes || 0);
        if (!Number.isFinite(value) || value <= 0) return '-';
        const units = ['B', 'KB', 'MB', 'GB', 'TB'];
        let current = value;
        let idx = 0;
        while (current >= 1024 && idx < units.length - 1) {
            current /= 1024;
            idx += 1;
        }
        return `${current.toFixed(current >= 10 || idx === 0 ? 0 : 1)} ${units[idx]}`;
    }
%>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'backups' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Backups / <span class="text-secondary"><%= server.name %></span></h1>
        </header>

        <section class="scroll">
            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <div class="cardx p-3 mb-3">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                    <h2 class="h6 mb-0">Google Drive Status</h2>
                    <% if (canConnectGoogleDrive) { %>
                        <a href="<%= drive.connectUrl || '#' %>" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-google me-1"></i><%= drive.linked ? 'Reconnect Google Drive' : 'Connect Google Drive' %>
                        </a>
                    <% } %>
                </div>
                <div class="small text-secondary mb-2">Backup folder in Drive: <span class="text-mono"><%= server.name %></span></div>
                <div class="small text-secondary mb-2">Drive owner user ID: <span class="text-mono"><%= drive.ownerId || '-' %></span></div>
                <div class="small text-secondary mb-2">Backup upload mode: direct stream to Google Drive (no persistent local backup file).</div>
                <% if (!canConnectGoogleDrive && canManageBackups) { %>
                    <div class="small text-warning mb-2">Only the server owner can link/relink Google Drive for this server.</div>
                <% } %>
                <div class="mb-2">
                    <% if (drive.ready) { %>
                        <span class="badge bg-success">Ready</span>
                    <% } else { %>
                        <span class="badge bg-warning text-dark">Action Required</span>
                    <% } %>
                    <% if (drive.linked) { %><span class="badge badge-soft ms-1">Google linked</span><% } %>
                    <% if (drive.hasDriveScope) { %><span class="badge badge-soft ms-1">Drive scope granted</span><% } %>
                    <% if (drive.hasRefreshToken) { %><span class="badge badge-soft ms-1">Refresh token present</span><% } %>
                </div>
                <div class="text-secondary small"><%= drive.statusText || 'Unknown Google Drive state.' %></div>
            </div>

            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-3">Backup Controls</h2>
                <% if (!canManageBackups) { %>
                    <div class="alert alert-warning mb-0">You do not have permission to manage backups.</div>
                <% } else { %>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <form method="POST" action="/server/<%= server.containerId %>/backups/run" class="mb-0" id="manualBackupForm">
                            <button type="submit" class="btn btn-primary"
                                <%= hasActiveJob ? 'disabled' : '' %>>
                                <i class="bi bi-cloud-arrow-up me-1"></i>Run Backup Now
                            </button>
                        </form>
                        <% if (hasActiveJob) { %>
                            <span class="badge bg-info text-dark align-self-center">Job #<%= activeJob.id %> <%= activeJob.status %></span>
                        <% } %>
                        <% if (!drive.ready) { %>
                            <span class="badge bg-secondary align-self-center">Connect/authorize Google Drive first</span>
                        <% } %>
                    </div>

                    <form method="POST" action="/server/<%= server.containerId %>/backups/policy" class="row g-3 align-items-end" id="backupPolicyForm">
                        <div class="col-lg-4 col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="backupEnabled" name="enabled" <%= autoEnabled ? 'checked' : '' %>>
                                <label class="form-check-label" for="backupEnabled">Enable automatic backups</label>
                            </div>
                            <div class="small text-secondary">If enabled, old Drive backup file is deleted before uploading a new one.</div>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <label class="form-label">Interval</label>
                            <select class="form-select" name="intervalMinutes">
                                <% intervalOptions.forEach((value) => { %>
                                    <option value="<%= value %>" <%= selectedInterval === value ? 'selected' : '' %>>
                                        <%= value >= 60 ? (value % 60 === 0 ? `${value / 60} hour(s)` : `${value} minutes`) : `${value} minutes` %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-lg-4">
                            <div class="small text-secondary mb-2">Last auto/manual run: <%= fmtDate(policyLastRunAt) %></div>
                            <button type="submit" class="btn btn-outline-success w-100">Save Backup Policy</button>
                        </div>
                    </form>
                <% } %>
            </div>

            <div class="cardx p-3">
                <h2 class="h6 mb-3">Backup History</h2>
                <% if (!history.length) { %>
                    <div class="text-secondary">No backup entries yet.</div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-sm table-darkx align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th>Size</th>
                                    <th>Trigger</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% history.forEach((row) => { %>
                                    <tr>
                                        <td><%= row.id %></td>
                                        <td>
                                            <% if (row.status === 'completed') { %>
                                                <span class="badge bg-success">completed</span>
                                            <% } else if (row.status === 'failed') { %>
                                                <span class="badge bg-danger">failed</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary"><%= row.status || 'unknown' %></span>
                                            <% } %>
                                        </td>
                                        <td><%= fmtDate(row.createdAt) %></td>
                                        <td><%= fmtSize(row.sizeBytes) %></td>
                                        <td><span class="text-mono"><%= row.trigger || '-' %></span></td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2">
                                                <% if (row.webViewLink) { %>
                                                    <a class="btn btn-sm btn-outline-primary" href="<%= row.webViewLink %>" target="_blank" rel="noopener">File</a>
                                                <% } %>
                                                <% if (row.folderLink) { %>
                                                    <a class="btn btn-sm btn-outline-light" href="<%= row.folderLink %>" target="_blank" rel="noopener">Folder</a>
                                                <% } %>
                                                <% if (row.error) { %>
                                                    <span class="text-danger small"><%= row.error %></span>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </section>
    </main>
</div>

<div class="backup-modal-overlay" id="gdriveLinkModal" role="dialog" aria-modal="true" aria-labelledby="gdriveLinkModalTitle">
    <div class="backup-modal">
        <h3 class="h6 mb-2" id="gdriveLinkModalTitle">Google Drive Not Linked</h3>
        <p class="text-secondary mb-3" id="gdriveLinkModalBody">You need to link Google Drive before backup can continue.</p>
        <div class="d-flex flex-wrap gap-2 justify-content-end">
            <button type="button" class="btn btn-outline-light btn-sm" id="closeGdriveModalBtn">Close</button>
            <% if (canConnectGoogleDrive) { %>
                <a href="<%= drive.connectUrl || '#' %>" class="btn btn-primary btn-sm" id="connectGdriveModalBtn">
                    <i class="bi bi-google me-1"></i>Connect Google Drive
                </a>
            <% } %>
        </div>
    </div>
</div>

<script>
    document.getElementById('sidebarToggle')?.addEventListener('click',()=>document.getElementById('sidebar')?.classList.toggle('collapsed'));

    const googleDriveReady = <%= drive.ready ? 'true' : 'false' %>;
    const canConnectGoogleDrive = <%= canConnectGoogleDrive ? 'true' : 'false' %>;

    const modalEl = document.getElementById('gdriveLinkModal');
    const modalBodyEl = document.getElementById('gdriveLinkModalBody');
    const closeModalBtn = document.getElementById('closeGdriveModalBtn');
    const manualBackupForm = document.getElementById('manualBackupForm');
    const backupPolicyForm = document.getElementById('backupPolicyForm');
    const backupEnabledInput = document.getElementById('backupEnabled');

    function showGoogleModal(message) {
        if (!modalEl) return;
        if (modalBodyEl && message) modalBodyEl.textContent = message;
        modalEl.style.display = 'flex';
    }

    function closeGoogleModal() {
        if (!modalEl) return;
        modalEl.style.display = 'none';
    }

    closeModalBtn?.addEventListener('click', closeGoogleModal);
    modalEl?.addEventListener('click', (event) => {
        if (event.target === modalEl) closeGoogleModal();
    });

    manualBackupForm?.addEventListener('submit', (event) => {
        if (googleDriveReady) return;
        event.preventDefault();
        const message = canConnectGoogleDrive
            ? 'Link your Google account with Drive permission, then run backup again.'
            : 'Only the server owner can link Google Drive for this server. Ask the owner to connect it.';
        showGoogleModal(message);
    });

    backupPolicyForm?.addEventListener('submit', (event) => {
        const wantsAuto = Boolean(backupEnabledInput && backupEnabledInput.checked);
        if (!wantsAuto || googleDriveReady) return;
        event.preventDefault();
        const message = canConnectGoogleDrive
            ? 'Enable auto-backup after linking Google Drive. Connect Google, then save policy again.'
            : 'Auto-backup needs a linked Google Drive account from the server owner.';
        showGoogleModal(message);
    });
</script>
</body>
</html>

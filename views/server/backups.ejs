<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SFTP Backup <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}.btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .form-control[readonly] { background:#18181d; border-color:#2d2d35; color:#e1e1e6; }
        .copy-btn { white-space: nowrap; }
        code { color: #93c5fd; }
    </style>
</head>
<body>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'backups' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">SFTP Backup / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <% const sftpInfo = sftpDetails || {}; %>
            <% const sftpHostValue = sftpInfo.host || ''; %>
            <% const sftpPortValue = sftpInfo.port || ''; %>
            <% const sftpUserValue = sftpInfo.username || ''; %>
            <% const sftpFeatureEnabledValue = (typeof sftpFeatureEnabled === 'undefined') ? true : Boolean(sftpFeatureEnabled); %>
            <% const sftpAvailable = Boolean(sftpInfo.available); %>
            <% const sftpCommand = sftpAvailable ? `sftp -P ${sftpPortValue} ${sftpUserValue}@${sftpHostValue}` : ''; %>

            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-2">Backup Mode Changed</h2>
                <p class="text-secondary mb-2">Built-in backup jobs were replaced. Use SFTP to create, store, and download your backup archives.</p>
                <ul class="text-secondary mb-0">
                    <li>Use your panel password for SFTP authentication.</li>
                    <li>If server is suspended, SFTP access is blocked.</li>
                    <li>Archive files manually (zip/tar.gz) and keep them in a dedicated backup folder.</li>
                </ul>
            </div>

            <div class="cardx p-3 mb-3">
                <h2 class="h6 mb-3">SFTP Connection</h2>
                <% if (!sftpAvailable) { %>
                    <div class="alert alert-warning mb-0">
                        <%= sftpFeatureEnabledValue
                            ? 'SFTP is currently unavailable for this server. Check connector host/port configuration or suspension status.'
                            : 'SFTP is currently disabled by panel admin.' %>
                    </div>
                <% } else { %>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small">Host</label>
                        <div class="input-group">
                            <input id="sftpHostInput" class="form-control" type="text" readonly value="<%= sftpHostValue %>">
                            <button class="btn btn-outline-light copy-btn" type="button" data-copy-target="sftpHostInput"><i class="bi bi-copy"></i></button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Port</label>
                        <div class="input-group">
                            <input id="sftpPortInput" class="form-control" type="text" readonly value="<%= sftpPortValue %>">
                            <button class="btn btn-outline-light copy-btn" type="button" data-copy-target="sftpPortInput"><i class="bi bi-copy"></i></button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Username</label>
                        <div class="input-group">
                            <input id="sftpUserInput" class="form-control" type="text" readonly value="<%= sftpUserValue %>">
                            <button class="btn btn-outline-light copy-btn" type="button" data-copy-target="sftpUserInput"><i class="bi bi-copy"></i></button>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label small">Password</label>
                        <input class="form-control" type="text" readonly value="<%= sftpInfo.passwordHint || 'Use your account password from this panel.' %>">
                    </div>
                    <div class="col-12">
                        <label class="form-label small">Quick Command</label>
                        <div class="input-group">
                            <input id="sftpCommandInput" class="form-control" type="text" readonly value="<%= sftpCommand %>">
                            <button class="btn btn-outline-primary copy-btn" type="button" data-copy-target="sftpCommandInput">Copy</button>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>

            <div class="cardx p-3">
                <h2 class="h6 mb-3">Recommended Workflow</h2>
                <ol class="text-secondary mb-3">
                    <li>Connect with SFTP.</li>
                    <li>Create a folder like <code>/backups</code> or <code>/backup-archives</code>.</li>
                    <li>Generate archive files from your world/plugins/config data.</li>
                    <li>Download archives to local/offsite storage.</li>
                    <li>Keep multiple restore points and naming convention by date.</li>
                </ol>
                <div class="small text-secondary">Tip: for large files, use an SFTP client like FileZilla/WinSCP and verify file sizes after transfer.</div>
            </div>
        </section>
    </main>
</div>
<script>
    document.getElementById('sidebarToggle')?.addEventListener('click',()=>document.getElementById('sidebar')?.classList.toggle('collapsed'));

    function copyFromInput(inputId, button) {
        const input = document.getElementById(inputId);
        if (!input) return;
        const value = String(input.value || '');
        if (!value) return;
        navigator.clipboard.writeText(value).then(() => {
            const old = button.innerHTML;
            button.innerHTML = '<i class="bi bi-check2"></i>';
            setTimeout(() => { button.innerHTML = old; }, 1000);
        }).catch(() => {});
    }

    document.querySelectorAll('[data-copy-target]').forEach((button) => {
        button.addEventListener('click', () => copyFromInput(button.getAttribute('data-copy-target'), button));
    });
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Debug Logs <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper { display:flex; height:100vh; }
        .sidebar { width:260px; background:#121216; border-right:1px solid #2d2d35; overflow-y:auto; }
        .sidebar.collapsed { margin-left:-260px; }
        .content { flex:1; display:flex; flex-direction:column; min-width:0; }
        .top { background:#121216; border-bottom:1px solid #2d2d35; padding:.75rem 1rem; display:flex; align-items:center; gap:.75rem; }
        .scroll { flex:1; overflow:auto; padding:1rem; }
        .cardx { background:#121216; border:1px solid #2d2d35; border-radius:.8rem; }
        .btn-icon { background:transparent; border:0; color:#8b8b9a; font-size:1.2rem; }
        .log-box {
            background:#0a0a0d;
            border:1px solid #2d2d35;
            border-radius:.6rem;
            padding:.75rem;
            color:#cfd4dc;
            white-space:pre-wrap;
            word-break:break-word;
            font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
            font-size:.82rem;
            max-height:360px;
            overflow:auto;
        }
        .muted { color:#8b8b9a; }
        .mirror-check-row-ok { color:#86efac; }
        .mirror-check-row-bad { color:#fca5a5; }
        .mirror-check-table code {
            color: #c4b5fd;
            font-size: .78rem;
        }
    </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>
<body>

<%- include('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'debuglogs' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Debug Logs / <span class="text-secondary"><%= server.name %></span></h1>
            <div class="ms-auto d-flex gap-2">
                <% if (canFixPermissions) { %>
                    <form method="POST" action="/server/<%= server.containerId %>/fix-permissions" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-warning">Fix Permissions</button>
                    </form>
                <% } %>
                <button id="runDependencyMirrorCheckBtn" type="button" class="btn btn-sm btn-outline-info">
                    <i class="bi bi-diagram-3 me-1"></i>Dependency Mirror Check
                </button>
                <a class="btn btn-sm btn-outline-light" href="/server/<%= server.containerId %>">Console</a>
                <a class="btn btn-sm btn-primary" href="/server/<%= server.containerId %>/debug-logs">Refresh</a>
            </div>
        </header>
        <section class="scroll">
            <% if (success) { %>
                <div class="alert alert-success"><%= success %></div>
            <% } %>
            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <div id="dependencyMirrorCheckCard" class="cardx p-3 mb-3 d-none">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                    <h2 class="h6 mb-0">Dependency Mirror Check</h2>
                    <span id="dependencyMirrorCheckStatus" class="badge text-bg-secondary">Idle</span>
                </div>
                <div id="dependencyMirrorCheckSummary" class="small muted mb-2">Run a check to validate mirror DNS/connectivity and container network state.</div>
                <div class="row g-2 mb-2">
                    <div class="col-md-4">
                        <div class="cardx p-2">
                            <div class="small muted">Container</div>
                            <div id="dependencyMirrorContainerState" class="fw-semibold">-</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cardx p-2">
                            <div class="small muted">Network</div>
                            <div id="dependencyMirrorNetworkState" class="fw-semibold">-</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cardx p-2">
                            <div class="small muted">Reachable Mirrors</div>
                            <div id="dependencyMirrorReachableState" class="fw-semibold">-</div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive mirror-check-table">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Host</th>
                                <th>DNS</th>
                                <th>Connect</th>
                                <th>Latency</th>
                                <th>Error</th>
                            </tr>
                        </thead>
                        <tbody id="dependencyMirrorCheckResultsBody">
                            <tr><td colspan="5" class="muted">No check run yet.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <% if (!logs || logs.length === 0) { %>
                <div class="cardx p-4">
                    <h2 class="h6 mb-2">No debug entries yet</h2>
                    <p class="mb-0 muted">When the server crashes, gets killed, or connector reports startup/runtime errors, snapshots will appear here.</p>
                </div>
            <% } else { %>
                <div class="d-flex flex-column gap-3">
                    <% logs.forEach((entry) => { %>
                        <article class="cardx p-3">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                <span class="badge text-bg-<%= entry.severity %>"><%= entry.action %></span>
                                <span class="muted"><i class="bi bi-clock-history me-1"></i><%= new Date(entry.createdAt).toLocaleString() %></span>
                                <% if (entry.metadata && entry.metadata.powerIntent) { %>
                                    <span class="badge text-bg-secondary">Intent: <%= entry.metadata.powerIntent %></span>
                                <% } %>
                                <% if (entry.metadata && entry.metadata.state && entry.metadata.state.exitCode !== undefined) { %>
                                    <span class="badge text-bg-dark border">ExitCode: <%= entry.metadata.state.exitCode %></span>
                                <% } %>
                                <% if (entry.metadata && entry.metadata.state && entry.metadata.state.oomKilled === true) { %>
                                    <span class="badge text-bg-danger">OOMKilled</span>
                                <% } %>
                                <% if (entry.metadata && entry.metadata.logSource) { %>
                                    <span class="badge text-bg-secondary">Logs: <%= entry.metadata.logSource %></span>
                                <% } %>
                            </div>

                            <% if (entry.metadata && entry.metadata.message) { %>
                                <div class="mb-2"><strong>Message:</strong> <span class="muted"><%= entry.metadata.message %></span></div>
                            <% } %>
                            <% if (entry.metadata && entry.metadata.error) { %>
                                <div class="mb-2"><strong>Error:</strong> <span class="text-danger"><%= entry.metadata.error %></span></div>
                            <% } %>

                            <% if (entry.logTail) { %>
                                <div class="log-box"><%= entry.logTail %></div>
                            <% } else { %>
                                <div class="muted">No console tail was available for this event.</div>
                            <% } %>
                        </article>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>
</div>
<script>
document.getElementById('sidebarToggle')?.addEventListener('click', () => document.getElementById('sidebar')?.classList.toggle('collapsed'));

(() => {
    const runButton = document.getElementById('runDependencyMirrorCheckBtn');
    const card = document.getElementById('dependencyMirrorCheckCard');
    const statusBadge = document.getElementById('dependencyMirrorCheckStatus');
    const summary = document.getElementById('dependencyMirrorCheckSummary');
    const containerState = document.getElementById('dependencyMirrorContainerState');
    const networkState = document.getElementById('dependencyMirrorNetworkState');
    const reachableState = document.getElementById('dependencyMirrorReachableState');
    const resultBody = document.getElementById('dependencyMirrorCheckResultsBody');
    if (!runButton || !card || !statusBadge || !summary || !resultBody) return;

    function setStatus(label, badgeClass) {
        statusBadge.className = `badge ${badgeClass || 'text-bg-secondary'}`;
        statusBadge.textContent = label;
    }

    function renderRows(rows) {
        if (!Array.isArray(rows) || rows.length === 0) {
            resultBody.innerHTML = '<tr><td colspan="5" class="muted">No mirror hosts were tested.</td></tr>';
            return;
        }
        const escapeHtml = (value) => String(value === undefined || value === null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        resultBody.innerHTML = rows.map((row) => {
            const ok = Boolean(row && row.reachable);
            const dns = Boolean(row && row.dnsResolved);
            const latency = Number.isFinite(Number(row && row.latencyMs)) ? `${Number(row.latencyMs)} ms` : '-';
            const error = String(row && row.error || '').trim();
            return `
                <tr class="${ok ? 'mirror-check-row-ok' : 'mirror-check-row-bad'}">
                    <td><code>${escapeHtml(String(row && row.host || '-'))}</code></td>
                    <td>${dns ? 'OK' : 'Fail'}</td>
                    <td>${ok ? 'OK' : 'Fail'}</td>
                    <td>${latency}</td>
                    <td class="text-break">${escapeHtml(error || '-')}</td>
                </tr>
            `;
        }).join('');
    }

    async function runCheck() {
        card.classList.remove('d-none');
        setStatus('Running', 'text-bg-info');
        summary.textContent = 'Running dependency mirror diagnostics...';
        runButton.disabled = true;
        runButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Checking';

        try {
            const response = await fetch('/server/<%= server.containerId %>/debug-logs/dependency-mirror-check', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: '{}'
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || !payload.success) {
                const message = String(payload && payload.error || `Request failed (${response.status}).`);
                setStatus('Failed', 'text-bg-danger');
                summary.textContent = message;
                renderRows(payload && payload.mirrors);
                containerState.textContent = '-';
                networkState.textContent = '-';
                reachableState.textContent = '-';
                return;
            }

            const container = payload.container || {};
            const summaryData = payload.summary || {};
            const networks = Array.isArray(container.networks) ? container.networks : [];
            const reachable = Number.parseInt(summaryData.reachableMirrors, 10) || 0;
            const total = Number.parseInt(summaryData.totalMirrors, 10) || 0;

            setStatus('Completed', 'text-bg-success');
            summary.textContent = String(summaryData.likelyRootCause || 'Dependency mirror diagnostics completed.');
            containerState.textContent = container.exists
                ? (container.running ? `Running (${String(container.status || 'running')})` : `Stopped (${String(container.status || 'stopped')})`)
                : 'Missing';
            networkState.textContent = networks.length > 0
                ? `${networks.join(', ')}`
                : 'No network attached';
            reachableState.textContent = `${reachable} / ${total}`;
            renderRows(payload.mirrors);
        } catch (error) {
            setStatus('Failed', 'text-bg-danger');
            summary.textContent = String(error && error.message || 'Dependency mirror check failed.');
            containerState.textContent = '-';
            networkState.textContent = '-';
            reachableState.textContent = '-';
            renderRows([]);
        } finally {
            runButton.disabled = false;
            runButton.innerHTML = '<i class="bi bi-diagram-3 me-1"></i>Dependency Mirror Check';
        }
    }

    runButton.addEventListener('click', runCheck);
})();
</script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

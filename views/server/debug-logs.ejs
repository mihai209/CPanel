<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Debug Logs <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper { display:flex; height:100vh; }
        .sidebar { width:260px; background:#121216; border-right:1px solid #2d2d35; overflow-y:auto; }
        .sidebar.collapsed { margin-left:-260px; }
        .content { flex:1; display:flex; flex-direction:column; min-width:0; }
        .top { background:#121216; border-bottom:1px solid #2d2d35; padding:.75rem 1rem; display:flex; align-items:center; gap:.75rem; }
        .scroll { flex:1; overflow:auto; padding:1rem; }
        .cardx { background:#121216; border:1px solid #2d2d35; border-radius:.8rem; }
        .btn-icon { background:transparent; border:0; color:#8b8b9a; font-size:1.2rem; }
        .log-box {
            background:#0a0a0d;
            border:1px solid #2d2d35;
            border-radius:.6rem;
            padding:.75rem;
            color:#cfd4dc;
            white-space:pre-wrap;
            word-break:break-word;
            font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
            font-size:.82rem;
            max-height:360px;
            overflow:auto;
        }
        .muted { color:#8b8b9a; }
    </style>
</head>
<body>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'debuglogs' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Debug Logs / <span class="text-secondary"><%= server.name %></span></h1>
            <div class="ms-auto d-flex gap-2">
                <a class="btn btn-sm btn-outline-light" href="/server/<%= server.containerId %>">Console</a>
                <a class="btn btn-sm btn-primary" href="/server/<%= server.containerId %>/debug-logs">Refresh</a>
            </div>
        </header>
        <section class="scroll">
            <% if (!logs || logs.length === 0) { %>
                <div class="cardx p-4">
                    <h2 class="h6 mb-2">No debug entries yet</h2>
                    <p class="mb-0 muted">When the server crashes, gets killed, or connector reports startup/runtime errors, snapshots will appear here.</p>
                </div>
            <% } else { %>
                <div class="d-flex flex-column gap-3">
                    <% logs.forEach((entry) => { %>
                        <article class="cardx p-3">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                <span class="badge text-bg-<%= entry.severity %>"><%= entry.action %></span>
                                <span class="muted"><i class="bi bi-clock-history me-1"></i><%= new Date(entry.createdAt).toLocaleString() %></span>
                                <% if (entry.metadata && entry.metadata.powerIntent) { %>
                                    <span class="badge text-bg-secondary">Intent: <%= entry.metadata.powerIntent %></span>
                                <% } %>
                                <% if (entry.metadata && entry.metadata.state && entry.metadata.state.exitCode !== undefined) { %>
                                    <span class="badge text-bg-dark border">ExitCode: <%= entry.metadata.state.exitCode %></span>
                                <% } %>
                                <% if (entry.metadata && entry.metadata.state && entry.metadata.state.oomKilled === true) { %>
                                    <span class="badge text-bg-danger">OOMKilled</span>
                                <% } %>
                                <% if (entry.metadata && entry.metadata.logSource) { %>
                                    <span class="badge text-bg-secondary">Logs: <%= entry.metadata.logSource %></span>
                                <% } %>
                            </div>

                            <% if (entry.metadata && entry.metadata.message) { %>
                                <div class="mb-2"><strong>Message:</strong> <span class="muted"><%= entry.metadata.message %></span></div>
                            <% } %>
                            <% if (entry.metadata && entry.metadata.error) { %>
                                <div class="mb-2"><strong>Error:</strong> <span class="text-danger"><%= entry.metadata.error %></span></div>
                            <% } %>

                            <% if (entry.logTail) { %>
                                <div class="log-box"><%= entry.logTail %></div>
                            <% } else { %>
                                <div class="muted">No console tail was available for this event.</div>
                            <% } %>
                        </article>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>
</div>
<script>
document.getElementById('sidebarToggle')?.addEventListener('click', () => document.getElementById('sidebar')?.classList.toggle('collapsed'));
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Server Suspended | <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <style>
            body {
                background-color: #0c0c10;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                margin: 0;
                font-family: 'Inter', sans-serif;
                color: #ffffff;
            }

            .suspended-card {
                background-color: #141419;
                border: 1px solid rgba(245, 158, 11, 0.15);
                border-radius: 1.5rem;
                padding: 3rem;
                max-width: 540px;
                width: 100%;
                text-align: center;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(245, 158, 11, 0.05);
            }

            .mascot-img {
                max-width: 180px;
                height: auto;
                border-radius: 1rem;
                margin-bottom: 1.75rem;
            }

            .brand-name {
                font-weight: 800;
                letter-spacing: 0.1em;
                color: #f59e0b;
                margin-bottom: 0.5rem;
                font-size: 0.75rem;
            }

            .reason-box {
                background: rgba(245, 158, 11, 0.06);
                border: 1px solid rgba(245, 158, 11, 0.2);
                border-radius: 0.875rem;
                padding: 1rem 1.25rem;
                margin: 1.5rem 0;
                text-align: left;
            }

            .reason-label {
                font-size: 0.65rem;
                text-transform: uppercase;
                font-weight: 700;
                letter-spacing: 0.1em;
                color: #f59e0b;
                margin-bottom: 0.4rem;
            }

            .reason-text {
                color: #e2e8f0;
                font-size: 0.925rem;
                line-height: 1.5;
            }

            .btn-back {
                background: #2d2d35;
                border: none;
                color: #ffffff;
                font-weight: 600;
                padding: 0.75rem 2rem;
                border-radius: 0.75rem;
                transition: all 0.2s;
                text-decoration: none;
                display: inline-block;
                margin-top: 0.5rem;
            }

            .btn-back:hover {
                background: #3f3f4a;
                color: #ffffff;
                transform: translateY(-2px);
            }

            .server-name {
                background: rgba(255, 255, 255, 0.04);
                border-radius: 0.5rem;
                padding: 0.25rem 0.75rem;
                font-size: 0.875rem;
                color: #94a3b8;
                display: inline-block;
                font-family: monospace;
                margin-bottom: 1.25rem;
            }
        </style>
</head>

<body>
    <div class="suspended-card">
        <img src="/assets/sad-rocky.png" alt="Sad Mascot" class="mascot-img">

        <div class="brand-name small text-uppercase">
            <%= settings.brandName || 'CPanel' %>
        </div>

        <h2 class="fw-bold mb-2">Server Suspended</h2>

        <div class="server-name">
            <i class="bi bi-server me-1"></i>
            <%= server.name %>
        </div>

        <p class="text-white mb-0" style="font-size: 0.9rem;">
            This server has been suspended by an administrator and is temporarily unavailable.
        </p>

        <% if (server.suspendReason) { %>
            <div class="reason-box">
                <div class="reason-label"><i class="bi bi-chat-left-text me-1"></i>Reason</div>
                <div class="reason-text">
                    <%= server.suspendReason %>
                </div>
            </div>
            <% } else { %>
                <div class="reason-box"
                    style="border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.03);">
                    <div class="reason-label" style="color: #64748b;"><i class="bi bi-dash-circle me-1"></i>Reason</div>
                    <div class="reason-text" style="color: #64748b; font-style: italic;">No reason was provided.</div>
                </div>
                <% } %>

                    <p class="text-white" style="font-size: 0.8rem; margin-bottom: 1.5rem;">
                        Please contact support or an administrator for more information.
                    </p>

                    <a href="/" class="btn-back">
                        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                    </a>
    </div>
</body>

</html>
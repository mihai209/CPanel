                    lower.endsWith('.tgz') ||
                    lower.endsWith('.tar.bz2') ||
                    lower.endsWith('.tbz2') ||
                    lower.endsWith('.tar.xz') ||
                    lower.endsWith('.txz') ||
                    lower.endsWith('.gz') ||

        <style>
            #newFileModal .form-control:focus,
            #newFolderModal .form-control:focus,
            #renameModal .form-control:focus,
            #permissionsModal .form-control:focus,
            #bulkRenameModal .form-control:focus,
            #bulkPermissionsModal .form-control:focus,
            #sftpModal .form-control:focus {
                background: rgba(255, 255, 255, 0.05);
                box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.5);
            }
        </style>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <script>
            // Sidebar toggle
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', () => sidebar.classList.toggle('show'));
            }

            // File Manager Actions (Listeners moved to bottom for modal integration)

            // Breadcrumb Event Delegation (CSP Fix)
            document.getElementById('breadcrumb').addEventListener('click', (e) => {
                const link = e.target.closest('a[data-path]');
                if (link) {
                    e.preventDefault();
                    navigateTo(link.getAttribute('data-path'));
                }
            });

            // File Manager Logic
            let currentPath = '<%= initialPath %>';
            const serverId = '<%= server.containerId %>';
            const webUploadEnabled = <%= fileUploadEnabled ? 'true' : 'false' %>;
            const webUploadMaxMb = <%= fileUploadMaxMbValue %>;
            const webUploadMaxBytes = webUploadMaxMb * 1024 * 1024;
            const wsToken = '<%= wsToken || "" %>';
            const wsUrl = window.location.protocol.replace('http', 'ws') + '//' + window.location.host + '/ws/server/' + serverId + '?token=' + encodeURIComponent(wsToken);

            let ws;
            let pollingTimer = null;
            let isConnectorOnline = true; // Assume online on load

            function startStatusCheck() {
                if (pollingTimer) return;
                console.log('Starting persistent status polling (3.5s)...');
                pollingTimer = setInterval(checkStatus, 3500);
            }

            async function checkStatus() {
                try {
                    const response = await fetch(`/server/${serverId}/status`);
                    const data = await response.json();

                    if (data.online) {
                        if (!isConnectorOnline) {
                            console.log('Connector is back online (polling detected)');
                            isConnectorOnline = true;
                            renderRestoredState();
                            // If WebSocket is closed, it will eventually try to reconnect via connect() loop
                            // but we can also trigger it manually here for faster recovery
                            if (!ws || ws.readyState === WebSocket.CLOSED) {
                                connect();
                            }
                        }
                    } else {
                        if (isConnectorOnline) {
                            console.log('Connector went offline (polling detected)');
                            isConnectorOnline = false;
                            renderOfflineState();
                        }
                    }
                } catch (err) {
                    console.error('Status check error:', err);
                    // On network error to panel, we might want to flag as offline too
                    if (isConnectorOnline) {
                        isConnectorOnline = false;
                        renderOfflineState();
                    }
                }
            }

            function connect() {
                if (ws && (ws.readyState === WebSocket.CONNECTING || ws.readyState === WebSocket.OPEN)) return;

                ws = new WebSocket(wsUrl);

                ws.onopen = () => {
                    console.log('WebSocket Connected');

                    // If we were offline, show restored state
                    const container = document.getElementById('fileList');
                    if (container && container.querySelector('.empty-state.offline')) {
                        renderRestoredState();
                    } else {
                        listFiles(currentPath);
                    }
                };

                ws.onmessage = (event) => {
                    try {
                        const data = JSON.parse(event.data);
                        if (data.type === 'file_list') {
                            renderFiles(data.files);
                            renderBreadcrumbs(data.directory);
                        } else if (data.type === 'extract_started') {
                            if (window.showStatusModal) {
                                window.showStatusModal('Archive extraction started in background.', 'success');
                            }
                        } else if (data.type === 'extract_complete') {
                            if (Boolean(data.success)) {
                                if (window.showStatusModal) {
                                    window.showStatusModal('Archive extracted successfully.', 'success');
                                }
                            } else {
                                const errText = String(data.error || 'Archive extraction failed.');
                                if (window.showStatusModal) {
                                    window.showStatusModal(errText, 'error');
                                } else {
                                    showError(errText);
                                }
                            }
                            listFiles(currentPath);
                        } else if (data.type === 'error') {
                            showError(data.message);
                        }
                    } catch (e) {
                        console.error('Failed to parse WS message', e);
                    }
                };

                ws.onclose = () => {
                    console.log('WebSocket Disconnected. Reconnecting...');
                    renderOfflineState();
                    // Status polling is already persistent, no need to start it here
                    setTimeout(connect, 5000);
                };
            }

            function listFiles(path) {
                if (ws && ws.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({
                        type: 'list_files',
                        directory: path
                    }));
                }
            }

            function formatSize(bytes) {
                if (bytes === 0) return '0 B';
                const k = 1024;
                const sizes = ['B', 'KB', 'MB', 'GB', 'TB', 'PB', 'EB', 'ZB', 'YB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            function formatDate(dateStr) {
                const date = new Date(dateStr);
                return date.toLocaleString();
            }

            function renderFiles(files) {
                const container = document.getElementById('fileList');
                container.innerHTML = '';
                currentEntriesByName.clear();

                if (files.length === 0) {
                    container.innerHTML = `
                    <tr>
                        <td colspan="5" class="empty-state">
                            <i class="bi bi-folder2-open empty-icon"></i>
                            <p>This directory is empty.</p>
                        </td>
                    </tr>
                `;
                    return;
                }

                // Sort: Folders first, then alphabetically
                files.sort((a, b) => {
                    if (a.isDirectory && !b.isDirectory) return -1;
                    if (!a.isDirectory && b.isDirectory) return 1;
                    return a.name.localeCompare(b.name);
                });

                // Retain selected items that still exist in the current folder
                const currentFileNames = new Set(files.map(f => f.name));
                for (const name of selectedItems) {
                    if (!currentFileNames.has(name)) {
                        selectedItems.delete(name);
                    }
                }

                document.getElementById('selectAll').checked = files.length > 0 && selectedItems.size === files.length;
                updateBulkActionsUI();

                files.forEach(file => {
                    currentEntriesByName.set(file.name, file);
                    const row = document.createElement('tr');
                    row.className = 'file-row';
                    row.setAttribute('data-name', file.name);
                    row.setAttribute('data-is-directory', file.isDirectory);
                    row.setAttribute('data-permissions', file.permissions || '');

                    if (selectedItems.has(file.name)) {
                        row.classList.add('selected');
                    }

                    const icon = file.isDirectory ? 'bi-folder-fill icon-folder' : 'bi-file-earmark-text icon-file';
                    const isChecked = selectedItems.has(file.name) ? 'checked' : '';

                    row.innerHTML = `
                        <td class="file-checkbox-col">
                            <input type="checkbox" class="file-checkbox item-checkbox" data-name="${file.name}" ${isChecked}>
                        </td>
                        <td class="file-name">
                            <div class="d-flex align-items-center">
                                <i class="bi ${icon} me-3 fs-5"></i>
                                <span class="fw-medium">${file.name}</span>
                            </div>
                        </td>
                        <td class="d-none d-xl-table-cell text-info small fw-semibold">${file.permissions || '-'}</td>
                        <td class="d-none d-md-table-cell text-secondary small">${file.isDirectory ? '-' : formatSize(file.size)}</td>
                        <td class="d-none d-lg-table-cell text-secondary small">${formatDate(file.mtime)}</td>
                    `;
                    row.addEventListener('click', (e) => {
                        // Don't navigate if clicking the checkbox
                        if (e.target.closest('.file-checkbox-col')) return;

                        if (file.isDirectory) {
                            const newPath = currentPath === '/' ? `/${file.name}` : `${currentPath}/${file.name}`;
                            navigateTo(newPath);
                        } else {
                            const filePath = currentPath === '/' ? `/${file.name}` : `${currentPath}/${file.name}`;
                            window.location.href = `/server/${serverId}/files/edit#file=${encodeURIComponent(filePath)}`;
                        }
                    });

                    container.appendChild(row);
                });
            }

            function renderBreadcrumbs(path) {
                const container = document.getElementById('breadcrumb');
                container.innerHTML = '';

                const parts = path.split('/').filter(p => p !== '');

                // Home link
                const homeItem = document.createElement('div');
                homeItem.className = 'breadcrumb-item';
                homeItem.innerHTML = `<a href="#" data-path="/">/root</a>`;
                container.appendChild(homeItem);

                let accumulatedPath = '';
                parts.forEach((part, index) => {
                    accumulatedPath += '/' + part;

                    const sep = document.createElement('span');
                    sep.className = 'breadcrumb-separator';
                    sep.innerHTML = '<i class="bi bi-chevron-right"></i>';
                    container.appendChild(sep);

                    const item = document.createElement('div');
                    item.className = 'breadcrumb-item';
                    if (index === parts.length - 1) {
                        item.textContent = part;
                    } else {
                        item.innerHTML = `<a href="#" data-path="${accumulatedPath}">${part}</a>`;
                    }
                    container.appendChild(item);
                });
            }

            function navigateTo(path) {
                currentPath = path;
                selectedItems.clear();
                document.getElementById('selectAll').checked = false;
                updateBulkActionsUI();
                listFiles(currentPath);

                // Sync browser URL
                const url = new URL(window.location);
                if (path === '/' || path === '') {
                    url.searchParams.delete('path');
                } else {
                    url.searchParams.set('path', path);
                }
                window.history.pushState({ path }, '', url);

                return false;
            }

            // Handle browser back/forward
            window.addEventListener('popstate', (event) => {
                if (event.state && event.state.path) {
                    currentPath = event.state.path;
                    listFiles(currentPath);
                } else {
                    currentPath = '/';
                    listFiles(currentPath);
                }
            });

            function renderOfflineState() {
                const container = document.getElementById('fileList');
                if (container.querySelector('.empty-state.offline')) return;

                container.innerHTML = `
                <tr>
                    <td colspan="5" class="empty-state offline py-5">
                        <div class="mb-4">
                            <img src="/assets/sad-rocky.png" alt="Offline" style="width: 240px; height: 240px; object-fit: contain; opacity: 0.8;">
                        </div>
                        <h4 class="text-danger fw-bold mb-2">Connector Offline</h4>
                        <p class="text-secondary">The connection to the server was lost. We're trying to reconnect...</p>
                        <div class="mt-4">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                            <span class="text-secondary small">Auto-reconnecting...</span>
                        </div>
                    </td>
                </tr>
            `;
            }

            function renderRestoredState() {
                const container = document.getElementById('fileList');
                container.innerHTML = `
                <tr>
                    <td colspan="5" class="empty-state py-5">
                        <div class="mb-4">
                            <img src="/assets/happy-rocky.png" alt="Online" style="width: 240px; height: 240px; object-fit: contain;">
                        </div>
                        <h4 class="text-success fw-bold mb-2">Connection Restored!</h4>
                        <p class="text-secondary">We're back online. Loading your files now...</p>
                        <div class="mt-4">
                            <button id="btnRefreshNow" class="btn btn-primary btn-sm px-4">
                                <i class="bi bi-arrow-clockwise me-2"></i>Refresh Now
                            </button>
                        </div>
                    </td>
                </tr>
            `;

                document.getElementById('btnRefreshNow').addEventListener('click', () => {
                    listFiles(currentPath);
                });

                // Auto-refresh after 2 seconds
                setTimeout(() => {
                    if (container.querySelector('img[alt="Online"]')) {
                        listFiles(currentPath);
                    }
                }, 2000);
            }

            function showError(msg) {
                console.error(msg);

                // If it's a connector offline error, show inline state instead of modal
                if (msg.toLowerCase().includes('connector is offline') || msg.toLowerCase().includes('failed to connect')) {
                    renderOfflineState();
                    return;
                }


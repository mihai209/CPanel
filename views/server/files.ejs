            function showError(msg) {
                console.error(msg);

                // If it's a connector offline error, show inline state instead of modal
                if (msg.toLowerCase().includes('connector is offline') || msg.toLowerCase().includes('failed to connect')) {
                    renderOfflineState();
                    return;
                }

                if (window.showStatusModal) {
                    window.showStatusModal(msg, 'error');
                } else {
                    alert(msg);
                }

                // Security/Safety: Only navigate back to root if the error is path-related
                // to avoid kicking the user out during temporary refresh glitches
                if (msg.toLowerCase().includes('not found') || msg.toLowerCase().includes('denied') || msg.toLowerCase().includes('invalid')) {
                    navigateTo('/');
                }
            }




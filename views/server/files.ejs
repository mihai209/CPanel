            // Auto-refresh logic
            let autoRefreshInterval = null;

            function startAutoRefresh() {
                if (autoRefreshInterval) return;
                autoRefreshInterval = setInterval(async () => {
                    // Only poll if tab is active and we are NOT offline
                    if (document.hidden) return;
                    if (!isConnectorOnline) return;

                    try {
                        const response = await fetch(`/server/${serverId}/files-fetch?path=${encodeURIComponent(currentPath)}`);
                        if (response.ok) {
                            const data = await response.json();
                            if (data.type === 'file_list') {
                                // Only re-render if something changed (simple check)
                                renderFiles(data.files);
                                renderBreadcrumbs(data.directory);
                            }
                        }
                    } catch (err) {
                        console.warn('Auto-refresh failed:', err);
                    }
                }, 4500);
            }

            function stopAutoRefresh() {
                if (autoRefreshInterval) {
                    clearInterval(autoRefreshInterval);
                    autoRefreshInterval = null;
                }
            }

            // Context Menu Logic
            const contextMenu = document.getElementById('contextMenu');
            const fileListContainer = document.querySelector('.file-list-container');

            if (fileListContainer && contextMenu) {
                fileListContainer.addEventListener('contextmenu', (e) => {
                    e.preventDefault();

                    // Capture right-clicked item
                    const row = e.target.closest('.file-row');
                    if (row) {
                        rightClickedItem = {
                            name: row.getAttribute('data-name'),
                            isDirectory: row.getAttribute('data-is-directory') === 'true',
                            permissions: row.getAttribute('data-permissions') || ''
                        };

                        const ctxDownload = document.getElementById('ctxDownload');
                        if (ctxDownload) {
                            ctxDownload.style.display = rightClickedItem.isDirectory ? 'none' : 'flex';
                        }
                        const ctxUnarchive = document.getElementById('ctxUnarchive');
                        if (ctxUnarchive) {
                            const canUnarchive = !rightClickedItem.isDirectory && isArchiveFileName(rightClickedItem.name);
                            ctxUnarchive.style.display = canUnarchive ? 'flex' : 'none';
                        }
                    } else {
                        rightClickedItem = null;
                        const ctxUnarchive = document.getElementById('ctxUnarchive');
                        if (ctxUnarchive) {
                            ctxUnarchive.style.display = 'none';
                        }
                    }

                    const x = e.clientX;
                    const y = e.clientY;

                    contextMenu.style.display = 'block';

                    // Adjust position if it goes off screen
                    const menuWidth = contextMenu.offsetWidth;
                    const menuHeight = contextMenu.offsetHeight;
                    const windowWidth = window.innerWidth;
                    const windowHeight = window.innerHeight;

                    let left = x;
                    let top = y;

                    if (x + menuWidth > windowWidth) left = x - menuWidth;
                    if (y + menuHeight > windowHeight) top = y - menuHeight;

                    contextMenu.style.left = left + 'px';
                    contextMenu.style.top = top + 'px';
                });

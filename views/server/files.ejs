            const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function normalizeServerPath(pathValue) {
                const raw = String(pathValue || '/').trim() || '/';
                let normalized = raw.startsWith('/') ? raw : `/${raw}`;
                normalized = normalized.replace(/\/+/g, '/');
                if (normalized.length > 1 && normalized.endsWith('/')) {
                    normalized = normalized.slice(0, -1);
                }
                return normalized || '/';
            }

            function joinServerPath(parentPath, entryName) {
                const base = normalizeServerPath(parentPath);
                return base === '/' ? `/${entryName}` : `${base}/${entryName}`;
            }

            const SEARCH_MEMORY_KEY = `cpanel.file.search.${serverId}`;
            let lastSearchResults = [];

            function getSearchFilterValue() {
                if (!searchFilterMode) return 'all';
                const selected = String(searchFilterMode.value || 'all').trim().toLowerCase();
                if (selected === 'files' || selected === 'folders') return selected;
                return 'all';
            }

            function shouldRememberSearch() {
                return Boolean(searchRememberChoice && searchRememberChoice.checked);
            }

            function setSearchBusyState(busy) {
                const isBusy = Boolean(busy);
                if (btnRunFileSearch) btnRunFileSearch.disabled = isBusy;
                if (searchFilesInput) searchFilesInput.disabled = isBusy;
                if (searchFilterMode) searchFilterMode.disabled = isBusy;
                if (btnCancelFileSearch) {
                    btnCancelFileSearch.style.display = isBusy ? 'inline-block' : 'none';
                    btnCancelFileSearch.disabled = !isBusy;
                }
            }

            function persistSearchPreference(query, filterMode) {
                try {
                    if (!shouldRememberSearch()) {
                        window.localStorage.removeItem(SEARCH_MEMORY_KEY);
                        return;
                    }
                    const payload = {
                        query: String(query || ''),
                        filterMode: String(filterMode || 'all'),
                        remember: true,
                        updatedAt: Date.now()
                    };
                    window.localStorage.setItem(SEARCH_MEMORY_KEY, JSON.stringify(payload));
                } catch {
                    // Ignore storage issues (private mode or quota).
                }
            }

            function loadSearchPreference() {
                try {
                    const raw = window.localStorage.getItem(SEARCH_MEMORY_KEY);
                    if (!raw) return null;
                    const parsed = JSON.parse(raw);
                    if (!parsed || parsed.remember !== true) return null;
                    const query = String(parsed.query || '');
                    const filterModeRaw = String(parsed.filterMode || 'all').toLowerCase();
                    const filterMode = (filterModeRaw === 'files' || filterModeRaw === 'folders') ? filterModeRaw : 'all';
                    return { query, filterMode };
                } catch {
                    return null;
                }
            }

            function refreshSearchHitsForCurrentPath() {
                const normalizedPath = normalizeServerPath(currentPath);
                searchHitNamesInCurrentPath = new Set(
                    lastSearchResults
                        .filter((entry) => normalizeServerPath(entry.parentPath) === normalizedPath)
                        .map((entry) => entry.name)
                );
            }

            function getMediaKindFromFileName(fileName) {
                const lower = String(fileName || '').toLowerCase();
                if (/\.(png|jpg|jpeg|gif|webp|bmp|svg)$/i.test(lower)) return 'image';
                if (/\.(mp4|webm|ogg|mov|m4v|mkv)$/i.test(lower)) return 'video';
                if (/\.(mp3|wav|ogg|m4a|aac|flac|opus)$/i.test(lower)) return 'audio';
                return null;
            }

            function formatMediaTime(seconds) {
                const safe = Number.isFinite(seconds) && seconds >= 0 ? Math.floor(seconds) : 0;
                const hrs = Math.floor(safe / 3600);
                const mins = Math.floor((safe % 3600) / 60);
                const secs = safe % 60;
                if (hrs > 0) return `${String(hrs).padStart(2, '0')}:${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
                return `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
            }

            function updateMediaPlayPauseIcon() {
                if (!mediaBtnPlayPause) return;
                const icon = mediaBtnPlayPause.querySelector('i');
                if (!icon) return;
                if (!activeMediaElement) {
                    icon.className = 'bi bi-play-fill';
                    return;
                }
                icon.className = activeMediaElement.paused ? 'bi bi-play-fill' : 'bi bi-pause-fill';
            }

            function updateMediaMuteIcon() {
                if (!mediaBtnMute || !activeMediaElement) return;
                const icon = mediaBtnMute.querySelector('i');
                if (!icon) return;
                if (activeMediaElement.muted || activeMediaElement.volume === 0) {
                    icon.className = 'bi bi-volume-mute';
                    return;
                }
                icon.className = 'bi bi-volume-up';
            }

            function updateMediaTimeline() {
                if (!activeMediaElement || !mediaProgress || !mediaTime) return;
                const duration = Number.isFinite(activeMediaElement.duration) ? activeMediaElement.duration : 0;
                const current = Number.isFinite(activeMediaElement.currentTime) ? activeMediaElement.currentTime : 0;
                const ratio = duration > 0 ? Math.min(100, Math.max(0, Math.round((current / duration) * 100))) : 0;
                mediaProgress.value = String(ratio);
                mediaTime.textContent = `${formatMediaTime(current)} / ${formatMediaTime(duration)}`;
            }

            function resetMediaViewer() {
                [mediaViewerImage, mediaViewerVideo, mediaViewerAudio].forEach((el) => {
                    if (!el) return;
                    try { el.pause && el.pause(); } catch {}
                    if (el.tagName === 'VIDEO' || el.tagName === 'AUDIO') {
                        el.removeAttribute('src');
                        el.load();
                    } else {
                        el.removeAttribute('src');
                    }
                    el.style.display = 'none';
                });
                activeMediaElement = null;
                activeMediaKind = null;
                if (mediaControls) mediaControls.style.display = 'none';
                if (mediaEmptyNote) {
                    mediaEmptyNote.textContent = 'Loading media...';
                    mediaEmptyNote.style.display = 'block';
                }
                if (mediaTime) mediaTime.textContent = '00:00 / 00:00';
                if (mediaProgress) mediaProgress.value = '0';
                updateMediaPlayPauseIcon();
            }

            function bindActiveMediaEvents(mediaEl) {
                if (!mediaEl) return;
                mediaEl.onloadedmetadata = () => {
                    if (mediaEmptyNote) mediaEmptyNote.style.display = 'none';
                    updateMediaTimeline();
                    updateMediaPlayPauseIcon();
                    updateMediaMuteIcon();
                };
                mediaEl.ontimeupdate = () => updateMediaTimeline();
                mediaEl.onplay = () => updateMediaPlayPauseIcon();
                mediaEl.onpause = () => updateMediaPlayPauseIcon();
                mediaEl.onvolumechange = () => {
                    if (mediaVolume) mediaVolume.value = String(mediaEl.volume);
                    updateMediaMuteIcon();
                };
                mediaEl.onended = () => updateMediaPlayPauseIcon();
                mediaEl.onerror = () => {
                    if (mediaEmptyNote) {
                        mediaEmptyNote.textContent = 'Preview failed for this media file.';
                        mediaEmptyNote.style.display = 'block';
                    }
                };
            }

            function openMediaViewer(filePath, fileName, mediaKind) {
                if (!mediaViewerModal) return false;
                resetMediaViewer();
                const normalizedPath = normalizeServerPath(filePath);
                const mediaSrc = `/server/${serverId}/files/preview?file=${encodeURIComponent(normalizedPath)}&t=${Date.now()}`;
                if (mediaViewerTitle) mediaViewerTitle.textContent = String(fileName || 'Media Viewer');

                if (mediaKind === 'image' && mediaViewerImage) {
                    activeMediaKind = 'image';
                    mediaViewerImage.style.display = 'block';
                    mediaViewerImage.src = mediaSrc;
                    mediaViewerImage.onload = () => {
                        if (mediaEmptyNote) mediaEmptyNote.style.display = 'none';
                    };
                    mediaViewerImage.onerror = () => {
                        if (mediaEmptyNote) {
                            mediaEmptyNote.textContent = 'Preview failed for this image.';
                            mediaEmptyNote.style.display = 'block';
                        }
                    };
                } else if (mediaKind === 'video' && mediaViewerVideo) {
                    activeMediaKind = 'video';
                    activeMediaElement = mediaViewerVideo;
                    mediaViewerVideo.style.display = 'block';
                    mediaViewerVideo.controls = false;
                    mediaViewerVideo.src = mediaSrc;
                    mediaViewerVideo.playbackRate = mediaSpeed ? Number(mediaSpeed.value || '1') : 1;
                    bindActiveMediaEvents(mediaViewerVideo);
                    if (mediaControls) mediaControls.style.display = 'flex';
                } else if (mediaKind === 'audio' && mediaViewerAudio) {
                    activeMediaKind = 'audio';
                    activeMediaElement = mediaViewerAudio;
                    mediaViewerAudio.style.display = 'block';
                    mediaViewerAudio.controls = false;
                    mediaViewerAudio.src = mediaSrc;
                    mediaViewerAudio.playbackRate = mediaSpeed ? Number(mediaSpeed.value || '1') : 1;
                    bindActiveMediaEvents(mediaViewerAudio);
                    if (mediaControls) mediaControls.style.display = 'flex';
                } else {
                    return false;
                }

                mediaViewerModal.show();
                return true;
            }

            function isArchiveFileName(fileName) {
                const lower = String(fileName || '').trim().toLowerCase();
                return (
                    lower.endsWith('.zip') ||
                    lower.endsWith('.tar') ||
                    lower.endsWith('.tar.gz') ||
                    lower.endsWith('.tgz') ||
                    lower.endsWith('.tar.bz2') ||
                    lower.endsWith('.tbz2') ||
                    lower.endsWith('.tar.xz') ||
                    lower.endsWith('.txz') ||
                    lower.endsWith('.gz') ||
                    lower.endsWith('.bz2') ||
                    lower.endsWith('.xz')
                );
            }

            function updateUploadQueueVisibility() {
                if (!uploadQueue || !uploadQueueList) return;
                const realItems = Array.from(uploadQueueList.children).filter((node) => !node.classList.contains('upload-empty'));
                uploadQueue.style.display = 'block';
                if (realItems.length === 0) {
                    uploadQueueList.innerHTML = '<div class="small text-secondary upload-empty">No files in queue.</div>';
                } else {
                    const emptyNode = uploadQueueList.querySelector('.upload-empty');
                    if (emptyNode) emptyNode.remove();
                }
                if (uploadQueueCount) {
                    uploadQueueCount.textContent = String(realItems.length);
                }
            }

            function applySearchHighlightsToTable() {
                const fileRows = document.querySelectorAll('#fileList .file-row');
                fileRows.forEach((row) => {
                    const name = String(row.getAttribute('data-name') || '');
                    row.classList.toggle('file-row-search-hit', searchHitNamesInCurrentPath.has(name));
                });
            }

            function createUploadQueueItem(file) {
                if (!uploadQueueList) return null;
                const emptyNode = uploadQueueList.querySelector('.upload-empty');
                if (emptyNode) emptyNode.remove();
                const item = document.createElement('div');
                item.className = 'upload-item';
                item.innerHTML = `
                    <div class="d-flex justify-content-between gap-3 mb-1">
                        <div class="upload-item-name">${escapeHtml(file.name)}</div>
                        <div class="upload-item-status">queued</div>
                    </div>
                    <div class="progress" style="height:6px;background:rgba(255,255,255,0.08);">
                        <div class="progress-bar bg-primary" role="progressbar" style="width:0%"></div>
                    </div>
                `;
                uploadQueueList.appendChild(item);
                updateUploadQueueVisibility();
                return item;
            }

            async function uploadFileWithProgress(file, queueItem) {
                return new Promise((resolve, reject) => {
                    const progressBar = queueItem ? queueItem.querySelector('.progress-bar') : null;
                    const statusEl = queueItem ? queueItem.querySelector('.upload-item-status') : null;
                    const uploadUrl = `/server/${serverId}/files/upload?path=${encodeURIComponent(currentPath)}&name=${encodeURIComponent(file.name)}`;
                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', uploadUrl, true);
                    xhr.setRequestHeader('Content-Type', 'application/octet-stream');

                    if (statusEl) statusEl.textContent = 'uploading';
                    xhr.upload.onprogress = (event) => {
                        if (!event.lengthComputable || !progressBar) return;
                        const pct = Math.max(0, Math.min(100, Math.round((event.loaded / event.total) * 100)));
                        progressBar.style.width = `${pct}%`;
                        if (statusEl) statusEl.textContent = `uploading ${pct}%`;
                    };

                    xhr.onreadystatechange = () => {
                        if (xhr.readyState !== XMLHttpRequest.DONE) return;
                        let payload = null;
                        try {
                            payload = JSON.parse(xhr.responseText || '{}');
                        } catch {
                            payload = null;
                        }
                        if (xhr.status >= 200 && xhr.status < 300 && payload && payload.success) {
                            if (progressBar) progressBar.style.width = '100%';
                            if (statusEl) statusEl.textContent = 'done';
                            if (queueItem) queueItem.classList.add('border-success');
                            if (queueItem) {
                                setTimeout(() => {
                                    if (queueItem.parentNode) {
                                        queueItem.remove();
                                        updateUploadQueueVisibility();
                                    }
                                }, 700);
                            }
                            resolve(payload);
                            return;
                        }
                        const errorText = payload && payload.error ? payload.error : `Upload failed (${xhr.status})`;
                        if (statusEl) statusEl.textContent = 'failed';
                        if (queueItem) queueItem.classList.add('border-danger');
                        reject(new Error(errorText));
                    };

                    xhr.onerror = () => {
                        if (statusEl) statusEl.textContent = 'failed';
                        if (queueItem) queueItem.classList.add('border-danger');
                        reject(new Error('Upload request failed.'));
                    };

                    xhr.send(file);
                });
            }

            async function fetchDirectoryForSearch(directory, signal) {
                const normalizedDir = normalizeServerPath(directory);
                const response = await fetch(`/server/${serverId}/files-fetch?path=${encodeURIComponent(normalizedDir)}`, { signal });
                if (!response.ok) {
                    throw new Error(`Search failed in ${normalizedDir}`);
                }
                const payload = await response.json();
                if (!payload || payload.error) {
                    throw new Error(payload && payload.error ? payload.error : 'Search request failed.');
                }
                return Array.isArray(payload.files) ? payload.files : [];
            }

            function renderSearchResults(results) {
                if (!searchResultsList) return;
                if (!Array.isArray(results) || results.length === 0) {
                    searchResultsList.innerHTML = '<div class="search-result-item text-secondary">No files found.</div>';
                    return;
                }

                searchResultsList.innerHTML = results.map((entry) => {
                    const isRoot = normalizeServerPath(entry.parentPath) === '/';
                    const rootLabel = isRoot ? '<span class="badge bg-warning text-dark ms-2">ROOT</span>' : '';
                    const safePath = escapeHtml(entry.path);
                    const safeParent = escapeHtml(entry.parentPath);
                    const safeName = escapeHtml(entry.name);
                    const typeLabel = entry.isDirectory ? 'Folder' : 'File';

                    return `
                        <div class="search-result-item ${isRoot ? 'search-hit-root' : ''}">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold text-light">${safeName}${rootLabel}</div>
                                    <div class="small text-secondary">${typeLabel}</div>
                                    <div class="small mt-1">
                                        ${isRoot
                                            ? '<span class="text-warning">Located in /root</span>'
                                            : `Path: <a href="#" class="search-result-link" data-open-path="${safeParent}">${safeParent}</a>`}
                                    </div>
                                </div>
                                <div class="text-end d-flex flex-column gap-1">
                                    <a href="#" class="search-result-link" data-open-path="${safeParent}">Open folder</a>
                                    ${entry.isDirectory
                                        ? `<a href="#" class="search-result-link" data-open-path="${safePath}">Enter folder</a>`
                                        : `<a href="#" class="search-result-link" data-open-file="${safePath}">Open file</a>`}
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            async function runFileSearch(rawQuery) {
                if (searchInProgress) return;
                const query = String(rawQuery || '').trim().toLowerCase();
                const filterMode = getSearchFilterValue();
                if (!query) {
                    if (searchFilesStatus) searchFilesStatus.textContent = 'Type a file name to search.';
                    lastSearchResults = [];
                    refreshSearchHitsForCurrentPath();
                    applySearchHighlightsToTable();
                    renderSearchResults([]);
                    persistSearchPreference('', filterMode);
                    return;
                }

                searchInProgress = true;
                searchCancelRequested = false;
                searchAbortController = new AbortController();
                setSearchBusyState(true);
                if (searchFilesStatus) searchFilesStatus.textContent = 'Starting recursive search...';
                if (searchResultsList) searchResultsList.innerHTML = '';

                const queue = ['/'];
                const visited = new Set();
                const found = [];
                const maxDirectories = 600;
                const maxResults = 300;
                let canceled = false;

                try {
                    while (queue.length > 0 && visited.size < maxDirectories && found.length < maxResults) {
                        if (searchCancelRequested) {
                            canceled = true;
                            break;
                        }
                        const directory = normalizeServerPath(queue.shift());
                        if (visited.has(directory)) continue;
                        visited.add(directory);
                        if (searchFilesStatus) {
                            searchFilesStatus.textContent = `Searching in ${directory} (${found.length} hits)...`;
                        }

                        let entries = [];
                        try {
                            entries = await fetchDirectoryForSearch(directory, searchAbortController.signal);
                        } catch (dirError) {
                            if (searchCancelRequested || (dirError && dirError.name === 'AbortError')) {
                                canceled = true;
                                break;
                            }
                            continue;
                        }

                        for (const entry of entries) {
                            if (!entry) continue;
                            const name = String(entry.name || '').trim();
                            if (!name || name === '.' || name === '..') continue;
                            const isDirectory = Boolean(entry.isDirectory);
                            const path = joinServerPath(directory, name);
                            const includeByFilter = filterMode === 'all'
                                || (filterMode === 'files' && !isDirectory)
                                || (filterMode === 'folders' && isDirectory);

                            if (includeByFilter && name.toLowerCase().includes(query)) {
                                found.push({
                                    name,
                                    path,
                                    parentPath: directory,
                                    isDirectory
                                });
                                if (found.length >= maxResults) break;
                            }

                            if (isDirectory) {
                                queue.push(path);
                            }
                        }
                    }

                    lastSearchResults = found;
                    refreshSearchHitsForCurrentPath();
                    applySearchHighlightsToTable();
                    renderSearchResults(found);
                    persistSearchPreference(query, filterMode);

                    const limitHit = found.length >= maxResults || visited.size >= maxDirectories;
                    if (searchFilesStatus) {
                        if (canceled) {
                            searchFilesStatus.textContent = `Search canceled. ${found.length} result(s) collected.`;
                        } else {
                            searchFilesStatus.textContent = limitHit
                                ? `Found ${found.length} result(s). Search stopped at safety limit.`
                                : `Found ${found.length} result(s).`;
                        }
                    }
                } catch (error) {
                    if (searchCancelRequested || (error && error.name === 'AbortError')) {
                        if (searchFilesStatus) searchFilesStatus.textContent = `Search canceled. ${found.length} result(s) collected.`;
                    } else {
                        if (searchFilesStatus) searchFilesStatus.textContent = 'Search failed.';
                        showError(error.message || 'Search failed.');
                    }
                } finally {
                    searchAbortController = null;
                    searchCancelRequested = false;
                    searchInProgress = false;
                    setSearchBusyState(false);
                }
            }

            function buildBulkRenameTarget(oldName, isDirectory, prefix, suffix, keepExtension, usedNames) {
                let baseName = oldName;
                let extension = '';
                if (!isDirectory && keepExtension) {
                    const dotIdx = oldName.lastIndexOf('.');
                    if (dotIdx > 0 && dotIdx < oldName.length - 1) {
                        baseName = oldName.slice(0, dotIdx);
                        extension = oldName.slice(dotIdx);
                    }
                }

                let candidate = `${prefix}${baseName}${suffix}${extension}`.trim();
                if (!candidate) candidate = oldName;
                if (!usedNames.has(candidate) && candidate !== '.' && candidate !== '..') {
                    usedNames.add(candidate);
                    return candidate;
                }

                let idx = 1;
                while (idx < 10000) {
                    const fallback = `${prefix}${baseName}${suffix}-${idx}${extension}`.trim();
                    if (fallback && !usedNames.has(fallback) && fallback !== '.' && fallback !== '..') {
                        usedNames.add(fallback);
                        return fallback;
                    }
                    idx += 1;
                }
                return oldName;
            }


            async function processUploadFiles(fileList) {
                if (!webUploadEnabled) {
                    showError('Web upload is disabled by admin.');
                    return;
                }
                const files = Array.from(fileList || []);
                if (!files.length) return;

                let uploadedCount = 0;
                let failedCount = 0;
                for (const file of files) {
                    const queueItem = createUploadQueueItem(file);
                    if (file.size > webUploadMaxBytes) {
                        failedCount += 1;
                        if (queueItem) {
                            const statusEl = queueItem.querySelector('.upload-item-status');
                            if (statusEl) statusEl.textContent = `too large (max ${webUploadMaxMb} MB)`;
                            queueItem.classList.add('border-danger');
                        }
                        continue;
                    }

                    try {
                        await uploadFileWithProgress(file, queueItem);
                        uploadedCount += 1;
                    } catch (uploadError) {
                        failedCount += 1;
                        if (queueItem) {
                            const statusEl = queueItem.querySelector('.upload-item-status');
                            if (statusEl) statusEl.textContent = String(uploadError.message || 'failed');
                        }
                    }
                }

                if (uploadedCount > 0) {
                    listFiles(currentPath);
                }
                if (window.showStatusModal) {
                    if (failedCount === 0) {
                        window.showStatusModal(`Uploaded ${uploadedCount} file(s).`, 'success');
                    } else {
                        window.showStatusModal(`Uploaded ${uploadedCount} file(s), failed ${failedCount}.`, 'error');
                    }
                }
            }


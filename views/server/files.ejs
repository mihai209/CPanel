<%
const fileUploadEnabled = Boolean(webUploadEnabled);
const fileUploadMaxMbValue = Math.max(1, Number.parseInt(webUploadMaxMb, 10) || 50);
const sftpUiEnabled = Boolean(sftpFeatureEnabled !== false);
%>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-visit-control" content="reload">
    <title>
        Files <%= server.name %> | <%= settings.brandName.toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
        <style>
            :root {
                --bg-dark: #0f0f12;
                --bg-darker: #0a0a0c;
                --bg-sidebar: #121216;
                --border-color: #2d2d35;
                --text-primary: #e1e1e6;
                --text-secondary: #8b8b9a;
                --accent-blue: #3b82f6;
                --accent-green: #10b981;
                --accent-red: #ef4444;
                --accent-yellow: #f59e0b;
            }

            body {
                background-color: var(--bg-dark);
                color: var(--text-primary);
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                overflow: hidden;
                height: 100vh;
                margin: 0;
            }

            /* Wrapper for sidebar + content */
            .wrapper {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            /* Sidebar styles (Pterodactyl-like) */
            .sidebar {
                width: 260px;
                background: var(--bg-sidebar);
                border-right: 1px solid var(--border-color);
                transition: all 0.3s ease;
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                overflow-y: auto;
            }

            .sidebar.collapsed {
                margin-left: -260px;
            }

            .sidebar .sidebar-content {
                padding: 1.5rem 0.75rem;
            }

            .sidebar-item {
                display: flex;
                align-items: center;
                padding: 0.75rem 1rem;
                color: var(--text-secondary);
                text-decoration: none;
                border-radius: 8px;
                transition: all 0.2s ease;
                font-weight: 500;
                font-size: 0.9rem;
                margin-bottom: 0.25rem;
            }

            .sidebar-item:hover {
                background: rgba(255, 255, 255, 0.03);
                color: var(--text-primary);
            }

            .sidebar-item.active {
                background: rgba(59, 130, 246, 0.1);
                color: var(--accent-blue);
            }

            .sidebar-icon {
                margin-right: 12px;
                font-size: 1.1rem;
                width: 24px;
                text-align: center;
            }

            .content {
                flex: 1;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                background: var(--bg-dark);
            }

            .top-navbar {
                background: var(--bg-sidebar);
                border-bottom: 1px solid var(--border-color);
                padding: 0.75rem 1.5rem;
                display: flex;
                align-items: center;
                flex-shrink: 0;
            }

            .navbar-toggle {
                background: transparent;
                border: none;
                color: var(--text-secondary);
                font-size: 1.5rem;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-right: 1rem;
                cursor: pointer;
                padding: 0;
            }

            .navbar-toggle:hover {
                color: var(--text-primary);
            }

            .server-info {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .server-name {
                font-size: 1.25rem;
                font-weight: 600;
                margin: 0;
            }

            .scroll-area {
                flex: 1;
                overflow-y: auto;
                padding: 1.5rem;
            }

            /* Context Menu */
            .context-menu {
                position: fixed;
                z-index: 10000;
                background: rgba(26, 26, 32, 0.98);
                backdrop-filter: blur(10px);
                border: 1px solid var(--border-color);
                border-radius: 10px;
                padding: 6px;
                min-width: 180px;
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
                display: none;
                animation: contextFadeIn 0.15s ease-out;
            }

            @keyframes contextFadeIn {
                from {
                    opacity: 0;
                    transform: scale(0.95);
                }

                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            .context-menu-item {
                display: flex;
                align-items: center;
                padding: 10px 14px;
                color: var(--text-primary);
                font-size: 0.85rem;
                font-weight: 500;
                border-radius: 6px;
                cursor: pointer;
                transition: all 0.2s ease;
            }

            .context-menu-item:hover {
                background: rgba(59, 130, 246, 0.1);
                color: var(--accent-blue);
            }

            .context-menu-icon {
                margin-right: 12px;
                font-size: 1rem;
                opacity: 0.8;
            }

            .context-menu-divider {
                height: 1px;
                background: var(--border-color);
                margin: 4px 0;
            }

            /* File Manager Styles */
            .file-manager-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 1.5rem;
            }

            .file-actions {
                display: flex;
                gap: 0.75rem;
            }

            .btn-action {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid var(--border-color);
                color: var(--text-primary);
                padding: 0.5rem 1rem;
                border-radius: 8px;
                font-size: 0.9rem;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                transition: all 0.2s ease;
                text-decoration: none;
            }

            .btn-action:hover {
                background: rgba(255, 255, 255, 0.08);
                color: white;
            }

            .btn-action i {
                font-size: 1.1rem;
            }

            .btn-action-primary {
                background: var(--accent-blue);
                border-color: var(--accent-blue);
                color: white;
            }

            .btn-action-primary:hover {
                background: #2563eb;
                border-color: #2563eb;
            }

            .breadcrumb-container {
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid var(--border-color);
                border-radius: 8px;
                padding: 10px 16px;
                margin-bottom: 1.5rem;
                display: flex;
                align-items: center;
                overflow-x: auto;
                white-space: nowrap;
            }

            .breadcrumb-item {
                color: var(--text-secondary);
                font-size: 0.9rem;
                display: flex;
                align-items: center;
            }

            .breadcrumb-item a {
                color: var(--accent-blue);
                text-decoration: none;
                font-weight: 500;
                transition: color 0.2s ease;
            }

            .breadcrumb-item a:hover {
                color: #60a5fa;
            }

            .breadcrumb-separator {
                margin: 0 10px;
                color: var(--border-color);
                font-size: 0.8rem;
            }

            .file-list-container {
                background: var(--bg-sidebar);
                border: 1px solid var(--border-color);
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            }

            .file-table {
                width: 100%;
                margin-bottom: 0;
                color: var(--text-primary);
                border-collapse: separate;
                border-spacing: 0;
            }

            .file-table th {
                background: rgba(255, 255, 255, 0.02);
                font-size: 0.75rem;
                text-transform: uppercase;
                font-weight: 600;
                letter-spacing: 0.05em;
                color: var(--text-secondary);
                padding: 1rem 1.5rem;
                border-bottom: 1px solid var(--border-color);
            }

            .file-table td {
                padding: 1rem 1.5rem;
                border-bottom: 1px solid var(--border-color);
                vertical-align: middle;
                font-size: 0.925rem;
            }

            .file-row {
                cursor: pointer;
                transition: background 0.2s ease;
            }

            .file-row:hover {
                background: rgba(255, 255, 255, 0.04);
            }

            .file-icon {
                font-size: 1.25rem;
                margin-right: 12px;
                width: 24px;
                display: inline-block;
                text-align: center;
            }

            .icon-folder {
                color: var(--accent-yellow);
            }

            .icon-file {
                color: var(--text-secondary);
                opacity: 0.8;
            }

            .empty-state {
                padding: 5rem 2rem;
                text-align: center;
                color: var(--text-secondary);
            }

            .empty-icon {
                font-size: 3.5rem;
                margin-bottom: 1.5rem;
                opacity: 0.3;
                display: block;
            }

            @media (max-width: 768px) {
                .sidebar {
                    margin-left: -260px;
                    position: fixed;
                    top: 0;
                    bottom: 0;
                    z-index: 1050;
                    box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
                }

                .sidebar.show {
                    margin-left: 0;
                }

                .content {
                    width: 100%;
                }

                .file-actions span {
                    display: none;
                }
            }

            /* Selection & Bulk Actions */
            .file-checkbox-col {
                width: 45px;
                text-align: center;
                vertical-align: middle;
            }

            .file-checkbox {
                width: 18px;
                height: 18px;
                cursor: pointer;
                accent-color: var(--accent-blue);
                background: rgba(0, 0, 0, 0.5);
                border: 1px solid var(--border-color);
                border-radius: 4px;
            }

            #bulkActions {
                display: none;
                animation: fadeIn 0.3s ease;
                gap: 0.5rem;
                align-items: center;
            }

            .upload-queue {
                display: none;
                margin-top: 1rem;
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid var(--border-color);
                border-radius: 10px;
                padding: 0.75rem;
            }

            .upload-dropzone {
                margin-top: 0.9rem;
                border: 1px dashed rgba(59, 130, 246, 0.35);
                border-radius: 10px;
                padding: 1rem;
                color: var(--text-secondary);
                background: rgba(59, 130, 246, 0.06);
                transition: all 0.2s ease;
                cursor: pointer;
            }

            .upload-dropzone strong {
                color: var(--text-primary);
            }

            .upload-dropzone.drag-over {
                border-color: rgba(59, 130, 246, 0.9);
                background: rgba(59, 130, 246, 0.14);
                color: var(--text-primary);
            }

            .upload-item {
                padding: 0.6rem 0.75rem;
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 8px;
                background: rgba(0, 0, 0, 0.2);
                margin-bottom: 0.55rem;
            }

            .upload-item:last-child {
                margin-bottom: 0;
            }

            .upload-item-name {
                font-size: 0.85rem;
                color: var(--text-primary);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .upload-item-status {
                font-size: 0.8rem;
                color: var(--text-secondary);
            }

            .btn-danger-soft {
                background: rgba(239, 68, 68, 0.1);
                color: #ef4444;
                border: 1px solid rgba(239, 68, 68, 0.2);
            }

            .btn-danger-soft:hover {
                background: rgba(239, 68, 68, 0.2);
                color: #ef4444;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(-10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        </style>
</head>

<body data-turbo="false">
    <%- include ('../partials/error-modal') %>
        <div class="wrapper">
            <!-- Sidebar -->
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-content">
                    <%- include('../partials/server-sidebar', { server, active: 'files' , settings }) %>
                </div>
            </nav>

            <!-- Main Content -->
            <div class="content">
                <!-- Top Navbar -->
                <div class="top-navbar">
                    <button id="sidebarToggle" class="navbar-toggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="server-info">
                        <h1 class="server-name">File Manager</h1>
                        <span class="text-secondary opacity-50 mx-2">/</span>
                        <span class="text-secondary">
                            <%= server.name %>
                        </span>
                    </div>
                </div>

                <!-- Scroll Area -->
                <div class="scroll-area">
                    <div class="file-manager-header">

                        <div id="breadcrumb" class="breadcrumb-container mb-0">
                            <!-- Dynamic breadcrumbs will be rendered here -->
                        </div>
                        <div class="file-actions">
                            <div id="bulkActions" class="me-2">
                                <a href="#" id="btnBulkRename" class="btn-action me-2">
                                    <i class="bi bi-input-cursor-text"></i>
                                    <span>Bulk Rename</span>
                                </a>
                                <a href="#" id="btnBulkPermissions" class="btn-action me-2">
                                    <i class="bi bi-shield-lock"></i>
                                    <span>Bulk CHMOD</span>
                                </a>
                                <a href="#" id="btnBulkDelete" class="btn-action btn-danger-soft">
                                    <i class="bi bi-trash3"></i>
                                    <span>Delete <b id="selectedCount">0</b> items</span>
                                </a>
                            </div>
                            <% if (fileUploadEnabled) { %>
                            <a href="#" id="btnUploadFiles" class="btn-action me-2">
                                <i class="bi bi-cloud-upload"></i>
                                <span>Upload</span>
                            </a>
                            <% } else { %>
                            <span class="btn-action me-2" style="opacity:0.65; pointer-events:none;">
                                <i class="bi bi-cloud-upload"></i>
                                <span>Upload Disabled</span>
                            </span>
                            <% } %>
                            <% if (sftpUiEnabled) { %>
                            <a href="#" id="btnSftp" class="btn-action me-2">
                                <i class="bi bi-hdd-network"></i>
                                <span>SFTP</span>
                            </a>
                            <% } %>
                            <a href="#" id="btnNewFile" class="btn-action me-2">
                                <i class="bi bi-file-earmark-plus"></i>
                                <span>New File</span>
                            </a>
                            <a href="#" id="btnNewFolder" class="btn-action">
                                <i class="bi bi-folder-plus"></i>
                                <span>New Folder</span>
                            </a>
                        </div>
                    </div>
                    <!-- File List -->

                    <div class="file-list-container">
                        
                        <table class="file-table">
                            <thead>
                                <tr>
                                    <th class="file-checkbox-col">
                                        <input type="checkbox" id="selectAll" class="file-checkbox">
                                    </th>
                                    <th>Name</th>
                                    <th class="d-none d-xl-table-cell" style="width: 130px;">Permissions</th>
                                    <th class="d-none d-md-table-cell" style="width: 150px;">Size</th>
                                    <th class="d-none d-lg-table-cell" style="width: 200px;">Last Modified</th>
                                </tr>
                            </thead>
                            <tbody id="fileList">
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                        </div>
                                        Loading files...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                                         <input type="file" id="uploadInput" class="d-none" multiple>
                    <% if (fileUploadEnabled) { %>
                    <div id="uploadDropzone" class="upload-dropzone">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div>
                                <strong>Drag and drop files here</strong>
                                <div class="small">or click <b>Upload</b> button. Max file size: <%= fileUploadMaxMbValue %> MB.</div>
                            </div>
                            <i class="bi bi-cloud-arrow-up fs-5"></i>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="upload-dropzone" style="opacity:0.7; border-style:solid;">
                        <div class="small text-warning">Web upload is disabled by admin.</div>
                    </div>
                    <% } %>
                    <div id="uploadQueue" class="upload-queue">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong class="small text-light">Upload Queue</strong>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" id="btnClearUploads">Clear</button>
                        </div>
                        <div id="uploadQueueList"></div>
                    </div>
                </div>
            </div>

            <!-- Context Menu -->
            <div id="contextMenu" class="context-menu">
                <div class="context-menu-item" id="ctxNewFile">
                    <i class="bi bi-file-earmark-plus context-menu-icon"></i>
                    <span>New File</span>
                </div>
                <div class="context-menu-item" id="ctxNewFolder">
                    <i class="bi bi-folder-plus context-menu-icon"></i>
                    <span>New Folder</span>
                </div>
                <div class="context-menu-divider"></div>
                <div class="context-menu-item" id="ctxRename">
                    <i class="bi bi-pencil-square context-menu-icon" style="color: var(--accent-yellow)"></i>
                    <span>Rename</span>
                </div>
                <div class="context-menu-item" id="ctxDownload">
                    <i class="bi bi-cloud-arrow-down context-menu-icon" style="color: var(--accent-green)"></i>
                    <span>Download</span>
                </div>
                <div class="context-menu-item" id="ctxUnarchive">
                    <i class="bi bi-file-earmark-zip context-menu-icon" style="color: var(--accent-green)"></i>
                    <span>Unarchive</span>
                </div>
                <div class="context-menu-item" id="ctxPermissions">
                    <i class="bi bi-shield-lock context-menu-icon" style="color: var(--accent-blue)"></i>
                    <span>Permissions</span>
                </div>
                <div class="context-menu-item" id="ctxDelete">
                    <i class="bi bi-trash3 context-menu-icon" style="color: var(--accent-red)"></i>
                    <span>Delete</span>
                </div>
                <div class="context-menu-divider"></div>
                <div class="context-menu-item" id="ctxRefreshPage">
                    <i class="bi bi-arrow-clockwise context-menu-icon"></i>
                    <span>Refresh Page</span>
                </div>
            </div>
        </div>

        <% if (sftpUiEnabled) { %>
        <!-- SFTP Modal -->
        <div class="modal fade" id="sftpModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content overflow-hidden border-0 shadow-lg"
                    style="background: rgba(26, 26, 32, 0.95); backdrop-filter: blur(10px); border-radius: 20px;">
                    <div style="height: 6px; background: linear-gradient(90deg, #10b981, #059669);"></div>
                    <div class="modal-header border-0 pt-4 px-4">
                        <h5 class="modal-title fw-bold text-light">SFTP Details</h5>
                        <button type="button" class="btn-close btn-close-white opacity-50" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <% const sftpInfo=sftpDetails || {}; %>
                            <% const sftpHostValue=sftpInfo.host || '' ; %>
                                <% const sftpPortValue=sftpInfo.port || '' ; %>
                                    <% const sftpUserValue=sftpInfo.username || '' ; %>
                                        <% const sftpAvailable=Boolean(sftpInfo.available); %>
                                            <% const sftpCommand=sftpAvailable ? `sftp -P ${sftpPortValue}
                                                ${sftpUserValue}@${sftpHostValue}` : '' ; %>
                                                <% if (!sftpAvailable) { %>
                                                    <div class="alert alert-warning border-0 mb-3"
                                                        style="background: rgba(245, 158, 11, 0.15); color: #fbbf24;">
                                                        SFTP is not available for this server right now.
                                                    </div>
                                                    <% } %>
                                                        <div class="mb-3">
                                                            <label
                                                                class="form-label text-secondary small fw-bold">HOST</label>
                                                            <div class="input-group">
                                                                <input type="text"
                                                                    class="form-control bg-dark bg-opacity-50 text-light border-0 py-3"
                                                                    id="sftpHostInput" readonly
                                                                    value="<%= sftpHostValue %>"
                                                                    style="border-radius: 12px 0 0 12px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);">
                                                                <button class="btn btn-outline-secondary px-3"
                                                                    type="button" data-copy-target="sftpHostInput">
                                                                    <i class="bi bi-clipboard"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label
                                                                class="form-label text-secondary small fw-bold">PORT</label>
                                                            <div class="input-group">
                                                                <input type="text"
                                                                    class="form-control bg-dark bg-opacity-50 text-light border-0 py-3"
                                                                    id="sftpPortInput" readonly
                                                                    value="<%= sftpPortValue %>"
                                                                    style="border-radius: 12px 0 0 12px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);">
                                                                <button class="btn btn-outline-secondary px-3"
                                                                    type="button" data-copy-target="sftpPortInput">
                                                                    <i class="bi bi-clipboard"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label
                                                                class="form-label text-secondary small fw-bold">USERNAME</label>
                                                            <div class="input-group">
                                                                <input type="text"
                                                                    class="form-control bg-dark bg-opacity-50 text-light border-0 py-3"
                                                                    id="sftpUsernameInput" readonly
                                                                    value="<%= sftpUserValue %>"
                                                                    style="border-radius: 12px 0 0 12px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);">
                                                                <button class="btn btn-outline-secondary px-3"
                                                                    type="button" data-copy-target="sftpUsernameInput">
                                                                    <i class="bi bi-clipboard"></i>
                                                                </button>
                                                            </div>
                                                            <p class="text-secondary small mt-2 mb-0">Generated and
                                                                fixed format: <code
                                                                    class="text-info">username.random5</code></p>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label
                                                                class="form-label text-secondary small fw-bold">PASSWORD</label>
                                                            <input type="text"
                                                                class="form-control bg-dark bg-opacity-50 text-light border-0 py-3"
                                                                readonly
                                                                value="<%= sftpInfo.passwordHint || 'Use your account password from this panel.' %>"
                                                                style="border-radius: 12px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);">
                                                        </div>
                                                        <div class="mt-4 text-center">
                                                            <a href="https://cpanel-rocky.netlify.app/docs/sftp"
                                                                target="_blank"
                                                                class="btn btn-outline-primary px-4 py-2"
                                                                style="border-radius: 12px; font-weight: 500;">
                                                                <i class="bi bi-book me-2"></i>Cum sa folosesti SFTP
                                                            </a>
                                                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="button" class="btn btn-link text-secondary text-decoration-none fw-bold"
                            data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- New File Modal -->
        <div class="modal fade" id="newFileModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content overflow-hidden border-0 shadow-lg"

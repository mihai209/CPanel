            if (ctxDownload) {
                ctxDownload.addEventListener('click', () => {
                    if (!rightClickedItem || rightClickedItem.isDirectory) return;
                    // Trigger download via the API route
                    const filePath = currentPath === '/' ? `/${rightClickedItem.name}` : `${currentPath}/${rightClickedItem.name}`;
                    window.location.href = `/server/${serverId}/files/download?file=${encodeURIComponent(filePath)}`;
                });
            }

            const ctxUnarchive = document.getElementById('ctxUnarchive');
            if (ctxUnarchive) {
                ctxUnarchive.addEventListener('click', () => {
                    if (!rightClickedItem || rightClickedItem.isDirectory) return;
                    if (!isArchiveFileName(rightClickedItem.name)) return;
                    if (!ws || ws.readyState !== WebSocket.OPEN) {
                        showError('Connection lost. Please wait or refresh.');
                        return;
                    }
                    ws.send(JSON.stringify({
                        type: 'extract_archive',
                        directory: currentPath,
                        name: rightClickedItem.name,
                        targetDirectory: currentPath
                    }));
                });
            }

            const ctxDelete = document.getElementById('ctxDelete');
            if (ctxDelete) {
                ctxDelete.addEventListener('click', () => {
                    if (!rightClickedItem || !deleteModal) return;
                    deleteModalTitle.innerText = `Delete "${rightClickedItem.name}"?`;
                    deleteModalBody.innerText = `Are you sure you want to delete this ${rightClickedItem.isDirectory ? 'folder' : 'file'}? This cannot be undone.`;
                    deleteModal.show();
                });
            }

            const ctxRefreshPage = document.getElementById('ctxRefreshPage');
            if (ctxRefreshPage) {
                ctxRefreshPage.addEventListener('click', () => {
                    location.reload();
                });
            }

            // Selection Logic
            document.getElementById('selectAll').addEventListener('change', (e) => {
                const checked = e.target.checked;
                document.querySelectorAll('.item-checkbox').forEach(cb => {
                    cb.checked = checked;
                    const name = cb.getAttribute('data-name');
                    if (checked) selectedItems.add(name);
                    else selectedItems.delete(name);
                });
                updateBulkActionsUI();
            });

            document.getElementById('fileList').addEventListener('change', (e) => {
                if (e.target.classList.contains('item-checkbox')) {
                    const name = e.target.getAttribute('data-name');
                    if (e.target.checked) selectedItems.add(name);
                    else selectedItems.delete(name);

                    // Update Select All state
                    const allCheckboxes = document.querySelectorAll('.item-checkbox');
                    const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
                    document.getElementById('selectAll').checked = allChecked;

                    updateBulkActionsUI();
                }
            });

            function updateBulkActionsUI() {
                const bulkActions = document.getElementById('bulkActions');
                const selectedCount = document.getElementById('selectedCount');
                if (selectedItems.size > 0) {
                    bulkActions.style.display = 'flex';
                    selectedCount.innerText = selectedItems.size;
                } else {
                    bulkActions.style.display = 'none';
                }
            }

            // Bulk Delete Handler
            document.getElementById('btnBulkDelete').addEventListener('click', (e) => {
                e.preventDefault();
                if (selectedItems.size === 0 || !deleteModal) return;
                deleteModalTitle.innerText = `Delete ${selectedItems.size} items?`;
                deleteModalBody.innerText = `Are you sure you want to permanently delete these ${selectedItems.size} selected items?`;
                deleteModal.show();
            });

            const btnBulkRename = document.getElementById('btnBulkRename');
            if (btnBulkRename) {
                btnBulkRename.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (selectedItems.size === 0 || !bulkRenameModal) return;
                    bulkRenamePrefixInput.value = '';
                    bulkRenameSuffixInput.value = '';
                    bulkRenameKeepExtension.checked = true;
                    bulkRenameModal.show();
                    setTimeout(() => bulkRenamePrefixInput.focus(), 500);
                });
            }

            const btnBulkPermissions = document.getElementById('btnBulkPermissions');
            if (btnBulkPermissions) {
                btnBulkPermissions.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (selectedItems.size === 0 || !bulkPermissionsModal) return;
                    bulkPermissionsInput.value = '644';
                    bulkPermissionsModal.show();
                    setTimeout(() => bulkPermissionsInput.focus(), 500);
                });
            }

            // Modal Confirmation Logic
            document.getElementById('btnConfirmRename').addEventListener('click', () => {
                const newName = renameInput.value.trim();
                if (newName && rightClickedItem && newName !== rightClickedItem.name) {
                    if (ws && ws.readyState === WebSocket.OPEN) {
                        ws.send(JSON.stringify({
                            type: 'rename_file',
                            directory: currentPath,
                            name: rightClickedItem.name,
                            newName: newName
                        }));
                        if (renameModal) renameModal.hide();
                    }
                }
            });

            document.getElementById('btnConfirmDelete').addEventListener('click', () => {
                let filesToRemove = [];
                if (selectedItems.size > 0 && deleteModalTitle.innerText.includes(selectedItems.size.toString())) {
                    filesToRemove = Array.from(selectedItems);
                } else if (rightClickedItem) {
                    filesToRemove = [rightClickedItem.name];
                }

                if (filesToRemove.length > 0) {
                    if (ws && ws.readyState === WebSocket.OPEN) {
                        ws.send(JSON.stringify({
                            type: 'delete_files',
                            directory: currentPath,
                            files: filesToRemove
                        }));
                        selectedItems.clear();
                        updateBulkActionsUI();
                        if (deleteModal) deleteModal.hide();
                    }
                }
            });

            document.getElementById('btnConfirmPermissions').addEventListener('click', () => {
                const permissions = permissionsInput.value.trim();
                if (!rightClickedItem) return;

                if (!/^[0-7]{3,4}$/.test(permissions)) {
                    showError('Permissions must be octal digits, e.g. 644, 755 or 0755.');
                    return;
                }

                if (ws && ws.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({
                        type: 'set_permissions',
                        directory: currentPath,
                        name: rightClickedItem.name,
                        permissions
                    }));
                    if (permissionsModal) permissionsModal.hide();
                } else {
                    showError('Connection lost. Please wait or refresh.');
                }
            });

            document.getElementById('btnConfirmBulkRename').addEventListener('click', async () => {
                if (!bulkRenameModal || selectedItems.size === 0) return;
                if (!ws || ws.readyState !== WebSocket.OPEN) {
                    showError('Connection lost. Please wait or refresh.');
                    return;
                }

                const prefix = String(bulkRenamePrefixInput.value || '');
                const suffix = String(bulkRenameSuffixInput.value || '');
                const keepExtension = Boolean(bulkRenameKeepExtension && bulkRenameKeepExtension.checked);
                const names = Array.from(selectedItems);
                const usedNames = new Set(Array.from(currentEntriesByName.keys()));

                let renamed = 0;
                for (const name of names) {
                    const entry = currentEntriesByName.get(name);
                    if (!entry) continue;
                    const nextName = buildBulkRenameTarget(name, Boolean(entry.isDirectory), prefix, suffix, keepExtension, usedNames);
                    if (!nextName || nextName === name) continue;

                    ws.send(JSON.stringify({
                        type: 'rename_file',
                        directory: currentPath,
                        name,
                        newName: nextName
                    }));
                    renamed += 1;
                    await sleep(80);
                }

                if (bulkRenameModal) bulkRenameModal.hide();
                selectedItems.clear();
                updateBulkActionsUI();
                setTimeout(() => listFiles(currentPath), 350);

                if (window.showStatusModal) {
                    window.showStatusModal(`Bulk rename queued for ${renamed} item(s).`, renamed > 0 ? 'success' : 'error');
                }
            });

            document.getElementById('btnConfirmBulkPermissions').addEventListener('click', async () => {
                if (!bulkPermissionsModal || selectedItems.size === 0) return;
                const permissions = String(bulkPermissionsInput.value || '').trim();
                if (!/^[0-7]{3,4}$/.test(permissions)) {
                    showError('Permissions must be octal digits, e.g. 644, 755 or 0755.');
                    return;
                }
                if (!ws || ws.readyState !== WebSocket.OPEN) {
                    showError('Connection lost. Please wait or refresh.');
                    return;
                }

                const names = Array.from(selectedItems);
                for (const name of names) {
                    ws.send(JSON.stringify({
                        type: 'set_permissions',
                        directory: currentPath,
                        name,
                        permissions
                    }));
                    await sleep(40);
                }

                if (bulkPermissionsModal) bulkPermissionsModal.hide();
                setTimeout(() => listFiles(currentPath), 250);
                if (window.showStatusModal) {
                    window.showStatusModal(`Applied chmod ${permissions} on ${names.length} item(s).`, 'success');
                }
            });

            renameInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') document.getElementById('btnConfirmRename').click();
            });
            permissionsInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') document.getElementById('btnConfirmPermissions').click();
            });
            if (bulkPermissionsInput) {
                bulkPermissionsInput.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') document.getElementById('btnConfirmBulkPermissions').click();
                });
            }

            // Start all tasks
            startStatusCheck();
            startAutoRefresh();
            connect();
        </script>
</body>

</html>

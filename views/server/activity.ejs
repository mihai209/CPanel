<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activity <%= server.name %> | <%= settings.brandName.toUpperCase() %></title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { background:#0f0f12; color:#e1e1e6; margin:0; font-family:Inter,system-ui,-apple-system,sans-serif; height:100vh; overflow:hidden; }
        .wrapper{display:flex;height:100vh}.sidebar{width:260px;background:#121216;border-right:1px solid #2d2d35;overflow-y:auto}.sidebar.collapsed{margin-left:-260px}
        .content{flex:1;display:flex;flex-direction:column;min-width:0}.top{background:#121216;border-bottom:1px solid #2d2d35;padding:.75rem 1rem;display:flex;align-items:center;gap:.75rem}
        .scroll{flex:1;overflow:auto;padding:1rem}.cardx{background:#121216;border:1px solid #2d2d35;border-radius:.8rem}.btn-icon{background:transparent;border:0;color:#8b8b9a;font-size:1.2rem}
        .table-dark{--bs-table-bg:transparent}
    </style>
</head>
<body>

<%- include('../partials/error-modal') %>
<div class="wrapper">
    <nav class="sidebar" id="sidebar"><div class="p-3"><%- include('../partials/server-sidebar', { server, active: 'activity' }) %></div></nav>
    <main class="content">
        <header class="top">
            <button class="btn-icon" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <h1 class="h5 mb-0">Activity / <span class="text-secondary"><%= server.name %></span></h1>
        </header>
        <section class="scroll">
            <div class="cardx p-3">
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>When</th>
                                <th>Actor</th>
                                <th>Action</th>
                                <th>Target</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!logs || logs.length === 0) { %>
                                <tr><td colspan="5" class="text-secondary">No activity entries yet.</td></tr>
                            <% } else { logs.forEach((log) => { %>
                                <tr>
                                    <td><%= new Date(log.createdAt).toLocaleString() %></td>
                                    <td><%= log.actor ? log.actor.username : 'system' %></td>
                                    <td><code><%= log.action || '-' %></code></td>
                                    <td><%= [log.targetType || '', log.targetId || ''].filter(Boolean).join(' / ') || '-' %></td>
                                    <td><%= log.ip || '-' %></td>
                                </tr>
                            <% }) } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</div>
<script>document.getElementById('sidebarToggle')?.addEventListener('click',()=>document.getElementById('sidebar')?.classList.toggle('collapsed'));</script>
</body>
</html>

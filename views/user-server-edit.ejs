<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<style>
    .edit-shell { max-width: 860px; margin: 0 auto; }
    .edit-card { border: 1px solid #2e3036; background: linear-gradient(180deg, rgba(31, 32, 35, 0.95), rgba(31, 32, 35, 0.72)); border-radius: 14px; padding: 1.25rem; }
</style>

<div class="container-fluid py-4">
    <div class="edit-shell">
        <div class="edit-card mb-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h1 class="h4 fw-bold mb-1">Edit Server</h1>
                    <p class="text-muted mb-0 small">Update basic server metadata for <strong><%= server.name %></strong>.</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="/server/<%= server.containerId %>" class="btn btn-outline-light btn-sm">Open Server</a>
                    <a href="/store" class="btn btn-outline-primary btn-sm">Back to Store</a>
                </div>
            </div>
        </div>

        <% if (success) { %>
            <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle-fill me-2"></i><%= success %></div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
        <% } %>

        <div class="edit-card mb-3">
            <div class="row g-2 small">
                <div class="col-md-6">
                    <div class="text-muted">Container</div>
                    <div class="fw-semibold">/<%= server.containerId %></div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted">Node</div>
                    <div class="fw-semibold"><%= server.allocation && server.allocation.connector ? server.allocation.connector.name : 'N/A' %></div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted">Memory</div>
                    <div class="fw-semibold"><%= Number(server.memory || 0) %> MB</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted">CPU</div>
                    <div class="fw-semibold"><%= Number(server.cpu || 0) %>%</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted">Disk</div>
                    <div class="fw-semibold"><%= Number(server.disk || 0) %> MB</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted">Swap</div>
                    <div class="fw-semibold"><%= Number(server.swapLimit || 0) %> MB</div>
                </div>
            </div>
        </div>

        <div class="edit-card">
            <form method="POST" action="/user/server/<%= server.containerId %>/edit" class="row g-3">
                <div class="col-12">
                    <label class="form-label text-muted small text-uppercase fw-bold">Server Name</label>
                    <input
                        type="text"
                        class="form-control"
                        name="name"
                        maxlength="100"
                        required
                        value="<%= server.name %>"
                        style="background-color:#1a1a20;border-color:#2d2d35;"
                    >
                </div>
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a href="/store" class="btn btn-outline-light">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

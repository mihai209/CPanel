<nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
    <div class="container-fluid">
        <% const userCreateEnabled = String((settings && settings.featureUserCreateEnabled) || 'false') === 'true'; %>
        <% const storeDealsEnabled = String((settings && settings.featureStoreDealsEnabled) || 'false') === 'true'; %>
        <% const storeRedeemCodesEnabled = String((settings && settings.featureStoreRedeemCodesEnabled) || 'false') === 'true'; %>
        <!-- Brand -->
        <div class="d-flex align-items-center">
            <img src="<%= settings.faviconUrl %>" alt="Favicon"
                class="rounded-circle border border-secondary border-opacity-25 me-2" style="object-fit: cover;"
                width="40" height="40">
            <a class="navbar-brand text-uppercase fw-bold mb-0" href="/">
                <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %>
            </a>
        </div>

        <!-- Right Side: Profile + Toggler (Always visible on same row) -->
        <div class="d-flex align-items-center gap-2 order-lg-3">
            <% if (user) { %>
                <a href="/rewards" class="btn btn-outline-warning btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-coin"></i>
                    <span><%= new Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 }).format(Number(user.coins || 0)) %></span>
                </a>
                <div class="dropdown">
                    <button type="button"
                        class="btn d-flex align-items-center gap-2 text-decoration-none text-light py-1 px-2 rounded hover-bg-light dropdown-toggle border-0 shadow-none"
                        id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false"
                        style="transition: background 0.2s;">
                        <img src="<%= (user.avatarProvider === 'url' && user.avatarUrl) ? user.avatarUrl : `https://www.gravatar.com/avatar/${user.gravatarHash}?d=retro` %>"
                            alt="Avatar" class="rounded-circle border border-secondary border-opacity-25"
                            style="object-fit: cover;" width="30" height="30">
                        <span class="d-none d-lg-inline fw-medium small">
                            <%= user.username %>
                        </span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark shadow-lg border-secondary border-opacity-25 mt-2 py-2"
                        aria-labelledby="userDropdown" style="min-width: 200px; background-color: #1a1a20;">
                        <li>
                            <div class="dropdown-header text-muted small text-uppercase fw-bold pb-1"
                                style="font-size: 0.65rem; letter-spacing: 0.05em;">User Actions</div>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/">
                                <i class="bi bi-house-door-fill"></i> Home
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/account">
                                <i class="bi bi-person-fill"></i> Account Settings
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/rewards">
                                <i class="bi bi-coin"></i> Rewards
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/afk">
                                <i class="bi bi-hourglass-split"></i> AFK Timer
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/connectors-check">
                                <i class="bi bi-hdd-network"></i> Connectors Check
                            </a>
                        </li>
                        <% if (userCreateEnabled) { %>
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/store">
                                    <i class="bi bi-shop"></i> Store
                                </a>
                            </li>
                            <% if (storeDealsEnabled) { %>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/store/deals">
                                        <i class="bi bi-stars"></i> Store Deals
                                    </a>
                                </li>
                            <% } %>
                            <% if (storeRedeemCodesEnabled) { %>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/store/redeem">
                                        <i class="bi bi-ticket-perforated"></i> Redeem Codes
                                    </a>
                                </li>
                            <% } %>
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="/user/create">
                                    <i class="bi bi-plus-square"></i> Create Server
                                </a>
                            </li>
                        <% } %>
                        <li>
                            <hr class="dropdown-divider border-secondary border-opacity-25">
                        </li>

                        <% if (user.isAdmin) { %>
                            <div class="dropdown-header text-muted small text-uppercase fw-bold pb-1"
                                style="font-size: 0.65rem; letter-spacing: 0.05em;">Admin Area</div>
                            <a href="/admin" class="dropdown-item d-flex align-items-center gap-2 py-2 text-danger">
                                <i class="bi bi-shield-lock-fill"></i>
                                <span class="small fw-bold text-uppercase">Admin Panel</span>
                            </a>
                            <hr class="dropdown-divider border-secondary border-opacity-25">
                            <% } %>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 py-2 text-danger"
                                        href="/logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                    </ul>
                </div>
                <% } %>

                    <button class="navbar-toggler border-0 shadow-none px-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
        </div>

        <!-- Collapsible Content -->
        <div class="collapse navbar-collapse order-lg-2" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <!-- Main user links can go here if needed -->
            </ul>
        </div>
    </div>
</nav>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3" data-turbo="false">
    <div class="container-fluid">
        <% const userCreateEnabled = String((settings && settings.featureUserCreateEnabled) || 'false') === 'true'; %>
        <% const storeDealsEnabled = String((settings && settings.featureStoreDealsEnabled) || 'false') === 'true'; %>
        <% const storeRedeemCodesEnabled = String((settings && settings.featureStoreRedeemCodesEnabled) || 'false') === 'true'; %>

        <div class="d-flex align-items-center">
            <img src="<%= settings.faviconUrl %>" alt="Favicon"
                class="rounded-circle border border-secondary border-opacity-25 me-2" style="object-fit: cover;"
                width="40" height="40">
            <a class="navbar-brand text-uppercase fw-bold mb-0" href="/">
                <span class="brand-main"><%= (settings.brandName || 'CPanel' ).toUpperCase() %></span>
                <% if (locals.title) { %>
                    <span class="brand-section d-none d-md-inline"> - <%= title.toUpperCase() %></span>
                <% } %>
            </a>
        </div>

        <div class="d-flex align-items-center gap-2 order-lg-3">
            <% if (user) { %>
                <a href="/rewards" class="btn btn-outline-warning btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-coin"></i>
                    <span><%= new Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 }).format(Number(user.coins || 0)) %></span>
                </a>

                <button type="button"
                    class="btn d-flex align-items-center gap-2 text-decoration-none text-light py-1 px-2 rounded hover-bg-light border-0 shadow-none"
                    id="userProfileButton"
                    data-bs-toggle="modal"
                    data-bs-target="#userProfileModal"
                    aria-label="Open profile menu"
                    style="transition: background 0.2s;">
                    <img src="<%= (user.avatarProvider === 'url' && user.avatarUrl) ? user.avatarUrl : `https://www.gravatar.com/avatar/${user.gravatarHash}?d=retro` %>"
                        alt="Avatar" class="rounded-circle border border-secondary border-opacity-25"
                        style="object-fit: cover;" width="30" height="30">
                    <span class="d-none d-lg-inline fw-medium small"><%= user.username %></span>
                    <i class="bi bi-list"></i>
                </button>
            <% } %>

            <button class="navbar-toggler border-0 shadow-none px-0" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        <div class="collapse navbar-collapse order-lg-2" id="navbarNav">
            <ul class="navbar-nav me-auto"></ul>
        </div>
    </div>
</nav>

<% if (user) { %>
<div class="modal fade" id="userProfileModal" tabindex="-1" aria-labelledby="userProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="background-color:#1a1a20;border:1px solid #2d2d35;">
            <div class="modal-header border-bottom border-secondary border-opacity-25">
                <div class="d-flex align-items-center gap-2">
                    <img src="<%= (user.avatarProvider === 'url' && user.avatarUrl) ? user.avatarUrl : `https://www.gravatar.com/avatar/${user.gravatarHash}?d=retro` %>"
                        alt="Avatar" class="rounded-circle border border-secondary border-opacity-25"
                        style="object-fit: cover;" width="32" height="32">
                    <div>
                        <h5 class="modal-title fs-6 fw-bold mb-0" id="userProfileModalLabel"><%= user.username %></h5>
                        <small class="text-muted">Profile menu</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-2">
                <div class="d-grid gap-1">
                    <a class="btn btn-dark text-start" href="/"><i class="bi bi-house-door-fill me-2"></i>Home</a>
                    <a class="btn btn-dark text-start" href="/account"><i class="bi bi-person-fill me-2"></i>Account Settings</a>
                    <a class="btn btn-dark text-start" href="/rewards"><i class="bi bi-coin me-2"></i>Rewards</a>
                    <a class="btn btn-dark text-start" href="/afk"><i class="bi bi-hourglass-split me-2"></i>AFK Timer</a>
                    <a class="btn btn-dark text-start" href="/connectors-check"><i class="bi bi-hdd-network me-2"></i>Connectors Check</a>

                    <% if (userCreateEnabled) { %>
                        <a class="btn btn-dark text-start" href="/store"><i class="bi bi-shop me-2"></i>Store</a>
                        <% if (storeDealsEnabled) { %>
                            <a class="btn btn-dark text-start" href="/store/deals"><i class="bi bi-stars me-2"></i>Store Deals</a>
                        <% } %>
                        <% if (storeRedeemCodesEnabled) { %>
                            <a class="btn btn-dark text-start" href="/store/redeem"><i class="bi bi-ticket-perforated me-2"></i>Redeem Codes</a>
                        <% } %>
                        <a class="btn btn-dark text-start" href="/user/create"><i class="bi bi-plus-square me-2"></i>Create Server</a>
                    <% } %>

                    <% const languageCodes = Array.isArray(locals.availableLanguages) ? locals.availableLanguages : ['english']; %>
                    <% const currentLang = String(locals.langCode || 'english'); %>
                    <% const languageLabel = (code) => {
                        if (code === 'english') return 'English';
                        if (code === 'espanol') return 'Español';
                        if (code === 'romana') return 'Română';
                        return code;
                    }; %>
                    <hr class="my-1 border-secondary border-opacity-25">
                    <div class="px-2 py-1">
                        <small class="text-muted text-uppercase d-block mb-2">Language</small>
                        <div class="d-flex flex-wrap gap-1">
                            <% languageCodes.forEach((code) => { %>
                                <form method="POST" action="/language" class="m-0">
                                    <input type="hidden" name="languageCode" value="<%= code %>">
                                    <input type="hidden" name="redirect" value="<%= locals.currentPath || '/' %>">
                                    <button type="submit" class="btn btn-sm <%= currentLang === code ? 'btn-primary' : 'btn-outline-light' %>">
                                        <%= languageLabel(code) %>
                                    </button>
                                </form>
                            <% }); %>
                        </div>
                    </div>

                    <% if (user.isAdmin) { %>
                        <hr class="my-1 border-secondary border-opacity-25">
                        <a class="btn btn-outline-danger text-start" href="/admin"><i class="bi bi-shield-lock-fill me-2"></i>Admin Panel</a>
                    <% } %>

                    <hr class="my-1 border-secondary border-opacity-25">
                    <a class="btn btn-outline-danger text-start" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
                </div>
            </div>
        </div>
    </div>
</div>
<% } %>

<style>
    /* Custom Scrollbar for Sidebar */
    .sidebar-nav-container::-webkit-scrollbar {
        width: 4px;
    }

    .sidebar-nav-container::-webkit-scrollbar-track {
        background: transparent;
    }

    .sidebar-nav-container::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }

    .sidebar-nav-container::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .sidebar-category-header {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.2);
        padding: 1.5rem 1.5rem 0.5rem;
        margin: 0;
    }

    .sidebar.collapsed .sidebar-category-header {
        display: none;
    }
</style>

<div class="sidebar d-flex flex-column flex-shrink-0" id="adminSidebar">
    <!-- Header/Logo Area -->
    <div class="sidebar-header">
        <a href="/" class="d-flex align-items-center text-decoration-none text-light fade-in">
            <img src="<%= settings.faviconUrl %>" alt="Favicon" width="32" height="32">
            <span class="sidebar-brand sidebar-text text-uppercase">
                <%= settings.brandName %>
            </span>
        </a>
        <button class="btn btn-link text-muted p-0 ms-auto d-none d-lg-block" id="sidebarToggle">
            <i class="bi bi-list fs-4"></i>
        </button>
    </div>

    <!-- Navigation -->
    <div class="flex-grow-1 overflow-auto sidebar-nav-container">
        <%
        const currentAdminPath = String(path || '');
        const adminNavSections = [
            {
                title: 'Core',
                items: [
                    { href: '/admin/overview', icon: 'bi-house-door', label: 'Overview' },
                    { href: '/admin/settings', icon: 'bi-gear', label: 'Settings' },
                    { href: '/admin/platform', icon: 'bi-command', label: 'Platform Ops' },
                    { href: '/admin/incidents', icon: 'bi-exclamation-triangle', label: 'Incident Center' },
                    { href: '/admin/logs', icon: 'bi-file-text', label: 'Logs' }
                ]
            },
            {
                title: 'Commerce',
                items: [
                    { href: '/admin/let-user-create', icon: 'bi-shop', label: 'Let User Create' },
                    { href: '/admin/revenue-plans', icon: 'bi-cash-stack', label: 'Revenue Plans' },
                    { href: '/admin/store/deals', icon: 'bi-stars', label: 'Store Deals' },
                    { href: '/admin/store/redeem-codes', icon: 'bi-ticket-perforated', label: 'Redeem Codes' },
                    { href: '/admin/forecasting', icon: 'bi-graph-up-arrow', label: 'Forecasting' }
                ]
            },
            {
                title: 'Infrastructure',
                items: [
                    { href: '/admin/connectors', icon: 'bi-diagram-3', label: 'Connectors' },
                    { href: '/admin/connect-info', icon: 'bi-activity', label: 'Connector(s) Health' },
                    { href: '/admin/locations', icon: 'bi-geo-alt', label: 'Locations' },
                    { href: '/admin/users', icon: 'bi-people', label: 'Users' },
                    { href: '/admin/servers', icon: 'bi-hdd-stack', label: 'Servers' },
                    { href: '/admin/databases', icon: 'bi-database', label: 'Databases' },
                    { href: '/admin/mounts', icon: 'bi-link-45deg', label: 'Mounts' },
                    { href: '/admin/redis', icon: 'bi-hdd-network', label: 'Redis' }
                ]
            },
            {
                title: 'Security',
                items: [
                    { href: '/admin/abuse-scores', icon: 'bi-shield-exclamation', label: 'Abuse Scores' },
                    { href: '/admin/service-health-checks', icon: 'bi-heart-pulse', label: 'Health Checks' },
                    { href: '/admin/auth-providers', icon: 'bi-shield-lock', label: 'Auth Providers' },
                    { href: '/admin/captcha', icon: 'bi-robot', label: 'Captcha' },
                    { href: '/admin/api', icon: 'bi-code-square', label: 'CPanel API' }
                ]
            },
            {
                title: 'Content',
                items: [
                    { href: '/admin/images', icon: 'bi-grid-3x3-gap', label: 'Images' },
                    { href: '/admin/packages', icon: 'bi-box', label: 'Packages' },
                    { href: '/admin/migrations/pterodactyl', icon: 'bi-arrow-left-right', label: 'Migrations' },
                    { href: '/admin/extensions', icon: 'bi-puzzle', label: 'Extensions' },
                    { href: '/admin/themes', icon: 'bi-palette', label: 'Themes' },
                    { href: '/admin/lang', icon: 'bi-translate', label: 'Languages' }
                ]
            }
        ];
        const isAdminNavActive = (item) => {
            const matches = Array.isArray(item && item.match) && item.match.length ? item.match : [item && item.href];
            return matches.some((entry) => {
                const value = String(entry || '').trim();
                if (!value) return false;
                return currentAdminPath === value || currentAdminPath.startsWith(`${value}/`);
            });
        };
        %>
        <ul class="nav flex-column mb-auto">
            <% adminNavSections.forEach((section) => { %>
                <li class="sidebar-category-header"><%= section.title %></li>
                <% section.items.forEach((item) => { %>
                    <li class="nav-item">
                        <a href="<%= item.href %>" class="nav-link <%= isAdminNavActive(item) ? 'active' : '' %>">
                            <i class="bi <%= item.icon %>"></i>
                            <span class="sidebar-text"><%= item.label %></span>
                        </a>
                    </li>
                <% }) %>
            <% }) %>
        </ul>
    </div>

    <!-- User Footer (Mini) -->
    <div class="sidebar-footer border-top border-secondary border-opacity-10 p-3">
        <div class="d-flex align-items-center">
            <img src="<%= user.avatarUrl || `https://www.gravatar.com/avatar/${user.gravatarHash}?d=retro` %>" alt=""
                width="34" height="34" class="rounded-circle me-2">
            <span class="sidebar-text small text-muted">
                <%= user.username %>
            </span>
            <a href="/logout" class="btn btn-link text-muted p-0 ms-auto d-none d-lg-block">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
    </div>
</div>

<button type="button" class="admin-mobile-toggle" id="adminSidebarMobileToggle" aria-label="Toggle admin sidebar">
    <i class="bi bi-list fs-5"></i>
</button>
<div class="admin-mobile-backdrop" id="adminSidebarBackdrop" aria-hidden="true"></div>

<script>
    (function () {
        const sidebar = document.getElementById('adminSidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        if (!sidebar) return;

        const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        if (isCollapsed) {
            sidebar.classList.add('collapsed');
        }

        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('collapsed');
                localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
            });
        }
    })();
</script>

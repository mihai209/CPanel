<style>
    .copyright-footer {
        text-align: center;
        padding: 2rem 0;
        color: #6b7280;
        font-size: 0.875rem;
    }

    .copyright-footer a {
        color: #9ca3af;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

    .copyright-footer a:hover {
        color: #ffffff;
    }

    .copyright-info-btn {
        background: none;
        border: none;
        color: inherit;
        font: inherit;
        cursor: pointer;
        padding: 0;
        text-decoration: underline;
    }

    .copyright-info-btn:hover {
        color: #ffffff;
    }
</style>

<div class="copyright-footer">
    <p>
        <a href="https://cpanel-rocky.netlify.app" target="_blank">CPANEL</a> &copy; 2026
        All rights reserved. Developed by
        <a href="https://github.com/mihai209" target="_blank">Mihai209</a>.
        <br>
        <button type="button" class="copyright-info-btn" data-bs-toggle="modal" data-bs-target="#copyrightInfoModal">
            Licensing & Support Information
        </button>
    </p>
</div>

<script>
    window.__CPANEL_I18N = Object.assign(window.__CPANEL_I18N || {}, {
        lang: '<%= locals.langCode || "english" %>',
        fallback: 'english'
    });
</script>
<script src="/js/i18n-runtime.js"></script>

<!-- Copyright Info Modal -->

    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg text-start"
            style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
            <div class="modal-header border-bottom border-secondary border-opacity-10">
                <h5 class="modal-title fs-6 fw-bold text-light" id="copyrightInfoModalLabel">Licensing & Support</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <h6 class="text-light fw-bold mb-2">MIT License</h6>
                <p class="text-muted small mb-4">
                    CPanel is distributed under the MIT License. You are free to use, copy, modify, merge, publish,
                    distribute, sublicense, and/or sell copies of the software, subject to the conditions of the
                    license.
                </p>

                <h6 class="text-light fw-bold mb-2">Disclaimer</h6>
                <p class="text-muted small mb-4">
                    CPanel is <strong>not associated</strong> with <a href="https://pterodactyl.io" target="_blank"

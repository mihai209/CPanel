</style>

<script>
    (function () {
        const storageKey = 'cpanel.serverNavMode';
        const root = document.documentElement;
        const modeButtons = Array.from(document.querySelectorAll('[data-server-nav-mode]'));
        const modalEl = document.getElementById('serverNavModal');
        const serverId = "<%= server.containerId %>";
        const applyMode = (mode) => {
            const next = ['modal', 'sidebar', 'navbar'].includes(mode) ? mode : 'modal';
            root.dataset.serverNav = next;
            localStorage.setItem(storageKey, next);
            modeButtons.forEach((button) => {
                button.classList.toggle('active', button.dataset.serverNavMode === next);
            });
            if (next !== 'modal' && modalEl && window.bootstrap) {
                const modal = window.bootstrap.Modal.getInstance(modalEl);
                if (modal) modal.hide();
            }
        };
        const savedMode = localStorage.getItem(storageKey);
        applyMode(savedMode || 'modal');
        modeButtons.forEach((button) => {
            button.addEventListener('click', () => {
                applyMode(button.dataset.serverNavMode);
            });
        });

        const isEditableTarget = (target) => {
            if (!target) return false;
            const tag = String(target.tagName || '').toLowerCase();
            return target.isContentEditable || tag === 'input' || tag === 'textarea' || tag === 'select';
        };

        const openServerMenu = () => {
            if (root.dataset.serverNav !== 'modal') return;
            const modalEl = document.getElementById('serverNavModal');
            if (!modalEl || !window.bootstrap) return;
            const modal = window.bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        };

        const sidebarEl = document.querySelector('.sidebar');
        const sidebarScrollKey = `cpanel.serverSidebarScroll.${serverId}`;
        if (sidebarEl) {
            const savedScroll = Number.parseInt(localStorage.getItem(sidebarScrollKey), 10);
            if (Number.isFinite(savedScroll)) {
                sidebarEl.scrollTop = savedScroll;
            }
            let sidebarScrollTimer;
            sidebarEl.addEventListener('scroll', () => {
                window.clearTimeout(sidebarScrollTimer);
                sidebarScrollTimer = window.setTimeout(() => {
                    localStorage.setItem(sidebarScrollKey, String(sidebarEl.scrollTop || 0));
                }, 120);
            });
        }

        const navScrollEl = document.getElementById('serverNavScroll');
        const navScrollKey = `cpanel.serverNavbarScroll.${serverId}`;
        if (navScrollEl) {
            const savedLeft = Number.parseInt(localStorage.getItem(navScrollKey), 10);
            if (Number.isFinite(savedLeft)) {
                navScrollEl.scrollLeft = savedLeft;
            }
            let navScrollTimer;
            navScrollEl.addEventListener('scroll', () => {
                window.clearTimeout(navScrollTimer);
                navScrollTimer = window.setTimeout(() => {
                    localStorage.setItem(navScrollKey, String(navScrollEl.scrollLeft || 0));
                }, 120);
            });
        }

        document.addEventListener('keydown', (event) => {
            if (event.defaultPrevented) return;
            if (isEditableTarget(event.target)) return;
            const key = String(event.key || '').toLowerCase();
            if ((event.ctrlKey || event.metaKey) && !event.shiftKey && key === 'k') {
                event.preventDefault();
                openServerMenu();
            }
        });
    })();
</script>

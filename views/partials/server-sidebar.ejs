    }

    :root[data-server-nav="modal"] .sidebar {
        width: 0 !important;
        min-width: 0 !important;
        padding: 0 !important;
        border: 0 !important;
        background: transparent !important;
        overflow: visible !important;
    }

    :root[data-server-nav="modal"] .server-sidebar-panel {
        display: none;
    }

    :root[data-server-nav="sidebar"] .server-menu-toggle,
    :root[data-server-nav="navbar"] .server-menu-toggle {
        display: none;
    }


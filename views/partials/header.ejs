<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title class="text-uppercase">
        <%= ((typeof settings !== 'undefined' && settings && settings.brandName) ? settings.brandName : 'CPanel').toUpperCase() %>
            <%= (typeof locals !== 'undefined' && locals && locals.title) ? ' - ' + String(locals.title).toUpperCase() : '' %>
    </title>

    <%- include('favicon') %>


        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

        <!-- Bootstrap 5 CDN -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

        <!-- Custom CSS -->
        <link rel="stylesheet" href="/css/style.css">

        <!-- SweetAlert2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <style>
            .swal2-popup {
                background-color: #1a1a20 !important;
                color: #fff !important;
                border: 1px solid rgba(255, 255, 255, 0.05) !important;
                border-radius: 15px !important;
            }
        </style>
    <link rel="stylesheet" href="/css/mobile-layout.css">
</head>

<%
    const __activeUserCustomThemeEnabled =
        (typeof activeUserCustomThemeEnabled !== 'undefined')
            ? Boolean(activeUserCustomThemeEnabled)
            : false;
    const __activeUserCustomTheme =
        (typeof activeUserCustomTheme !== 'undefined')
            ? activeUserCustomTheme
            : null;
%>
<body data-user-custom-theme="<%= __activeUserCustomThemeEnabled ? 'on' : 'off' %>">
    <script>
    (() => {
        const customTheme = <%- JSON.stringify(__activeUserCustomTheme || null) %>;
        const isEnabled = <%= __activeUserCustomThemeEnabled ? 'true' : 'false' %>;
        const root = document.documentElement;
        const body = document.body;
        const state = isEnabled ? 'on' : 'off';
        root.setAttribute('data-user-custom-theme', state);
        if (body) body.setAttribute('data-user-custom-theme', state);
        if (!isEnabled || !customTheme || typeof customTheme !== 'object') return;

        const cssVars = {
            '--cp-user-bg-color': String(customTheme.backgroundColor || '#0d0d0f'),
            '--cp-user-panel-surface': String(customTheme.panelSurface || '#141419'),
            '--cp-user-card-bg': String(customTheme.cardBackground || '#1f2023'),
            '--cp-user-card-border': String(customTheme.cardBorder || '#2e3036'),
            '--cp-user-accent-color': String(customTheme.accentColor || '#3b82f6'),
            '--cp-user-text-color': String(customTheme.textColor || '#ffffff'),
            '--cp-user-muted-text-color': String(customTheme.mutedTextColor || '#a1a1aa'),
            '--cp-user-server-card-bg': String(customTheme.serverCardBackground || '#1f2023'),
            '--cp-user-server-card-border': String(customTheme.serverCardBorder || '#2e3036'),
            '--cp-user-server-card-radius': String(Number.parseInt(customTheme.serverCardRadius, 10) || 12) + 'px'
        };

        Object.keys(cssVars).forEach((key) => {
            root.style.setProperty(key, cssVars[key]);
        });

        const bgImage = String(customTheme.backgroundImageUrl || '').trim();
        root.style.setProperty('--cp-user-bg-image', bgImage ? 'url("' + bgImage.replace(/"/g, '\\"') + '")' : 'none');
    })();
    </script>

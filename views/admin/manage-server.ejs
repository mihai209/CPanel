<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %> - Manage Server: <%= server.name %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-dark text-light"> <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <%- include('../partials/admin-sidebar') %>
                <div class="admin-content">
                    <div class="admin-header">
                        <div class="d-flex align-items-baseline gap-3">
                            <h4 class="mb-0 text-light fw-normal">Manage Server</h4>
                            <small class="text-muted">
                                <%= server.name %>
                            </small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <a
                                href="/admin/servers">Servers</a> <span class="mx-2">&gt;</span> <span
                                class="text-light">Manage</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <form id="edit-server-form" action="/admin/servers/edit/<%= server.containerId %>"
                            method="POST">
                            <div class="row g-4">
                                <div class="col-lg-8">
                                    <div class="card border-0 shadow-sm" style="background-color: #141419;">
                                        <div
                                            class="card-header border-bottom border-secondary border-opacity-10 py-3 bg-transparent d-flex justify-content-between align-items-center">
                                            <h5 class="card-title mb-0 fs-6 fw-bold text-light">Server Information</h5>
                                            <div class="d-flex align-items-center gap-2">
                                                <span
                                                    class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25">
                                                    <%= server.status.toUpperCase() %>
                                                </span>
                                                <% if (server.isSuspended) { %>
                                                    <span
                                                        class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                                                        <i class="bi bi-pause-circle me-1"></i>SUSPENDED
                                                    </span>
                                                    <% } %>
                                            </div>
                                        </div>
                                        <div class="card-body">
                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Server
                                                        Name</label>
                                                    <input type="text" name="name" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.name %>" required>
                                                </div>
                                                <div class="col-md-6">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Owner</label>
                                                    <select name="ownerId" class="form-select"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        required>
                                                        <% users.forEach(u=> { %>
                                                            <option value="<%= u.id %>" <%=server.ownerId===u.id
                                                                ? 'selected' : '' %>><%= u.username %> (<%= u.email %>)
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Image</label>
                                                    <select name="imageId" class="form-select"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        required>
                                                        <% images.forEach(img=> { %>
                                                            <option value="<%= img.id %>" <%=server.imageId===img.id
                                                                ? 'selected' : '' %>><%= img.name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-12">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Startup
                                                        Command</label>
                                                    <input type="text" name="startup"
                                                        class="form-control font-monospace"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: #a5b4fc; font-size: 0.85rem;"
                                                        placeholder="Leave blank to use default image startup..."
                                                        value="<%= server.startup || '' %>">
                                                    <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">
                                                        <i class="bi bi-info-circle me-1"></i> Override the default
                                                        startup command for this server. Custom flags can be added here.
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card border-0 shadow-sm mt-4" style="background-color: #141419;">
                                        <div
                                            class="card-header border-bottom border-secondary border-opacity-10 py-3 bg-transparent">
                                            <h5 class="card-title mb-0 fs-6 fw-bold text-light">Resource Allocation</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Memory
                                                        (MB)</label>
                                                    <input type="number" id="memoryInput" name="memory" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.memory %>" required>
                                                </div>
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">CPU
                                                        Limit (%)</label>
                                                    <input type="number" id="cpuInput" name="cpu" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.cpu %>" required>
                                                </div>
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Disk
                                                        Space (MB)</label>
                                                    <input type="number" id="diskInput" name="disk" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.disk %>" required>
                                                </div>
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">Swap
                                                        (MB)</label>
                                                    <input type="number" id="swapLimitInput" name="swapLimit" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.swapLimit %>">
                                                    <small class="text-muted">0 = no swap, -1 = unlimited</small>
                                                </div>
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">I/O
                                                        Weight</label>
                                                    <input type="number" id="ioWeightInput" name="ioWeight" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.ioWeight %>" min="10" max="1000">
                                                </div>
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">PIDs
                                                        Limit</label>
                                                    <input type="number" id="pidsLimitInput" name="pidsLimit" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.pidsLimit %>" min="0">
                                                </div>
                                                <div class="col-md-4">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold">OOM
                                                        Score Adj</label>
                                                    <input type="number" id="oomScoreAdjInput" name="oomScoreAdj" class="form-control"
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;"
                                                        value="<%= server.oomScoreAdj %>" min="-1000" max="1000">
                                                </div>
                                                <div class="col-md-4 d-flex align-items-end">
                                                    <div class="form-check form-switch w-100 p-2 rounded-2"
                                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                                        <input type="hidden" name="oomKillDisable" value="0">
                                                        <input class="form-check-input ms-0 me-2" type="checkbox"
                                                            name="oomKillDisable" id="oomKillDisableEdit"
                                                            <%=server.oomKillDisable ? 'checked' : '' %>>
                                                        <label class="form-check-label text-light fw-bold"
                                                            for="oomKillDisableEdit">Disable OOM Killer</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <% const liveMemoryMax = Math.max(
                                                Number(server.memory || 1024),
                                                server.allocation && server.allocation.connector
                                                    ? Math.floor((Number(server.allocation.connector.totalMemory || 0) * 1024) * (1 + (Number(server.allocation.connector.memoryOverAllocation || 0) / 100)))
                                                    : Number(server.memory || 1024) * 4
                                            ); %>
                                            <% const liveDiskMax = Math.max(
                                                Number(server.disk || 10240),
                                                server.allocation && server.allocation.connector
                                                    ? Math.floor((Number(server.allocation.connector.totalDisk || 0) * 1024) * (1 + (Number(server.allocation.connector.diskOverAllocation || 0) / 100)))
                                                    : Number(server.disk || 10240) * 4
                                            ); %>
                                            <div class="mt-4 p-3 rounded-3 border border-primary border-opacity-25" style="background: rgba(59,130,246,0.08);">
                                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                                    <h6 class="mb-0 text-info fw-bold"><i class="bi bi-sliders me-2"></i>Live Resource Caps Editor</h6>
                                                    <span class="small text-muted">Applies immediately in panel and to next deploy/runtime refresh.</span>
                                                </div>
                                                <div class="row g-3">
                                                    <div class="col-md-4">
                                                        <label class="form-label text-muted small text-uppercase fw-bold">Memory Slider</label>
                                                        <input type="range" id="memoryRange" class="form-range" min="64" max="<%= liveMemoryMax %>" step="64" value="<%= server.memory %>">
                                                        <div class="small text-muted"><span id="memoryRangeValue"><%= server.memory %></span> MB</div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label text-muted small text-uppercase fw-bold">CPU Slider</label>
                                                        <input type="range" id="cpuRange" class="form-range" min="10" max="400" step="10" value="<%= server.cpu %>">
                                                        <div class="small text-muted"><span id="cpuRangeValue"><%= server.cpu %></span>%</div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label text-muted small text-uppercase fw-bold">Disk Slider</label>
                                                        <input type="range" id="diskRange" class="form-range" min="512" max="<%= liveDiskMax %>" step="128" value="<%= server.disk %>">
                                                        <div class="small text-muted"><span id="diskRangeValue"><%= server.disk %></span> MB</div>
                                                    </div>
                                                </div>
                                                <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
                                                    <button type="button" class="btn btn-outline-info btn-sm fw-bold" id="applyLiveCapsBtn">
                                                        <i class="bi bi-lightning-charge me-1"></i>Apply Live Caps
                                                    </button>
                                                    <div class="small text-muted" id="liveCapsStatus">Ready.</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="card border-0 shadow-sm mb-4" style="background-color: #141419;">
                                        <div
                                            class="card-header border-bottom border-secondary border-opacity-10 py-3 bg-transparent">
                                            <h5 class="card-title mb-0 fs-6 fw-bold text-light">Network Information</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Connector</label>
                                                <div class="form-control-plaintext text-info fw-bold">
                                                    <%= server.allocation && server.allocation.connector ?
                                                        server.allocation.connector.name : 'N/A' %>
                                                </div>
                                            </div>
                                            <div class="mb-0">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Default
                                                    IP:Port</label>
                                                <div class="form-control-plaintext text-light">
                                                    <%= server.allocation ?
                                                        `${server.allocation.ip}:${server.allocation.port}` : 'N/A' %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div
                                        class="card border-0 shadow-sm bg-transparent border border-danger border-opacity-10">
                                        <div class="card-body p-4">
                                            <h6 class="text-danger fw-bold mb-3"><i
                                                    class="bi bi-shield-lock me-2"></i>Danger Zone</h6>

                                            <% let connectorOnline=(connectorStatus==='online' ); %>

                                                <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3"
                                                    style="background: rgba(255,255,255,0.03);">
                                                    <div class="flex-shrink-0">
                                                        <% if (connectorStatus==='online' ) { %>
                                                            <div
                                                                class="p-2 rounded-circle bg-success bg-opacity-10 text-success">
                                                                <i class="bi bi-cloud-check fs-4"></i>
                                                            </div>
                                                            <% } else { %>
                                                                <div
                                                                    class="p-2 rounded-circle bg-danger bg-opacity-10 text-danger">
                                                                    <i class="bi bi-cloud-slash fs-4"></i>
                                                                </div>
                                                                <% } %>
                                                    </div>
                                                    <div>
                                                        <div class="small text-muted text-uppercase fw-bold"
                                                            style="font-size: 0.65rem;">Connector Status</div>
                                                        <div class="text-light fw-bold">
                                                            <%= connectorStatus==='online' ? 'Online & Ready'
                                                                : 'Offline / Unreachable' %>
                                                        </div>
                                                    </div>
                                                </div>

                                                <button type="button" class="btn btn-primary w-100 mb-3 fw-bold"
                                                    id="saveChangesBtn">
                                                    <i class="bi bi-save me-2"></i>Save Changes
                                                </button>

                                                <div class="d-grid gap-2">
                                                    <button type="button"
                                                        class="btn btn-outline-danger btn-sm fw-bold py-2"
                                                        id="safeDeleteBtn" <%=connectorStatus !=='online' ? 'disabled'
                                                        : '' %>>
                                                        <i class="bi bi-trash-fill me-2"></i>Safe Delete
                                                    </button>
                                                    <% if (server.isSuspended) { %>
                                                        <button type="button"
                                                            class="btn btn-outline-success btn-sm fw-bold py-2"
                                                            id="unsuspendBtn">
                                                            <i class="bi bi-play-circle me-2"></i>Unsuspend Server
                                                        </button>
                                                        <% } else { %>
                                                            <button type="button"
                                                                class="btn btn-outline-warning btn-sm fw-bold py-2"
                                                                id="suspendBtn">
                                                                <i class="bi bi-pause-circle me-2"></i>Suspend Server
                                                            </button>
                                                            <% } %>
                                                                <button type="button"
                                                                    class="btn btn-outline-secondary btn-sm fw-bold py-2 <%= connectorStatus !== 'online' ? 'disabled' : '' %>"
                                                                    id="reinstallBtn" <%=connectorStatus !=='online'
                                                                    ? 'disabled' : '' %>>
                                                                    <i class="bi bi-arrow-clockwise me-2"></i>Reinstall
                                                                    Server
                                                                </button>
                                                                <button type="button"
                                                                    class="btn btn-link text-danger text-decoration-none small fw-bold mt-1"
                                                                    id="forceDeleteBtn">
                                                                    <i
                                                                        class="bi bi-exclamation-triangle me-1"></i>Forced
                                                                    Deletion (Skip Offline Node)
                                                                </button>
                                                </div>

                                                <% if (connectorStatus !=='online' ) { %>
                                                    <div
                                                        class="mt-3 p-2 rounded bg-danger bg-opacity-10 border border-danger border-opacity-20">
                                                        <small class="text-danger d-block text-center"
                                                            style="font-size: 0.75rem;">
                                                            <i class="bi bi-info-circle me-1"></i> Connector must be
                                                            online for Safe Delete.
                                                        </small>
                                                    </div>
                                                    <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>

                        <form id="delete-form" action="/admin/servers/delete/<%= server.containerId %>" method="POST"
                            style="display: none;"></form>
                        <form id="suspend-form" action="/admin/servers/suspend/<%= server.containerId %>" method="POST"
                            style="display: none;">
                            <input type="hidden" name="reason" id="suspend-reason-input">
                        </form>
                        <form id="unsuspend-form" action="/admin/servers/unsuspend/<%= server.containerId %>"
                            method="POST" style="display: none;"></form>
                        <form id="reinstall-form" action="/admin/servers/reinstall/<%= server.containerId %>"
                            method="POST" style="display: none;"></form>
                    </div>
                    <%- include('../partials/footer') %>
                </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            // Constants for mascots
            const SAD_ROCKY = '/assets/sad-rocky.png';
            const SECURITY_ROCKY = '/assets/rocky-security.png';
            const memoryInput = document.getElementById('memoryInput');
            const cpuInput = document.getElementById('cpuInput');
            const diskInput = document.getElementById('diskInput');
            const swapLimitInput = document.getElementById('swapLimitInput');
            const ioWeightInput = document.getElementById('ioWeightInput');
            const pidsLimitInput = document.getElementById('pidsLimitInput');
            const oomScoreAdjInput = document.getElementById('oomScoreAdjInput');
            const oomKillDisableInput = document.getElementById('oomKillDisableEdit');
            const memoryRange = document.getElementById('memoryRange');
            const cpuRange = document.getElementById('cpuRange');
            const diskRange = document.getElementById('diskRange');
            const memoryRangeValue = document.getElementById('memoryRangeValue');
            const cpuRangeValue = document.getElementById('cpuRangeValue');
            const diskRangeValue = document.getElementById('diskRangeValue');
            const liveCapsStatus = document.getElementById('liveCapsStatus');
            const applyLiveCapsBtn = document.getElementById('applyLiveCapsBtn');

            const bindRangeToInput = (rangeNode, inputNode, valueNode) => {
                if (!rangeNode || !inputNode) return;
                const syncFromRange = () => {
                    inputNode.value = String(rangeNode.value);
                    if (valueNode) valueNode.textContent = String(rangeNode.value);
                };
                const syncFromInput = () => {
                    const raw = Number.parseInt(inputNode.value, 10);
                    if (!Number.isFinite(raw)) return;
                    const clamped = Math.max(Number.parseInt(rangeNode.min, 10) || raw, Math.min(Number.parseInt(rangeNode.max, 10) || raw, raw));
                    rangeNode.value = String(clamped);
                    inputNode.value = String(clamped);
                    if (valueNode) valueNode.textContent = String(clamped);
                };
                rangeNode.addEventListener('input', syncFromRange);
                inputNode.addEventListener('change', syncFromInput);
                syncFromInput();
            };

            bindRangeToInput(memoryRange, memoryInput, memoryRangeValue);
            bindRangeToInput(cpuRange, cpuInput, cpuRangeValue);
            bindRangeToInput(diskRange, diskInput, diskRangeValue);

            applyLiveCapsBtn?.addEventListener('click', async function () {
                try {
                    applyLiveCapsBtn.disabled = true;
                    if (liveCapsStatus) {
                        liveCapsStatus.textContent = 'Applying...';
                        liveCapsStatus.classList.remove('text-warning', 'text-success');
                        liveCapsStatus.classList.add('text-muted');
                    }

                    const payload = {
                        memory: Number.parseInt(memoryInput && memoryInput.value, 10) || 0,
                        cpu: Number.parseInt(cpuInput && cpuInput.value, 10) || 0,
                        disk: Number.parseInt(diskInput && diskInput.value, 10) || 0,
                        swapLimit: Number.parseInt(swapLimitInput && swapLimitInput.value, 10) || 0,
                        ioWeight: Number.parseInt(ioWeightInput && ioWeightInput.value, 10) || 500,
                        pidsLimit: Number.parseInt(pidsLimitInput && pidsLimitInput.value, 10) || 0,
                        oomScoreAdj: Number.parseInt(oomScoreAdjInput && oomScoreAdjInput.value, 10) || 0,
                        oomKillDisable: Boolean(oomKillDisableInput && oomKillDisableInput.checked)
                    };

                    const response = await fetch('/api/admin/servers/<%= server.containerId %>/resource-caps', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await response.json();
                    if (!response.ok || !data.success) {
                        throw new Error(data && data.error ? data.error : `Failed (${response.status})`);
                    }

                    if (liveCapsStatus) {
                        liveCapsStatus.textContent = 'Live caps updated.';
                        liveCapsStatus.classList.remove('text-muted', 'text-warning');
                        liveCapsStatus.classList.add('text-success');
                    }
                    Swal.fire({
                        title: 'Updated',
                        text: 'Resource caps were updated successfully.',
                        icon: 'success',
                        background: '#141419',
                        color: '#ffffff',
                        confirmButtonColor: '#3b82f6'
                    });
                } catch (error) {
                    if (liveCapsStatus) {
                        liveCapsStatus.textContent = String(error && error.message ? error.message : 'Failed to update live caps.');
                        liveCapsStatus.classList.remove('text-muted', 'text-success');
                        liveCapsStatus.classList.add('text-warning');
                    }
                    Swal.fire({
                        title: 'Update Failed',
                        text: String(error && error.message ? error.message : 'Failed to update live caps.'),
                        icon: 'error',
                        background: '#141419',
                        color: '#ffffff',
                        confirmButtonColor: '#ef4444'
                    });
                } finally {
                    applyLiveCapsBtn.disabled = false;
                }
            });

            // Save Changes Handler
            document.getElementById('saveChangesBtn')?.addEventListener('click', function () {
                Swal.fire({
                    title: 'Save Changes?',
                    text: "Apply these new configurations to the server?",
                    imageUrl: SECURITY_ROCKY,
                    imageWidth: 150,
                    imageAlt: 'Security Rocky',
                    showCancelButton: true,
                    confirmButtonColor: '#3b82f6',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, save it!',
                    background: '#141419',
                    color: '#ffffff',
                    customClass: {
                        popup: 'border border-secondary border-opacity-10 shadow-lg',
                        title: 'text-light fw-bold'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('edit-server-form').submit();
                    }
                });
            });

            // Safe Delete Handler
            document.getElementById('safeDeleteBtn')?.addEventListener('click', function () {
                Swal.fire({
                    title: 'Safe Deletion',
                    text: "This will remove the server from the panel and cleanup all files on the connector. Are you sure?",
                    imageUrl: SAD_ROCKY,
                    imageWidth: 150,
                    imageAlt: 'Sad Rocky',
                    showCancelButton: true,
                    confirmButtonColor: '#3b82f6',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, cleanup & delete',
                    background: '#141419',
                    color: '#ffffff',
                    customClass: {
                        popup: 'border border-secondary border-opacity-10 shadow-lg',
                        title: 'text-light fw-bold'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.getElementById('delete-form');
                        form.action = '/admin/servers/delete/<%= server.containerId %>';
                        form.submit();
                    }
                });
            });

            // Force Delete Handler
            document.getElementById('forceDeleteBtn')?.addEventListener('click', function () {
                Swal.fire({
                    title: 'CRITICAL WARNING!',
                    html: `
                        <div class="text-start">
                            <p class="mb-3">You are about to perform a <span class="text-danger fw-bold">FORCED DELETION</span>.</p>
                            <ul class="small text-muted">
                                <li>The server will be removed from the Panel immediately.</li>
                                <li class="text-warning">Residual files may remain on the connector (requires manual cleanup later).</li>
                                <li>Use this ONLY if the node is permanently dead or unreachable.</li>
                            </ul>
                        </div>
                    `,
                    imageUrl: SECURITY_ROCKY,
                    imageWidth: 150,
                    imageAlt: 'Security Rocky',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'FORCE DELETE',
                    background: '#141419',
                    color: '#ffffff',
                    customClass: {
                        popup: 'border border-danger border-opacity-20 shadow-lg',
                        title: 'text-danger fw-bold fs-4'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.getElementById('delete-form');
                        form.action = '/admin/servers/delete/<%= server.containerId %>?force=true';
                        form.submit();
                    }
                });
            });

            // Suspend Handler
            document.getElementById('suspendBtn')?.addEventListener('click', function () {
                Swal.fire({
                    title: 'Suspend Server?',
                    html: `<div class="text-start mb-3">
                        <p class="mb-1">This will <strong>stop the server</strong> and prevent users from controlling it.</p>
                        <p class="small text-muted mb-0">You can unsuspend it at any time from this page.</p>
                    </div>`,
                    input: 'textarea',
                    inputPlaceholder: 'Reason for suspension (will be shown to the user)...',
                    inputAttributes: { 'aria-label': 'Suspension reason', rows: 3 },
                    imageUrl: SAD_ROCKY,
                    imageWidth: 120,
                    imageAlt: 'Sad Rocky',
                    showCancelButton: true,
                    confirmButtonColor: '#f59e0b',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, suspend it',
                    background: '#141419',
                    color: '#ffffff',
                    customClass: {
                        popup: 'border border-warning border-opacity-15 shadow-lg',
                        title: 'text-warning fw-bold',
                        input: 'mt-2 bg-dark text-light border-secondary'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('suspend-reason-input').value = result.value || '';
                        document.getElementById('suspend-form').submit();
                    }
                });
            });

            // Unsuspend Handler
            document.getElementById('unsuspendBtn')?.addEventListener('click', function () {
                Swal.fire({
                    title: 'Unsuspend Server?',
                    text: 'The server will return to an offline state and users can control it again.',
                    imageUrl: SECURITY_ROCKY,
                    imageWidth: 130,
                    imageAlt: 'Security Rocky',
                    showCancelButton: true,
                    confirmButtonColor: '#22c55e',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, unsuspend',
                    background: '#141419',
                    color: '#ffffff',
                    customClass: {
                        popup: 'border border-success border-opacity-15 shadow-lg',
                        title: 'text-success fw-bold'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('unsuspend-form').submit();
                    }
                });
            });

            // Reinstall Handler
            document.getElementById('reinstallBtn')?.addEventListener('click', function () {
                Swal.fire({
                    title: 'Reinstall Server?',
                    html: `<div class="text-start">
                        <p class="mb-3">This will trigger a <strong>full reinstallation</strong> of the server.</p>
                        <ul class="small text-muted">
                            <li class="text-warning">All server files may be overwritten by the installation script.</li>
                            <li>User data may be lost if not backed up.</li>
                            <li>The connector must be online for this to work.</li>
                        </ul>
                    </div>`,
                    imageUrl: SECURITY_ROCKY,
                    imageWidth: 130,
                    imageAlt: 'Security Rocky',
                    showCancelButton: true,
                    confirmButtonColor: '#6366f1',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, reinstall',
                    background: '#141419',
                    color: '#ffffff',
                    customClass: {
                        popup: 'border border-secondary border-opacity-20 shadow-lg',
                        title: 'text-light fw-bold'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('reinstall-form').submit();
                    }
                });
            });
        </script>
</body>

</html>

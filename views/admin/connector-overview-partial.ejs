<%- include ('../partials/error-modal') %>
<!-- Resource Usage Cards -->
<% const isOnline=statusData && statusData.status==='online' && (new Date() - new Date(statusData.lastSeen)) < 30000;
    const allocUsage = allocatedUsage || { memoryGb: 0, diskGb: 0 };
    const memUsed = Number(allocUsage.memoryGb || 0);
    const diskUsed = Number(allocUsage.diskGb || 0);
    const totalMemoryGb = Number(connector.totalMemory || 0);
    const totalDiskGb = Number(connector.totalDisk || 0);
    const memPercent = totalMemoryGb > 0 ? Math.min(100, Math.round((memUsed / totalMemoryGb) * 100)) : 0;
    const diskPercent = totalDiskGb > 0 ? Math.min(100, Math.round((diskUsed / totalDiskGb) * 100)) : 0; %>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background-color: #141419;">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold mb-3">Memory Allocated</h6>
                <div class="d-flex align-items-end justify-content-between mb-2">
                    <h3 class="text-light mb-0" id="memUsedText">
                        <%= memUsed.toFixed(1) %> GB
                    </h3>
                    <span class="text-muted small">of <%= totalMemoryGb.toFixed(1) %> GB</span>
                </div>
                <div class="progress" style="height: 6px; background-color: rgba(255,255,255,0.05);">
                    <div class="progress-bar bg-primary" id="memProgressBar" role="progressbar"
                        style="width: <%= memPercent %>%"></div>
                </div>
                <div class="mt-3 text-muted x-small">
                    Allocation: <%= connector.memoryOverAllocation %>% Over-provisioning allowed
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background-color: #141419;">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold mb-3">Storage Allocated</h6>
                <div class="d-flex align-items-end justify-content-between mb-2">
                    <h3 class="text-light mb-0" id="diskUsedText">
                        <%= diskUsed.toFixed(1) %> GB
                    </h3>
                    <span class="text-muted small">of <%= totalDiskGb.toFixed(1) %> GB</span>
                </div>
                <div class="progress" style="height: 6px; background-color: rgba(255,255,255,0.05);">
                    <div class="progress-bar bg-warning" id="diskProgressBar" role="progressbar"
                        style="width: <%= diskPercent %>%"></div>
                </div>
                <div class="mt-3 text-muted x-small">
                    Allocation: <%= connector.diskOverAllocation %>% Over-provisioning allowed
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background-color: #141419;">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold mb-3">Connection Status</h6>
                <div class="d-flex align-items-center gap-2 mb-2" id="statusBadgeContainer">
                    <% if (isOnline) { %>
                        <span
                            class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
                            <i class="bi bi-circle-fill small me-2"></i>ONLINE
                        </span>
                        <% } else { %>
                            <span
                                class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2">
                                <i class="bi bi-circle-fill small me-2"></i>OFFLINE
                            </span>
                            <% } %>
                </div>
                <div class="text-muted small mt-2" id="lastSeenText">
                    Last seen: <%= statusData.lastSeen ? new Date(statusData.lastSeen).toLocaleString() : 'Never' %>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background-color: #141419;">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold mb-3">Configuration</h6>
                <ul class="list-unstyled text-muted small mb-0">
                    <li class="mb-2"><strong class="text-light">SFTP Port:</strong>
                        <%= connector.sftpPort %>
                    </li>
                    <li class="mb-2"><strong class="text-light">File Dir:</strong>
                        <%= connector.fileDirectory %>
                    </li>
                    <li class="mb-2"><strong class="text-light">SSL:</strong>
                        <%= connector.ssl ? 'Enabled' : 'Disabled' %>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background-color: #141419;">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h6 class="text-light mb-1">Support The Dev</h6>
                    <p class="text-muted small mb-0">If this panel helps your infrastructure, you can support ongoing development.</p>
                </div>
                <a href="https://ko-fi.com/S6S11A22SE" target="_blank" rel="noopener noreferrer" aria-label="Support the developer on Ko-fi">
                    <img src="https://storage.ko-fi.com/cdn/kofi5.png?v=6" alt="Support the developer on Ko-fi" style="height:36px;border:0;">
                </a>
            </div>
        </div>
    </div>

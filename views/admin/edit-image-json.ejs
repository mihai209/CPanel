<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit JSON | <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <style>
            :root {
                --editor-bg: #0b0b0e;
                --glass-bg: rgba(20, 20, 25, 0.7);
                --glass-border: rgba(255, 255, 255, 0.08);
                --accent-color: #3b82f6;
            }

            body {
                background-color: #09090b;
            }

            .admin-content {
                background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.05), transparent 400px),
                    radial-gradient(circle at bottom left, rgba(99, 102, 241, 0.05), transparent 400px);
            }

            .editor-container-wrapper {
                background: var(--glass-bg);
                backdrop-filter: blur(12px);
                border: 1px solid var(--glass-border);
                border-radius: 1rem;
                overflow: hidden;
                box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2), 0 10px 10px -5px rgba(0, 0, 0, 0.1);
                transition: all 0.3s ease;
            }

            .editor-container-wrapper:hover {
                border-color: rgba(59, 130, 246, 0.3);
            }

            .editor-toolbar {
                background: rgba(255, 255, 255, 0.03);
                border-bottom: 1px solid var(--glass-border);
                padding: 0.75rem 1.25rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            #monaco-editor-container {
                height: 600px;
                width: 100%;
            }

            .btn-editor {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: #d1d5db;
                padding: 0.4rem 0.8rem;
                font-size: 0.8rem;
                font-weight: 500;
                border-radius: 0.5rem;
                transition: all 0.2s ease;
            }

            .btn-editor:hover {
                background: rgba(255, 255, 255, 0.1);
                color: #fff;
                border-color: var(--accent-color);
            }

            .btn-editor-primary {
                background: var(--accent-color);
                border-color: var(--accent-color);
                color: white;
            }

            .btn-editor-primary:hover {
                background: #2563eb;
                box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
            }

            .editor-status {
                font-size: 0.75rem;
                color: #6b7280;
                font-family: 'JetBrains Mono', monospace;
            }

            .breadcrumb-admin a {
                transition: color 0.2s ease;
            }

            .breadcrumb-admin a:hover {
                color: var(--accent-color) !important;
            }

            /* Monaco overrides */
            .monaco-editor,
            .monaco-editor .margin,
            .monaco-editor-background {
                background-color: var(--editor-bg) !important;
            }
        </style>
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <%- include('../partials/admin-sidebar') %>
                <div class="admin-content">
                    <div class="admin-header">
                        <div>
                            <div class="d-flex align-items-center gap-2">
                                <h4 class="mb-0 text-light fw-bold">Edit Image JSON</h4>
                                <span
                                    class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20 rounded-pill px-3">RAW</span>
                            </div>
                            <small class="text-muted">
                                <%= image.name %>
                            </small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span>
                            <a href="/admin/images">Images</a> <span class="mx-2">&gt;</span>
                            <a href="/admin/images/edit/<%= image.id %>">Edit</a> <span class="mx-2">&gt;</span>
                            <span class="text-light">JSON</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <% if (success) { %>
                            <div
                                class="alert alert-success border-0 bg-success bg-opacity-10 text-success mb-4 rounded-4">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <%= success %>
                            </div>
                            <% } %>
                                <% if (error) { %>
                                    <div
                                        class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger mb-4 rounded-4">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <%= error %>
                                    </div>
                                    <% } %>

                                        <div
                                            class="mb-4 p-4 rounded-4 border border-danger border-opacity-10 bg-danger bg-opacity-10 shadow-sm">
                                            <div class="d-flex gap-3">
                                                <div class="text-danger fs-4"><i class="bi bi-exclamation-octagon"></i>
                                                </div>
                                                <div>
                                                    <h6 class="text-danger fw-bold mb-1">Advanced Mode Caution</h6>
                                                    <p class="text-light opacity-75 small mb-0">
                                                        You are directly editing the raw image configuration. Invalid
                                                        JSON structure or missing required fields can cause significant
                                                        issues with server deployments. Fields like <code>id</code>,
                                                        <code>createdAt</code>, and <code>updatedAt</code> are protected
                                                        and will be ignored by the server.
                                                    </p>
                                                </div>
                                            </div>
                                        </div>

                                        <form id="json-form" method="POST"
                                            action="/admin/images/edit-json/<%= image.id %>">
                                            <textarea name="jsonPayload" id="hidden-json-input"
                                                style="display:none;"></textarea>

                                            <div class="row g-3 mb-4">
                                                <div class="col-md-12">
                                                    <label
                                                        class="form-label text-muted small text-uppercase fw-bold m-0 mb-2">Package
                                                        (Nest)</label>
                                                    <select name="packageId" form="json-form" class="form-select"
                                                        required
                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;">
                                                        <option value="" disabled>Select a package...</option>
                                                        <% if (packages && packages.length> 0) { %>
                                                            <% packages.forEach(pkg=> { %>
                                                                <option value="<%= pkg.id %>" <%=image.packageId==pkg.id
                                                                    ? 'selected' : '' %>><%= pkg.name %>
                                                                </option>
                                                                <% }) %>
                                                                    <% } %>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="editor-container-wrapper">
                                                <div class="editor-toolbar">
                                                    <div class="d-flex gap-2 align-items-center">
                                                        <button type="button" class="btn btn-editor"
                                                            id="format-json-btn" title="Format JSON (Shift+Alt+F)">
                                                            <i class="bi bi-code-square me-2"></i>Format
                                                        </button>
                                                        <button type="button" class="btn btn-editor" id="copy-json-btn"
                                                            title="Copy to Clipboard">
                                                            <i class="bi bi-clipboard me-2"></i>Copy
                                                        </button>
                                                        <div class="vr mx-2 bg-secondary opacity-25"></div>
                                                        <span class="editor-status" id="validation-status">
                                                            <i class="bi bi-check2-circle text-success me-1"></i>Valid
                                                            JSON
                                                        </span>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <a href="/admin/images/edit/<%= image.id %>"
                                                            class="btn btn-editor">Cancel</a>
                                                        <button type="submit"
                                                            class="btn btn-editor btn-editor-primary px-4 fw-bold">
                                                            <i class="bi bi-save me-2"></i>Save Changes
                                                        </button>
                                                    </div>
                                                </div>
                                                <div id="monaco-editor-container"></div>
                                            </div>
                                        </form>

                    </div>
                </div>
        </div>

        <!-- Monaco Editor Resources -->
        <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>
        <script>
            let editor;
            const initialContent = <%- JSON.stringify(JSON.stringify(image, null, 2)) %>;

            require.config({ paths: { 'vs': 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' } });

            require(['vs/editor/editor.main'], function () {
                monaco.editor.defineTheme('cpanel-dark', {
                    base: 'vs-dark',
                    inherit: true,
                    rules: [
                        { token: 'string.key.json', foreground: '9cdcfe' },
                        { token: 'string.value.json', foreground: 'ce9178' },
                        { token: 'number', foreground: 'b5cea8' },
                        { token: 'keyword.json', foreground: '569cd6' }
                    ],
                    colors: {
                        'editor.background': '#0b0b0e',
                        'editor.lineHighlightBackground': '#1a1a20',
                        'editorLineNumber.foreground': '#4b5563',
                        'editorLineNumber.activeForeground': '#9ca3af',
                        'editorIndentGuide.background': '#1f2937'
                    }
                });

                editor = monaco.editor.create(document.getElementById('monaco-editor-container'), {
                    value: initialContent,
                    language: 'json',
                    theme: 'cpanel-dark',
                    automaticLayout: true,
                    minimap: { enabled: true },
                    fontSize: 14,
                    fontFamily: "'JetBrains Mono', 'Fira Code', monospace",
                    scrollBeyondLastLine: false,
                    padding: { top: 20, bottom: 20 },
                    lineNumbersMinChars: 3,
                    wordWrap: 'on',
                    formatOnPaste: true,
                    formatOnType: true
                });

                // Handle validation status
                editor.onDidChangeModelDecorations(() => {
                    const model = editor.getModel();
                    const markers = monaco.editor.getModelMarkers({ owner: 'json' });
                    const statusEl = document.getElementById('validation-status');

                    if (markers.some(m => m.severity === monaco.MarkerSeverity.Error)) {
                        statusEl.innerHTML = `<i class="bi bi-x-circle text-danger me-1"></i>Invalid JSON`;
                    } else {
                        statusEl.innerHTML = `<i class="bi bi-check2-circle text-success me-1"></i>Valid JSON`;
                    }
                });

                // Form submission
                document.getElementById('json-form').addEventListener('submit', function (e) {
                    const content = editor.getValue();
                    try {
                        JSON.parse(content);
                        document.getElementById('hidden-json-input').value = content;
                    } catch (err) {
                        e.preventDefault();
                        alert('Cannot save invalid JSON. Please fix the errors highlighted in the editor.');
                    }
                });

                // Toolbar actions
                document.getElementById('format-json-btn').addEventListener('click', formatJson);
                document.getElementById('copy-json-btn').addEventListener('click', copyJson);
            });

            function formatJson() {
                editor.getAction('editor.action.formatDocument').run();
            }

            async function copyJson() {
                const content = editor.getValue();
                try {
                    await navigator.clipboard.writeText(content);
                    const btn = document.getElementById('copy-json-btn');
                    const originalHtml = btn.innerHTML;
                    btn.innerHTML = '<i class="bi bi-check2 me-2"></i>Copied!';
                    btn.classList.add('text-success');
                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                        btn.classList.remove('text-success');
                    }, 2000);
                } catch (err) {
                    console.error('Failed to copy: ', err);
                }
            }
        </script>
</body>

</html>

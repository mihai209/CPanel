<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> - Manage Connector
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
        <style>
            .connector-sidebar {
                background-color: #141419;
                border-right: 1px solid #2d2d35;
                min-height: calc(100vh - 120px);
            }

            .connector-nav .nav-link {
                color: #a0a0a0;
                padding: 12px 20px;
                border-left: 3px solid transparent;
                transition: all 0.2s;
            }

            .connector-nav .nav-link:hover {
                color: #fff;
                background-color: rgba(255, 255, 255, 0.05);
            }

            .connector-nav .nav-link.active {
                color: #fff;
                background-color: rgba(67, 97, 238, 0.1);
                border-left-color: #4361ee;
            }
        </style>
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <%- include('../partials/admin-sidebar') %>

                <div class="admin-content">
                    <!-- Header -->
                    <div class="admin-header">
                        <div class="d-flex align-items-baseline gap-3">
                            <h4 class="mb-0 text-light fw-normal">Manage Connector</h4>
                            <small class="text-muted">
                                <%= connector.name %>
                            </small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span>
                            <a href="/admin/connectors">Connectors</a> <span class="mx-2">&gt;</span>
                            <span class="text-light">Manage</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <div class="row">
                            <!-- Sub-Sidebar -->
                            <div class="col-md-3 col-lg-2 p-0">
                                <div class="connector-sidebar rounded-3 shadow-sm mx-2">
                                    <div class="p-4 border-bottom border-secondary border-opacity-10">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="p-2 rounded bg-primary bg-opacity-10 text-primary">
                                                <i class="bi bi-diagram-3-fill fs-4"></i>
                                            </div>
                                            <div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <h6 class="mb-0 text-light fw-bold">
                                                        <%= connector.name %>
                                                    </h6>
                                                    <% const isOnline=statusData && statusData.status==='online' && (new
                                                        Date() - new Date(statusData.lastSeen)) < 30000; %>
                                                        <span id="sidebarStatusDot"
                                                            class="status-indicator <%= isOnline ? 'online' : 'offline' %>"
                                                            style="width: 8px; height: 8px; border-radius: 50%; display: inline-block; background-color: <%= isOnline ? '#10b981' : '#ef4444' %>; box-shadow: 0 0 10px <%= isOnline ? 'rgba(16, 185, 129, 0.4)' : 'rgba(239, 68, 68, 0.4)' %>;"></span>
                                                </div>
                                                <small class="text-muted">
                                                    <%= connector.fqdn %>
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                    <nav class="nav flex-column connector-nav py-2">
                                        <a class="nav-link <%= currentTab === 'overview' ? 'active' : '' %>"
                                            href="/admin/connectors/<%= connector.id %>/manage">
                                            <i class="bi bi-speedometer2 me-2"></i> Overview
                                        </a>
                                        <a class="nav-link <%= currentTab === 'allocations' ? 'active' : '' %>"
                                            href="/admin/connectors/<%= connector.id %>/allocations">
                                            <i class="bi bi-signpost-split me-2"></i> Allocations
                                        </a>
                                        <a class="nav-link <%= currentTab === 'configuration' ? 'active' : '' %>"
                                            href="/admin/connectors/<%= connector.id %>/configuration">
                                            <i class="bi bi-gear me-2"></i> Configuration
                                        </a>
                                    </nav>
                                </div>
                            </div>

                            <!-- Main Content Area -->
                            <div class="col-md-9 col-lg-10">
                                <% if (currentTab==='overview' ) { %>
                                    <!-- OVERVIEW CONTENT -->
                                    <div class="row g-4">
                                        <%- include('connector-overview-partial', { connector, statusData, allocatedUsage }) %>
                                    </div>
                                    <% } else if (currentTab==='allocations' ) { %>
                                        <!-- ALLOCATIONS CONTENT -->
                                        <div class="card border-0 shadow-sm" style="background-color: #1a1a20;">
                                            <div
                                                class="card-header border-bottom border-secondary border-opacity-10 bg-transparent py-3 d-flex justify-content-between align-items-center">
                                                <h5 class="mb-0 text-light fw-bold">Allocations</h5>
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-danger btn-sm" id="bulkDeleteBtn" disabled
                                                        data-bs-toggle="modal" data-bs-target="#bulkDeleteModal">
                                                        <i class="bi bi-trash me-1"></i> Delete Selected
                                                    </button>
                                                    <button class="btn btn-outline-info btn-sm" id="bulkAliasBtn" disabled
                                                        data-bs-toggle="modal" data-bs-target="#bulkAliasModal">
                                                        <i class="bi bi-pencil-square me-1"></i> Bulk Alias
                                                    </button>
                                                    <button class="btn btn-primary btn-sm fw-bold"
                                                        data-bs-toggle="modal" data-bs-target="#createAllocationModal">
                                                        <i class="bi bi-plus-lg me-1"></i> Assign New
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="card-body p-0">
                                                <div class="table-responsive">
                                                    <table class="table table-dark table-hover mb-0 align-middle"
                                                        style="background-color: transparent;">
                                                        <thead class="text-secondary text-uppercase small bg-opacity-10"
                                                            style="background-color: #141419;">
                                                            <tr>
                                                                <th class="ps-4 py-3" style="width: 40px;">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox"
                                                                            id="selectAll">
                                                                    </div>
                                                                </th>
                                                                <th class="py-3">IP Address</th>
                                                                <th class="py-3">Port</th>
                                                                <th class="py-3">Alias</th>
                                                                <th class="py-3">Notes</th>
                                                                <th class="py-3">Assigned To</th>
                                                                <th class="py-3 text-end pe-4">Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody class="border-secondary border-opacity-10">
                                                            <% if (allocations && allocations.length> 0) { %>
                                                                <% allocations.forEach(alloc=> { %>
                                                                    <tr>
                                                                        <td class="ps-4">
                                                                            <div class="form-check">
                                                                                <input
                                                                                    class="form-check-input alloc-check"
                                                                                    type="checkbox"
                                                                                    value="<%= alloc.id %>">
                                                                            </div>
                                                                        </td>
                                                                        <td><code
                                                                                class="text-primary"><%= alloc.ip %></code>
                                                                        </td>
                                                                        <td><span
                                                                                class="badge bg-secondary bg-opacity-25 text-light fw-normal">
                                                                                <%= alloc.port %>
                                                                            </span></td>
                                                                        <td>
                                                                            <span class="alias-display"
                                                                                data-id="<%= alloc.id %>"
                                                                                style="cursor: pointer;"
                                                                                title="Click to edit">
                                                                                <span class="alias-text"><%= alloc.alias || '-' %></span>
                                                                                    <i class="bi bi-pencil-fill ms-1 text-muted"
                                                                                        style="font-size: 0.7rem;"></i>
                                                                            </span>
                                                                            <form class="alias-edit d-none"
                                                                                data-id="<%= alloc.id %>"
                                                                                style="display: inline-block;">
                                                                                <input type="text"
                                                                                    class="form-control form-control-sm d-inline-block"
                                                                                    value="<%= alloc.alias || '' %>"
                                                                                    style="width: 150px; background-color: #141419; border-color: #2d2d35; color: white;">
                                                                                <button type="submit"
                                                                                    class="btn btn-sm btn-success ms-1"><i
                                                                                        class="bi bi-check"></i></button>
                                                                                <button type="button"
                                                                                    class="btn btn-sm btn-secondary alias-cancel"><i
                                                                                        class="bi bi-x"></i></button>
                                                                            </form>
                                                                        </td>
                                                                        <td>
                                                                            <span class="notes-display"
                                                                                data-id="<%= alloc.id %>"
                                                                                style="cursor: pointer;"
                                                                                title="Click to edit">
                                                                                <span class="notes-text"><%= alloc.notes || '-' %></span>
                                                                                    <i class="bi bi-pencil-fill ms-1 text-muted"
                                                                                        style="font-size: 0.7rem;"></i>
                                                                            </span>
                                                                            <form class="notes-edit d-none"
                                                                                data-id="<%= alloc.id %>"
                                                                                style="display: inline-block;">
                                                                                <input type="text" maxlength="20"
                                                                                    class="form-control form-control-sm d-inline-block"
                                                                                    value="<%= alloc.notes || '' %>"
                                                                                    style="width: 170px; background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                    placeholder="max 20 chars">
                                                                                <button type="submit"
                                                                                    class="btn btn-sm btn-success ms-1"><i
                                                                                        class="bi bi-check"></i></button>
                                                                                <button type="button"
                                                                                    class="btn btn-sm btn-secondary notes-cancel"><i
                                                                                        class="bi bi-x"></i></button>
                                                                            </form>
                                                                        </td>
                                                                        <td>
                                                                            <% const assignedServer = alloc.assignedServer || alloc.server || null; %>
                                                                            <% if (assignedServer && assignedServer.containerId) { %>
                                                                                <a href="/admin/servers/<%= assignedServer.containerId %>/manage"
                                                                                    class="text-decoration-none text-light">
                                                                                    <i class="bi bi-hdd-network me-1"></i>
                                                                                    <%= assignedServer.name || (`Server #${assignedServer.id}`) %>
                                                                                </a>
                                                                            <% } else if (assignedServer) { %>
                                                                                <span class="text-light">
                                                                                    <i class="bi bi-hdd-network me-1"></i>
                                                                                    <%= assignedServer.name || (`Server #${assignedServer.id}`) %>
                                                                                </span>
                                                                            <% } else if (alloc.serverId) { %>
                                                                                <span class="text-warning fst-italic">Server #<%= alloc.serverId %> (missing)</span>
                                                                            <% } else { %>
                                                                                <span class="text-muted fst-italic">Unassigned</span>
                                                                            <% } %>
                                                                        </td>
                                                                        <td class="text-end pe-4">
                                                                            <form
                                                                                action="/admin/connectors/<%= connector.id %>/allocations/delete"
                                                                                method="POST" class="d-inline">
                                                                                <input type="hidden" name="ids[]"
                                                                                    value="<%= alloc.id %>">
                                                                                <button type="submit"
                                                                                    class="btn btn-link text-danger p-0">
                                                                                    <i class="bi bi-trash"></i>
                                                                                </button>
                                                                            </form>
                                                                        </td>
                                                                    </tr>
                                                                    <% }); %>
                                                                        <% } else { %>
                                                                            <tr>
                                                                                <td colspan="7"
                                                                                    class="text-center py-5 text-muted">
                                                                                    <i
                                                                                        class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                                                                    No allocations found for this
                                                                                    connector.
                                                                                </td>
                                                                            </tr>
                                                                            <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        <% } else if (currentTab==='configuration' ) { %>
                                            <!-- CONFIGURATION CONTENT -->
                                            <div class="card border-0 shadow-sm" style="background-color: #1a1a20;">
                                                <div
                                                    class="card-header border-bottom border-secondary border-opacity-10 bg-transparent py-3">
                                                    <h5 class="mb-0 text-light fw-bold">Connector Configuration</h5>
                                                </div>
                                                <div class="card-body p-4">
                                                    <!-- Authentication Token -->
                                                    <div class="mb-4">
                                                        <label
                                                            class="form-label text-muted small text-uppercase fw-bold">Authentication
                                                            Token</label>
                                                        <div class="input-group">
                                                            <input type="password" id="tokenInput" class="form-control"
                                                                value="<%= connector.token %>" readonly
                                                                style="background-color: #141419; border-color: #2d2d35; color: white; font-family: monospace;">
                                                            <button class="btn btn-outline-secondary" type="button"
                                                                id="toggleToken">
                                                                <i class="bi bi-eye" id="toggleIcon"></i>
                                                            </button>
                                                            <button class="btn btn-outline-secondary" type="button"
                                                                id="copyToken" title="Copy to clipboard">
                                                                <i class="bi bi-clipboard"></i>
                                                            </button>
                                                        </div>
                                                        <small class="text-muted">This token is used by the connector
                                                            daemon to authenticate with the panel.</small>
                                                    </div>

                                                    <!-- Configuration File -->
                                                    <div class="mb-4">
                                                        <div
                                                            class="d-flex justify-content-between align-items-center mb-2">
                                                            <label
                                                                class="form-label text-muted small text-uppercase fw-bold mb-0">Configuration
                                                                File (config.json)</label>
                                                            <button class="btn btn-sm btn-outline-primary" type="button"
                                                                id="copyConfig">
                                                                <i class="bi bi-clipboard me-2"></i>Copy Config
                                                            </button>
                                                        </div>
                                                        <pre id="configDisplay" class="p-3 rounded mb-0"
                                                            style="background-color: #141419; border: 1px solid #2d2d35; color: #a5acff; font-family: monospace; font-size: 0.85rem; max-height: 400px; overflow-y: auto;"><%= configJson %></pre>
                                                    </div>

                                                    <div class="mb-4">
                                                        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-2">
                                                            <label class="form-label text-muted small text-uppercase fw-bold mb-0">Web Server Template</label>
                                                            <div class="d-flex gap-2">
                                                                <button class="btn btn-sm btn-outline-secondary" type="button" id="copyWebTemplate">
                                                                    <i class="bi bi-clipboard me-1"></i>Copy
                                                                </button>
                                                                <a class="btn btn-sm btn-outline-primary" id="webTemplateDownload"
                                                                    href="/admin/connectors/<%= connector.id %>/webserver-template?type=<%= webServerTemplateType || 'standalone' %>&download=1">
                                                                    <i class="bi bi-download me-1"></i>Download
                                                                </a>
                                                            </div>
                                                        </div>
                                                        <div class="mb-2">
                                                            <select class="form-select" id="webTemplateType"
                                                                style="background-color: #141419; border-color: #2d2d35; color: white; max-width: 260px;">
                                                                <option value="standalone" <%= webServerTemplateType === 'standalone' ? 'selected' : '' %>>Standalone</option>
                                                                <option value="nginx" <%= webServerTemplateType === 'nginx' ? 'selected' : '' %>>Nginx</option>
                                                                <option value="apache2" <%= webServerTemplateType === 'apache2' ? 'selected' : '' %>>Apache2</option>
                                                            </select>
                                                        </div>
                                                        <pre id="webTemplateDisplay" class="p-3 rounded mb-0"
                                                            style="background-color: #141419; border: 1px solid #2d2d35; color: #9cc7ff; font-family: monospace; font-size: 0.85rem; max-height: 350px; overflow-y: auto;"><%= webServerTemplateContent || '' %></pre>
                                                        <small class="text-muted d-block mt-2">Template-ul este precompletat cu URL-ul panel-ului curent.</small>
                                                    </div>

                                                    <div class="mb-4">
                                                        <label
                                                            class="form-label text-muted small text-uppercase fw-bold">Allowed
                                                            Panel URLs</label>
                                                        <div class="p-3 rounded"
                                                            style="background-color: #141419; border: 1px solid #2d2d35;">
                                                            <% if (allowedOrigins && allowedOrigins.length > 0) { %>
                                                                <% allowedOrigins.forEach((origin) => { %>
                                                                    <div><code class="text-info"><%= origin %></code>
                                                                    </div>
                                                                <% }) %>
                                                            <% } else { %>
                                                                <div class="text-muted small">No explicit allowlist
                                                                    found.</div>
                                                            <% } %>
                                                        </div>
                                                    </div>

                                                    <!-- Actions -->
                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-warning" data-bs-toggle="modal"
                                                            data-bs-target="#regenerateTokenModal">
                                                            <i class="bi bi-arrow-clockwise me-2"></i>Regenerate Token
                                                        </button>
                                                    </div>

                                                    <!-- Config Info -->
                                                    <div class="mt-4 p-3 rounded"
                                                        style="background-color: rgba(67, 97, 238, 0.1); border-left: 3px solid #4361ee;">
                                                        <h6 class="text-light mb-2"><i
                                                                class="bi bi-info-circle me-2"></i>How to use</h6>
                                                        <ol class="text-muted small mb-0">
                                                            <li>Copy the configuration JSON from the box above.</li>
                                                            <li>Create a file named <code>config.json</code> on your
                                                                connector server.</li>
                                                            <li>Paste the configuration into that file.</li>
                                                            <li>Place it in the connector daemon's directory (e.g.,
                                                                <code>/etc/cpanel-connector/config.json</code>).
                                                            </li>
                                                            <li>Restart the connector daemon.</li>
                                                        </ol>
                                                    </div>
                                                </div>
                                            </div>
                                            <% } %>
                            </div>
                        </div>
                    </div>
                    <%- include('../partials/footer') %>
                </div>
        </div>

        <!-- Create Allocation Modal -->
        <div class="modal fade" id="createAllocationModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg text-start"
                    style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                    <div class="modal-header border-bottom border-secondary border-opacity-10">
                        <h5 class="modal-title fs-6 fw-bold text-light">Assign New Allocation</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <form action="/admin/connectors/<%= connector.id %>/allocations" method="POST">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">IP Address</label>
                                <input type="text" name="ip" class="form-control"
                                    style="background-color: #141419; border-color: #2d2d35; color: white;" required
                                    placeholder="192.168.1.1">
                            </div>
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-muted small text-uppercase fw-bold">Start Port</label>
                                    <input type="number" name="port" id="startPort" class="form-control"
                                        style="background-color: #141419; border-color: #2d2d35; color: white;" required
                                        placeholder="25565">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small text-uppercase fw-bold">End Port
                                        (Optional)</label>
                                    <input type="number" name="portEnd" id="endPort" class="form-control"
                                        style="background-color: #141419; border-color: #2d2d35; color: white;"
                                        placeholder="25570">
                                    <small class="text-muted" style="font-size: 0.75rem;">Leave empty for single
                                        port</small>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">Alias
                                    (Optional)</label>
                                <input type="text" name="alias" class="form-control"
                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                    placeholder="play.example.com">
                            </div>
                            <div class="mb-1">
                                <label class="form-label text-muted small text-uppercase fw-bold">Notes
                                    (Optional)</label>
                                <input type="text" name="notes" maxlength="20" class="form-control"
                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                    placeholder="max 20 chars">
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary border-opacity-10">
                            <button type="button" class="btn btn-link text-muted text-decoration-none fw-medium"
                                data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Add Allocation</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Bulk Delete Modal -->
        <div class="modal fade" id="bulkDeleteModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg text-start"
                    style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                    <div class="modal-header border-bottom border-secondary border-opacity-10">
                        <h5 class="modal-title fs-6 fw-bold text-light">Confirm Bulk Delete</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        Are you sure you want to delete the selected allocations? This action cannot be undone.
                    </div>
                    <div class="modal-footer border-top border-secondary border-opacity-10">
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-medium"
                            data-bs-dismiss="modal">Cancel</button>
                        <form action="/admin/connectors/<%= connector.id %>/allocations/delete" method="POST"
                            id="bulkDeleteForm">
                            <!-- Inputs will be injected here via JS -->
                            <button type="submit" class="btn btn-danger px-4 fw-bold">Delete Selected</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bulk Alias Modal -->
        <div class="modal fade" id="bulkAliasModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg text-start"
                    style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                    <div class="modal-header border-bottom border-secondary border-opacity-10">
                        <h5 class="modal-title fs-6 fw-bold text-light">Bulk Update Alias</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <form id="bulkAliasForm">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">Alias Template</label>
                                <input
                                    type="text"
                                    id="bulkAliasInput"
                                    class="form-control"
                                    maxlength="191"
                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                    placeholder="play.example.com:{port}"
                                >
                                <small class="text-muted d-block mt-2">
                                    Tokens: <code>{ip}</code>, <code>{port}</code>, <code>{id}</code>, <code>{alias}</code>.
                                </small>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="bulkAliasClear">
                                <label class="form-check-label text-muted" for="bulkAliasClear">
                                    Clear alias on selected allocations
                                </label>
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary border-opacity-10">
                            <button type="button" class="btn btn-link text-muted text-decoration-none fw-medium"
                                data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-info px-4 fw-bold">Apply Alias</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Toast Notification -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="copyToast" class="toast align-items-center text-white bg-primary border-0" role="alert"
                aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle me-2"></i> Configuration copied to clipboard!
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                        aria-label="Close"></button>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <script>
            (() => {
                // Checkbox logic
                const selectAll = document.getElementById('selectAll');
                const checks = document.querySelectorAll('.alloc-check');
                const bulkBtn = document.getElementById('bulkDeleteBtn');
                const bulkAliasBtn = document.getElementById('bulkAliasBtn');
                const bulkForm = document.getElementById('bulkDeleteForm');
                const bulkAliasForm = document.getElementById('bulkAliasForm');
                const bulkAliasInput = document.getElementById('bulkAliasInput');
                const bulkAliasClear = document.getElementById('bulkAliasClear');
                const bulkAliasModal = document.getElementById('bulkAliasModal');
                const copyToast = document.getElementById('copyToast');

                function updateBulkBtn() {
                    const anyChecked = Array.from(checks).some(c => c.checked);
                    if (bulkBtn) bulkBtn.disabled = !anyChecked;
                    if (bulkAliasBtn) bulkAliasBtn.disabled = !anyChecked;
                }

                function getSelectedAllocationIds() {
                    return Array.from(checks)
                        .filter((c) => c.checked)
                        .map((c) => Number.parseInt(c.value, 10))
                        .filter((id) => Number.isInteger(id) && id > 0);
                }

                function setInlineValue(span, selector, value) {
                    if (!span) return;
                    const displayValue = value || '-';
                    const target = span.querySelector(selector);
                    if (target) {
                        target.textContent = displayValue;
                        return;
                    }
                    if (span.childNodes && span.childNodes[0]) {
                        span.childNodes[0].textContent = displayValue;
                    }
                }

                function showToast(message) {
                    if (!copyToast) return;
                    const body = copyToast.querySelector('.toast-body');
                    if (body) {
                        body.innerHTML = `<i class="bi bi-check-circle me-2"></i>${message}`;
                    }
                    const toast = new bootstrap.Toast(copyToast);
                    toast.show();
                }

                if (selectAll) {
                    selectAll.addEventListener('change', function () {
                        checks.forEach(c => c.checked = this.checked);
                        updateBulkBtn();
                    });
                }

                checks.forEach(c => {
                    c.addEventListener('change', updateBulkBtn);
                });
                updateBulkBtn();

                // Inject IDs into bulk form on submit
                if (bulkForm) {
                    bulkForm.addEventListener('submit', function () {
                        // Remove old hidden inputs
                        const oldInputs = this.querySelectorAll('input[name="ids[]"]');
                        oldInputs.forEach(i => i.remove());

                        // Add new ones
                        checks.forEach(c => {
                            if (c.checked) {
                                const input = document.createElement('input');
                                input.type = 'hidden';
                                input.name = 'ids[]';
                                input.value = c.value;
                                this.appendChild(input);
                            }
                        });
                    });
                }

                if (bulkAliasClear && bulkAliasInput) {
                    bulkAliasClear.addEventListener('change', function () {
                        bulkAliasInput.disabled = this.checked;
                    });
                }

                if (bulkAliasModal && bulkAliasClear && bulkAliasInput) {
                    bulkAliasModal.addEventListener('show.bs.modal', function () {
                        bulkAliasClear.checked = false;
                        bulkAliasInput.disabled = false;
                    });
                }

                if (bulkAliasForm) {
                    bulkAliasForm.addEventListener('submit', async function (e) {
                        e.preventDefault();
                        const ids = getSelectedAllocationIds();
                        if (ids.length === 0) {
                            alert('No allocations selected.');
                            return;
                        }

                        const clearMode = bulkAliasClear && bulkAliasClear.checked;
                        const aliasValue = bulkAliasInput ? bulkAliasInput.value.trim() : '';

                        if (!clearMode && !aliasValue) {
                            alert('Alias template is required unless clear mode is enabled.');
                            return;
                        }

                        const submitButton = this.querySelector('button[type="submit"]');
                        if (submitButton) submitButton.disabled = true;

                        try {
                            const res = await fetch(`/admin/connectors/<%= connector.id %>/allocations/alias/bulk`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    ids,
                                    mode: clearMode ? 'clear' : 'set',
                                    alias: aliasValue
                                })
                            });
                            const data = await res.json();
                            if (!res.ok || !data.success) {
                                throw new Error(data.error || 'Failed to bulk update aliases.');
                            }

                            const updated = Array.isArray(data.updated) ? data.updated : [];
                            updated.forEach((entry) => {
                                const id = Number.parseInt(entry && entry.id, 10);
                                if (!Number.isInteger(id) || id <= 0) return;
                                const span = document.querySelector(`.alias-display[data-id="${id}"]`);
                                const form = document.querySelector(`.alias-edit[data-id="${id}"]`);
                                if (span) {
                                    setInlineValue(span, '.alias-text', entry.alias || null);
                                    span.classList.remove('d-none');
                                }
                                if (form) {
                                    form.classList.add('d-none');
                                    const input = form.querySelector('input');
                                    if (input) input.value = entry.alias || '';
                                }
                            });

                            if (bulkAliasModal) {
                                const modalInstance = bootstrap.Modal.getInstance(bulkAliasModal);
                                if (modalInstance) modalInstance.hide();
                            }
                            showToast(`Updated alias for ${updated.length} allocation(s).`);
                        } catch (err) {
                            alert(err.message || 'Failed to bulk update aliases.');
                        } finally {
                            if (submitButton) submitButton.disabled = false;
                        }
                    });
                }

                // Inline alias editing
                document.querySelectorAll('.alias-display').forEach(span => {
                    span.addEventListener('click', function () {
                        const id = this.dataset.id;
                        const form = document.querySelector(`.alias-edit[data-id="${id}"]`);
                        if (!form) return;
                        this.classList.add('d-none');
                        form.classList.remove('d-none');
                        const input = form.querySelector('input');
                        if (input) input.focus();
                    });
                });

                document.querySelectorAll('.alias-edit').forEach(form => {
                    const id = form.dataset.id;
                    const span = document.querySelector(`.alias-display[data-id="${id}"]`);
                    const input = form.querySelector('input');
                    const cancelBtn = form.querySelector('.alias-cancel');

                    if (cancelBtn && span) {
                        // Handle cancel
                        cancelBtn.addEventListener('click', function () {
                            form.classList.add('d-none');
                            span.classList.remove('d-none');
                        });
                    }

                    // Handle submit
                    form.addEventListener('submit', async function (e) {
                        e.preventDefault();
                        const newAlias = input ? input.value.trim() : '';

                        try {
                            const res = await fetch(`/admin/connectors/<%= connector.id %>/allocations/${id}/alias`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ alias: newAlias })
                            });

                            const data = await res.json();
                            if (data.success && span) {
                                // Update display
                                setInlineValue(span, '.alias-text', data.alias || null);
                                form.classList.add('d-none');
                                span.classList.remove('d-none');
                            } else {
                                alert('Failed to update alias');
                            }
                        } catch (err) {
                            alert('Error updating alias');
                        }
                    });
                });

                // Inline notes editing
                document.querySelectorAll('.notes-display').forEach(span => {
                    span.addEventListener('click', function () {
                        const id = this.dataset.id;
                        const form = document.querySelector(`.notes-edit[data-id="${id}"]`);
                        if (!form) return;
                        this.classList.add('d-none');
                        form.classList.remove('d-none');
                        const input = form.querySelector('input');
                        if (input) input.focus();
                    });
                });

                document.querySelectorAll('.notes-edit').forEach(form => {
                    const id = form.dataset.id;
                    const span = document.querySelector(`.notes-display[data-id="${id}"]`);
                    const input = form.querySelector('input');
                    const cancelBtn = form.querySelector('.notes-cancel');

                    if (cancelBtn && span) {
                        cancelBtn.addEventListener('click', function () {
                            form.classList.add('d-none');
                            span.classList.remove('d-none');
                        });
                    }

                    form.addEventListener('submit', async function (e) {
                        e.preventDefault();
                        const nextValue = (input ? input.value : '').trim().slice(0, 20);
                        try {
                            const res = await fetch(`/admin/connectors/<%= connector.id %>/allocations/${id}/notes`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ notes: nextValue })
                            });
                            const data = await res.json();
                            if (data.success && span) {
                                setInlineValue(span, '.notes-text', data.notes || null);
                                form.classList.add('d-none');
                                span.classList.remove('d-none');
                            } else {
                                alert('Failed to update notes');
                            }
                        } catch (err) {
                            alert('Error updating notes');
                        }
                    });
                });

                // Configuration tab - Token visibility toggle
                const toggleToken = document.getElementById('toggleToken');
                const tokenInput = document.getElementById('tokenInput');
                const toggleIcon = document.getElementById('toggleIcon');

                if (toggleToken && tokenInput && toggleIcon) {
                    toggleToken.addEventListener('click', function () {
                        if (tokenInput.type === 'password') {
                            tokenInput.type = 'text';
                            toggleIcon.classList.remove('bi-eye');
                            toggleIcon.classList.add('bi-eye-slash');
                        } else {
                            tokenInput.type = 'password';
                            toggleIcon.classList.remove('bi-eye-slash');
                            toggleIcon.classList.add('bi-eye');
                        }
                    });
                }

                // Configuration tab - Copy config to clipboard
                const copyConfig = document.getElementById('copyConfig');
                const configDisplay = document.getElementById('configDisplay');

                if (copyConfig && configDisplay) {
                    copyConfig.addEventListener('click', async function () {
                        try {
                            await navigator.clipboard.writeText(configDisplay.innerText);

                            // Show Toast
                            if (copyToast) {
                                const toast = new bootstrap.Toast(copyToast);
                                toast.show();
                            }

                            const icon = this.querySelector('i');
                            const text = this.childNodes[this.childNodes.length - 1];
                            const originalText = text.textContent;

                            icon.classList.remove('bi-clipboard');
                            icon.classList.add('bi-check');
                            text.textContent = ' Copied!';

                            setTimeout(() => {
                                icon.classList.remove('bi-check');
                                icon.classList.add('bi-clipboard');
                                text.textContent = originalText;
                            }, 2000);
                        } catch (err) {
                            alert('Failed to copy configuration');
                        }
                    });
                }

                // Configuration tab - Web server template selector
                const webTemplateType = document.getElementById('webTemplateType');
                const webTemplateDisplay = document.getElementById('webTemplateDisplay');
                const webTemplateDownload = document.getElementById('webTemplateDownload');
                const copyWebTemplate = document.getElementById('copyWebTemplate');

                async function loadWebTemplate(type) {
                    if (!webTemplateDisplay) return;

                    webTemplateDisplay.textContent = 'Loading template...';
                    try {
                        const response = await fetch(`/admin/connectors/<%= connector.id %>/webserver-template?type=${encodeURIComponent(type)}`);
                        const data = await response.json();
                        if (!response.ok || !data.success) {
                            throw new Error(data.error || 'Failed loading template');
                        }

                        webTemplateDisplay.textContent = data.content || '';
                        if (webTemplateDownload) {
                            webTemplateDownload.href = `/admin/connectors/<%= connector.id %>/webserver-template?type=${encodeURIComponent(type)}&download=1`;
                        }
                    } catch (err) {
                        webTemplateDisplay.textContent = `Failed to load template: ${err.message}`;
                    }
                }

                if (webTemplateType) {
                    webTemplateType.addEventListener('change', function () {
                        loadWebTemplate(this.value);
                    });
                }

                if (copyWebTemplate && webTemplateDisplay) {
                    copyWebTemplate.addEventListener('click', async function () {
                        try {
                            await navigator.clipboard.writeText(webTemplateDisplay.innerText || '');
                            if (copyToast) {
                                const toast = new bootstrap.Toast(copyToast);
                                toast.show();
                            }
                        } catch (err) {
                            alert('Failed to copy template');
                        }
                    });
                }
            })();
        </script>

        <!-- Regenerate Token Modal -->
        <div class="modal fade" id="regenerateTokenModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg text-start"
                    style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                    <div class="modal-header border-bottom border-secondary border-opacity-10">
                        <h5 class="modal-title fs-6 fw-bold text-light">Regenerate Authentication Token</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="alert alert-warning mb-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Warning!</strong> Regenerating the token will invalidate the current configuration.
                            You'll need to update your connector daemon with the new configuration.
                        </div>
                        Are you sure you want to regenerate the authentication token?
                    </div>
                    <div class="modal-footer border-top border-secondary border-opacity-10">
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-medium"
                            data-bs-dismiss="modal">Cancel</button>
                        <form action="/admin/connectors/<%= connector.id %>/regenerate-token" method="POST"
                            class="d-inline">
                            <button type="submit" class="btn btn-warning px-4 fw-bold">Regenerate Token</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script>
            (() => {
                let connectorState = null;

                function updateUI(data) {
                    const isOnline = data.status === 'online';

                    const sidebarDot = document.getElementById('sidebarStatusDot');
                    if (sidebarDot) {
                        sidebarDot.style.backgroundColor = isOnline ? '#10b981' : '#ef4444';
                        sidebarDot.style.boxShadow = isOnline ? '0 0 10px rgba(16, 185, 129, 0.4)' : '0 0 10px rgba(239, 68, 68, 0.4)';
                    }

                    const badgeContainer = document.getElementById('statusBadgeContainer');
                    if (badgeContainer) {
                        if (isOnline) {
                            badgeContainer.innerHTML = '<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2"><i class="bi bi-circle-fill small me-2"></i>ONLINE</span>';
                        } else {
                            badgeContainer.innerHTML = '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2"><i class="bi bi-circle-fill small me-2"></i>OFFLINE</span>';
                        }
                    }

                    const lastSeenText = document.getElementById('lastSeenText');
                    if (lastSeenText && data.lastSeen) {
                        lastSeenText.innerText = `Last seen: ${new Date(data.lastSeen).toLocaleString()}`;
                    }
                }

                function initConnectorRealtime() {
                    const pageRoot = document.body;
                    if (!pageRoot) return;
                    if (pageRoot.dataset.cpanelConnectorRealtimeInit === '1') return;
                    pageRoot.dataset.cpanelConnectorRealtimeInit = '1';

                    const connectorId = '<%= connector.id %>';
                    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
                    const wsUrl = `${protocol}//${window.location.host}/ws/ui`;

                    const state = {
                        destroyed: false,
                        ws: null,
                        reconnectTimer: null
                    };

                    const connectWS = () => {
                        if (state.destroyed) return;
                        state.ws = new WebSocket(wsUrl);

                        state.ws.onmessage = (event) => {
                            if (state.destroyed) return;
                            try {
                                const data = JSON.parse(event.data);
                                if (data.type === 'status_update' && String(data.connectorId) === String(connectorId)) {
                                    updateUI(data);
                                }
                            } catch {
                                // ignore malformed frame
                            }
                        };

                        state.ws.onclose = () => {
                            if (state.destroyed) return;
                            state.reconnectTimer = setTimeout(connectWS, 2000);
                        };
                    };

                    connectWS();
                    connectorState = { ...state, pageRoot };
                }

                function cleanupConnectorRealtime() {
                    if (!connectorState) return;
                    connectorState.destroyed = true;
                    if (connectorState.reconnectTimer) {
                        clearTimeout(connectorState.reconnectTimer);
                        connectorState.reconnectTimer = null;
                    }
                    if (connectorState.ws && (connectorState.ws.readyState === WebSocket.OPEN || connectorState.ws.readyState === WebSocket.CONNECTING)) {
                        connectorState.ws.close(1000, 'Turbo navigation');
                    }
                    if (connectorState.pageRoot) {
                        connectorState.pageRoot.dataset.cpanelConnectorRealtimeInit = '0';
                    }
                    connectorState = null;
                }

                document.addEventListener('turbo:load', initConnectorRealtime);
                document.addEventListener('turbo:before-cache', cleanupConnectorRealtime);
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initConnectorRealtime, { once: true });
                } else {
                    initConnectorRealtime();
                }
            })();
        </script>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (settings.brandName || 'CPanel').toUpperCase() %> - Service Health Checks</title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/error-modal') %>
<div class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <div class="admin-content">
        <div class="admin-header">
            <div>
                <h4 class="mb-0 text-light fw-normal">Service Health Checks</h4>
                <small class="text-muted">Panel/DB/Redis/connectors background health probes.</small>
            </div>
            <div class="breadcrumb-admin">
                <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span class="text-light">Service Health Checks</span>
            </div>
        </div>

        <div class="container-fluid py-4 px-lg-4">
            <% if (success) { %><div class="alert alert-success border-0 bg-success bg-opacity-10 text-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger"><%= error %></div><% } %>

            <div class="card border-0 shadow-sm mb-3" style="background-color:#141419;">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1 text-light">Latest Snapshot</h5>
                        <% if (latest) { %>
                            <div class="text-muted small">Generated: <%= new Date(latest.createdAtMs || Date.now()).toLocaleString() %> | Duration: <%= latest.durationMs || 0 %>ms</div>
                        <% } else { %>
                            <div class="text-muted small">No checks executed yet.</div>
                        <% } %>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/admin/service-health-checks?run=1" class="btn btn-outline-info btn-sm">Run (GET)</a>
                        <form method="POST" action="/admin/service-health-checks/run" class="d-inline">
                            <button type="submit" class="btn btn-primary btn-sm">Run Health Check</button>
                        </form>
                    </div>
                </div>
            </div>

            <% if (latest) { %>
                <div class="card border-0 shadow-sm mb-3" style="background-color:#141419;">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge <%= latest.status === 'ok' ? 'bg-success' : (latest.status === 'warn' ? 'bg-warning text-dark' : 'bg-danger') %>"><%= String(latest.status || 'unknown').toUpperCase() %></span>
                            <span class="text-muted small">Current overall status</span>
                        </div>
                        <div class="row g-2">
                            <% (latest.checks || []).forEach((check) => { %>
                                <div class="col-md-6 col-xl-4">
                                    <div class="p-3 rounded border border-secondary border-opacity-25 h-100">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="fw-semibold text-light"><%= check.label %></div>
                                            <span class="badge <%= check.status === 'ok' ? 'bg-success' : (check.status === 'warn' ? 'bg-warning text-dark' : 'bg-danger') %>"><%= String(check.status || 'unknown').toUpperCase() %></span>
                                        </div>
                                        <div class="text-muted small mt-2"><%= check.message %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            <% } %>

            <div class="card border-0 shadow-sm" style="background-color:#141419;">
                <div class="card-body">
                    <h5 class="mb-3 text-light"><i class="bi bi-clock-history me-2"></i>History</h5>
                    <div class="table-responsive">
                        <table class="table table-dark table-sm mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Status</th>
                                    <th>Duration</th>
                                    <th>Checks</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% (history || []).forEach((row) => { %>
                                    <tr>
                                        <td class="text-nowrap"><%= new Date(row.createdAtMs || Date.now()).toLocaleString() %></td>
                                        <td><span class="badge <%= row.status === 'ok' ? 'bg-success' : (row.status === 'warn' ? 'bg-warning text-dark' : 'bg-danger') %>"><%= String(row.status || 'unknown').toUpperCase() %></span></td>
                                        <td><%= row.durationMs || 0 %>ms</td>
                                        <td>
                                            <% const checks = Array.isArray(row.checks) ? row.checks : []; %>
                                            <span class="text-muted small"><%= checks.map((c) => `${c.label}: ${String(c.status || '').toUpperCase()}`).join(' | ') || '-' %></span>
                                        </td>
                                    </tr>
                                <% }) %>
                                <% if (!(history || []).length) { %>
                                    <tr><td colspan="4" class="text-muted">No health snapshots saved yet.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../partials/footer') %>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>
</html>

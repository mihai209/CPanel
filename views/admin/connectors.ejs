<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> - Connectors
    </title>
    <!-- Favicon -->
    <%- include('../partials/favicon') %>
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Bootstrap Icons -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <!-- Custom CSS -->
        <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <!-- Sidebar -->
            <%- include('../partials/admin-sidebar') %>

                <!-- Content -->
                <div class="admin-content">
                    <!-- Admin Top Header -->
                    <div class="admin-header">
                        <div class="d-flex align-items-baseline gap-3">
                            <h4 class="mb-0 text-light fw-normal">Connectors</h4>
                            <small class="text-muted">Manage remote connector nodes.</small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span
                                class="text-light">Connectors</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <div class="row">
                            <!-- List of Connectors -->
                            <div class="col-lg-12">
                                <div class="card border-0 shadow-sm" style="background-color: #141419;">
                                    <div
                                        class="card-header border-bottom border-secondary border-opacity-10 py-3 bg-transparent d-flex justify-content-between align-items-center">
                                        <h5 class="card-title mb-0 fs-6 fw-bold text-light"><i
                                                class="bi bi-diagram-3 me-2"></i>Existing Connectors</h5>
                                        <button class="btn btn-sm btn-primary px-3 fw-bold shadow-sm"
                                            data-bs-toggle="modal" data-bs-target="#createConnectorModal">
                                            <i class="bi bi-plus-lg me-1"></i> Create Connector
                                        </button>
                                    </div>
                                    <div class="card-body p-0">
                                        <% if (success) { %>
                                            <div
                                                class="alert alert-success m-3 border-0 bg-success bg-opacity-10 text-success">
                                                <i class="bi bi-check-circle-fill me-2"></i>
                                                <%= success %>
                                            </div>
                                            <% } %>
                                                <% if (error) { %>
                                                    <div
                                                        class="alert alert-danger m-3 border-0 bg-danger bg-opacity-10 text-danger">
                                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                        <%= error %>
                                                    </div>
                                                    <% } %>

                                                        <div class="table-responsive">
                                                            <table class="table table-dark table-hover mb-0"
                                                                style="--bs-table-bg: transparent;">
                                                                <thead class="text-muted small text-uppercase">
                                                                    <tr>
                                                                        <th class="ps-3 fw-bold text-light"
                                                                            style="letter-spacing: 0.05em;">ID</th>
                                                                        <th class="ps-3 fw-bold text-light"
                                                                            style="letter-spacing: 0.05em;">Token</th>
                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">Status</th>
                                                                        <th class="ps-4 py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">Name</th>
                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">FQDN</th>

                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">Location
                                                                        </th>
                                                                        <!--<th class="py-3 fw-bold"
                                                                        style="letter-spacing: 0.05em;">Resources
                                                                        (RAM/Disk)</th>-->
                                                                        <th class="pe-4 py-3 text-end fw-bold"
                                                                            style="letter-spacing: 0.05em;">Actions</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody class="border-top-0">
                                                                    <% if (connectors && connectors.length> 0) { %>
                                                                        <% connectors.forEach(conn=> { %>
                                                                            <tr
                                                                                class="align-middle border-bottom border-secondary border-opacity-10">
                                                                                <td class="ps-4 fw-bold text-light">
                                                                                    <%= conn.id %>
                                                                                </td>
                                                                                <td class="text-muted small"
                                                                                    title="Check Connector with ID <%= conn.id %> configuration file for the full token.">
                                                                                    <%= conn.token.substring(0, 5) %>...
                                                                                </td>



                                                                                <td class="text-muted small">
                                                                                    <% const
                                                                                        statusData=connectorStatus[conn.id];
                                                                                        const isOnline=statusData &&
                                                                                        statusData.status==='online' &&
                                                                                        (new Date() - new
                                                                                        Date(statusData.lastSeen)) <
                                                                                        30000; %>
                                                                                        <% if (isOnline) { %>
                                                                                            <span
                                                                                                class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">
                                                                                                <i
                                                                                                    class="bi bi-circle-fill small me-1"></i>
                                                                                                ONLINE
                                                                                            </span>
                                                                                            <% } else { %>
                                                                                                <span
                                                                                                    class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1">
                                                                                                    <i
                                                                                                        class="bi bi-circle-fill small me-1"></i>
                                                                                                    OFFLINE
                                                                                                </span>
                                                                                                <% } %>
                                                                                </td>
                                                                                <td class="ps-4 fw-bold text-light"
                                                                                    title="Connector Description:  <%= conn.description %>"
                                                                                    style="font-weight: bold;">
                                                                                    <%= conn.name %>
                                                                                    <% const connectorPublic = conn.isPublic !== false; %>
                                                                                    <span class="ms-2 badge <%= connectorPublic ? 'bg-success bg-opacity-10 text-success border border-success border-opacity-25' : 'bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25' %>">
                                                                                        <%= connectorPublic ? 'PUBLIC' : 'PRIVATE' %>
                                                                                    </span>
                                                                                </td>
                                                                                <td class="text-muted small">
                                                                                    <%= conn.fqdn %>:<%= conn.port %>
                                                                                </td>

                                                                                <td>
                                                                                    <span
                                                                                        class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 py-1 px-2 d-inline-flex align-items-center">
                                                                                        <% if (conn.location &&
                                                                                            conn.location.imageUrl) { %>
                                                                                            <img src="<%= conn.location.imageUrl %>"
                                                                                                alt="" width="16"
                                                                                                height="16"
                                                                                                class="rounded-circle me-1 shadow-sm">
                                                                                            <% } else { %>
                                                                                                <i
                                                                                                    class="bi bi-geo-alt-fill me-1"></i>
                                                                                                <% } %>
                                                                                                    <%= conn.location ?
                                                                                                        conn.location.shortName
                                                                                                        : 'N/A' %>
                                                                                    </span>
                                                                                </td>
                                                                                <!--<td class="text-muted small">
                                                                                RAM: <%= conn.totalMemory %>GB (<%=
                                                                                        conn.memoryOverAllocation %>
                                                                                        %)<br>
                                                                                        Disk: <%= conn.totalDisk %>GB (
                                                                                            <%= conn.diskOverAllocation
                                                                                                %>%)
                                                                            </td>-->
                                                                                <td class="pe-4 text-end">
                                                                                    <div
                                                                                        class="d-flex justify-content-end gap-2">
                                                                                        <a href="/admin/connectors/<%= conn.id %>/manage"
                                                                                            class="btn btn-sm btn-outline-info">
                                                                                            <i
                                                                                                class="bi bi-gear-wide-connected"></i>
                                                                                            Manage
                                                                                        </a>
                                                                                        <button
                                                                                            class="btn btn-sm btn-outline-primary"
                                                                                            data-bs-toggle="modal"
                                                                                            data-bs-target="#editModal<%= conn.id %>">
                                                                                            <i
                                                                                                class="bi bi-pencil-square"></i>
                                                                                        </button>
                                                                                        <button type="button"
                                                                                            class="btn btn-sm btn-outline-danger btn-delete-connector"
                                                                                            data-id="<%= conn.id %>"
                                                                                            data-name="<%= conn.name %>">
                                                                                            <i class="bi bi-trash"></i>
                                                                                        </button>
                                                                                        <form
                                                                                            id="delete-form-<%= conn.id %>"
                                                                                            method="POST"
                                                                                            action="/admin/connectors/delete/<%= conn.id %>"
                                                                                            style="display: none;">
                                                                                        </form>
                                                                                    </div>

                                                                                    <!-- Edit Modal -->
                                                                                    <div class="modal fade"
                                                                                        id="editModal<%= conn.id %>"
                                                                                        tabindex="-1"
                                                                                        aria-hidden="true">
                                                                                        <div
                                                                                            class="modal-dialog modal-dialog-centered modal-lg">
                                                                                            <div class="modal-content border-0 shadow-lg text-start"
                                                                                                style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                                                                                                <div
                                                                                                    class="modal-header border-bottom border-secondary border-opacity-10">
                                                                                                    <h5
                                                                                                        class="modal-title fs-6 fw-bold text-light">
                                                                                                        Edit Connector:
                                                                                                        <%= conn.name %>
                                                                                                    </h5>
                                                                                                    <button
                                                                                                        type="button"
                                                                                                        class="btn-close btn-close-white"
                                                                                                        data-bs-dismiss="modal"
                                                                                                        aria-label="Close"></button>
                                                                                                </div>
                                                                                                <form method="POST"
                                                                                                    action="/admin/connectors/edit/<%= conn.id %>">
                                                                                                    <div
                                                                                                        class="modal-body p-4">
                                                                                                        <div
                                                                                                            class="row g-3">
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Name</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="name"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.name %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">FQDN
                                                                                                                    /
                                                                                                                    IP</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="fqdn"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.fqdn %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Connector
                                                                                                                    Port</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="port"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.port %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">SFTP
                                                                                                                    Port</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="sftpPort"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.sftpPort %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Location</label>
                                                                                                                <select
                                                                                                                    name="locationId"
                                                                                                                    class="form-select"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;">
                                                                                                                    <%
                                                                                                                        locations.forEach(loc=>
                                                                                                                        {
                                                                                                                        %>
                                                                                                                        <option
                                                                                                                            value="<%= loc.id %>"
                                                                                                                            <%=conn.locationId===loc.id
                                                                                                                            ? 'selected'
                                                                                                                            : ''
                                                                                                                            %>
                                                                                                                            >
                                                                                                                            <%= loc.shortName
                                                                                                                                %>
                                                                                                                                -
                                                                                                                                <%= loc.description
                                                                                                                                    %>
                                                                                                                        </option>
                                                                                                                        <% });
                                                                                                                            %>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">File
                                                                                                                    Directory</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="fileDirectory"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.fileDirectory %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-3">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Total
                                                                                                                    RAM
                                                                                                                    (GB)</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="totalMemory"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.totalMemory %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-3">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">RAM
                                                                                                                    Overalloc
                                                                                                                    (%)</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="memoryOverAllocation"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.memoryOverAllocation %>">
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-3">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Total
                                                                                                                    Disk
                                                                                                                    (GB)</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="totalDisk"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.totalDisk %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-3">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Disk
                                                                                                                    Overalloc
                                                                                                                    (%)</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="diskOverAllocation"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.diskOverAllocation %>">
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-12">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Description</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="description"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= conn.description %>"
                                                                                                                    maxlength="50">
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-12">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Allowed
                                                                                                                    Panel URLs</label>
                                                                                                                <textarea
                                                                                                                    name="allowedUrls"
                                                                                                                    class="form-control"
                                                                                                                    rows="3"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white; font-family: monospace;"
                                                                                                                    placeholder="https://panel.example.com&#10;https://admin.example.com"><%= conn.allowedOrigins || defaultAllowedOrigins || '' %></textarea>
                                                                                                                <small
                                                                                                                    class="text-muted">One
                                                                                                                    URL per line (or comma-separated). Connector accepts only these panel origins.</small>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-12">
                                                                                                                <div class="form-check form-switch p-3 rounded-3 mb-2"
                                                                                                                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                                                                                                    <input
                                                                                                                        class="form-check-input ms-0 me-2"
                                                                                                                        type="checkbox"
                                                                                                                        name="isPublic"
                                                                                                                        id="isPublicSwitch<%= conn.id %>"
                                                                                                                        value="1"
                                                                                                                        <%= conn.isPublic !== false ? 'checked' : '' %>>
                                                                                                                    <label
                                                                                                                        class="form-check-label text-light fw-bold"
                                                                                                                        for="isPublicSwitch<%= conn.id %>">Public connector (visible in <code>/user/create</code>)</label>
                                                                                                                </div>
                                                                                                                <div class="form-check form-switch p-3 rounded-3"
                                                                                                                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                                                                                                    <input
                                                                                                                        class="form-check-input ms-0 me-2"
                                                                                                                        type="checkbox"
                                                                                                                        name="ssl"
                                                                                                                        id="sslSwitch<%= conn.id %>"
                                                                                                                        <%=conn.ssl
                                                                                                                        ? 'checked'
                                                                                                                        : ''
                                                                                                                        %>>
                                                                                                                    <label
                                                                                                                        class="form-check-label text-light fw-bold"
                                                                                                                        for="sslSwitch<%= conn.id %>">Enable
                                                                                                                        SSL</label>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div
                                                                                                        class="modal-footer border-top border-secondary border-opacity-10">
                                                                                                        <button
                                                                                                            type="button"
                                                                                                            class="btn btn-link text-muted text-decoration-none fw-medium"
                                                                                                            data-bs-dismiss="modal">Cancel</button>
                                                                                                        <button
                                                                                                            type="submit"
                                                                                                            class="btn btn-primary px-4 fw-bold">Save
                                                                                                            Changes</button>
                                                                                                    </div>
                                                                                                </form>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                            <% }); %>
                                                                                <% } else { %>
                                                                                    <tr>
                                                                                        <td colspan="6"
                                                                                            class="py-5 text-center text-muted italic">
                                                                                            No connectors configured
                                                                                            yet.
                                                                                        </td>
                                                                                    </tr>
                                                                                    <% } %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Create Connector Modal -->
                    <div class="modal fade" id="createConnectorModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content border-0 shadow-lg text-start"
                                style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                                <div class="modal-header border-bottom border-secondary border-opacity-10">
                                    <h5 class="modal-title fs-6 fw-bold text-light">
                                        <i class="bi bi-plus-circle me-2 text-primary"></i>Create New Connector
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                        aria-label="Close"></button>
                                </div>
                                <form method="POST" action="/admin/connectors">
                                    <div class="modal-body p-4">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Name</label>
                                                <input type="text" name="name" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required placeholder="Node-1">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-muted small text-uppercase fw-bold">FQDN /
                                                    IP</label>
                                                <input type="text" name="fqdn" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required placeholder="node1.example.com">
                                            </div>
                                            <div class="col-md-6">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Connector
                                                    Port</label>
                                                <input type="number" name="port" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    value="2009" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-muted small text-uppercase fw-bold">SFTP
                                                    Port</label>
                                                <input type="number" name="sftpPort" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    value="8312" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Location</label>
                                                <select name="locationId" class="form-select"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required>
                                                    <% locations.forEach(loc=> { %>
                                                        <option value="<%= loc.id %>">
                                                            <%= loc.shortName %> - <%= loc.description %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-muted small text-uppercase fw-bold">File
                                                    Directory</label>
                                                <input type="text" name="fileDirectory" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    value="/var/lib/cpanel/volumes" required>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-muted small text-uppercase fw-bold">Total
                                                    RAM
                                                    (GB)</label>
                                                <input type="number" name="totalMemory" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    placeholder="32" required>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-muted small text-uppercase fw-bold">RAM
                                                    Overalloc (%)</label>
                                                <input type="number" name="memoryOverAllocation" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    value="0">
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-muted small text-uppercase fw-bold">Total
                                                    Disk
                                                    (GB)</label>
                                                <input type="number" name="totalDisk" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    placeholder="500" required>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-muted small text-uppercase fw-bold">Disk
                                                    Overalloc (%)</label>
                                                <input type="number" name="diskOverAllocation" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    value="0">
                                            </div>
                                            <div class="col-12">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Description</label>
                                                <input type="text" name="description" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    placeholder="e.g. Primary Node US-East" maxlength="50">
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label text-muted small text-uppercase fw-bold">Allowed
                                                    Panel URLs</label>
                                                <textarea name="allowedUrls" class="form-control" rows="3"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white; font-family: monospace;"
                                                    placeholder="https://panel.example.com&#10;https://admin.example.com"><%= defaultAllowedOrigins || '' %></textarea>
                                                <small class="text-muted">One URL per line (or comma-separated).
                                                    Connector accepts only these panel origins.</small>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-check form-switch p-3 rounded-3 mb-2"
                                                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                                    <input class="form-check-input ms-0 me-2" type="checkbox" name="isPublic"
                                                        id="isPublicSwitchNew" value="1" checked>
                                                    <label class="form-check-label text-light fw-bold"
                                                        for="isPublicSwitchNew">Public connector (visible in <code>/user/create</code>)</label>
                                                </div>
                                                <div class="form-check form-switch p-3 rounded-3"
                                                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                                    <input class="form-check-input ms-0 me-2" type="checkbox" name="ssl"
                                                        id="sslSwitchNew">
                                                    <label class="form-check-label text-light fw-bold"
                                                        for="sslSwitchNew">Enable SSL</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-top border-secondary border-opacity-10">
                                        <button type="button"
                                            class="btn btn-link text-muted text-decoration-none fw-medium"
                                            data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                                            Create Connector
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <%- include('../partials/footer') %>
                </div>
        </div>
        </div>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <!-- SweetAlert2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.addEventListener('click', function (e) {
                if (e.target.closest('.btn-delete-connector')) {
                    const btn = e.target.closest('.btn-delete-connector');
                    const id = btn.getAttribute('data-id');
                    const name = btn.getAttribute('data-name');
                    confirmDelete(id, name);
                }
            });

            function confirmDelete(id, name) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: `You are about to delete the connector "${name}". This action cannot be undone!`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, delete it!',
                    background: '#1a1a20',
                    color: '#ffffff'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('delete-form-' + id).submit();
                    }
                })
            }
        </script>
</body>

</html>

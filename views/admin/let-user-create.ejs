<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> - Let User Create
    </title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include ('../partials/error-modal') %>
    <div class="admin-wrapper">
        <%- include('../partials/admin-sidebar') %>

        <div class="admin-content">
            <div class="admin-header">
                <div class="d-flex align-items-baseline gap-3">
                    <h4 class="mb-0 text-light fw-normal">Let User Create</h4>
                    <small class="text-muted">Self-service create/store and billing lifecycle.</small>
                </div>
                <div class="breadcrumb-admin">
                    <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span class="text-light">Let User Create</span>
                </div>
            </div>

            <div class="container-fluid py-4 px-lg-4">
                <div class="row g-4 justify-content-center">
                    <div class="col-lg-10">
                        <div class="card border-0 shadow-sm" style="background-color: #141419;">
                                <div class="card-header border-bottom border-secondary border-opacity-10 py-3 bg-transparent">
                                    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                        <h5 class="card-title mb-0 fs-6 fw-bold text-light"><i class="bi bi-shop me-2"></i>User Create + Store</h5>
                                        <div class="d-flex gap-2">
                                            <a href="/admin/store/deals" class="btn btn-outline-light btn-sm">Manage Deals</a>
                                            <a href="/admin/store/redeem-codes" class="btn btn-outline-light btn-sm">Manage Redeem Codes</a>
                                            <a href="/admin/revenue-plans" class="btn btn-outline-light btn-sm">Manage Revenue Plans</a>
                                        </div>
                                    </div>
                                </div>
                            <div class="card-body p-4">
                                <% if (success) { %>
                                    <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success">
                                        <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                                    </div>
                                <% } %>
                                <% if (error) { %>
                                    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                                    </div>
                                <% } %>

                                <form method="POST" action="/admin/let-user-create" class="row g-3">
                                    <div class="col-12">
                                        <h6 class="text-light mb-3"><i class="bi bi-toggles me-2"></i>Feature Toggles</h6>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureUserCreateEnabled" name="featureUserCreateEnabled" value="1"
                                                <%= String(settings.featureUserCreateEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureUserCreateEnabled">Enable /user/create and /store</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureCostPerServerEnabled" name="featureCostPerServerEnabled" value="1"
                                                <%= String(settings.featureCostPerServerEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureCostPerServerEnabled">Enable renew billing lifecycle</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureInventoryEnabled" name="featureInventoryEnabled" value="1"
                                                <%= String(settings.featureInventoryEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureInventoryEnabled">Enable inventory-based resource stacking</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureStoreDealsEnabled" name="featureStoreDealsEnabled" value="1"
                                                <%= String(settings.featureStoreDealsEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureStoreDealsEnabled">Enable Store Deals bundles</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureStoreRedeemCodesEnabled" name="featureStoreRedeemCodesEnabled" value="1"
                                                <%= String(settings.featureStoreRedeemCodesEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureStoreRedeemCodesEnabled">Enable Redeem Codes</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureBillingInvoicesEnabled" name="featureBillingInvoicesEnabled" value="1"
                                                <%= String(settings.featureBillingInvoicesEnabled || 'true') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureBillingInvoicesEnabled">Enable billing invoices</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureBillingInvoiceWebhookEnabled" name="featureBillingInvoiceWebhookEnabled" value="1"
                                                <%= String(settings.featureBillingInvoiceWebhookEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureBillingInvoiceWebhookEnabled">Invoice webhook dispatch</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureQuotaForecastingEnabled" name="featureQuotaForecastingEnabled" value="1"
                                                <%= String(settings.featureQuotaForecastingEnabled || 'true') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureQuotaForecastingEnabled">Enable quota forecasting on store</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureScheduledScalingEnabled" name="featureScheduledScalingEnabled" value="1"
                                                <%= String(settings.featureScheduledScalingEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureScheduledScalingEnabled">Enable scheduled scaling engine</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureAdminApiRatePlansEnabled" name="featureAdminApiRatePlansEnabled" value="1"
                                                <%= String(settings.featureAdminApiRatePlansEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureAdminApiRatePlansEnabled">Enable Admin API rate plans</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureRevenueModeEnabled" name="featureRevenueModeEnabled" value="1"
                                                <%= String(settings.featureRevenueModeEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureRevenueModeEnabled">Enable Revenue mode (subscriptions)</label>
                                        </div>
                                    </div>

                                    <div class="col-12 mt-4">
                                        <h6 class="text-light mb-3"><i class="bi bi-currency-exchange me-2"></i>Recurring Renew Cost (per cycle)</h6>
                                        <div class="form-text text-muted mb-2">Folosește formula de server cost la renew.</div>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Economy Unit</label>
                                        <input type="text" name="economyUnit" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.economyUnit || 'Coins' %>" maxlength="16">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Revenue Trial Days</label>
                                        <input type="number" min="0" max="365" name="revenueDefaultTrialDays" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.revenueDefaultTrialDays || '3' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Revenue Grace Days</label>
                                        <input type="number" min="0" max="365" name="revenueGraceDays" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.revenueGraceDays || '2' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Base Cost</label>
                                        <input type="number" step="0.01" min="0" name="costBasePerServerMonthly" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.costBasePerServerMonthly || '0' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">RAM / GB</label>
                                        <input type="number" step="0.01" min="0" name="costPerGbRamMonthly" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.costPerGbRamMonthly || '1.5' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">CPU / Core</label>
                                        <input type="number" step="0.01" min="0" name="costPerCpuCoreMonthly" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.costPerCpuCoreMonthly || '2.5' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Disk / GB</label>
                                        <input type="number" step="0.01" min="0" name="costPerGbDiskMonthly" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.costPerGbDiskMonthly || '0.2' %>">
                                    </div>

                                    <div class="col-12 mt-4">
                                        <h6 class="text-light mb-3"><i class="bi bi-basket me-2"></i>Mini Shop Pricing (one-time create charge)</h6>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">RAM / GB</label>
                                        <input type="number" step="0.01" min="0" name="storeRamPerGbCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeRamPerGbCoins || '10' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">CPU / Core</label>
                                        <input type="number" step="0.01" min="0" name="storeCpuPerCoreCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeCpuPerCoreCoins || '20' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Swap / GB</label>
                                        <input type="number" step="0.01" min="0" name="storeSwapPerGbCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeSwapPerGbCoins || '3' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Storage / GB</label>
                                        <input type="number" step="0.01" min="0" name="storeDiskPerGbCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeDiskPerGbCoins || '2' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Allocation</label>
                                        <input type="number" step="0.01" min="0" name="storeAllocationCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeAllocationCoins || '5' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Image</label>
                                        <input type="number" step="0.01" min="0" name="storeImageCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeImageCoins || '15' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Database Slot</label>
                                        <input type="number" step="0.01" min="0" name="storeDatabaseCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeDatabaseCoins || '5' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Package</label>
                                        <input type="number" step="0.01" min="0" name="storePackageCoins" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storePackageCoins || '25' %>">
                                    </div>

                                    <div class="col-12 mt-4">
                                        <h6 class="text-light mb-3"><i class="bi bi-hourglass-split me-2"></i>Renew Lifecycle</h6>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Renew Period (days)</label>
                                        <input type="number" min="1" max="3650" name="storeRenewDays" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeRenewDays || '30' %>">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Delete Grace After Suspend (days)</label>
                                        <input type="number" min="1" max="3650" name="storeDeleteGraceDays" class="form-control" style="background-color: #1a1a20; border-color: #2d2d35;"
                                            value="<%= settings.storeDeleteGraceDays || '7' %>">
                                    </div>

                                    <div class="col-12 text-end mt-4">
                                        <button type="submit" class="btn btn-primary px-4 fw-medium">Save Let User Create Settings</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer') %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>

</html>

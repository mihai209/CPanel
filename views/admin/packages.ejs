<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %> - Packages
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
        <style>
            .package-card {
                background: rgba(20, 20, 25, 0.7);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 1rem;
                transition: all 0.3s ease;
            }

            .package-card:hover {
                border-color: rgba(59, 130, 246, 0.3);
                transform: translateY(-5px);
            }

            .package-icon {
                width: 48px;
                height: 48px;
                border-radius: 12px;
                background: rgba(59, 130, 246, 0.1);
                color: #3b82f6;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
            }
        </style>
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <%- include('../partials/admin-sidebar') %>
                <div class="admin-content">
                    <div class="admin-header">
                        <div class="d-flex align-items-center gap-3">
                            <h4 class="mb-0 text-light fw-bold">Packages</h4>
                            <span
                                class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20 rounded-pill px-3">Organize</span>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span
                                class="text-light">Packages</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h5 class="text-light mb-1">Image Packages</h5>
                                <p class="text-muted small mb-0">Manage groups of images to organize your deployment
                                    library.</p>
                            </div>
                            <button class="btn btn-primary fw-bold" data-bs-toggle="modal"
                                data-bs-target="#createPackageModal">
                                <i class="bi bi-plus-lg me-2"></i>Create New Package
                            </button>
                        </div>

                        <% if (success) { %>
                            <div
                                class="alert alert-success border-0 bg-success bg-opacity-10 text-success mb-4 rounded-4">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <%= success %>
                            </div>
                            <% } %>
                                <% if (error) { %>
                                    <div
                                        class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger mb-4 rounded-4">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <%= error %>
                                    </div>
                                    <% } %>

                                        <div class="row g-4">
                                            <% if (packages && packages.length> 0) { %>
                                                <% packages.forEach(pkg=> { %>
                                                    <div class="col-xl-4 col-md-6">
                                                        <div class="package-card p-4 h-100 d-flex flex-column">
                                                            <div
                                                                class="d-flex justify-content-between align-items-start mb-3">
                                                                <div class="package-icon">
                                                                    <% if (pkg.imageUrl) { %>
                                                                        <img src="<%= pkg.imageUrl %>"
                                                                            alt="<%= pkg.name %>"
                                                                            style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;">
                                                                        <% } else { %>
                                                                            <i class="bi bi-box"></i>
                                                                            <% } %>
                                                                </div>
                                                                <div class="dropdown">
                                                                    <button class="btn btn-link text-muted p-0"
                                                                        data-bs-toggle="dropdown">
                                                                        <i class="bi bi-three-dots-vertical"></i>
                                                                    </button>
                                                                    <ul
                                                                        class="dropdown-menu dropdown-menu-dark dropdown-menu-end border-secondary border-opacity-20 shadow-lg">
                                                                        <li>
                                                                            <button
                                                                                class="dropdown-item edit-package-btn"
                                                                                data-id="<%= pkg.id %>"
                                                                                data-name="<%= pkg.name %>"
                                                                                data-description="<%= pkg.description %>"
                                                                                data-imageurl="<%= pkg.imageUrl %>"
                                                                                data-bs-toggle="modal"
                                                                                data-bs-target="#editPackageModal">
                                                                                <i class="bi bi-pencil me-2"></i>Edit
                                                                                Package
                                                                            </button>
                                                                        </li>
                                                                        <li>
                                                                            <hr
                                                                                class="dropdown-divider border-secondary border-opacity-20">
                                                                        </li>
                                                                        <li>
                                                                            <a class="dropdown-item text-danger"
                                                                                href="/admin/packages/delete/<%= pkg.id %>"
                                                                                onclick="return confirm('Are you sure you want to delete this package? This action cannot be undone.')">
                                                                                <i class="bi bi-trash me-2"></i>Delete
                                                                                Package
                                                                            </a>
                                                                        </li>
                                                                    </ul>
                                                                </div>
                                                            </div>
                                                            <h5 class="text-light fw-bold mb-2">
                                                                <%= pkg.name %>
                                                            </h5>
                                                            <p class="text-muted small flex-grow-1">
                                                                <%= pkg.description || 'No description provided.' %>
                                                            </p>
                                                            <div
                                                                class="mt-auto pt-3 border-top border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                                                                <span
                                                                    class="badge bg-secondary bg-opacity-10 text-muted border border-secondary border-opacity-10">
                                                                    <i class="bi bi-grid-3x3-gap me-1"></i>
                                                                    <%= pkg.images ? pkg.images.length : 0 %> Images
                                                                </span>
                                                                <a href="/admin/images?packageId=<%= pkg.id %>"
                                                                    class="btn btn-link btn-sm text-primary text-decoration-none">
                                                                    View Images <i class="bi bi-arrow-right ms-1"></i>
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div class="col-12 text-center py-5">
                                                                <div class="mb-3 text-muted opacity-20"
                                                                    style="font-size: 4rem;">
                                                                    <i class="bi bi-box"></i>
                                                                </div>
                                                                <h5 class="text-muted">No packages found</h5>
                                                                <p class="text-muted small">Create your first package to
                                                                    start organizing your images.</p>
                                                            </div>
                                                            <% } %>
                                        </div>
                    </div>
                    <%- include('../partials/footer') %>
                </div>
        </div>

        <!-- Create Package Modal -->
        <div class="modal fade" id="createPackageModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg"
                    style="background-color: #141419; border: 1px solid rgba(255,255,255,0.08) !important;">
                    <div class="modal-header border-bottom border-secondary border-opacity-10">
                        <h5 class="modal-title fs-6 fw-bold text-light">Create New Package</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/admin/packages" method="POST">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">Package Name</label>
                                <input type="text" name="name" class="form-control" placeholder="e.g. Minecraft Servers"
                                    required style="background: #0b0b0e; border-color: #2d2d35; color: white;">
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">Description</label>
                                <textarea name="description" class="form-control" rows="3" maxlength="150"
                                    placeholder="Small description (max 150 chars)"
                                    style="background: #0b0b0e; border-color: #2d2d35; color: white;"></textarea>
                                <div class="form-text text-muted small">Maximum 150 characters.</div>
                            </div>
                            <div class="mb-0">
                                <label class="form-label text-muted small text-uppercase fw-bold">Image URL</label>
                                <input type="url" name="imageUrl" class="form-control"
                                    placeholder="https://example.com/icon.png"
                                    style="background: #0b0b0e; border-color: #2d2d35; color: white;">
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary border-opacity-10">
                            <button type="button" class="btn btn-link text-muted text-decoration-none"
                                data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Create Package</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Edit Package Modal -->
        <div class="modal fade" id="editPackageModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg"
                    style="background-color: #141419; border: 1px solid rgba(255,255,255,0.08) !important;">
                    <div class="modal-header border-bottom border-secondary border-opacity-10">
                        <h5 class="modal-title fs-6 fw-bold text-light">Edit Package</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form id="editPackageForm" method="POST">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">Package Name</label>
                                <input type="text" name="name" id="editPackageName" class="form-control"
                                    placeholder="e.g. Minecraft Servers" required
                                    style="background: #0b0b0e; border-color: #2d2d35; color: white;">
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase fw-bold">Description</label>
                                <textarea name="description" id="editPackageDescription" class="form-control" rows="3"
                                    maxlength="150" placeholder="Small description (max 150 chars)"
                                    style="background: #0b0b0e; border-color: #2d2d35; color: white;"></textarea>
                                <div class="form-text text-muted small">Maximum 150 characters.</div>
                            </div>
                            <div class="mb-0">
                                <label class="form-label text-muted small text-uppercase fw-bold">Image URL</label>
                                <input type="url" name="imageUrl" id="editPackageImageUrl" class="form-control"
                                    placeholder="https://example.com/icon.png"
                                    style="background: #0b0b0e; border-color: #2d2d35; color: white;">
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary border-opacity-10">
                            <button type="button" class="btn btn-link text-muted text-decoration-none"
                                data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
        <script>
            document.querySelectorAll('.edit-package-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const id = this.getAttribute('data-id');
                    const name = this.getAttribute('data-name');
                    const description = this.getAttribute('data-description');
                    const imageUrl = this.getAttribute('data-imageurl');

                    document.getElementById('editPackageForm').action = '/admin/packages/edit/' + id;
                    document.getElementById('editPackageName').value = name;
                    document.getElementById('editPackageDescription').value = description;
                    document.getElementById('editPackageImageUrl').value = imageUrl;
                });
            });
        </script>
</body>

</html>
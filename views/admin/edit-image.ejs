<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Image | <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
        <style>
            .code-editor {
                font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
                font-size: 0.875rem;
                background-color: #1a1a20;
                border-color: #2d2d35;
                color: #e1e1e6;
            }
        </style>
</head>

<body> <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <%- include('../partials/admin-sidebar') %>
                <div class="admin-content">
                    <div class="admin-header">
                        <div class="d-flex align-items-baseline gap-3">
                            <h4 class="mb-0 text-light fw-normal">Edit Image</h4>
                            <small class="text-muted">
                                <%= image.name %>
                            </small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span>
                            <a href="/admin/images">Images</a> <span class="mx-2">&gt;</span>
                            <span class="text-light">Edit</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <% if (success) { %>
                            <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <%= success %>
                            </div>
                            <% } %>
                                <% if (error) { %>
                                    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <%= error %>
                                    </div>
                                    <% } %>

                                        <div class="row g-4">
                                            <div class="col-lg-12">
                                                <div class="card border-0 shadow-sm" style="background-color: #141419;">
                                                    <div class="card-body">
                                                        <form method="POST" action="/admin/images/edit/<%= image.id %>">
                                                            <div class="row g-3">
                                                                <div class="col-md-6">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Name</label>
                                                                    <input type="text" name="name" class="form-control"
                                                                        value="<%= image.name %>" required
                                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;">
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Description</label>
                                                                    <input type="text" name="description"
                                                                        class="form-control"
                                                                        value="<%= image.description %>"
                                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;">
                                                                </div>
                                                                <div class="col-12">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Package
                                                                        (Nest)</label>
                                                                    <select name="packageId" class="form-select"
                                                                        required
                                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;">
                                                                        <option value="" disabled>Select a package...
                                                                        </option>
                                                                        <% if (packages && packages.length> 0) { %>
                                                                            <% packages.forEach(pkg=> { %>
                                                                                <option value="<%= pkg.id %>"
                                                                                    <%=image.packageId==pkg.id
                                                                                    ? 'selected' : '' %>><%= pkg.name %>
                                                                                </option>
                                                                                <% }) %>
                                                                                    <% } %>
                                                                    </select>
                                                                    <div class="form-text text-muted">The package this
                                                                        image belongs to.</div>
                                                                </div>
                                                                <div class="col-12">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Docker
                                                                        Image</label>
                                                                    <input type="text" name="dockerImage"
                                                                        class="form-control font-monospace"
                                                                        value="<%= image.dockerImage %>" required
                                                                        style="background-color: #1a1a20; border-color: #2d2d35; color: white;">
                                                                    <div class="form-text text-muted">The default docker
                                                                        image
                                                                        to use.</div>
                                                                </div>

                                                                <div class="col-12">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Startup
                                                                        Command</label>
                                                                    <textarea name="startup"
                                                                        class="form-control code-editor" rows="3"
                                                                        required><%= image.startup %></textarea>
                                                                </div>

                                                                <div class="col-12">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Environment
                                                                        Variables (JSON)</label>
                                                                    <textarea name="environment"
                                                                        class="form-control code-editor"
                                                                        rows="6"><%= JSON.stringify(image.environment || {}, null, 2) %></textarea>
                                                                    <div class="form-text text-muted">Key-value pairs
                                                                        for
                                                                        default environment variables.</div>
                                                                </div>

                                                                <div class="col-12">
                                                                    <label
                                                                        class="form-label text-muted small text-uppercase fw-bold">Docker
                                                                        Images (JSON)</label>
                                                                    <textarea name="dockerImages"
                                                                        class="form-control code-editor"
                                                                        rows="4"><%= JSON.stringify(image.dockerImages || {}, null, 2) %></textarea>
                                                                    <div class="form-text text-muted">Map of Display
                                                                        Name ->
                                                                        Docker Image (e.g. {"Latest": "ghcr.io/..."})
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="d-flex justify-content-end gap-2 mt-4">
                                                                <a href="/admin/images/edit-json/<%= image.id %>"
                                                                    class="btn btn-outline-secondary">
                                                                    <i class="bi bi-code-square me-2"></i>Edit as JSON
                                                                </a>
                                                                <a href="/admin/images"
                                                                    class="btn btn-secondary">Cancel</a>
                                                                <button type="submit" class="btn btn-primary fw-bold">
                                                                    <i class="bi bi-save me-2"></i>Save Changes
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                    </div>
                </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
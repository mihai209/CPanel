<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> - Databases
    </title>
    <!-- Favicon -->
    <%- include('../partials/favicon') %>
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Bootstrap Icons -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <!-- Custom CSS -->
        <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <!-- Sidebar -->
            <%- include('../partials/admin-sidebar') %>

                <!-- Content -->
                <div class="admin-content">
                    <!-- Admin Top Header -->
                    <div class="admin-header">
                        <div class="d-flex align-items-baseline gap-3">
                            <h4 class="mb-0 text-light fw-normal">Databases</h4>
                            <small class="text-muted">Manage external database hosts for your application.</small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span
                                class="text-light">Databases</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <!-- Informational Box -->
                        <div class="alert alert-info border-0 bg-info bg-opacity-10 text-info mb-4 shadow-sm"
                            style="border-left: 4px solid #0dcaf0 !important;">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                                <div>
                                    <h6 class="mb-1 fw-bold">Why do I need a Database Host?</h6>
                                    <p class="mb-0 small opacity-75">A database host is required when you want to add a
                                        <strong>Connector</strong>, because the Connector can manage server databases,
                                        states, backups, sub-users, and much more.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- List of Database Hosts -->
                            <div class="col-lg-12">
                                <div class="card border-0 shadow-sm" style="background-color: #141419;">
                                    <div
                                        class="card-header border-bottom border-secondary border-opacity-10 py-3 bg-transparent d-flex justify-content-between align-items-center">
                                        <h5 class="card-title mb-0 fs-6 fw-bold text-light"><i
                                                class="bi bi-database me-2"></i>Database Hosts</h5>
                                        <button class="btn btn-sm btn-primary px-3 fw-bold shadow-sm"
                                            data-bs-toggle="modal" data-bs-target="#createHostModal">
                                            <i class="bi bi-plus-lg me-1"></i> Create Host
                                        </button>
                                    </div>
                                    <div class="card-body p-0">
                                        <% if (success) { %>
                                            <div
                                                class="alert alert-success m-3 border-0 bg-success bg-opacity-10 text-success">
                                                <i class="bi bi-check-circle-fill me-2"></i>
                                                <%= success %>
                                            </div>
                                            <% } %>
                                                <% if (error) { %>
                                                    <div
                                                        class="alert alert-danger m-3 border-0 bg-danger bg-opacity-10 text-danger">
                                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                        <%= error %>
                                                    </div>
                                                    <% } %>

                                                        <div class="table-responsive">
                                                            <table class="table table-dark table-hover mb-0"
                                                                style="--bs-table-bg: transparent;">
                                                                <thead class="text-muted small text-uppercase">
                                                                    <tr>
                                                                        <th class="ps-4 py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">Name</th>
                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">Host:Port
                                                                        </th>
                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">User</th>
                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">DB Name</th>
                                                                        <th class="py-3 fw-bold"
                                                                            style="letter-spacing: 0.05em;">Location
                                                                        </th>
                                                                        <th class="py-3 text-center fw-bold"
                                                                            style="letter-spacing: 0.05em;">Type</th>
                                                                        <th class="pe-4 py-3 text-end fw-bold"
                                                                            style="letter-spacing: 0.05em;">Actions</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody class="border-top-0">
                                                                    <% if (hosts && hosts.length> 0) { %>
                                                                        <% hosts.forEach(host=> { %>
                                                                            <tr
                                                                                class="align-middle border-bottom border-secondary border-opacity-10">
                                                                                <td class="ps-4 fw-bold text-light">
                                                                                    <%= host.name %>
                                                                                </td>
                                                                                <td class="text-muted small">
                                                                                    <%= host.host %>:<%= host.port %>
                                                                                </td>
                                                                                <td class="text-muted small">
                                                                                    <%= host.username %>
                                                                                </td>
                                                                                <td class="text-muted small text-info">
                                                                                    <%= host.database %>
                                                                                </td>
                                                                                <td class="small">
                                                                                    <span
                                                                                        class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 py-1 px-2 d-inline-flex align-items-center">
                                                                                        <% if (host.location &&
                                                                                            host.location.imageUrl) { %>
                                                                                            <img src="<%= host.location.imageUrl %>"
                                                                                                alt="" width="16"
                                                                                                height="16"
                                                                                                class="rounded-circle me-1 shadow-sm">
                                                                                            <% } else { %>
                                                                                                <i
                                                                                                    class="bi bi-geo-alt-fill me-1"></i>
                                                                                                <% } %>
                                                                                                    <%= host.location ?
                                                                                                        host.location.shortName
                                                                                                        : 'N/A' %>
                                                                                    </span>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <span
                                                                                        class="badge bg-secondary text-uppercase"
                                                                                        style="font-size: 0.65rem;">
                                                                                        <%= host.type %>
                                                                                    </span>
                                                                                </td>
                                                                                <td class="pe-4 text-end">
                                                                                    <div
                                                                                        class="d-flex justify-content-end gap-2">
                                                                                        <button
                                                                                            class="btn btn-sm btn-outline-info btn-ping-host"
                                                                                            data-id="<%= host.id %>"
                                                                                            data-name="<%= host.name %>"
                                                                                            title="Ping Database">
                                                                                            <i
                                                                                                class="bi bi-broadcast"></i>
                                                                                        </button>
                                                                                        <button
                                                                                            class="btn btn-sm btn-outline-primary"
                                                                                            data-bs-toggle="modal"
                                                                                            data-bs-target="#editModal<%= host.id %>"
                                                                                            title="Edit Host">
                                                                                            <i
                                                                                                class="bi bi-pencil-square"></i>
                                                                                        </button>
                                                                                        <button type="button"
                                                                                            class="btn btn-sm btn-outline-danger btn-delete-host"
                                                                                            data-id="<%= host.id %>"
                                                                                            data-name="<%= host.name %>"
                                                                                            title="Delete Host">
                                                                                            <i class="bi bi-trash"></i>
                                                                                        </button>
                                                                                        <form
                                                                                            id="delete-form-<%= host.id %>"
                                                                                            method="POST"
                                                                                            action="/admin/databases/delete/<%= host.id %>"
                                                                                            style="display: none;">
                                                                                        </form>
                                                                                    </div>

                                                                                    <!-- Edit Modal -->
                                                                                    <div class="modal fade"
                                                                                        id="editModal<%= host.id %>"
                                                                                        tabindex="-1"
                                                                                        aria-hidden="true">
                                                                                        <div
                                                                                            class="modal-dialog modal-dialog-centered">
                                                                                            <div class="modal-content border-0 shadow-lg text-start"
                                                                                                style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                                                                                                <div
                                                                                                    class="modal-header border-bottom border-secondary border-opacity-10">
                                                                                                    <h5
                                                                                                        class="modal-title fs-6 fw-bold text-light">
                                                                                                        Edit Host: <%=
                                                                                                            host.name %>
                                                                                                    </h5>
                                                                                                    <button
                                                                                                        type="button"
                                                                                                        class="btn-close btn-close-white"
                                                                                                        data-bs-dismiss="modal"
                                                                                                        aria-label="Close"></button>
                                                                                                </div>
                                                                                                <form method="POST"
                                                                                                    action="/admin/databases/edit/<%= host.id %>">
                                                                                                    <div
                                                                                                        class="modal-body p-4 text-start">
                                                                                                        <div
                                                                                                            class="row g-3">
                                                                                                            <div
                                                                                                                class="col-12">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Display
                                                                                                                    Name</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="name"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= host.name %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-9">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Host
                                                                                                                    /
                                                                                                                    IP</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="host"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= host.host %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-3">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Port</label>
                                                                                                                <input
                                                                                                                    type="number"
                                                                                                                    name="port"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= host.port %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Username</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="username"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= host.username %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-md-6">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Password</label>
                                                                                                                <input
                                                                                                                    type="password"
                                                                                                                    name="password"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= host.password %>"
                                                                                                                    required>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-12 text-start">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Default
                                                                                                                    Database
                                                                                                                    (Required
                                                                                                                    for
                                                                                                                    Ping/Connect)</label>
                                                                                                                <input
                                                                                                                    type="text"
                                                                                                                    name="database"
                                                                                                                    class="form-control"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    value="<%= host.database %>"
                                                                                                                    required
                                                                                                                    placeholder="mysql">
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-12 text-start mt-3">
                                                                                                                <div
                                                                                                                    class="d-flex align-items-center justify-content-between mb-2">
                                                                                                                    <label
                                                                                                                        class="form-label text-muted small text-uppercase fw-bold mb-0">Location</label>
                                                                                                                    <% if
                                                                                                                        (host.location
                                                                                                                        &&
                                                                                                                        host.location.imageUrl)
                                                                                                                        {
                                                                                                                        %>
                                                                                                                        <img src="<%= host.location.imageUrl %>"
                                                                                                                            alt=""
                                                                                                                            width="20"
                                                                                                                            height="20"
                                                                                                                            class="rounded shadow-sm">
                                                                                                                        <% }
                                                                                                                            %>
                                                                                                                </div>
                                                                                                                <select
                                                                                                                    name="locationId"
                                                                                                                    class="form-select"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                                                                                    required>
                                                                                                                    <%
                                                                                                                        locations.forEach(loc=>
                                                                                                                        {
                                                                                                                        %>
                                                                                                                        <option
                                                                                                                            value="<%= loc.id %>"
                                                                                                                            <%=host.locationId===loc.id
                                                                                                                            ? 'selected'
                                                                                                                            : ''
                                                                                                                            %>
                                                                                                                            >
                                                                                                                            <%= loc.shortName
                                                                                                                                %>
                                                                                                                                (
                                                                                                                                <%= loc.description
                                                                                                                                    %>
                                                                                                                                    )
                                                                                                                        </option>
                                                                                                                        <% });
                                                                                                                            %>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="col-12">
                                                                                                                <label
                                                                                                                    class="form-label text-muted small text-uppercase fw-bold">Host
                                                                                                                    Type</label>
                                                                                                                <select
                                                                                                                    name="type"
                                                                                                                    class="form-select"
                                                                                                                    style="background-color: #141419; border-color: #2d2d35; color: white;">
                                                                                                                    <option
                                                                                                                        value="mysql"
                                                                                                                        <%=host.type==='mysql'
                                                                                                                        ? 'selected'
                                                                                                                        : ''
                                                                                                                        %>
                                                                                                                        >MySQL
                                                                                                                    </option>
                                                                                                                    <option
                                                                                                                        disabled
                                                                                                                        value="postgres"
                                                                                                                        <%=host.type==='postgres'
                                                                                                                        ? 'selected'
                                                                                                                        : ''
                                                                                                                        %>
                                                                                                                        >PostgreSQL
                                                                                                                        (Coming
                                                                                                                        Soon)
                                                                                                                    </option>
                                                                                                                    <option
                                                                                                                        disabled
                                                                                                                        value="mongodb"
                                                                                                                        <%=host.type==='mongodb'
                                                                                                                        ? 'selected'
                                                                                                                        : ''
                                                                                                                        %>
                                                                                                                        >MongoDB
                                                                                                                        (Coming
                                                                                                                        Soon)
                                                                                                                    </option>
                                                                                                                    <option
                                                                                                                        value="mariadb"
                                                                                                                        <%=host.type==='mariadb'
                                                                                                                        ? 'selected'
                                                                                                                        : ''
                                                                                                                        %>
                                                                                                                        >MariaDB

                                                                                                                    </option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div
                                                                                                        class="modal-footer border-top border-secondary border-opacity-10">
                                                                                                        <button
                                                                                                            type="button"
                                                                                                            class="btn btn-link text-muted text-decoration-none fw-medium"
                                                                                                            data-bs-dismiss="modal">Cancel</button>
                                                                                                        <button
                                                                                                            type="submit"
                                                                                                            class="btn btn-primary px-4 fw-bold">Save
                                                                                                            Changes</button>
                                                                                                    </div>
                                                                                                </form>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                            <% }); %>
                                                                                <% } else { %>
                                                                                    <tr>
                                                                                        <td colspan="7"
                                                                                            class="py-5 text-center text-muted italic">
                                                                                            No database hosts configured
                                                                                            yet.</td>
                                                                                    </tr>
                                                                                    <% } %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Create Host Modal -->
                    <div class="modal fade" id="createHostModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg"
                                style="background-color: #1a1a20; border: 1px solid #2d2d35 !important;">
                                <div class="modal-header border-bottom border-secondary border-opacity-10">
                                    <h5 class="modal-title fs-6 fw-bold text-light">
                                        <i class="bi bi-plus-circle me-2 text-primary"></i>Create New Host
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                        aria-label="Close"></button>
                                </div>
                                <form method="POST" action="/admin/databases">
                                    <div class="modal-body p-4 text-start">
                                        <div class="row g-3">
                                            <div class="col-12">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Display
                                                    Name</label>
                                                <input type="text" name="name" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required placeholder="Local MySQL">
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label text-muted small text-uppercase fw-bold">Host /
                                                    IP</label>
                                                <input type="text" name="host" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required placeholder="127.0.0.1">
                                            </div>
                                            <div class="col-md-4">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Port</label>
                                                <input type="number" name="port" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    value="3306" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Username</label>
                                                <input type="text" name="username" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required placeholder="admin">
                                            </div>
                                            <div class="col-md-6">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Password</label>
                                                <input type="password" name="password" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required>
                                            </div>
                                            <div class="col-12">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Default
                                                    Database</label>
                                                <input type="text" name="database" class="form-control"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required value="mysql" placeholder="mysql">
                                            </div>
                                            <div class="col-12 mt-3">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Location</label>
                                                <select name="locationId" class="form-select"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;"
                                                    required>
                                                    <option value="" disabled selected>Select a location...</option>
                                                    <% locations.forEach(loc=> { %>
                                                        <option value="<%= loc.id %>">
                                                            <%= loc.shortName %> (<%= loc.description %>)
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label text-muted small text-uppercase fw-bold">Host
                                                    Type</label>
                                                <select name="type" class="form-select"
                                                    style="background-color: #141419; border-color: #2d2d35; color: white;">
                                                    <option value="mysql">MySQL</option>
                                                    <option value="postgres" disabled>PostgreSQL (Coming Soon)</option>
                                                    <option value="mongodb" disabled>MongoDB (Coming Soon)</option>
                                                    <option value="mariadb">MariaDB</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-top border-secondary border-opacity-10">
                                        <button type="button"
                                            class="btn btn-link text-muted text-decoration-none fw-medium"
                                            data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                                            Create Database Host
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <%- include('../partials/footer') %>
                </div>
        </div>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <!-- SweetAlert2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.addEventListener('click', function (e) {
                if (e.target.closest('.btn-delete-host')) {
                    const btn = e.target.closest('.btn-delete-host');
                    const id = btn.getAttribute('data-id');
                    const name = btn.getAttribute('data-name');
                    confirmDelete(id, name);
                }

                if (e.target.closest('.btn-ping-host')) {
                    const btn = e.target.closest('.btn-ping-host');
                    const id = btn.getAttribute('data-id');
                    const name = btn.getAttribute('data-name');
                    pingHost(id, name, btn);
                }
            });

            async function pingHost(id, name, btn) {
                const icon = btn.querySelector('i');
                const originalClass = icon.className;

                // Loading state
                icon.className = 'bi bi-arrow-repeat spin d-inline-block';
                btn.disabled = true;

                try {
                    const response = await fetch(`/admin/databases/ping/${id}`, {
                        method: 'POST'
                    });
                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            title: 'Success!',
                            text: `Successfully connected to database host "${name}".`,
                            icon: 'success',
                            background: '#1a1a20',
                            color: '#ffffff',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire({
                            title: 'Connection Failed',
                            text: result.error || 'Unknown error occurred.',
                            icon: 'error',
                            background: '#1a1a20',
                            color: '#ffffff'
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        title: 'Error',
                        text: 'Failed to trigger ping request.',
                        icon: 'error',
                        background: '#1a1a20',
                        color: '#ffffff'
                    });
                } finally {
                    icon.className = originalClass;
                    btn.disabled = false;
                }
            }

            function confirmDelete(id, name) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: `You are about to delete the database host "${name}". This action cannot be undone!`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#2d2d35',
                    confirmButtonText: 'Yes, delete it!',
                    background: '#1a1a20',
                    color: '#ffffff'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('delete-form-' + id).submit();
                    }
                })
            }
        </script>
</body>


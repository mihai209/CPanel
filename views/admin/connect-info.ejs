<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %> - Connector(s) Health
    </title>
    <%- include('../partials/favicon') %>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css">
        <style>
            .node-card {
                background: var(--dashboard-card-bg);
                border: 1px solid var(--glass-border);
                backdrop-filter: blur(16px);
                border-radius: 1.5rem;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
            }

            .node-card:hover {
                transform: translateY(-5px);
                border-color: rgba(255, 255, 255, 0.1);
                background: var(--dashboard-hover-bg);
            }

            .node-status-badge {
                padding: 0.35rem 0.85rem;
                border-radius: 2rem;
                font-size: 0.7rem;
                font-weight: 700;
                letter-spacing: 0.05em;
            }

            .status-online {
                background: rgba(16, 185, 129, 0.1);
                color: #10b981;
                border: 1px solid rgba(16, 185, 129, 0.2);
            }

            .status-offline {
                background: rgba(239, 68, 68, 0.1);
                color: #ef4444;
                border: 1px solid rgba(239, 68, 68, 0.2);
            }

            .metric-progress {
                height: 6px;
                background: rgba(255, 255, 255, 0.05);
                border-radius: 10px;
                margin-top: 0.5rem;
            }

            .metric-label {
                font-size: 0.75rem;
                font-weight: 600;
                color: rgba(255, 255, 255, 0.4);
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            .metric-value {
                font-size: 0.9rem;
                font-weight: 700;
                color: #fff;
            }

            .node-icon-bg {
                width: 48px;
                height: 48px;
                border-radius: 1rem;
                background: rgba(99, 102, 241, 0.1);
                color: #6366f1;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                border: 1px solid rgba(99, 102, 241, 0.2);
            }

            .info-bit {
                background: rgba(255, 255, 255, 0.03);
                border-radius: 0.75rem;
                padding: 0.75rem;
                border: 1px solid rgba(255, 255, 255, 0.05);
            }
        </style>
</head>

<body>
    <%- include ('../partials/error-modal') %>
        <div class="admin-wrapper">
            <%- include('../partials/admin-sidebar') %>

                <div class="admin-content">
                    <div class="admin-header">
                        <div>
                            <h4 class="mb-0 text-light fw-normal">Connector(s) Health</h4>
                            <small class="text-muted">Real-time infrastructure monitoring</small>
                        </div>
                        <div class="breadcrumb-admin">
                            <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span
                                class="text-light">Connector(s) Health</span>
                        </div>
                    </div>

                    <div class="container-fluid py-4 px-lg-4">
                        <div class="row g-4">
                            <% if (connectors && connectors.length> 0) { %>
                                <% connectors.forEach(conn=> { %>
                                    <% const statusData=connectorStatus[conn.id]; const isOnline=statusData &&
                                        statusData.status==='online' && (new Date() - new Date(statusData.lastSeen)) <
                                        30000; const usage=statusData ? statusData.usage : null;
                                        const nodeUsage = nodeStats[conn.id] || {};
                                        const memAllocated = Number(nodeUsage.memoryAllocatedGb || 0);
                                        const diskAllocated = Number(nodeUsage.diskAllocatedGb || 0);
                                    %>
                                        <div class="col-xl-4 col-md-6">
                                            <div class="node-card p-4">
                                                <div class="d-flex justify-content-between align-items-center mb-4">
                                                    <div class="d-flex align-items-center gap-3">
                                                        <div class="node-icon-bg">
                                                            <i class="bi bi-cpu-fill"></i>
                                                        </div>
                                                        <div>
                                                            <h5 class="mb-0 fw-bold text-light">
                                                                <%= conn.name %>
                                                            </h5>
                                                            <span class="text-muted small">
                                                                <%= conn.fqdn %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <span
                                                        class="node-status-badge <%= isOnline ? 'status-online' : 'status-offline' %>">
                                                        <i class="bi bi-circle-fill me-1 small"></i>
                                                        <%= isOnline ? 'ONLINE' : 'OFFLINE' %>
                                                    </span>
                                                </div>

                                                <!-- Hardware Metrics -->
                                                <div class="mb-4">
                                                    <div class="row g-3">
                                                        <!-- CPU -->
                                                        <div class="col-12">
                                                            <div class="d-flex justify-content-between mb-1">
                                                                <span class="metric-label">CPU Usage</span>
                                                                <span class="metric-value">
                                                                    <%= (usage && usage.cpu) ? usage.cpu.toFixed(1) : 0
                                                                        %>%
                                                                </span>
                                                            </div>
                                                            <div class="metric-progress progress">
                                                                <div class="progress-bar bg-info"
                                                                    style="width: <%= (usage && usage.cpu) ? usage.cpu : 0 %>%">
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <!-- RAM -->
                                                        <div class="col-12">
                                                            <div class="d-flex justify-content-between mb-1">
                                                                <span class="metric-label">RAM Allocated</span>
                                                                <span class="metric-value">
                                                                    <%= memAllocated.toFixed(1) %> / <%= Number(conn.totalMemory || 0).toFixed(1) %> GB
                                                                </span>
                                                            </div>
                                                            <div class="metric-progress progress">
                                                                <% const memUsed=memAllocated; const
                                                                    memTotal=Number(conn.totalMemory || 0); const
                                                                    ramPct=memTotal> 0 ? (memUsed / memTotal * 100) : 0;
                                                                    %>
                                                                    <div class="progress-bar bg-primary"
                                                                        style="width: <%= Math.min(ramPct, 100) %>%">
                                                                    </div>
                                                            </div>
                                                        </div>
                                                        <!-- Disk -->
                                                        <div class="col-12">
                                                            <div class="d-flex justify-content-between mb-1">
                                                                <span class="metric-label">Disk Allocated</span>
                                                                <span class="metric-value">
                                                                    <%= diskAllocated.toFixed(1) %> / <%= Number(conn.totalDisk || 0).toFixed(1) %> GB
                                                                </span>
                                                            </div>
                                                            <div class="metric-progress progress">
                                                                <% const diskUsed=diskAllocated; const
                                                                    diskTotal=Number(conn.totalDisk || 0); const
                                                                    diskPct=diskTotal> 0 ? (diskUsed / diskTotal * 100)
                                                                    : 0; %>
                                                                    <div class="progress-bar bg-warning"
                                                                        style="width: <%= Math.min(diskPct, 100) %>%">
                                                                    </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Secondary Info -->
                                                <div class="row g-2 mb-4">
                                                    <div class="col-6">
                                                        <div class="info-bit text-center">
                                                            <span class="d-block metric-label">Servers</span>
                                                            <span class="metric-value fs-5">
                                                                <%= nodeStats[conn.id].servers %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="col-6">
                                                        <div class="info-bit text-center">
                                                            <span class="d-block metric-label">Allocations</span>
                                                            <span class="metric-value fs-5">
                                                                <%= nodeStats[conn.id].allocations %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div
                                                    class="border-top border-secondary border-opacity-10 pt-3 d-flex justify-content-between align-items-center">
                                                    <div class="small">
                                                        <span class="text-muted">Last Seen:</span>
                                                        <span class="text-light opacity-75">
                                                            <%= statusData ? new
                                                                Date(statusData.lastSeen).toLocaleTimeString() : 'Never'
                                                                %>
                                                        </span>
                                                    </div>
                                                    <a href="/admin/connectors/<%= conn.id %>/manage"
                                                        class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                        <i class="bi bi-gear-fill me-1"></i> Configure
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <div class="col-12 text-center py-5">
                                                    <img src="/assets/rocky.png" alt="Rocky"
                                                        style="width: 200px; opacity: 0.3;" class="mb-4">
                                                    <h5 class="text-muted italic">No connectors detected in the network.
                                                    </h5>
                                                </div>
                                                <% } %>
                        </div>
                    </div>

                    <%- include('../partials/footer') %>
                </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            // Auto-refresh logic can be added here if needed for peak real-time feels
            setTimeout(() => {
                if (!document.hidden) location.reload();
            }, 30000);
        </script>
</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (settings.brandName || 'CPanel' ).toUpperCase() %>
            <%= locals.title ? ' - ' + title.toUpperCase() : '' %> - Extensions
    </title>
    <%- include('../partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include ('../partials/error-modal') %>
    <%
    const webhooks = webhooksConfig || {
        enabled: false,
        discordWebhook: '',
        telegramBotToken: '',
        telegramChatId: '',
        events: {
            incidentCreated: true,
            incidentResolved: true,
            maintenanceScheduled: true,
            maintenanceCompleted: true,
            securityAlertCreated: true,
            securityAlertResolved: true,
            serverStarted: true,
            serverStopped: true,
            serverCrashed: true,
            serverInstallFailed: true,
            connectorError: true,
            commandFailed: true,
            runtimeIncidentCreated: true
        }
    };
    const incidentList = Array.isArray(incidents) ? incidents : [];
    const maintenanceList = Array.isArray(maintenanceItems) ? maintenanceItems : [];
    const securityList = Array.isArray(securityAlerts) ? securityAlerts : [];
    const now = Number.isFinite(Number(nowMs)) ? Number(nowMs) : Date.now();
    const isWebhooksModuleEnabled = String(settings.featureExtensionWebhooksEnabled || 'false') === 'true';
    const isIncidentsModuleEnabled = String(settings.featureExtensionIncidentsEnabled || 'false') === 'true';
    const isMaintenanceModuleEnabled = String(settings.featureExtensionMaintenanceEnabled || 'false') === 'true';
    const isSecurityModuleEnabled = String(settings.featureExtensionSecurityCenterEnabled || 'false') === 'true';
    const normalizeTimestamp = (value) => {
        const parsed = Number.parseInt(value, 10);
        if (!Number.isFinite(parsed) || parsed <= 0) return 0;
        if (parsed < 10000000000) return parsed * 1000;
        return parsed;
    };
    const formatDateTime = (ms) => {
        const parsed = normalizeTimestamp(ms);
        if (!Number.isFinite(parsed) || parsed <= 0) return 'N/A';
        return new Date(parsed).toLocaleString();
    };
    const maintenanceStateLabel = (item) => {
        const startsAt = normalizeTimestamp(item.startsAtMs);
        const endsAt = normalizeTimestamp(item.endsAtMs);
        if (item.completed) return 'completed';
        if (now < startsAt) return 'upcoming';
        if (now > endsAt) return 'awaiting completion';
        return 'active';
    };
    const statusBadgeClass = (severity) => {
        const normalized = String(severity || '').toLowerCase();
        if (normalized === 'critical') return 'bg-danger';
        if (normalized === 'warning') return 'bg-warning text-dark';
        return 'bg-success';
    };
    %>
    <style>
        .extension-card {
            background-color: #141419;
            border: 1px solid #2d2d35;
            border-radius: 12px;
        }

        .module-header {
            border-bottom: 1px solid rgba(148, 163, 184, 0.12);
            padding: 0.9rem 1.1rem;
        }

        .module-body {
            padding: 1rem 1.1rem 1.2rem;
        }

        .record-list {
            max-height: 360px;
            overflow: auto;
        }

        .record-item {
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 10px;
            padding: 0.75rem 0.8rem;
            background: rgba(255, 255, 255, 0.02);
        }

        .record-meta {
            font-size: 0.78rem;
            color: #9ca3af;
        }

        .record-title {
            font-weight: 600;
            color: #f3f4f6;
            font-size: 0.95rem;
        }

        .record-message {
            margin-top: 0.4rem;
            color: #d1d5db;
            font-size: 0.88rem;
            white-space: pre-wrap;
        }
    </style>
    <div class="admin-wrapper">
        <%- include('../partials/admin-sidebar') %>

        <div class="admin-content">
            <div class="admin-header">
                <div class="d-flex align-items-baseline gap-3">
                    <h4 class="mb-0 text-light fw-normal">Extensions</h4>
                    <small class="text-muted">Modules: Announcer, Webhooks, Incidents, Maintenance, Security Center.</small>
                </div>
                <div class="breadcrumb-admin">
                    <a href="/admin/overview">Admin</a> <span class="mx-2">&gt;</span> <span class="text-light">Extensions</span>
                </div>
            </div>

            <div class="container-fluid py-4 px-lg-4">
                <% if (success) { %>
                    <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success">
                        <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                    </div>
                <% } %>
                <% if (error) { %>
                    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                    </div>
                <% } %>

                <div class="row g-4">
                    <div class="col-12">
                        <div class="extension-card">
                            <div class="module-header d-flex align-items-center justify-content-between">
                                <h5 class="mb-0 fs-6 fw-bold text-light"><i class="bi bi-megaphone me-2"></i>Announcer</h5>
                            </div>
                            <div class="module-body">
                                <form method="POST" action="/admin/extensions/announcer" class="row g-3">
                                    <div class="col-12">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="extensionAnnouncerEnabled" name="extensionAnnouncerEnabled" value="1"
                                                <%= String(settings.extensionAnnouncerEnabled || 'false') === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="extensionAnnouncerEnabled">Enable dashboard announcement</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Severity</label>
                                        <select name="extensionAnnouncerSeverity" class="form-select">
                                            <option value="normal" <%= String(settings.extensionAnnouncerSeverity || 'normal') === 'normal' ? 'selected' : '' %>>Normal (Green)</option>
                                            <option value="warning" <%= String(settings.extensionAnnouncerSeverity || '') === 'warning' ? 'selected' : '' %>>Warning (Yellow)</option>
                                            <option value="critical" <%= String(settings.extensionAnnouncerSeverity || '') === 'critical' ? 'selected' : '' %>>Critical (Red)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-9">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Message</label>
                                        <textarea name="extensionAnnouncerMessage" rows="3" maxlength="500" class="form-control"
                                            placeholder="Example: Planned maintenance tonight at 23:00 UTC."><%= settings.extensionAnnouncerMessage || '' %></textarea>
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-primary btn-sm px-4 fw-semibold">Save Announcer</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="extension-card">
                            <div class="module-header d-flex align-items-center justify-content-between">
                                <h5 class="mb-0 fs-6 fw-bold text-light"><i class="bi bi-broadcast-pin me-2"></i>Webhooks Module</h5>
                                <form method="POST" action="/admin/extensions/webhooks/test">
                                    <button type="submit" class="btn btn-outline-light btn-sm">Send Test</button>
                                </form>
                            </div>
                            <div class="module-body">
                                <form method="POST" action="/admin/extensions/webhooks" class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="featureExtensionWebhooksEnabled" name="featureExtensionWebhooksEnabled" value="1"
                                                <%= isWebhooksModuleEnabled ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="featureExtensionWebhooksEnabled">Enable Webhooks module</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="extensionWebhooksEnabled" name="extensionWebhooksEnabled" value="1"
                                                <%= webhooks.enabled ? 'checked' : '' %>>
                                            <label class="form-check-label text-light" for="extensionWebhooksEnabled">Dispatch events</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Discord Webhook URL</label>
                                        <input type="url" class="form-control" name="discordWebhook" placeholder="https://discord.com/api/webhooks/..." value="<%= webhooks.discordWebhook || '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Telegram Bot Token</label>
                                        <input type="text" class="form-control" name="telegramBotToken" value="<%= webhooks.telegramBotToken || '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Telegram Chat ID</label>
                                        <input type="text" class="form-control" name="telegramChatId" value="<%= webhooks.telegramChatId || '' %>">
                                    </div>
                                    <div class="col-12">
                                        <div class="row g-2">
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventIncidentCreated" name="webhookEventIncidentCreated" value="1" <%= webhooks.events && webhooks.events.incidentCreated ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventIncidentCreated">Incident Created</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventIncidentResolved" name="webhookEventIncidentResolved" value="1" <%= webhooks.events && webhooks.events.incidentResolved ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventIncidentResolved">Incident Resolved</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventMaintenanceScheduled" name="webhookEventMaintenanceScheduled" value="1" <%= webhooks.events && webhooks.events.maintenanceScheduled ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventMaintenanceScheduled">Maintenance Scheduled</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventMaintenanceCompleted" name="webhookEventMaintenanceCompleted" value="1" <%= webhooks.events && webhooks.events.maintenanceCompleted ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventMaintenanceCompleted">Maintenance Completed</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventSecurityAlertCreated" name="webhookEventSecurityAlertCreated" value="1" <%= webhooks.events && webhooks.events.securityAlertCreated ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventSecurityAlertCreated">Security Alert Created</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventSecurityAlertResolved" name="webhookEventSecurityAlertResolved" value="1" <%= webhooks.events && webhooks.events.securityAlertResolved ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventSecurityAlertResolved">Security Alert Resolved</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventServerStarted" name="webhookEventServerStarted" value="1" <%= webhooks.events && webhooks.events.serverStarted ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventServerStarted">Server Started</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventServerStopped" name="webhookEventServerStopped" value="1" <%= webhooks.events && webhooks.events.serverStopped ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventServerStopped">Server Stopped</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventServerCrashed" name="webhookEventServerCrashed" value="1" <%= webhooks.events && webhooks.events.serverCrashed ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventServerCrashed">Server Crashed</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventServerInstallFailed" name="webhookEventServerInstallFailed" value="1" <%= webhooks.events && webhooks.events.serverInstallFailed ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventServerInstallFailed">Server Install Failed</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventConnectorError" name="webhookEventConnectorError" value="1" <%= webhooks.events && webhooks.events.connectorError ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventConnectorError">Connector Error</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventCommandFailed" name="webhookEventCommandFailed" value="1" <%= webhooks.events && webhooks.events.commandFailed ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventCommandFailed">Command Failed</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="webhookEventRuntimeIncidentCreated" name="webhookEventRuntimeIncidentCreated" value="1" <%= webhooks.events && webhooks.events.runtimeIncidentCreated ? 'checked' : '' %>>
                                                    <label class="form-check-label text-light" for="webhookEventRuntimeIncidentCreated">Runtime Incident Created</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-primary btn-sm px-4 fw-semibold">Save Webhooks</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xxl-6">
                        <div class="extension-card h-100">
                            <div class="module-header d-flex align-items-center justify-content-between">
                                <h5 class="mb-0 fs-6 fw-bold text-light"><i class="bi bi-exclamation-octagon me-2"></i>Incidents</h5>
                            </div>
                            <div class="module-body">
                                <form method="POST" action="/admin/extensions/incidents/settings" class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="featureExtensionIncidentsEnabled" name="featureExtensionIncidentsEnabled" value="1"
                                            <%= isIncidentsModuleEnabled ? 'checked' : '' %>>
                                        <label class="form-check-label text-light" for="featureExtensionIncidentsEnabled">Enable Incidents module</label>
                                    </div>
                                    <div class="mt-2 text-end">
                                        <button type="submit" class="btn btn-outline-light btn-sm">Save Module Toggle</button>
                                    </div>
                                </form>

                                <form method="POST" action="/admin/extensions/incidents/create" class="row g-2 mb-3">
                                    <div class="col-md-7">
                                        <input class="form-control" type="text" name="incidentTitle" maxlength="120" placeholder="Incident title" required>
                                    </div>
                                    <div class="col-md-5">
                                        <select class="form-select" name="incidentSeverity">
                                            <option value="normal">Normal</option>
                                            <option value="warning">Warning</option>
                                            <option value="critical">Critical</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <textarea class="form-control" name="incidentMessage" rows="2" maxlength="1200" placeholder="Incident details"></textarea>
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-primary btn-sm">Create Incident</button>
                                    </div>
                                </form>

                                <div class="record-list d-grid gap-2">
                                    <% if (incidentList.length === 0) { %>
                                        <div class="record-item text-muted">No incidents yet.</div>
                                    <% } %>
                                    <% incidentList.forEach((item) => { %>
                                        <div class="record-item">
                                            <div class="d-flex align-items-center justify-content-between gap-2">
                                                <div class="record-title"><%= item.title %></div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge <%= statusBadgeClass(item.severity) %>"><%= item.severity %></span>
                                                    <span class="badge <%= item.status === 'resolved' ? 'bg-success' : 'bg-secondary' %>"><%= item.status %></span>
                                                </div>
                                            </div>
                                            <div class="record-meta mt-1">Created: <%= formatDateTime(item.createdAtMs) %></div>
                                            <% if (item.message) { %>
                                                <div class="record-message"><%= item.message %></div>
                                            <% } %>
                                            <div class="d-flex justify-content-end gap-2 mt-2">
                                                <form method="POST" action="/admin/extensions/incidents/<%= item.id %>/toggle">
                                                    <button type="submit" class="btn btn-outline-light btn-sm"><%= item.status === 'resolved' ? 'Reopen' : 'Resolve' %></button>
                                                </form>
                                                <form method="POST" action="/admin/extensions/incidents/<%= item.id %>/delete">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xxl-6">
                        <div class="extension-card h-100">
                            <div class="module-header d-flex align-items-center justify-content-between">
                                <h5 class="mb-0 fs-6 fw-bold text-light"><i class="bi bi-wrench-adjustable-circle me-2"></i>Maintenance Scheduler</h5>
                            </div>
                            <div class="module-body">
                                <form method="POST" action="/admin/extensions/maintenance/settings" class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="featureExtensionMaintenanceEnabled" name="featureExtensionMaintenanceEnabled" value="1"
                                            <%= isMaintenanceModuleEnabled ? 'checked' : '' %>>
                                        <label class="form-check-label text-light" for="featureExtensionMaintenanceEnabled">Enable Maintenance module</label>
                                    </div>
                                    <div class="mt-2 text-end">
                                        <button type="submit" class="btn btn-outline-light btn-sm">Save Module Toggle</button>
                                    </div>
                                </form>

                                <form method="POST" action="/admin/extensions/maintenance/create" class="row g-2 mb-3">
                                    <div class="col-md-7">
                                        <input class="form-control" type="text" name="maintenanceTitle" maxlength="120" placeholder="Maintenance title" required>
                                    </div>
                                    <div class="col-md-5">
                                        <select class="form-select" name="maintenanceSeverity">
                                            <option value="normal">Normal</option>
                                            <option value="warning">Warning</option>
                                            <option value="critical">Critical</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-muted small text-uppercase fw-bold">Start At</label>
                                        <input class="form-control" type="datetime-local" name="maintenanceStartAt" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-muted small text-uppercase fw-bold">End At</label>
                                        <input class="form-control" type="datetime-local" name="maintenanceEndAt" required>
                                    </div>
                                    <div class="col-12">
                                        <textarea class="form-control" name="maintenanceMessage" rows="2" maxlength="1200" placeholder="Maintenance details"></textarea>
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-primary btn-sm">Schedule Maintenance</button>
                                    </div>
                                </form>

                                <div class="record-list d-grid gap-2">
                                    <% if (maintenanceList.length === 0) { %>
                                        <div class="record-item text-muted">No maintenance entries yet.</div>
                                    <% } %>
                                    <% maintenanceList.forEach((item) => { %>
                                        <div class="record-item">
                                            <div class="d-flex align-items-center justify-content-between gap-2">
                                                <div class="record-title"><%= item.title %></div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge <%= statusBadgeClass(item.severity) %>"><%= item.severity %></span>
                                                    <span class="badge <%= item.completed ? 'bg-success' : 'bg-primary' %>"><%= maintenanceStateLabel(item) %></span>
                                                </div>
                                            </div>
                                            <div class="record-meta mt-1">Start: <%= formatDateTime(item.startsAtMs) %></div>
                                            <div class="record-meta">End: <%= formatDateTime(item.endsAtMs) %></div>
                                            <% if (item.message) { %>
                                                <div class="record-message"><%= item.message %></div>
                                            <% } %>
                                            <div class="d-flex justify-content-end gap-2 mt-2">
                                                <form method="POST" action="/admin/extensions/maintenance/<%= item.id %>/toggle-complete">
                                                    <button type="submit" class="btn btn-outline-light btn-sm"><%= item.completed ? 'Mark Incomplete' : 'Mark Completed' %></button>
                                                </form>
                                                <form method="POST" action="/admin/extensions/maintenance/<%= item.id %>/delete">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="extension-card">
                            <div class="module-header d-flex align-items-center justify-content-between">
                                <h5 class="mb-0 fs-6 fw-bold text-light"><i class="bi bi-shield-exclamation me-2"></i>Security Center</h5>
                            </div>
                            <div class="module-body">
                                <form method="POST" action="/admin/extensions/security/settings" class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="featureExtensionSecurityCenterEnabled" name="featureExtensionSecurityCenterEnabled" value="1"
                                            <%= isSecurityModuleEnabled ? 'checked' : '' %>>
                                        <label class="form-check-label text-light" for="featureExtensionSecurityCenterEnabled">Enable Security Center module</label>
                                    </div>
                                    <div class="mt-2 text-end">
                                        <button type="submit" class="btn btn-outline-light btn-sm">Save Module Toggle</button>
                                    </div>
                                </form>

                                <form method="POST" action="/admin/extensions/security/create" class="row g-2 mb-3">
                                    <div class="col-md-4">
                                        <input class="form-control" type="text" name="securityTitle" maxlength="120" placeholder="Security alert title" required>
                                    </div>
                                    <div class="col-md-3">
                                        <input class="form-control" type="text" name="securityCategory" maxlength="60" placeholder="Category (e.g. auth)">
                                    </div>
                                    <div class="col-md-2">
                                        <select class="form-select" name="securitySeverity">
                                            <option value="normal">Normal</option>
                                            <option value="warning">Warning</option>
                                            <option value="critical">Critical</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary btn-sm w-100">Create Security Alert</button>
                                    </div>
                                    <div class="col-12">
                                        <textarea class="form-control" name="securityMessage" rows="2" maxlength="1200" placeholder="Security details"></textarea>
                                    </div>
                                </form>

                                <div class="record-list d-grid gap-2">
                                    <% if (securityList.length === 0) { %>
                                        <div class="record-item text-muted">No security alerts yet.</div>
                                    <% } %>
                                    <% securityList.forEach((item) => { %>
                                        <div class="record-item">
                                            <div class="d-flex align-items-center justify-content-between gap-2">
                                                <div class="record-title"><%= item.title %></div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge bg-info text-dark"><%= item.category %></span>
                                                    <span class="badge <%= statusBadgeClass(item.severity) %>"><%= item.severity %></span>
                                                    <span class="badge <%= item.status === 'resolved' ? 'bg-success' : 'bg-secondary' %>"><%= item.status %></span>
                                                </div>
                                            </div>
                                            <div class="record-meta mt-1">Created: <%= formatDateTime(item.createdAtMs) %></div>
                                            <% if (item.message) { %>
                                                <div class="record-message"><%= item.message %></div>
                                            <% } %>
                                            <div class="d-flex justify-content-end gap-2 mt-2">
                                                <form method="POST" action="/admin/extensions/security/<%= item.id %>/toggle">
                                                    <button type="submit" class="btn btn-outline-light btn-sm"><%= item.status === 'resolved' ? 'Reopen' : 'Resolve' %></button>
                                                </form>
                                                <form method="POST" action="/admin/extensions/security/<%= item.id %>/delete">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer') %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" data-turbo-eval="false"></script>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (settings.brandName || 'CPanel').toUpperCase() %> - Status</title>
    <%- include('partials/favicon') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark text-light">
    <div class="container py-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
            <div>
                <h1 class="h3 mb-1"><%= settings.brandName || 'CPanel' %> Status</h1>
                <div class="text-muted small">Live infrastructure health snapshot.</div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-<%= snapshot.overall.className %> text-uppercase"><%= snapshot.overall.label %></span>
                <a href="/status.json" class="btn btn-outline-info btn-sm" target="_blank" rel="noopener">JSON</a>
                <% if (user) { %>
                    <a href="/" class="btn btn-outline-light btn-sm">Dashboard</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
                <% } %>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="background-color:#141419;">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase">Connectors</div>
                        <div class="h4 mb-0"><%= snapshot.counts.connectorsOnline %> / <%= snapshot.counts.connectorsTotal %> online</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="background-color:#141419;">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase">Last Updated</div>
                        <div class="h6 mb-0"><%= new Date(snapshot.generatedAt).toLocaleString() %></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <% (snapshot.nodes || []).forEach((node) => { %>
                <div class="col-xl-4 col-md-6">
                    <div class="card border-0 shadow-sm h-100" style="background-color:#141419;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-semibold"><%= node.name %></div>
                                    <div class="small text-muted"><%= node.fqdn %></div>
                                </div>
                                <span class="badge <%= node.online ? 'bg-success' : 'bg-danger' %>"><%= node.online ? 'ONLINE' : 'OFFLINE' %></span>
                            </div>
                            <div class="small text-muted mb-1">CPU <strong><%= Number(node.cpuPercent || 0).toFixed(1) %>%</strong></div>
                            <div class="progress mb-2" style="height:6px;">
                                <div class="progress-bar bg-info" style="width:<%= Math.min(100, Math.max(0, Number(node.cpuPercent || 0))) %>%"></div>
                            </div>
                            <div class="small text-muted mb-1">RAM <strong><%= Number(node.memoryAllocatedGb || 0).toFixed(2) %> / <%= Number(node.memoryCapacityGb || 0).toFixed(2) %> GB</strong></div>
                            <div class="progress mb-2" style="height:6px;">
                                <div class="progress-bar bg-primary" style="width:<%= Math.min(100, Math.max(0, Number(node.memoryPercent || 0))) %>%"></div>
                            </div>
                            <div class="small text-muted mb-1">Disk <strong><%= Number(node.diskAllocatedGb || 0).toFixed(2) %> / <%= Number(node.diskCapacityGb || 0).toFixed(2) %> GB</strong></div>
                            <div class="progress mb-2" style="height:6px;">
                                <div class="progress-bar bg-warning" style="width:<%= Math.min(100, Math.max(0, Number(node.diskPercent || 0))) %>%"></div>
                            </div>
                            <div class="small text-muted mt-2">
                                Servers: <strong><%= Number(node.servers || 0) %></strong> |
                                Allocations: <strong><%= Number(node.allocations || 0) %></strong> |
                                Free: <strong><%= Number(node.freeAllocations || 0) %></strong>
                            </div>
                            <div class="small text-muted mt-1">
                                Last seen: <%= node.lastSeen ? new Date(node.lastSeen).toLocaleString() : 'Never' %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
            <% if (!snapshot.nodes || snapshot.nodes.length === 0) { %>
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">No connectors configured yet.</div>
                </div>
            <% } %>
        </div>

        <div class="card border-0 shadow-sm" style="background-color:#141419;">
            <div class="card-header bg-transparent border-bottom border-secondary border-opacity-10">
                <h2 class="h6 mb-0 text-uppercase fw-bold">Recent Incidents (48h)</h2>
            </div>
            <div class="card-body p-0">
                <% if (snapshot.incidents && snapshot.incidents.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Event</th>
                                    <th>Target</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% snapshot.incidents.forEach((incident) => { %>
                                    <tr>
                                        <td class="small"><%= incident.createdAt ? new Date(incident.createdAt).toLocaleString() : '-' %></td>
                                        <td class="small"><%= incident.actionLabel %></td>
                                        <td class="small"><%= incident.targetType %>:<%= incident.targetId || '-' %></td>
                                        <td class="small text-muted">
                                            <% if (incident.exitCode !== null) { %>ExitCode: <%= incident.exitCode %><% } %>
                                            <% if (incident.message) { %><%= incident.exitCode !== null ? ' | ' : '' %><%= incident.message %><% } %>
                                            <% if (incident.exitCode === null && !incident.message) { %>-<% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="p-3 text-muted small">No incidents recorded in the last 48 hours.</div>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        setTimeout(() => {
            window.location.reload();
        }, 30000);
    </script>
</body>
</html>

<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/error-modal') %>

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h2 class="mb-0 text-light">Device Login History</h2>
            <div class="text-secondary small">Recent login activity for your account.</div>
        </div>
        <a href="/account" class="btn btn-outline-light btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Account
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="background-color:#141419; border:1px solid rgba(255,255,255,.05) !important; border-radius:15px;">
        <div class="card-header bg-transparent border-bottom border-secondary border-opacity-10 py-3">
            <h5 class="card-title mb-0 fs-6 fw-bold text-light">
                <i class="bi bi-phone me-2 text-primary"></i>Logins
            </h5>
        </div>
        <div class="card-body p-3 p-md-4">
            <% if (!Array.isArray(events) || events.length === 0) { %>
                <div class="text-secondary">No login history yet.</div>
            <% } else { %>
                <div class="list-group list-group-flush">
                    <% events.forEach((entry) => { %>
                        <div class="list-group-item px-0 py-3 border-secondary border-opacity-10 bg-transparent text-light">
                            <div class="small">
                                <span class="fw-semibold"><%= entry.username %></span>
                                -
                                <span><%= entry.operatingSystem %></span>
                                <span class="badge bg-primary bg-opacity-25 text-primary border border-primary border-opacity-25 mx-1"><%= entry.loginType %></span>
                                -
                                <span><%= entry.ipAddress %></span>
                                <span><%= entry.location || 'Unknown' %></span>
                                -
                                <span><%= new Date(entry.createdAt).toLocaleString() %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</div>
